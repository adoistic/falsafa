# Local config — never commit (contains DB credentials)
.claude/

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.astro/
.output/
.vercel/
.netlify/

# Test outputs
coverage/
.nyc_output/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Logs
*.log
logs/

# Env
.env
.env.local
.env.*.local

# Corpus build artifacts (regenerated, not source-of-truth)
corpus/.audit/
corpus/**/assets/*.tmp.png
corpus/**/.cache/
# paragraph-index.json: ~8 MB phone book mapping every paragraph_id → work/chapter/variant.
# Built by apps/site/scripts/build-paragraph-index.ts at predev/prebuild time.
# Used by the BYOK defensive linkifier (lazy-fetched on demand).
corpus/paragraph-index.json

# Chapter-splitting backups (kept locally for rollback after splits)
corpus/.staging-split/

# Astro site derived output
# (apps/site/public/covers/ is copied from corpus/works/*/cover.webp at build time
# via prepare-covers.ts; do not check it in)
apps/site/public/covers/
# (apps/site/public/corpus is a symlink to ../../../corpus generated at
# build time by prepare-corpus.ts so the browser-bundled MCP tools can
# fetch corpus markdown via static URLs; do not check it in)
apps/site/public/corpus

# OpenRouter / Replicate API keys (must never be in repo)
.openrouter
.replicate
secrets.json

# Pagefind index (generated for dev server; rebuild via 'bun run search:build')
apps/site/public/pagefind/
