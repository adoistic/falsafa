---
import type { GetStaticPaths } from "astro";
import Base from "../../../layouts/Base.astro";
import { works, listChapters, readWorkIndex } from "../../../lib/corpus";

export const getStaticPaths = (() => {
  return works().map((w) => ({ params: { slug: w.slug }, props: { work: w } }));
}) satisfies GetStaticPaths;

const { work } = Astro.props;
const idx = readWorkIndex(work.slug);
const chapters = listChapters(work.slug);
---

<Base
  title={work.title}
  description={work.description}
  ogImage={idx?.cover_url ?? undefined}
>
  <div class="container">
    {idx?.cover_url && (
      <div class="cover">
        <img src={idx.cover_url} alt={`Cover for ${work.title}`} />
      </div>
    )}

    <header class="work-header">
      <p class="era">{work.era} · {work.language}</p>
      <h1>{work.title}</h1>
      <p class="author">{work.author}</p>
      {work.description && <p class="description">{work.description}</p>}

      <div class="meta-grid">
        <div>
          <dt>Chapters</dt>
          <dd>{work.total_logical_chapters}</dd>
        </div>
        <div>
          <dt>Variants</dt>
          <dd>{work.total_variant_entries}</dd>
        </div>
        <div>
          <dt>Genre</dt>
          <dd>{work.genre}</dd>
        </div>
        {work.difficulty && (
          <div>
            <dt>Difficulty</dt>
            <dd>{work.difficulty}</dd>
          </div>
        )}
      </div>
    </header>

    <section class="chapters">
      <h2>Chapters</h2>
      <ol class="chapter-list">
        {
          chapters.map((c) => {
            const defaultVariant = c.variants.find((v) => v.file === c.default_variant);
            const variantType = defaultVariant?.content_type ?? "translation";
            return (
              <li>
                <a href={`/works/${work.slug}/${c.chapter_slug}/${variantType}/`}>
                  <span class="num">{String(c.chapter_number).padStart(2, "0")}</span>
                  <span class="title">{c.chapter_title}</span>
                  <span class="layout">{c.layout}</span>
                </a>
              </li>
            );
          })
        }
      </ol>
    </section>
  </div>
</Base>

<style>
  .container {
    max-width: 880px;
    margin: 0 auto;
    padding: var(--s-12) var(--s-8) var(--s-24);
  }

  .cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--rule);
    margin-bottom: var(--s-12);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-header {
    margin-bottom: var(--s-16);
  }

  .work-header .era {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-3);
  }

  .work-header h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-display);
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-2);
  }

  .work-header .author {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    margin: 0 0 var(--s-6);
  }

  .work-header .description {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: 0 0 var(--s-8);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--s-4);
    padding-top: var(--s-6);
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
  }

  .meta-grid dt {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: var(--s-1);
  }

  .meta-grid dd {
    font-size: var(--fs-body);
    margin: 0;
    color: var(--ink);
  }

  .chapters h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 600;
    margin: 0 0 var(--s-6);
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chapter-list li {
    border-bottom: 1px solid var(--rule);
  }

  .chapter-list a {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: var(--s-4);
    align-items: baseline;
    padding: var(--s-4) 0;
    color: var(--ink);
    transition: padding 0.15s ease;
  }

  .chapter-list a:hover {
    padding-left: var(--s-3);
    color: var(--accent);
  }

  .chapter-list .num {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--ink-muted);
  }

  .chapter-list .title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 500;
  }

  .chapter-list .layout {
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
  }
</style>
