---
import type { GetStaticPaths } from "astro";
import Base from "../../../layouts/Base.astro";
import { works, listChapters, readWorkIndex } from "../../../lib/corpus";

export const getStaticPaths = (() => {
  return works().map((w) => ({ params: { slug: w.slug }, props: { work: w } }));
}) satisfies GetStaticPaths;

const { work } = Astro.props;
const idx = readWorkIndex(work.slug);
const chapters = listChapters(work.slug);

// Build the union of variant types across all chapters (for the picker).
const variantTypeSet = new Set<string>();
for (const c of chapters) {
  for (const v of c.variants) variantTypeSet.add(v.content_type);
}
const variantTypes = [...variantTypeSet];
const variantLabels: Record<string, string> = {
  translation: "English",
  transliteration: "Romanized",
  original: "Original",
};
---

<Base
  title={work.title}
  description={work.description}
  ogImage={idx?.cover_url ?? undefined}
>
  <div class="container">
    {idx?.cover_url && (
      <div class="cover">
        <img src={idx.cover_url} alt={`Cover for ${work.title}`} />
      </div>
    )}

    <header class="work-header">
      <p class="era">{work.era} · {work.language}</p>
      <h1>{work.title}</h1>
      <p class="author">{work.author}</p>
      {work.description && <p class="description">{work.description}</p>}

      <div class="meta-grid">
        <div>
          <dt>Chapters</dt>
          <dd>{work.total_logical_chapters}</dd>
        </div>
        <div>
          <dt>Variants</dt>
          <dd>{work.total_variant_entries}</dd>
        </div>
        <div>
          <dt>Genre</dt>
          <dd>{work.genre}</dd>
        </div>
        {work.difficulty && (
          <div>
            <dt>Difficulty</dt>
            <dd>{work.difficulty}</dd>
          </div>
        )}
      </div>
    </header>

    <section class="chapters">
      <h2>Chapters</h2>

      {/* Reading-variant picker for works that ship multiple variants.
          The user's choice is saved to localStorage so chapter pages and
          this list stay in sync. */}
      {variantTypes.length > 1 && (
        <nav class="variant-picker" data-work-slug={work.slug} aria-label="Reading variant">
          <span class="variant-picker-label">Read as</span>
          {variantTypes.map((vt) => (
            <button type="button" data-variant={vt} class="variant-pill" aria-pressed="false">
              {variantLabels[vt] ?? vt}
            </button>
          ))}
        </nav>
      )}

      <ol class="chapter-list">
        {
          chapters.map((c) => {
            const defaultVariant = c.variants.find((v) => v.file === c.default_variant);
            const defaultVariantType = defaultVariant?.content_type ?? "translation";
            const availableVariants = c.variants.map((v) => v.content_type).join(",");
            return (
              <li>
                <a
                  href={`/works/${work.slug}/${c.chapter_slug}/${defaultVariantType}/`}
                  data-chapter-slug={c.chapter_slug}
                  data-default-variant={defaultVariantType}
                  data-available-variants={availableVariants}
                >
                  <span class="num">{String(c.chapter_number).padStart(2, "0")}</span>
                  <span class="title">{c.chapter_title}</span>
                  <span class="layout">{c.layout}</span>
                </a>
              </li>
            );
          })
        }
      </ol>
    </section>

    <script is:inline>
      // Read localStorage falsafa-variant-pref. If set, rewrite chapter links
      // to use that variant (when available for the chapter), and highlight
      // the matching pill in the picker.
      (function () {
        const pref = (() => {
          try { return localStorage.getItem("falsafa-variant-pref"); } catch { return null; }
        })();
        const picker = document.querySelector(".variant-picker");
        const buttons = picker ? picker.querySelectorAll("button[data-variant]") : [];

        function applyVariant(v) {
          // Update chapter links to use the chosen variant when available
          for (const a of document.querySelectorAll(".chapter-list a[data-chapter-slug]")) {
            const available = (a.getAttribute("data-available-variants") || "").split(",");
            const target = available.includes(v) ? v : a.getAttribute("data-default-variant");
            const slug = a.getAttribute("data-chapter-slug");
            const work = picker ? picker.getAttribute("data-work-slug") : a.getAttribute("href").split("/")[2];
            a.setAttribute("href", `/works/${work}/${slug}/${target}/`);
          }
          // Update pill state
          for (const b of buttons) {
            b.setAttribute("aria-pressed", b.getAttribute("data-variant") === v ? "true" : "false");
          }
        }

        if (pref) applyVariant(pref);

        for (const b of buttons) {
          b.addEventListener("click", function () {
            const v = b.getAttribute("data-variant");
            if (!v) return;
            try { localStorage.setItem("falsafa-variant-pref", v); } catch {}
            applyVariant(v);
          });
        }
      })();
    </script>
  </div>
</Base>

<style>
  .container {
    max-width: 880px;
    margin: 0 auto;
    padding: var(--s-12) var(--s-8) var(--s-24);
  }

  .cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--rule);
    margin-bottom: var(--s-12);
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-header {
    margin-bottom: var(--s-16);
  }

  .work-header .era {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-3);
  }

  .work-header h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-display);
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-2);
  }

  .work-header .author {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    margin: 0 0 var(--s-6);
  }

  .work-header .description {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    margin: 0 0 var(--s-8);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--s-4);
    padding-top: var(--s-6);
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
  }

  .meta-grid dt {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: var(--s-1);
  }

  .meta-grid dd {
    font-size: var(--fs-body);
    margin: 0;
    color: var(--ink);
  }

  .chapters h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 600;
    margin: 0 0 var(--s-6);
  }

  .variant-picker {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    margin: 0 0 var(--s-6);
    padding: var(--s-2);
    background: var(--rule);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 13px;
  }

  .variant-picker-label {
    padding: 0 var(--s-2) 0 var(--s-3);
    color: var(--ink-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 11px;
  }

  .variant-pill {
    padding: var(--s-1) var(--s-3);
    background: transparent;
    border: 0;
    border-radius: 999px;
    color: var(--ink-muted);
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .variant-pill:hover {
    color: var(--ink);
  }

  .variant-pill[aria-pressed="true"] {
    background: var(--paper);
    color: var(--ink);
  }

  .chapter-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .chapter-list li {
    border-bottom: 1px solid var(--rule);
  }

  .chapter-list a {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: var(--s-4);
    align-items: baseline;
    padding: var(--s-4) 0;
    color: var(--ink);
    transition: padding 0.15s ease;
  }

  .chapter-list a:hover {
    padding-left: var(--s-3);
    color: var(--accent);
  }

  .chapter-list .num {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--ink-muted);
  }

  .chapter-list .title {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 500;
  }

  .chapter-list .layout {
    font-family: var(--font-sans);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-muted);
  }
</style>
