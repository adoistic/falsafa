---
import type { GetStaticPaths } from "astro";
import Reader from "../../../../layouts/Reader.astro";
import VariantSwitcher from "../../../../components/VariantSwitcher.astro";
import ChapterBody from "../../../../components/ChapterBody.astro";
import {
  works,
  listChapters,
  readChapterVariant,
  readWorkIndex,
  type ContentType,
  type ChapterVariantContent,
} from "../../../../lib/corpus";

export const getStaticPaths = (() => {
  const paths: { params: { slug: string; chapter: string; variant: string }; props: any }[] = [];
  for (const w of works()) {
    const chapters = listChapters(w.slug);
    for (const c of chapters) {
      for (const v of c.variants) {
        paths.push({
          params: { slug: w.slug, chapter: c.chapter_slug, variant: v.content_type },
          props: { workSlug: w.slug, chapterSlug: c.chapter_slug, variantType: v.content_type },
        });
      }
    }
  }
  return paths;
}) satisfies GetStaticPaths;

const { workSlug, chapterSlug, variantType } = Astro.props;

const variant = readChapterVariant(workSlug, chapterSlug, variantType as ContentType);
if (!variant) {
  return new Response("Chapter not found", { status: 404 });
}
const work = works().find((w) => w.slug === workSlug)!;
const idx = readWorkIndex(workSlug);
const chapters = listChapters(workSlug);
const chapterIndex = chapters.findIndex((c) => c.chapter_slug === chapterSlug);
const prev = chapterIndex > 0 ? chapters[chapterIndex - 1] : null;
const next = chapterIndex < chapters.length - 1 ? chapters[chapterIndex + 1] : null;
// Single-chapter works (e.g. Cynewulf's Andreas/Elene/Juliana, the Comte
// volumes) carry no meaningful chapter title — the chapter IS the work. So
// the reader page drops the "Chapter 1" h1 and the work-title sub-link, and
// suppresses the prev/next/contents footer (no neighbors, and the
// work-detail page is now ToC-less anyway).
const isSingleChapter = chapters.length === 1;

function bylineFor(v: ChapterVariantContent) {
  if (v.frontmatter.translator) return { verb: "Translated by", who: "Thothica" };
  if (v.frontmatter.transliterator) return { verb: "Transliterated by", who: "Thothica" };
  if (v.frontmatter.curator) return { verb: "Curated by", who: "Thothica" };
  return null;
}
const byline = bylineFor(variant);

/**
 * Some source titles are entirely uppercase ("INTRODUCTION", "CHAPTER I").
 * In display-serif at 56px these read as shouty rather than monumental.
 * Convert all-caps strings to Title Case while leaving mixed-case titles alone.
 * Roman numerals (I, II, III, IV, etc.) stay uppercase.
 */
function softTitleCase(s: string): string {
  if (!/[a-z]/.test(s) && /[A-Z]/.test(s)) {
    // Entirely uppercase
    return s.toLowerCase().replace(/\b([a-z])/g, (m) => m.toUpperCase()).replace(
      /\b(I|II|III|IV|V|VI|VII|VIII|IX|X|XI|XII|XIII|XIV|XV|XVI|XVII|XVIII|XIX|XX)\b/gi,
      (m) => m.toUpperCase(),
    );
  }
  return s;
}
const displayChapterTitle = softTitleCase(variant.meta.chapter_title);
---

<Reader
  title={isSingleChapter ? work.title : `${variant.meta.chapter_title} · ${work.title}`}
  description={
    isSingleChapter
      ? `${work.title} by ${work.author} — ${variantType}`
      : `${work.title} by ${work.author} — chapter ${variant.meta.chapter_number}, ${variantType}`
  }
  ogImage={idx?.cover_url ?? undefined}
  layout={variant.meta.layout}
>
  {idx?.cover_url && (
    <div class="reader-cover">
      <img src={idx.cover_url} alt={`Cover for ${work.title}`} />
    </div>
  )}

  <header class="reader-header">
    {!isSingleChapter && (
      <p class="work-title">
        <a href={`/works/${work.slug}/`} data-pagefind-meta="work">{work.title}</a>
      </p>
    )}
    <h1 data-pagefind-meta="title">{isSingleChapter ? work.title : displayChapterTitle}</h1>
    {isSingleChapter && <span data-pagefind-meta="work" hidden>{work.title}</span>}
    {/* Hidden pagefind filter facets — extracted at build time, drive the
        author/era/language chips in the search dialog. Filter VALUE is
        the human-readable label (matches manifest); chip rendering shows
        the same string back. Source language uses --source not --display
        because some works are English-translated-from-X. */}
    <span data-pagefind-filter={`era:${work.era}`} hidden>{work.era}</span>
    <span data-pagefind-filter={`author:${work.author}`} hidden>{work.author}</span>
    <span data-pagefind-filter={`language:${work.language}`} hidden>{work.language}</span>
    <p class="author">
      <a href={`/authors/${work.author_slug}/`}>{work.author}</a>
    </p>
    {byline && (
      <p class="byline">
        {byline.verb}{" "}
        <a href="https://thothica.com" rel="noopener">
          {byline.who}
        </a>
      </p>
    )}
    <VariantSwitcher meta={variant.meta} workSlug={work.slug} current={variantType as ContentType} />
  </header>

  <ChapterBody body={variant.body} frontmatter={variant.frontmatter} />

  {!isSingleChapter && (
    <footer class="reader-footer">
      {prev ? (
        <a class="nav-link" href={`/works/${work.slug}/${prev.chapter_slug}/${variant.variant.content_type}/`}>
          ← Previous
          <strong>{prev.chapter_title}</strong>
        </a>
      ) : <span />}

      <a class="nav-link" href={`/works/${work.slug}/`} style="text-align: center">
        Contents
        <strong>{work.title}</strong>
      </a>

      {next ? (
        <a class="nav-link" href={`/works/${work.slug}/${next.chapter_slug}/${variant.variant.content_type}/`} style="text-align: right">
          Next →
          <strong>{next.chapter_title}</strong>
        </a>
      ) : <span />}
    </footer>
  )}
</Reader>
