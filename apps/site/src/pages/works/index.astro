---
import Base from "../../layouts/Base.astro";
import { manifest, readWorkIndex } from "../../lib/corpus";

const m = manifest();

// Group works by era for display
const byEra = new Map<string, typeof m.works>();
for (const w of m.works) {
  const arr = byEra.get(w.era) ?? [];
  arr.push(w);
  byEra.set(w.era, arr);
}

const eraOrder = ["Ancient", "Antiquity", "Medieval", "Enlightenment", "19th Century", "20th Century", "Unknown"];
const sortedEras = eraOrder.filter((e) => byEra.has(e)).map((e) => ({ era: e, works: byEra.get(e)! }));

// Pre-resolve cover URLs
const coversByWork = new Map<string, string | null>();
for (const w of m.works) {
  const idx = readWorkIndex(w.slug);
  coversByWork.set(w.slug, idx?.cover_url ?? null);
}
---

<Base
  title="Works"
  description={`Browse all ${m.counts.works} works in the Falsafa catalog. Translations and transliterations by Thothica.`}
>
  <div class="container">
    <header class="page-header">
      <p class="kicker">The catalog</p>
      <h1>{m.counts.works} works, {m.counts.languages} languages</h1>
      <p class="lede">Browse by era. Each work ships with 2-3 language variants.</p>
    </header>

    {
      sortedEras.map(({ era, works }) => (
        <section class="era-section">
          <h2>{era}</h2>
          <div class="works-grid">
            {works.map((w) => {
              const cover = coversByWork.get(w.slug);
              return (
                <a href={`/works/${w.slug}/`} class="work-card">
                  {cover ? (
                    <div class="cover">
                      <img src={cover} alt={`Cover for ${w.title}`} loading="lazy" />
                    </div>
                  ) : (
                    <div class="cover cover-placeholder" aria-hidden="true" />
                  )}
                  <div class="meta">
                    <h3 class="title">{w.title}</h3>
                    <p class="author">{w.author}</p>
                    <p class="extras">
                      <span>{w.language}</span>
                      <span class="dot">·</span>
                      <span>{w.total_logical_chapters} {w.total_logical_chapters === 1 ? "chapter" : "chapters"}</span>
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      ))
    }
  </div>
</Base>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: var(--s-12) var(--s-8) var(--s-24);
  }

  .page-header {
    max-width: 60ch;
    margin: 0 0 var(--s-16);
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-2);
  }

  h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    margin: 0 0 var(--s-3);
    letter-spacing: -0.02em;
  }

  .lede {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    line-height: 1.4;
  }

  .era-section {
    margin-bottom: var(--s-16);
  }

  .era-section h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 600;
    margin: 0 0 var(--s-6);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule);
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--s-8);
  }

  .work-card {
    display: flex;
    flex-direction: column;
    color: var(--ink);
    transition: transform 0.2s ease;
  }

  .work-card:hover {
    transform: translateY(-2px);
  }

  .work-card .cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--rule);
    margin-bottom: var(--s-3);
  }

  .work-card .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-card .cover-placeholder {
    background: linear-gradient(135deg, var(--rule) 0%, var(--paper) 100%);
  }

  .work-card .title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: 0 0 var(--s-1);
    line-height: 1.3;
  }

  .work-card .author {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    margin: 0 0 var(--s-2);
  }

  .work-card .extras {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    margin: 0;
  }

  .work-card .extras .dot {
    margin: 0 var(--s-1);
  }
</style>
