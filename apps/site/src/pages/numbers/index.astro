---
/**
 * /numbers — "Falsafa by the numbers" editorial spread.
 *
 * Design: variant A approved at
 * ~/.gstack/projects/falsafa/designs/perseus-launch-20260427/06-stats-page/.
 * Magazine 'In Numbers' rubric — big terracotta display-serif numbers,
 * sans-serif labels, small italic source-data deep-links, lots of white
 * space. NYT 'In Numbers' / FT special-report register.
 *
 * Implementation: CSS-native editorial typography. (The approved spec
 * mentioned chenglou/pretext as the framework, but eng review run-2 §1.1
 * rejected pretext for the current launch surfaces because it's
 * browser-only at runtime; CSS-native is the locked fallback.)
 *
 * Sections from the spec: CORPUS / ERAS / EVAL / BENCHMARK vs HYBRID RAG /
 * BUILD. Honest where data isn't yet there: the BENCHMARK section shows
 * structure with "forthcoming" placeholders since apps/baseline/ is not
 * yet built.
 */
import Base from "../../layouts/Base.astro";
import { readFileSync, readdirSync, existsSync, statSync } from "node:fs";
import { join } from "node:path";
import { CORPUS_ROOT } from "../../lib/corpus";
import "../../styles/numbers.css";

const CORPUS = CORPUS_ROOT;

interface ManifestWork {
  slug: string;
  title: string;
  author: string;
  language: string;
  language_slug: string;
  total_logical_chapters: number;
  total_variant_entries: number;
}
interface Manifest {
  generated_at: string;
  source: string;
  counts: { works: number; authors: number; eras: number; genres: number; languages: number };
  works: ManifestWork[];
}

const manifest: Manifest = JSON.parse(readFileSync(join(CORPUS, "manifest.json"), "utf-8"));

// Filesystem walk for paragraph + word totals.
function walkChapters() {
  let totalParagraphs = 0;
  let totalWords = 0;
  const worksDir = join(CORPUS, "works");
  if (!existsSync(worksDir)) return { totalParagraphs, totalWords };
  for (const slug of readdirSync(worksDir)) {
    const chaptersDir = join(worksDir, slug, "chapters");
    if (!existsSync(chaptersDir) || !statSync(chaptersDir).isDirectory()) continue;
    for (const ch of readdirSync(chaptersDir)) {
      const chapterDir = join(chaptersDir, ch);
      if (!statSync(chapterDir).isDirectory()) continue;
      const metaPath = join(chapterDir, "meta.json");
      if (existsSync(metaPath)) {
        try {
          const meta = JSON.parse(readFileSync(metaPath, "utf-8"));
          for (const v of meta.variants ?? []) totalWords += Number(v.word_count ?? 0);
        } catch { /* ignore */ }
      }
      for (const f of readdirSync(chapterDir)) {
        if (!f.endsWith(".paragraphs.json")) continue;
        try {
          const arr = JSON.parse(readFileSync(join(chapterDir, f), "utf-8"));
          if (Array.isArray(arr)) totalParagraphs += arr.length;
        } catch { /* ignore */ }
      }
    }
  }
  return { totalParagraphs, totalWords };
}

const fsStats = walkChapters();
const totalLogicalChapters = manifest.works.reduce((s, w) => s + w.total_logical_chapters, 0);
const totalVariantEntries = manifest.works.reduce((s, w) => s + w.total_variant_entries, 0);

// Languages list for the ERAS section's caption (mirrors the variant A mockup
// where the languages were enumerated under the "languages" stat).
const languageNames = [...new Set(manifest.works.map((w) => w.language))]
  .map((l) => (l === "old_english" ? "Old English" : l.charAt(0).toUpperCase() + l.slice(1)))
  .sort();

// Aggregate eval scores live from any post-patch run dir. Skips quarantined
// runs (`_INVALIDATED-*`, `*-NOT-BLIND`) and pre-anti-cheat smokes. Walks one
// level deep too so per-model subdirs (`sonnet/`, `opus/`) compose. New
// batches show up automatically — no allow-list to maintain.
function readLatestEval(): { pass: number | null; total: number | null; rate: number | null; verseLabels: number | null; totalCitations: number | null } {
  const runsRoot = join(CORPUS, "..", "apps/mcp/eval/runs");
  if (!existsSync(runsRoot)) {
    return { pass: null, total: null, rate: null, verseLabels: null, totalCitations: null };
  }
  let pass = 0, total = 0, citations = 0, verseLabels = 0, found = false;
  function isExcluded(dir: string): boolean {
    return dir.startsWith("_INVALIDATED") || dir.includes("NOT-BLIND") || dir.startsWith("1k-codex-smoke");
  }
  function ingest(scorePath: string) {
    if (!existsSync(scorePath)) return;
    try {
      const j = JSON.parse(readFileSync(scorePath, "utf-8"));
      pass += Number(j.total_pass ?? 0);
      total += Number(j.total_judged ?? 0);
      citations += Number(j.total_citations ?? 0);
      verseLabels += Number(j.verse_label_id_count ?? 0);
      found = true;
    } catch { /* skip */ }
  }
  for (const d of readdirSync(runsRoot)) {
    if (isExcluded(d)) continue;
    const runDir = join(runsRoot, d);
    try {
      if (!statSync(runDir).isDirectory()) continue;
    } catch { continue; }
    // Score at run root (orchestrator-1 layout).
    ingest(join(runDir, "_score-mechanical.json"));
    // Per-model subdirs (orchestrator layout).
    try {
      for (const sub of readdirSync(runDir)) {
        const subPath = join(runDir, sub);
        try {
          if (statSync(subPath).isDirectory()) ingest(join(subPath, "_score-mechanical.json"));
        } catch { /* skip */ }
      }
    } catch { /* skip */ }
  }
  if (!found || total === 0) return { pass: null, total: null, rate: null, verseLabels: null, totalCitations: null };
  return { pass, total, rate: pass / total, verseLabels, totalCitations: citations };
}

const evalStats = readLatestEval();

function formatDate(iso: string): string {
  try {
    const d = new Date(iso);
    return d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
  } catch { return iso; }
}
const fmt = (n: number) => n.toLocaleString("en-US");
const wordsHuman = `${(fsStats.totalWords / 1_000_000).toFixed(2)}M`;
---

<Base
  title="Falsafa by the numbers"
  description="Every claim in the Falsafa launch deep-links to its source. Audit anything."
  ogImage="/og/numbers.png"
>
  <article class="in-numbers">
    <header class="in-numbers-header">
      <h1>
        <span class="apos" aria-hidden="true">&lsquo;</span>Falsafa by the numbers
      </h1>
      <p class="in-numbers-lede">
        Every claim in the launch writeup deep-links to its source. Audit anything.
      </p>
    </header>

    <div class="in-numbers-grid">

      {/* ── CORPUS ─────────────────────────────────────────────── */}
      <section class="in-numbers-section in-numbers-section-corpus">
        <h2>Corpus</h2>
        <div class="in-numbers-row">
          <div class="stat">
            <div class="stat-num">{fmt(manifest.counts.works)}</div>
            <p class="stat-label">total works</p>
            <p class="stat-source">
              <a href="/works/">deep-links to the catalogue</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">{fmt(fsStats.totalWords)}</div>
            <p class="stat-label">total words across all variants</p>
            <p class="stat-source">
              <a href="https://github.com/adoistic/falsafa/blob/main/corpus/manifest.json">view raw manifest</a>
            </p>
          </div>
        </div>
      </section>

      {/* ── ERAS ───────────────────────────────────────────────── */}
      <section class="in-numbers-section in-numbers-section-eras">
        <h2>Eras &amp; languages</h2>
        <div class="in-numbers-row">
          <div class="stat">
            <div class="stat-num">{fmt(manifest.counts.languages)}</div>
            <p class="stat-label stat-label-uppercase">{languageNames.join(", ")}</p>
            <p class="stat-source">
              <a href="/works/">view languages</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">{fmt(manifest.counts.eras)}</div>
            <p class="stat-label">eras spanned</p>
            <p class="stat-source">
              <a href="/eras/">view era index</a>
            </p>
          </div>
        </div>
      </section>

      {/* ── EVAL ───────────────────────────────────────────────── */}
      <section class="in-numbers-section in-numbers-section-eval">
        <h2>Eval</h2>
        <div class="in-numbers-row">
          <div class="stat">
            <div class="stat-num">
              {evalStats.total !== null ? fmt(evalStats.total) : "—"}
            </div>
            <p class="stat-label">cases run, paper-grade post-patch</p>
            <p class="stat-source">
              <a href="/eval/">view raw eval JSON</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">
              {evalStats.rate !== null ? `${Math.round(evalStats.rate * 100)}%` : "—"}
            </div>
            <p class="stat-label">mechanical pass rate</p>
            <p class="stat-source">
              <a href="/eval/">view raw eval JSON</a>
            </p>
          </div>
        </div>
        <div class="in-numbers-row">
          <div class="stat">
            <div class="stat-num">
              {evalStats.totalCitations !== null ? fmt(evalStats.totalCitations) : "—"}
            </div>
            <p class="stat-label">paragraph citations resolved against the corpus</p>
            <p class="stat-source">
              <a href="/eval/">audit each one</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">
              {evalStats.verseLabels !== null ? fmt(evalStats.verseLabels) : "—"}
            </div>
            <p class="stat-label">verse-marker hallucinations (target: 0)</p>
            <p class="stat-source">
              <a href="https://github.com/adoistic/falsafa/blob/main/docs/designs/eval-protocol.md">why this matters</a>
            </p>
          </div>
        </div>
        <p class="in-numbers-section-note">
          Sample size is small (post-anti-cheat-patch). Scoring is deterministic
          — citation match against expected_works, no LLM judge.
        </p>
      </section>

      {/* ── BENCHMARK vs HYBRID RAG ────────────────────────────── */}
      <section class="in-numbers-section in-numbers-section-benchmark">
        <h2>Benchmark <span class="vs">vs</span> hybrid RAG</h2>
        <div class="in-numbers-row in-numbers-row-benchmark">
          <div class="stat-pair">
            <p class="stat-pair-label">Citation-validity rate</p>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Falsafa</span>
              <span class="stat-num stat-num-pair">forthcoming</span>
            </div>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Hybrid</span>
              <span class="stat-num stat-num-pair">forthcoming</span>
            </div>
          </div>
          <div class="stat-pair">
            <p class="stat-pair-label">p95 latency</p>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Falsafa</span>
              <span class="stat-num stat-num-pair">forthcoming</span>
            </div>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Hybrid</span>
              <span class="stat-num stat-num-pair">forthcoming</span>
            </div>
          </div>
          <div class="stat-pair">
            <p class="stat-pair-label">One-time embedding cost</p>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Falsafa</span>
              <span class="stat-num stat-num-pair">$0</span>
            </div>
            <div class="stat-pair-row">
              <span class="stat-pair-label-cell">Hybrid</span>
              <span class="stat-num stat-num-pair">forthcoming</span>
            </div>
          </div>
        </div>
        <p class="in-numbers-section-note">
          Hybrid RAG baseline (<code>apps/baseline/</code>) is in development.
          Falsafa's approach reads markdown directly through MCP tools, so
          there are no embeddings to compute. Hybrid figures land when the
          baseline runs against the same 1,000-question pool.
        </p>
      </section>

      {/* ── BUILD ──────────────────────────────────────────────── */}
      <section class="in-numbers-section in-numbers-section-build">
        <h2>Build</h2>
        <div class="in-numbers-row in-numbers-row-build">
          <div class="stat">
            <div class="stat-num">{fmt(totalLogicalChapters)}</div>
            <p class="stat-label">logical chapters</p>
            <p class="stat-source">
              <a href="https://github.com/adoistic/falsafa/blob/main/corpus/manifest.json">view manifest</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">{fmt(totalVariantEntries)}</div>
            <p class="stat-label">variant entries (translation, transliteration, original)</p>
            <p class="stat-source">
              <a href="https://github.com/adoistic/falsafa/blob/main/corpus/manifest.json">view manifest</a>
            </p>
          </div>
          <div class="stat">
            <div class="stat-num">{fmt(fsStats.totalParagraphs)}</div>
            <p class="stat-label">cited paragraphs with stable hash IDs</p>
            <p class="stat-source">
              <a href="https://github.com/adoistic/falsafa/tree/main/corpus/works">view corpus tree</a>
            </p>
          </div>
        </div>
      </section>

    </div>

    <footer class="in-numbers-footer">
      <p>
        Manifest generated <strong>{formatDate(manifest.generated_at)}</strong>
        {" "}· source <code>{manifest.source}</code>
        {" "}·{" "}
        <a href="https://github.com/adoistic/falsafa">repo</a>
      </p>
    </footer>
  </article>
</Base>
