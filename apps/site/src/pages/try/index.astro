---
import Base from "../../layouts/Base.astro";
import ByokDemo from "../../islands/byok/ByokDemo";
import InstallCard from "../../components/InstallCard.astro";
import NonDeterminismCaveat from "../../components/NonDeterminismCaveat.astro";
import ReportThis from "../../components/ReportThis.astro";
import "../../styles/byok.css";
// Note: tool-trace.css is imported by the BYOK island (ByokDemo.tsx) — that's
// the only consumer of .byok-toolcall* on this page. Don't re-import here.

// Twelve hand-picked question chips covering the eval categories. The
// curation pool grows in Phase 3 once the eval explorer ships and we
// can sample from the audited 1,000-question pool.
const CHIPS = [
  "What does Ghalib's couplet 168 say about the lover and the beloved?",
  "Compare Iqbal's 'Khudi' with Cynewulf's 'Dryhten' as conceptions of the self.",
  "Which works in the corpus discuss the soul's journey after death?",
  "Show me where Manu Smriti talks about the duties of a king.",
  "Find a moment where two traditions in the corpus say something near-identical about suffering.",
  "What's the original Urdu word that gets rendered as 'union' in the English translations?",
  "How does Cynewulf's Andreas frame heroic Christianity?",
  "Where does Fichte's Vocation of Man treat the question of agency?",
  "Quote the opening lines of Iqbal's 'Himalaya'.",
  "Which authors in the corpus write about poetry itself?",
  "Trace the metaphor of the lamp across Ghalib's ghazals.",
  "Compare the Sanskrit and Anglo-Saxon framings of cosmic order.",
];

---

<Base
  title="Try"
  description="One npx command wires Falsafa into Claude Desktop, Claude Code, Cursor, or Codex. Or skip the install and try it live in the browser with your own API key."
>
  {/* Page-level CSP: connect-src locks down to the four supported provider
      hosts + same-origin (the corpus markdown lives under /corpus/* on
      this site). No third-party JS, no remote MCP server.
      Per /plan-eng-review run 2 Issue 2.3 (P0 security hardening).

      script-src includes 'unsafe-eval' specifically because the
      browser-bundled MCP's search_corpus tool dynamically loads
      /pagefind/pagefind.js via `new Function()` — that's the standard
      Pagefind-in-a-framework integration pattern (Astro's dev server
      blocks /public/ dynamic imports; Vite's static analyzer follows
      everything else). The actual security guarantee here is
      `connect-src` which is locked to the LLM provider hosts — that's
      what prevents an XSS from exfiltrating the user's API key.
      `unsafe-eval` lets compiled-in-runtime code execute (Pagefind has
      its own bundle) but doesn't grant network reach.
  */}
  <meta
    http-equiv="Content-Security-Policy"
    content={`default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com https://openrouter.ai;`}
    slot="head"
  />

  <article class="try-page">
    <header class="try-header">
      <p class="kicker">Try</p>
      <h1>Run Falsafa in your daily LLM</h1>
      <p class="lede">
        One <code>npx</code> command wires Falsafa into Claude Desktop,
        Claude Code, Cursor, or Codex. Or skip the install and try it
        live in the browser with your own API key.
      </p>
    </header>

    <div class="try-hero">
      <InstallCard />

      <div class="try-byok-card">
        <header class="try-byok-card-head">
          <h2>Try it now (BYOK)</h2>
          <p>Bring your own API key. Stays in the browser.</p>
        </header>
        <ByokDemo client:only="preact" chips={CHIPS} />
      </div>
    </div>

    <details class="try-clone">
      <summary>Or clone & develop locally</summary>
      <pre><code>{`git clone https://github.com/adoistic/falsafa
cd falsafa && bun install
cd apps/site && bun run dev          # reading site
cd apps/mcp  && bun run dev          # MCP server (stdio)`}</code></pre>
      <p>See the <a href="https://github.com/adoistic/falsafa#readme">README</a> for the full eval / convert / image-gen scripts.</p>
    </details>

    <NonDeterminismCaveat />
    <ReportThis />
  </article>
</Base>

<style>
  .try-page {
    max-width: 70ch;
    margin: 0 auto;
    padding: var(--s-12) var(--s-6) var(--s-24);
  }

  .try-header {
    margin-bottom: var(--s-12);
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-2);
  }

  h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-4);
  }

  .lede {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    line-height: 1.5;
    margin: 0;
  }

  .try-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
    margin-bottom: var(--s-12);
  }

  @media (min-width: 768px) {
    .try-page {
      max-width: 90ch;
    }
    .try-hero {
      grid-template-columns: 1fr 1fr;
      gap: var(--s-8);
    }
  }

  .try-byok-card {
    border: 1px solid var(--rule);
    padding: var(--s-6);
  }
  .try-byok-card-head h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    margin: 0 0 var(--s-2);
  }
  .try-byok-card-head p {
    color: var(--ink-muted);
    margin: 0 0 var(--s-6);
  }

  .try-clone {
    margin-top: var(--s-6);
    padding: var(--s-4) var(--s-6);
    border: 1px dashed var(--rule);
  }
  .try-clone summary {
    cursor: pointer;
    font-family: var(--font-sans);
    color: var(--accent);
  }
  .try-clone pre {
    background: var(--paper-soft, var(--paper));
    border: 1px solid var(--rule);
    padding: var(--s-3) var(--s-4);
    font-family: var(--font-mono, "SF Mono", Menlo, monospace);
    font-size: 12px;
    overflow-x: auto;
    margin: var(--s-3) 0;
  }
</style>
