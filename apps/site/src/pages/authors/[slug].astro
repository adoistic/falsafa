---
import type { GetStaticPaths } from "astro";
import Base from "../../layouts/Base.astro";
import WorkCardGrid from "../../components/WorkCardGrid.astro";
import { manifest } from "../../lib/corpus";

export const getStaticPaths = (() => {
  const m = manifest();
  return Object.entries(m.authors).map(([slug, info]) => ({
    params: { slug },
    props: { authorSlug: slug, authorName: info.name, workSlugs: info.works },
  }));
}) satisfies GetStaticPaths;

const { authorSlug, authorName, workSlugs } = Astro.props;
const m = manifest();

// Resolve the author's works from the manifest (avoid per-chapter
// listChapters here — total_logical_chapters is already aggregated).
const authorWorks = workSlugs
  .map((s) => m.works.find((w) => w.slug === s))
  .filter((w): w is NonNullable<typeof w> => w !== undefined);

const totalChapters = authorWorks.reduce((acc, w) => acc + w.total_logical_chapters, 0);
const erasSet = new Set(authorWorks.map((w) => w.era));
const eras = [...erasSet];
const languagesSet = new Set(authorWorks.map((w) => w.language));
const languages = [...languagesSet];

// "Unknown" is a real bucket of 21 anonymous works (smṛtis, tattvas, etc.)
// that deserves a graceful landing page rather than a placeholder name.
const isUnknown = authorSlug === "unknown";
const headingName = isUnknown ? "Unknown" : authorName;
const description = isUnknown
  ? `${authorWorks.length} anonymous works in the Falsafa catalog — Sanskrit smṛtis, Old Javanese tattvas, and other texts whose authors have not been identified.`
  : `Works by ${authorName} in the Falsafa catalog: ${authorWorks
      .map((w) => w.title)
      .join(", ")}.`;
---

<Base title={headingName} description={description}>
  <div class="container">
    <header class="page-header">
      <p class="kicker">Author</p>
      <h1>{headingName}</h1>
      {isUnknown ? (
        <p class="lede">
          Anonymous works whose authorship has not been established. The translations stand on
          their own.
        </p>
      ) : (
        <p class="lede">
          {authorWorks.length} {authorWorks.length === 1 ? "work" : "works"} in the catalog.
        </p>
      )}

      <dl class="meta-grid">
        <div>
          <dt>Works</dt>
          <dd>{authorWorks.length}</dd>
        </div>
        <div>
          <dt>Chapters</dt>
          <dd>{totalChapters}</dd>
        </div>
        <div>
          <dt>{eras.length === 1 ? "Era" : "Eras"}</dt>
          <dd>{eras.join(", ")}</dd>
        </div>
        {languages.length > 0 && (
          <div>
            <dt>{languages.length === 1 ? "Language" : "Languages"}</dt>
            <dd>{languages.join(", ")}</dd>
          </div>
        )}
      </dl>
    </header>

    <WorkCardGrid works={authorWorks} />
  </div>
</Base>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: var(--s-12) var(--s-8) var(--s-24);
  }

  .page-header {
    max-width: 70ch;
    margin: 0 0 var(--s-16);
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-2);
  }

  h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    margin: 0 0 var(--s-3);
    letter-spacing: -0.02em;
  }

  .lede {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    line-height: 1.4;
    margin: 0 0 var(--s-8);
  }

  .meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--s-4);
    padding-top: var(--s-6);
    border-top: 1px solid var(--rule);
    font-family: var(--font-sans);
    margin: 0;
  }

  .meta-grid dt {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-bottom: var(--s-1);
  }

  .meta-grid dd {
    font-size: var(--fs-body);
    margin: 0;
    color: var(--ink);
  }
</style>
