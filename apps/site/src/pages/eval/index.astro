---
import Base from "../../layouts/Base.astro";
import EvalExplorer from "../../islands/eval-explorer/EvalExplorer";
import "../../styles/eval.css";

// /eval — the Falsafa adversarial eval browser. The "Audit" label in the
// top nav points here directly. We don't ship a separate editorial
// /audit landing page — one URL, one experience, less surface area to
// drift.
//
// Loads /eval.json (built by `bun run eval/build-eval-json.ts`) and lets a
// reader filter, search, and audit any case. Each result deep-links to
// the cited paragraph in /works/.../#p-x. If eval.json hasn't been built
// yet the island shows a helpful empty state with the build command.
---

<Base
  title="Eval"
  description="Browse the Falsafa adversarial eval suite. 1,000+ cases, per-model verdicts, citations that resolve to the paragraph. The audit trail behind the headline numbers."
  ogImage="/og/eval.png"
>
  <article class="eval-page">
    <header class="eval-page-header">
      <p class="eval-kicker">Eval</p>
      <h1>Every claim, browseable.</h1>
      <p class="eval-lede">
        The 1,000-case adversarial eval suite, side by side with the Sonnet
        judge's verdict on each case. Filter by category, difficulty, or
        model. Click a row to see the answer, the tool-call trace, and the
        cited paragraphs — every paragraph_id deep-links to the source in
        the reading site. If a model hallucinated, the judge says so and
        you can verify by following the citation.
      </p>
      <p class="eval-lede-meta">
        For the methodology, see <a href="/thesis/">/thesis</a>. For a live
        run with your own key, <a href="/try/">/try</a>. Source for the
        eval pipeline lives at <code>apps/mcp/eval/</code>.
      </p>
    </header>

    {/* client:only — the explorer reads window.location.hash on mount to
        seed filter state. SSR would diverge from client and break
        hydration. The cost is a brief skeleton-free flash before the
        bundle loads (~150ms). Same tradeoff as /try. */}
    <EvalExplorer client:only="preact" />
  </article>
</Base>
