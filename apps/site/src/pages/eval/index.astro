---
import Base from "../../layouts/Base.astro";
import EvalExplorer from "../../islands/eval-explorer/EvalExplorer";
import "../../styles/eval.css";

// /eval — the Falsafa adversarial eval browser. The "Audit" label in the
// top nav points here directly. We don't ship a separate editorial
// /audit landing page — one URL, one experience, less surface area to
// drift.
//
// Loads /eval.json (built by `bun run eval/build-eval-json.ts`) and lets a
// reader filter, search, and audit any case. Each result deep-links to
// the cited paragraph in /works/.../#p-x. If eval.json hasn't been built
// yet the island shows a helpful empty state with the build command.
---

<Base
  title="Eval"
  description="Browse the Falsafa adversarial eval suite. 1,120 cases, deterministic citation-based verdicts, every cited paragraph deep-links to the source. The audit trail behind the headline numbers."
  ogImage="/og/eval.png"
>
  <article class="eval-page">
    <header class="eval-page-header">
      <p class="eval-kicker">Eval</p>
      <h1>Every claim, browseable.</h1>
      <p class="eval-lede">
        The 1,120-case adversarial eval suite, side by side with each
        model's per-case answer and citations. Filter by category,
        difficulty, or comparison verdict. Click a row to see the answer,
        the tool-call trace, and the cited paragraphs — every
        paragraph_id deep-links to the source in the reading site.
      </p>
      <p class="eval-lede">
        <strong>Scoring is deterministic.</strong> A case passes when
        every <code>expected_works</code> entry appears in the model's
        answer, with NFKD diacritic folding so &ldquo;Manusm&#x1E5B;ti&rdquo; matches
        &ldquo;manusmrti.&rdquo; No LLM judge runs at score time &mdash; the verdict
        is a substring check on prose, not a graded judgment. A graded
        3-state score (pass / mixed / fail) tied to citation discipline
        is queued; see <a href="/thesis/#methodology">methodology</a> for
        the trade-off and what the current numbers mean.
      </p>
      <p class="eval-lede-meta">
        For the full thesis, see <a href="/thesis/">/thesis</a>. For a
        live run with your own key, <a href="/try/">/try</a>. Source
        for the eval pipeline lives at <code>apps/mcp/eval/</code>.
      </p>
    </header>

    {/* client:only — the explorer reads window.location.hash on mount to
        seed filter state. SSR would diverge from client and break
        hydration. The cost is a brief skeleton-free flash before the
        bundle loads (~150ms). Same tradeoff as /try. */}
    <EvalExplorer client:only="preact" />
  </article>
</Base>
