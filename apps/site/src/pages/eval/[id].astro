---
import Base from "../../layouts/Base.astro";
import NonDeterminismCaveat from "../../components/NonDeterminismCaveat.astro";
import ReportThis from "../../components/ReportThis.astro";
import ToolCallTrace from "../../components/ToolCallTrace.astro";
import RunItYourself from "../../components/RunItYourself.astro";
import { listChapters } from "../../lib/corpus";
import { linkifyHtml } from "../../lib/eval-paragraph-link";
import { passOf } from "../../lib/eval-types";
import type { EvalJson, EvalCase } from "../../lib/eval-types";
import type { GetStaticPaths } from "astro";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { Marked } from "marked";
import markedFootnote from "marked-footnote";
import DOMPurify from "isomorphic-dompurify";

// Mirror BYOK's MarkdownView config — gfm + breaks + footnote — so recorded
// answers render the same way they do in the live demo. Scoped Marked
// instance (not the global) so the footnote extension stays contained.
const md = new Marked({ gfm: true, breaks: true, async: false });
md.use(markedFootnote());

// Force noopener+noreferrer + target="_blank" on external links in sanitized
// model output. Same-tab open of a model-controlled URL has no opener
// isolation; this hook closes that gap. http(s) protocols only — relative
// links (e.g. /works/...) are internal and stay in-tab.
DOMPurify.addHook("afterSanitizeAttributes", (node: any) => {
  if (node.tagName === "A" && node.getAttribute("href")?.match(/^https?:/)) {
    node.setAttribute("rel", "noopener noreferrer");
    node.setAttribute("target", "_blank");
  }
});

export const getStaticPaths = (() => {
  // Inlined for locality; see Astro 5 getStaticPaths notes.
  const evalJsonPath = resolve(process.cwd(), "public", "eval.json");
  const data = JSON.parse(readFileSync(evalJsonPath, "utf-8")) as EvalJson;
  // The page is currently single-model (the redesign collapsed the four
  // sonnet runs into one entry). Pull the model id from data.models[0]
  // and pass it through props so the page renders whichever model is
  // primary today (sonnet, grok-4.1-fast, etc.) without code edits.
  const primaryModelId = data.models[0]?.id;
  return data.cases.map((c) => ({
    params: { id: c.id },
    props: { case: c, primaryModelId },
  }));
}) satisfies GetStaticPaths;

const { case: c, primaryModelId } = Astro.props as {
  case: EvalCase;
  primaryModelId: string | undefined;
};
const result = primaryModelId ? c.results[primaryModelId] : undefined;
const verdict = passOf(result);
const verdictText = verdict === true ? "Pass" : verdict === false ? "Fail" : "Unjudged";
const verdictGlyph = verdict === true ? "✓" : verdict === false ? "×" : "—";

// Render pipeline (order matters):
//   1. md.parse(answer)               → markdown-rendered HTML (gfm + breaks + footnote)
//   2. DOMPurify.sanitize(rendered)   → strips <script>, <iframe>, on*= handlers, etc.
//   3. linkifyHtml(sanitized, ...)    → wraps p-XXXXXX tokens in anchors,
//                                       skipping <pre>/<code> regions
const rendered = result ? md.parse(result.answer) : "";
if (typeof rendered !== "string") {
  throw new Error("marked.parse returned non-string; check marked version compat");
}
const sanitized = DOMPurify.sanitize(rendered, {
  // Comprehensive markdown-output set: tables, semantic inline tags, hr,
  // dl/dt/dd, sub/sup, kbd/samp/var. Real model output uses these; silently
  // stripping them would change how recorded answers render.
  ALLOWED_TAGS: [
    "p", "br", "hr", "strong", "em", "del", "ins", "mark", "sub", "sup",
    "code", "pre", "kbd", "samp", "var",
    "blockquote",
    "ul", "ol", "li", "dl", "dt", "dd",
    "h1", "h2", "h3", "h4", "h5", "h6",
    "a",
    "table", "thead", "tbody", "tfoot", "tr", "th", "td",
  ],
  ALLOWED_ATTR: ["href", "title", "colspan", "rowspan", "align", "scope", "target", "rel"],
});
const answerHtml = result ? linkifyHtml(sanitized, result.citations, listChapters) : "";

const caseUrl = `https://falsafa.ai/eval/${c.id}/`;
// The runner writes to runs/<run-name>/<model-label>/q-NNNN.json — same
// shape used by build-eval-json. The model-label and the model id at
// data.models[0].id match by construction (one model entry per
// modelLabel), so primaryModelId is the right path segment here.
const sourceUrl = result && primaryModelId
  ? `https://github.com/adoistic/falsafa/tree/main/apps/mcp/eval/runs/${result.from_run}/${primaryModelId}/${c.id}.json`
  : null;

// Citations chip row data — distinct from expected_works (auditor's intent).
// Citations are what the model actually cited; expected_works is what the
// auditor said it should land on. Showing both lets the reader compare.
const citationChips = result?.citations
  ?.filter((c) => c.work_slug)
  ?.reduce<Array<{ workSlug: string; chapterNumber?: number; chapterSlug?: string; paragraphIds: string[] }>>(
    (acc, c) => {
      const existing = acc.find(
        (a) => a.workSlug === c.work_slug && a.chapterNumber === c.chapter_number,
      );
      if (existing && c.paragraph_id) existing.paragraphIds.push(c.paragraph_id);
      else {
        // Resolve chapter_slug at build time so the chip can deep-link to
        // /works/<work>/<chapter>/translation/#<paragraph_id>. Falls back
        // to /works/<work>/ when the chapter can't be resolved.
        let chapterSlug: string | undefined;
        if (c.chapter_number !== undefined) {
          const chapters = listChapters(c.work_slug);
          chapterSlug = chapters.find((ch) => ch.chapter_number === c.chapter_number)?.chapter_slug;
        }
        acc.push({
          workSlug: c.work_slug,
          chapterNumber: c.chapter_number,
          chapterSlug,
          paragraphIds: c.paragraph_id ? [c.paragraph_id] : [],
        });
      }
      return acc;
    },
    [],
  ) ?? [];
---

<Base
  title={`${c.id} · Eval`}
  description={`Falsafa eval case ${c.id}: ${c.prompt.slice(0, 140)}…`}
>
  {/* Page-level CSP: the answer body is sanitized by DOMPurify but defense-
      in-depth via CSP keeps the surface tight. No 'unsafe-eval', no inline
      scripts allowed. The case page has no Pagefind dynamic-import need
      (Pagefind only runs on /eval/ via the search dialog), so we don't need
      the Pagefind escape that /try/ has. */}
  <Fragment slot="head">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';" />
    {/* Until a judge layer runs, every passOf() falls back to mechanical-pass —
        which over-counts on long/wordy answers. Don't let Google index recorded
        model output as 'audited' when the audit isn't real yet. Removed in the
        commit that ships the first judged batch. */}
    <meta name="robots" content="noindex,follow" />
  </Fragment>

  <article class="eval-case-page" data-pagefind-body>
    <nav class="eval-case-breadcrumb" aria-label="Breadcrumb">
      <a href="/eval/">← Eval</a>
      <span class="sep">/</span>
      <span>{c.id}</span>
      <span class={`verdict-pill verdict-${verdict === true ? "pass" : verdict === false ? "fail" : "unjudged"}`}>
        {verdictGlyph} {verdictText}
      </span>
    </nav>

    <header class="eval-case-header">
      <p class="kicker">
        {c.category} · {c.difficulty}
        {c.tier === "hidden" && (
          <span class="tier-badge tier-badge--hidden" title="Discovery tier — the question hides the work, testing whether the model can find it by content alone.">
            · discovery
          </span>
        )}
        {c.tier === "named" && (
          <span class="tier-badge tier-badge--named" title="Citation tier — the question names the work, testing citation precision.">
            · citation
          </span>
        )}
      </p>
      <h1>{c.prompt}</h1>
      {c.rationale && <p class="rationale">Why this is in the suite: {c.rationale}</p>}
      {c.expected_works.length > 0 && (
        <div class="expected-works">
          <span class="expected-works-label">Expected works:</span>
          {c.expected_works.map((slug) => (
            <a class="expected-works-chip" href={`/works/${slug}/`}>{slug}</a>
          ))}
        </div>
      )}
      {citationChips.length > 0 && (
        <div class="model-citations">
          <span class="model-citations-label">Model cited:</span>
          {citationChips.map((cite) => {
            const href = cite.chapterSlug
              ? `/works/${cite.workSlug}/${cite.chapterSlug}/translation/${cite.paragraphIds[0] ? `#${cite.paragraphIds[0]}` : ""}`
              : `/works/${cite.workSlug}/`;
            return (
              <a
                class="model-citations-chip"
                href={href}
                title={`${cite.workSlug}${cite.chapterNumber !== undefined ? ` ch.${cite.chapterNumber}` : ""}${cite.paragraphIds.length ? ` (${cite.paragraphIds.join(", ")})` : ""}`}
              >
                {cite.workSlug}{cite.chapterNumber !== undefined && ` · ch ${cite.chapterNumber}`}
              </a>
            );
          })}
        </div>
      )}
    </header>

    {result ? (
      <>
        <section class="eval-case-trace">
          <h2>Tool calls</h2>
          <ToolCallTrace calls={result.tool_calls} />
        </section>

        {result.usage && (
          <section class="eval-case-usage">
            <h2>Cost &amp; tokens</h2>
            <p class="usage-summary">
              {typeof result.usage.cost_usd === "number" && (
                <>
                  <strong>${result.usage.cost_usd.toFixed(4)}</strong> ·{" "}
                </>
              )}
              <strong>{result.usage.api_calls}</strong> API call{result.usage.api_calls === 1 ? "" : "s"} ·{" "}
              <strong>{result.usage.total_tokens.toLocaleString()}</strong> tokens
              {" "}({result.usage.prompt_tokens.toLocaleString()} prompt
              {result.usage.cached_tokens > 0 && (
                <> incl. <strong>{result.usage.cached_tokens.toLocaleString()}</strong> cached</>
              )}
              {" "}/ {result.usage.completion_tokens.toLocaleString()} completion)
            </p>
            {result.usage.usage_per_call && result.usage.usage_per_call.length > 0 && (
              <details class="usage-per-step">
                <summary>Per-step trace ({result.usage.usage_per_call.length} call{result.usage.usage_per_call.length === 1 ? "" : "s"})</summary>
                <table class="usage-table">
                  <thead>
                    <tr>
                      <th scope="col">#</th>
                      <th scope="col">Trigger</th>
                      <th scope="col">Preceded by</th>
                      <th scope="col" class="num">Prompt</th>
                      <th scope="col" class="num">Completion</th>
                      <th scope="col" class="num">Cached</th>
                      <th scope="col" class="num">Cost</th>
                    </tr>
                  </thead>
                  <tbody>
                    {result.usage.usage_per_call.map((step) => (
                      <tr>
                        <td class="num">{step.api_call_index}</td>
                        <td>{step.trigger}</td>
                        <td class="preceded-by">
                          {step.preceded_by && step.preceded_by.length > 0
                            ? step.preceded_by.join(", ")
                            : "—"}
                        </td>
                        <td class="num">{step.prompt_tokens.toLocaleString()}</td>
                        <td class="num">{step.completion_tokens.toLocaleString()}</td>
                        <td class="num">{step.cached_tokens > 0 ? step.cached_tokens.toLocaleString() : "—"}</td>
                        <td class="num">
                          {typeof step.cost_usd === "number" ? `$${step.cost_usd.toFixed(5)}` : "—"}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </details>
            )}
            <p class="usage-model">
              <small>Model: <code>{result.usage.model}</code></small>
            </p>
          </section>
        )}

        <section class="eval-case-answer">
          <h2>Answer</h2>
          <div class="answer-body" set:html={answerHtml} />
        </section>

        {result.judge && (
          <section class="eval-case-judge">
            <h2>Judge verdict</h2>
            <ul class="judge-badges">
              <li class={result.judge.factual_correct ? "ok" : "no"}>factual_correct</li>
              <li class={result.judge.citation_backed ? "ok" : "no"}>citation_backed</li>
              <li class={result.judge.hallucinated ? "no" : "ok"}>{result.judge.hallucinated ? "hallucinated" : "not hallucinated"}</li>
            </ul>
            <p class="judge-naturalness">Naturalness: {result.judge.naturalness_1to5}/5</p>
            <blockquote class="judge-reasoning">{result.judge.reasoning}</blockquote>
            <p class="judge-model"><small>Judged by {result.judge.judge_model}</small></p>
          </section>
        )}

        <RunItYourself prompt={c.prompt} toolCalls={result.tool_calls} />

        <NonDeterminismCaveat />
        <ReportThis caseId={c.id} caseUrl={caseUrl} recordedAnswer={result.answer} />

        {sourceUrl && (
          <footer class="eval-case-meta">
            <p>From run <a href={sourceUrl}>{result.from_run}</a> · <code>{c.id}.json</code></p>
          </footer>
        )}
      </>
    ) : (
      <p class="eval-case-no-result">No recorded result for this case.</p>
    )}
  </article>
</Base>

<style>
  .eval-case-page {
    max-width: 70ch;
    margin: 0 auto;
    padding: var(--s-12) var(--s-6) var(--s-24);
    font-family: var(--font-body);
  }
  .eval-case-breadcrumb {
    display: flex;
    gap: var(--s-3);
    align-items: center;
    font-family: var(--font-sans);
    font-size: 12px;
    text-transform: lowercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--s-8);
    color: var(--ink-muted);
  }
  .eval-case-breadcrumb a {
    color: var(--ink-muted);
  }
  .eval-case-breadcrumb .sep { color: var(--rule); }
  .verdict-pill {
    margin-left: auto;
    padding: 2px var(--s-3);
    border: 1px solid currentColor;
    font-weight: 600;
  }
  .verdict-pass { color: var(--accent-pass, var(--accent)); }
  .verdict-fail { color: var(--accent-fail, #b00); }
  .verdict-unjudged { color: var(--ink-muted); }

  .eval-case-header { margin-bottom: var(--s-12); }
  .eval-case-header .kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-3);
  }
  /* Tier badge — sits inline with the category/difficulty kicker.
     Hidden (discovery) is the headline tier — slightly emphasised. */
  .tier-badge { font-weight: 600; cursor: help; }
  .tier-badge--hidden { color: var(--accent); }
  .tier-badge--named { color: var(--ink-muted); }
  .eval-case-header h1 {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    line-height: var(--lh-display);
    margin: 0 0 var(--s-4);
  }
  .rationale {
    color: var(--ink-muted);
    font-style: italic;
    margin: 0 0 var(--s-4);
  }
  .expected-works {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .expected-works-label { color: var(--ink-muted); }
  .expected-works-chip {
    padding: 2px var(--s-3);
    border: 1px solid var(--rule);
    color: var(--ink);
    text-decoration: none;
  }

  .model-citations {
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 13px;
    margin-top: var(--s-3);
  }
  .model-citations-label { color: var(--ink-muted); }
  .model-citations-chip {
    padding: 2px var(--s-3);
    border: 1px dashed var(--rule);  /* dashed to differ from solid expected_works */
    color: var(--ink);
    text-decoration: none;
  }

  .eval-case-trace,
  .eval-case-answer,
  .eval-case-judge,
  .eval-case-usage { margin-bottom: var(--s-10); }
  .eval-case-trace h2,
  .eval-case-answer h2,
  .eval-case-judge h2,
  .eval-case-usage h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    margin: 0 0 var(--s-4);
  }
  .answer-body {
    line-height: var(--lh-body);
  }
  .answer-body a {
    color: var(--accent);
    border-bottom: 1px solid currentColor;
  }

  .judge-badges {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--s-3);
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
  .judge-badges li {
    padding: 2px var(--s-3);
    font-family: var(--font-sans);
    font-size: 12px;
  }
  .judge-badges .ok { background: #e8f3ea; color: #2a6f3c; }
  .judge-badges .no { background: #f7e3e3; color: #8a2222; }
  .judge-naturalness { color: var(--ink-muted); margin: 0 0 var(--s-3); }
  .judge-reasoning {
    border-left: 2px solid var(--rule);
    padding-left: var(--s-4);
    margin: 0 0 var(--s-3);
    color: var(--ink-muted);
  }

  .eval-case-meta {
    margin-top: var(--s-12);
    padding-top: var(--s-6);
    border-top: 1px solid var(--rule);
    font-size: 12px;
    color: var(--ink-muted);
    font-family: var(--font-sans);
  }
  .eval-case-no-result {
    padding: var(--s-12);
    text-align: center;
    color: var(--ink-muted);
  }

  /* Cost & tokens — per-case section */
  .usage-summary {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--ink);
    margin: 0 0 var(--s-3);
    line-height: 1.5;
  }
  .usage-per-step summary {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--accent);
    cursor: pointer;
    padding: var(--s-2) 0;
    user-select: none;
  }
  .usage-per-step summary:hover { text-decoration: underline; }
  .usage-table {
    width: 100%;
    margin-top: var(--s-3);
    font-family: var(--font-mono);
    font-size: 12px;
    border-collapse: collapse;
  }
  .usage-table th,
  .usage-table td {
    padding: var(--s-2) var(--s-3);
    border-bottom: 1px solid var(--rule);
    text-align: left;
    vertical-align: top;
  }
  .usage-table th {
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.06em;
  }
  .usage-table td.num,
  .usage-table th.num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .usage-table .preceded-by {
    color: var(--ink-muted);
    font-size: 11px;
    max-width: 240px;
    word-break: break-word;
  }
  .usage-model {
    color: var(--ink-muted);
    margin: var(--s-3) 0 0;
    font-size: 12px;
  }
  .usage-model code {
    background: rgba(138, 58, 46, 0.05);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: 11px;
  }
</style>
