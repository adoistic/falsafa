---
import Base from "../layouts/Base.astro";
import { manifest, readWorkIndex } from "../lib/corpus";

const m = manifest();

// All works that have a cover image — eligible for the featured slot.
// We embed the full eligible pool in the page (as JSON), and an inline
// script picks one at random on every page load. The first pick is also
// rendered server-side so search engines + no-JS readers see real
// content instead of a blank slot. A build-time random seed nudges the
// SSR pick so each new build is fresh too.
interface FeaturedEntry {
  slug: string;
  title: string;
  author: string;
  description: string;
  cover_url: string;
}
const featuredPool: FeaturedEntry[] = [];
for (const w of m.works) {
  const idx = readWorkIndex(w.slug);
  if (!idx?.cover_url) continue;
  featuredPool.push({
    slug: w.slug,
    title: w.title,
    author: w.author,
    description: w.description,
    cover_url: idx.cover_url,
  });
}
// Build-time SSR pick: deterministic per build (use the first work in
// the pool — the inline script will swap on load anyway). Keeping this
// stable makes Pagefind / SEO snapshots stable across reloads of the
// same build.
const ssrPick = featuredPool[0]!;

// Era nodes for the timeline
const eraOrder = ["Ancient", "Antiquity", "Medieval", "Enlightenment", "19th Century", "20th Century", "Unknown"];
const eraEntries = eraOrder
  .filter((e) => m.eras[e.toLowerCase().replace(/[^a-z0-9]+/g, "-")])
  .map((label) => {
    const slug = label.toLowerCase().replace(/[^a-z0-9]+/g, "-");
    return { label, slug, count: m.eras[slug]?.works.length ?? 0 };
  });

// Live totals for the description meta tag — derived from the manifest at
// build time so the SEO snippet stays in sync with /numbers as the corpus
// grows.
const totalChapters = m.works.reduce((s, w) => s + (w.total_logical_chapters ?? 0), 0);
const totalVariants = m.works.reduce((s, w) => s + (w.total_variant_entries ?? 0), 0);
const description = `A premium reading platform for translated philosophical and classical texts. ${m.counts.works} works, ${totalChapters.toLocaleString("en-US")} logical chapters, ${totalVariants.toLocaleString("en-US")} variant entries across ${m.counts.languages} languages. Free, public, open source.`;
---

<Base
  title="Falsafa"
  description={description}
>
  <div class="container">
    <section class="featured" data-featured>
      <a href={`/works/${ssrPick.slug}/`} class="featured-cover" data-featured-link>
        <img src={ssrPick.cover_url} alt={`Cover for ${ssrPick.title}`} data-featured-img />
      </a>
      <div class="featured-text">
        <p class="kicker">Featured reading</p>
        <h1 class="featured-title" data-featured-title>{ssrPick.title}</h1>
        <p class="featured-author" data-featured-author>{ssrPick.author}</p>
        <p class="featured-desc" data-featured-desc>{ssrPick.description}</p>
        <a href={`/works/${ssrPick.slug}/`} class="cta" data-featured-cta>Begin reading →</a>
      </div>
    </section>

    {/* Embedded pool for the on-load random swap. Kept as application/json
        so it doesn't block parsing and stays out of the global namespace. */}
    <script type="application/json" id="featured-pool" set:html={JSON.stringify(featuredPool)} />

    <script is:inline>
      /* Featured-work rotation: pick a different work on every page load.
         Inline + synchronous so it runs before the browser commits the
         initial paint, avoiding a flash of the SSR pick. */
      (function () {
        var poolNode = document.getElementById("featured-pool");
        if (!poolNode || !poolNode.textContent) return;
        var pool;
        try { pool = JSON.parse(poolNode.textContent); } catch { return; }
        if (!Array.isArray(pool) || pool.length < 2) return;
        var pick = pool[Math.floor(Math.random() * pool.length)];
        var section = document.querySelector("[data-featured]");
        if (!section) return;
        var link = section.querySelector("[data-featured-link]");
        var img = section.querySelector("[data-featured-img]");
        var title = section.querySelector("[data-featured-title]");
        var author = section.querySelector("[data-featured-author]");
        var desc = section.querySelector("[data-featured-desc]");
        var cta = section.querySelector("[data-featured-cta]");
        var href = "/works/" + pick.slug + "/";
        if (link) link.setAttribute("href", href);
        if (img) {
          img.setAttribute("src", pick.cover_url);
          img.setAttribute("alt", "Cover for " + pick.title);
        }
        if (title) title.textContent = pick.title;
        if (author) author.textContent = pick.author;
        if (desc) desc.textContent = pick.description;
        if (cta) cta.setAttribute("href", href);
      })();
    </script>

    <section class="catalog-overview">
      <h2>The catalog</h2>
      <p class="lede">
        {m.counts.works} works across {m.counts.eras} eras, {m.counts.languages} languages,
        {m.counts.authors} authors. Translations and transliterations by Thothica.
      </p>
      <div
        class="era-strip"
        role="list"
        style={`--era-count: ${eraEntries.length}`}
      >
        {eraEntries.map((e) => (
          <a
            href={`/eras/${e.slug}/`}
            class="era-node"
            role="listitem"
            aria-label={`${e.label}: ${e.count} ${e.count === 1 ? "work" : "works"}`}
          >
            <span class="era-count">{e.count}</span>
            <span class="era-label">{e.label}</span>
          </a>
        ))}
      </div>
      <p class="all-works-link">
        <a href="/works/">Browse all {m.counts.works} works →</a>
      </p>
    </section>
  </div>
</Base>

<style>
  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: var(--s-12) var(--s-8) var(--s-24);
  }

  .featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-12);
    margin-bottom: var(--s-24);
    align-items: center;
  }

  @media (min-width: 768px) {
    .featured {
      grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
      gap: var(--s-16);
    }
  }

  .featured-cover {
    display: block;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--rule);
    transition: transform 0.3s ease;
  }

  .featured-cover:hover {
    transform: scale(1.01);
  }

  .featured-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-text {
    font-family: var(--font-body);
  }

  .kicker {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin: 0 0 var(--s-3);
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: 700;
    line-height: var(--lh-display);
    letter-spacing: -0.02em;
    margin: 0 0 var(--s-2);
  }

  .featured-author {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    margin: 0 0 var(--s-6);
    font-size: var(--fs-h3);
  }

  .featured-desc {
    margin: 0 0 var(--s-6);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  .cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--accent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  .catalog-overview {
    margin-top: var(--s-24);
    padding-top: var(--s-12);
    border-top: 1px solid var(--rule);
  }

  .catalog-overview h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 600;
    margin: 0 0 var(--s-3);
  }

  .lede {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: var(--fs-h3);
    line-height: 1.4;
    max-width: 60ch;
    margin: 0 0 var(--s-12);
  }

  /* Era strip — a typographic timeline. Each cell is a clickable era,
     showing the work count as a display-serif anchor and the era name as
     a small-caps label below. Top + bottom rules tie the row together
     like an editorial axis; no boxes, no clutter. */
  .era-strip {
    display: grid;
    grid-template-columns: repeat(var(--era-count, 6), minmax(0, 1fr));
    gap: var(--s-6) var(--s-4);
    margin-bottom: var(--s-8);
    padding: var(--s-8) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  @media (max-width: 720px) {
    .era-strip {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .era-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .era-node {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    color: var(--ink);
    text-decoration: none;
  }

  .era-count {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: var(--s-2);
    transition: color 0.2s ease;
  }

  .era-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .era-node:hover .era-count,
  .era-node:focus-visible .era-count {
    color: var(--accent);
  }

  .era-node:hover .era-label,
  .era-node:focus-visible .era-label {
    color: var(--ink);
  }

  .era-node:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }

  .all-works-link {
    margin: 0;
    font-family: var(--font-sans);
  }
</style>
