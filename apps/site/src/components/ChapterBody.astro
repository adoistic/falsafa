---
/**
 * Renders the chapter body. The body markdown can include headings, lists,
 * blockquotes, emphasis — all the standard CommonMark constructs. We pass it
 * through `marked` (~30KB, pure-ESM) and inject the resulting HTML.
 *
 * Each top-level block also gets an id="p-xxx" attribute injected based on
 * the chapter's *.paragraphs.json sidecar, so citation URLs from the BYOK
 * demo (#p-x or ?paragraphs=p-1,p-2,p-3#p-1) can scroll to and highlight
 * specific paragraphs. When no sidecar is present, blocks render without
 * IDs — the page still works, just without citation anchors.
 *
 * Layout-specific styling lives in reader.css; this component is layout-agnostic.
 */
import { readParagraphSidecar, type ChapterFrontmatter } from "../lib/corpus";
import { renderMarkdownWithParagraphIds } from "../lib/inject-paragraph-ids";

interface Props {
  body: string;
  frontmatter: ChapterFrontmatter;
  /** Slugs needed to find the matching sidecar. Optional — when absent
   *  (older callers, ad-hoc render contexts) we render without IDs. */
  workSlug?: string;
  chapterSlug?: string;
  /** The variant's `file` field (e.g. "translation.md"). Needed to
   *  pick the correct sidecar (`translation.paragraphs.json`). */
  variantFile?: string;
}

const { body, frontmatter, workSlug, chapterSlug, variantFile } = Astro.props;

// Strip leading boilerplate that pollutes some chapters: a leading line equal
// to the work title, a leading "===" rule, redundant Source: lines, the
// section break "----...", or a duplicate chapter title at the top of the
// body. The frontmatter already carries this metadata, so we render the
// substantive content only.
function cleanBody(raw: string): string {
  let s = raw;
  // Drop "Source: …" line if present near the top — frontmatter has source_url
  s = s.replace(/^Source:\s*\S+\n?/m, "");
  // Drop generic "Lines: NNN" markers
  s = s.replace(/^Lines:\s*\d+\n?/m, "");
  // Drop horizontal-rule scarring (long runs of dashes or equals on their own line)
  s = s.replace(/^[-=─━]{10,}$/gm, "");
  // Drop sequence of header-style scarring at the top: lines that exactly
  // repeat the work title or are heading underlines
  return s.trim();
}

const cleaned = cleanBody(body);
const sidecar =
  workSlug && chapterSlug && variantFile
    ? readParagraphSidecar(workSlug, chapterSlug, variantFile)
    : [];
const html = renderMarkdownWithParagraphIds(cleaned, sidecar);

// Only English translation variants are indexed by Pagefind. Transliterations
// (romanized) and originals (source script) are quote-only material and would
// pollute the search corpus with romanized noise.
const indexable = frontmatter.content_type === "translation";
---

{
  indexable ? (
    <div class="reader-body" data-pagefind-body set:html={html} />
  ) : (
    <div class="reader-body" set:html={html} />
  )
}

{
  frontmatter.source_url && (
    <div class="source-citation">
      Source:{" "}
      <a href={frontmatter.source_url} rel="noopener noreferrer" target="_blank">
        {frontmatter.source_url}
      </a>
    </div>
  )
}
