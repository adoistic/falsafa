---
/**
 * SearchDialog — custom search overlay for Falsafa.
 *
 * Replaces @pagefind/default-ui because we need:
 *   - Comma-OR semantics ("dharma, courage" → either)
 *   - Trailing-wildcard typo fallback ("corage" → "courage")
 *   - Native facet filtering by era, author, source language
 *
 * Architecture:
 *   - Lazy-loads /pagefind/pagefind.js (the JS API, NOT the default UI)
 *     on first dialog open.
 *   - transformQuery() (../scripts/transform-query.ts) builds a strategy
 *     chain from the user's typed input.
 *   - search-runner orchestrates the chain + facet filters and renders
 *     to the result list.
 *
 * The dialog itself is mounted once in Base.astro and re-used across
 * pages. View transitions don't break it because we use addEventListener
 * with `{ once: false }` on a single element that survives navigations.
 */
---

<dialog id="search-dialog" class="search-dialog" aria-label="Search Falsafa">
  <div class="search-dialog-inner">
    <button type="button" class="search-close" aria-label="Close search" data-search-close>×</button>

    <form class="search-form" autocomplete="off" onsubmit="return false;">
      <label class="visually-hidden" for="search-input">Search query</label>
      <div class="search-input-wrap">
        <svg class="search-input-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          id="search-input"
          type="search"
          class="search-input"
          placeholder="Search translations  ⌘K"
          aria-describedby="search-help"
          spellcheck="false"
          autocapitalize="off"
        />
      </div>
      <p id="search-help" class="search-help">
        Comma for either/or — <em>dharma, courage</em>. Spelling forgiving — <em>corage</em> finds <em>courage</em>.
      </p>
    </form>

    <div class="search-filters" data-search-filters hidden>
      {/* Filter chip groups injected at runtime once pagefind.filters() resolves */}
    </div>

    <div class="search-status" data-search-status aria-live="polite"></div>

    <ol class="search-results" data-search-results></ol>
  </div>
</dialog>

<script>
import { transformQuery } from "../scripts/transform-query.ts";

interface PagefindResult {
  id: string;
  data(): Promise<PagefindResultData>;
}

interface PagefindResultData {
  url: string;
  excerpt: string;
  meta: Record<string, string>;
  filters?: Record<string, string[]>;
  raw_url?: string;
  word_count?: number;
}

interface PagefindSearchResponse {
  results: PagefindResult[];
}

interface PagefindAPI {
  search(query: string, options?: { filters?: Record<string, unknown> }): Promise<PagefindSearchResponse>;
  filters(): Promise<Record<string, Record<string, number>>>;
  options(opts: Record<string, unknown>): Promise<void>;
}

(() => {
  const dialog = document.getElementById("search-dialog") as HTMLDialogElement | null;
  const trigger = document.getElementById("search-trigger") as HTMLButtonElement | null;
  if (!dialog || !trigger) return;

  const input = dialog.querySelector<HTMLInputElement>("#search-input");
  const filtersHost = dialog.querySelector<HTMLElement>("[data-search-filters]");
  const status = dialog.querySelector<HTMLElement>("[data-search-status]");
  const resultsHost = dialog.querySelector<HTMLOListElement>("[data-search-results]");
  const closeBtn = dialog.querySelector<HTMLButtonElement>("[data-search-close]");

  if (!input || !filtersHost || !status || !resultsHost) return;

  // ── State ──────────────────────────────────────────────────────────────
  let pagefind: PagefindAPI | null = null;
  let pagefindLoadingError = false;
  /** Active filter selections: { era: ["Medieval"], author: [...], ... } */
  const activeFilters: Record<string, Set<string>> = {};
  let availableFilters: Record<string, Record<string, number>> = {};
  /** Generation token to ignore stale searches when the user types fast. */
  let searchGen = 0;

  // ── Bootstrapping ──────────────────────────────────────────────────────
  async function ensurePagefindLoaded(): Promise<PagefindAPI | null> {
    if (pagefind) return pagefind;
    if (pagefindLoadingError) return null;
    try {
      // The Pagefind index lives at /pagefind/pagefind.js, generated by
      // the pagefind CLI. Astro's dev server intentionally blocks
      // dynamic-imports of files in /public/ ("should not be imported
      // from source code; only referenced via HTML tags"), and Vite's
      // static analysis tries to resolve absolute paths at build time.
      // The standard workaround is `new Function('return import(...)')`
      // — fully hides the import from both layers of analysis. This is
      // the pattern Pagefind itself recommends for framework projects.
      const dynImport = new Function(
        "url",
        "return import(/* @vite-ignore */ url)",
      ) as (url: string) => Promise<unknown>;
      pagefind = (await dynImport("/pagefind/pagefind.js")) as PagefindAPI;
      await pagefind.options({ excerptLength: 30 });
      availableFilters = await pagefind.filters();
      renderFilterChips();
      return pagefind;
    } catch (err) {
      pagefindLoadingError = true;
      console.warn("[search] pagefind.js failed to load — index probably not built yet.", err);
      if (status) status.textContent = "Search index unavailable. Run bun run search:build to generate it.";
      return null;
    }
  }

  // ── Filter chips ───────────────────────────────────────────────────────
  const FACET_ORDER = ["era", "author", "language"] as const;
  const FACET_LABELS: Record<string, string> = {
    era: "Era",
    author: "Author",
    language: "Language",
  };

  function humanizeFilterValue(facet: string, value: string): string {
    if (facet === "language") {
      return value
        .replace(/_/g, " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());
    }
    return value;
  }

  function renderFilterChips() {
    if (!filtersHost) return;
    filtersHost.innerHTML = "";
    const rows: HTMLDivElement[] = [];
    for (const facet of FACET_ORDER) {
      const values = availableFilters[facet];
      if (!values || Object.keys(values).length === 0) continue;
      const row = document.createElement("div");
      row.className = "search-facet";
      const label = document.createElement("span");
      label.className = "search-facet-label";
      label.textContent = FACET_LABELS[facet] ?? facet;
      row.appendChild(label);
      const chipWrap = document.createElement("div");
      chipWrap.className = "search-facet-chips";
      // Sort by count desc, then alpha
      const entries = Object.entries(values).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
      for (const [value, count] of entries) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "search-chip";
        btn.dataset.facet = facet;
        btn.dataset.value = value;
        btn.setAttribute("aria-pressed", "false");
        btn.innerHTML = `<span class="search-chip-label">${humanizeFilterValue(facet, value)}</span><span class="search-chip-count">${count}</span>`;
        btn.addEventListener("click", () => toggleFilter(facet, value, btn));
        chipWrap.appendChild(btn);
      }
      row.appendChild(chipWrap);
      rows.push(row);
    }
    if (rows.length === 0) return;
    for (const r of rows) filtersHost.appendChild(r);
    filtersHost.hidden = false;
  }

  function toggleFilter(facet: string, value: string, btn: HTMLButtonElement) {
    if (!activeFilters[facet]) activeFilters[facet] = new Set();
    const set = activeFilters[facet]!;
    if (set.has(value)) {
      set.delete(value);
      btn.setAttribute("aria-pressed", "false");
    } else {
      set.add(value);
      btn.setAttribute("aria-pressed", "true");
    }
    if (set.size === 0) delete activeFilters[facet];
    runSearch();
  }

  function buildFilterArg(): Record<string, unknown> | undefined {
    const keys = Object.keys(activeFilters);
    if (keys.length === 0) return undefined;
    // Pagefind: { era: { any: ["Medieval", "19th Century"] }, author: ... }
    // any-within-facet (OR), all-across-facets (AND, implicit).
    const out: Record<string, unknown> = {};
    for (const k of keys) {
      const vals = [...activeFilters[k]!];
      out[k] = vals.length === 1 ? vals[0] : { any: vals };
    }
    return out;
  }

  // ── Search runner ──────────────────────────────────────────────────────
  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): T {
    let timer: ReturnType<typeof setTimeout> | null = null;
    return ((...args: Parameters<T>) => {
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => fn(...args), ms);
    }) as T;
  }

  async function runSearchInner() {
    if (!status || !resultsHost) return;
    const api = await ensurePagefindLoaded();
    if (!api) return;

    const raw = (input?.value ?? "").trim();
    const filters = buildFilterArg();
    const gen = ++searchGen;

    if (!raw && !filters) {
      status.textContent = "";
      resultsHost.innerHTML = "";
      return;
    }

    status.textContent = "Searching…";

    const transformed = transformQuery(raw);

    // Build the search plan.
    // - 0 groups: filter-only — empty query matches all, filtered by facets.
    // - 1 group: try strategies sequentially, take the first non-empty.
    // - >1 group (comma-OR): fan out, union by id, sort by max score.
    let response: PagefindSearchResponse | null = null;
    let usedStrategy: "exact" | "wildcard" | "filter-only" | "comma-or" | "none" = "none";

    try {
      if (transformed.groups.length === 0) {
        // Filter-only: pagefind.search("", { filters }) returns the
        // facet-filtered universe.
        response = await api.search("", { filters });
        usedStrategy = "filter-only";
      } else if (transformed.groups.length === 1) {
        // Strategies: exact then wildcard fallback.
        for (let i = 0; i < transformed.strategies.length; i++) {
          const s = transformed.strategies[i]!;
          const r = await api.search(s, { filters });
          if (gen !== searchGen) return; // a newer search superseded us
          if (r.results.length > 0) {
            response = r;
            usedStrategy = i === 0 ? "exact" : "wildcard";
            break;
          }
        }
        if (!response) response = { results: [] };
      } else {
        // Multi-group OR: fan out, union, dedupe by id.
        const queries = transformed.groups.map((g) => g.join(" "));
        const responses = await Promise.all(queries.map((q) => api.search(q, { filters })));
        if (gen !== searchGen) return;
        const seen = new Set<string>();
        const merged: PagefindResult[] = [];
        for (const r of responses) {
          for (const hit of r.results) {
            if (!seen.has(hit.id)) {
              seen.add(hit.id);
              merged.push(hit);
            }
          }
        }
        response = { results: merged };
        usedStrategy = "comma-or";
      }
    } catch (err) {
      console.error("[search] pagefind.search failed", err);
      status.textContent = "Search failed. Try a different query.";
      resultsHost.innerHTML = "";
      return;
    }

    if (gen !== searchGen) return;

    if (response.results.length === 0) {
      const filterDesc = describeActiveFilters();
      status.textContent =
        raw && filterDesc
          ? `No results for "${raw}" within ${filterDesc}. Try removing filters or different terms.`
          : raw
            ? `No results for "${raw}". Try different terms or a wildcard like "${raw}*".`
            : `No results within ${filterDesc}.`;
      resultsHost.innerHTML = "";
      return;
    }

    const cap = 30;
    const limited = response.results.slice(0, cap);
    const dataPromises = limited.map((r) => r.data());
    const datas = await Promise.all(dataPromises);
    if (gen !== searchGen) return;

    const total = response.results.length;
    const shown = limited.length;
    const strategyTag =
      usedStrategy === "wildcard"
        ? " · spelling-tolerant"
        : usedStrategy === "comma-or"
          ? " · either/or"
          : usedStrategy === "filter-only"
            ? ""
            : "";
    status.textContent = `${total} result${total === 1 ? "" : "s"}${strategyTag}${total > shown ? ` (showing first ${shown})` : ""}`;

    renderResults(datas);
  }

  function describeActiveFilters(): string {
    const parts: string[] = [];
    for (const facet of FACET_ORDER) {
      const set = activeFilters[facet];
      if (!set || set.size === 0) continue;
      const names = [...set].map((v) => humanizeFilterValue(facet, v)).join(", ");
      parts.push(`${FACET_LABELS[facet] ?? facet}: ${names}`);
    }
    return parts.join("; ");
  }

  function renderResults(datas: PagefindResultData[]) {
    if (!resultsHost) return;
    resultsHost.innerHTML = "";
    for (const d of datas) {
      const li = document.createElement("li");
      li.className = "search-result";
      const a = document.createElement("a");
      a.href = d.url;
      a.className = "search-result-link";

      const title = document.createElement("p");
      title.className = "search-result-title";
      title.textContent = d.meta?.title ?? d.url;

      const work = document.createElement("p");
      work.className = "search-result-work";
      const workName = d.meta?.work ?? "";
      const era = d.filters?.era?.[0] ?? "";
      const author = d.filters?.author?.[0] ?? "";
      const parts: string[] = [];
      if (workName) parts.push(workName);
      if (author) parts.push(author);
      if (era) parts.push(era);
      work.textContent = parts.join(" · ");

      const excerpt = document.createElement("p");
      excerpt.className = "search-result-excerpt";
      excerpt.innerHTML = d.excerpt; // Pagefind already wraps matches in <mark>

      a.appendChild(title);
      if (parts.length > 0) a.appendChild(work);
      a.appendChild(excerpt);
      a.addEventListener("click", () => closeDialog());
      li.appendChild(a);
      resultsHost.appendChild(li);
    }
  }

  const runSearch = debounce(runSearchInner, 180);

  // ── Dialog open/close ──────────────────────────────────────────────────
  function openDialog() {
    if (!dialog!.open) dialog!.showModal();
    requestAnimationFrame(() => input?.focus());
    void ensurePagefindLoaded();
  }
  function closeDialog() {
    if (dialog!.open) dialog!.close();
  }

  trigger.addEventListener("click", openDialog);
  closeBtn?.addEventListener("click", closeDialog);
  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) closeDialog();
  });
  input.addEventListener("input", () => runSearch());

  document.addEventListener("keydown", (e) => {
    const t = e.target as HTMLElement | null;
    const isTyping =
      t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable);
    if (!isTyping && (e.key === "/" || ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k"))) {
      e.preventDefault();
      openDialog();
    } else if (e.key === "Escape" && dialog!.open) {
      closeDialog();
    }
  });
})();
</script>
