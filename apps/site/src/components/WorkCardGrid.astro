---
/**
 * WorkCardGrid — a reusable grid of work cards used by the catalog,
 * author pages, and era pages.
 *
 * Visual contract: 3:2 cover, display-serif title, italic author, sans
 * extras line. The card hover lift and aspect-ratio rules live here so
 * the catalog, author, and era pages stay visually identical.
 *
 * Variant-pref aware: each card gets the same data-* attributes the
 * catalog uses, so the inline localStorage script can rewrite hrefs
 * for single-chapter works to land on the user's preferred variant.
 *
 * The component resolves its own covers and single-chapter shortcuts
 * via readWorkIndex + listChapters when no caller-provided
 * `coverByWork` map is supplied. Callers that already walked these
 * (e.g. the catalog page) can pass the map to avoid duplicate work.
 */
import type { ManifestWork } from "../lib/corpus";
import { readWorkIndex, listChapters } from "../lib/corpus";

interface Props {
  works: ManifestWork[];
  /** Optional pre-resolved covers; otherwise the component resolves them itself. */
  coverByWork?: Map<string, string | null>;
}

const { works, coverByWork } = Astro.props;

interface DirectRead {
  href: string;
  chapterSlug: string;
  defaultVariant: string;
  available: string;
}

const covers = new Map<string, string | null>();
const directReads = new Map<string, DirectRead | null>();

for (const w of works) {
  if (coverByWork && coverByWork.has(w.slug)) {
    covers.set(w.slug, coverByWork.get(w.slug)!);
  } else {
    const idx = readWorkIndex(w.slug);
    covers.set(w.slug, idx?.cover_url ?? null);
  }

  const chapters = listChapters(w.slug);
  if (chapters.length === 1) {
    const c = chapters[0]!;
    const def =
      c.variants.find((v) => v.file === c.default_variant)?.content_type ?? "translation";
    directReads.set(w.slug, {
      href: `/works/${w.slug}/${c.chapter_slug}/${def}/`,
      chapterSlug: c.chapter_slug,
      defaultVariant: def,
      available: c.variants.map((v) => v.content_type).join(","),
    });
  } else {
    directReads.set(w.slug, null);
  }
}
---

<div class="works-grid">
  {
    works.map((w) => {
      const cover = covers.get(w.slug);
      const direct = directReads.get(w.slug);
      const href = direct ? direct.href : `/works/${w.slug}/`;
      return (
        <a
          href={href}
          class="work-card"
          data-chapter-slug={direct?.chapterSlug}
          data-default-variant={direct?.defaultVariant}
          data-available-variants={direct?.available}
          data-work-slug={direct ? w.slug : undefined}
        >
          {cover ? (
            <div class="cover">
              <img src={cover} alt={`Cover for ${w.title}`} loading="lazy" />
            </div>
          ) : (
            <div class="cover cover-placeholder" aria-hidden="true" />
          )}
          <div class="meta">
            <h3 class="title">{w.title}</h3>
            <p class="author">{w.author}</p>
            <p class="extras">
              <span>{w.language}</span>
              <span class="dot">·</span>
              <span>
                {w.total_logical_chapters}{" "}
                {w.total_logical_chapters === 1 ? "chapter" : "chapters"}
              </span>
            </p>
          </div>
        </a>
      );
    })
  }
</div>

<script is:inline>
  /* Variant preference: for single-chapter works, the card href already
     points at the chapter reader's default variant. If the user has a
     localStorage preference and that variant exists for the chapter,
     rewrite the href so the catalog click lands on the preferred
     variant in one hop. Idempotent — safe if multiple grids render. */
  (function () {
    var pref;
    try {
      pref = localStorage.getItem("falsafa-variant-pref");
    } catch (e) {
      pref = null;
    }
    if (!pref) return;
    var cards = document.querySelectorAll("a.work-card[data-chapter-slug]");
    for (var i = 0; i < cards.length; i++) {
      var a = cards[i];
      var available = (a.getAttribute("data-available-variants") || "").split(",");
      if (available.indexOf(pref) < 0) continue;
      var slug = a.getAttribute("data-work-slug");
      var chapter = a.getAttribute("data-chapter-slug");
      a.setAttribute("href", "/works/" + slug + "/" + chapter + "/" + pref + "/");
    }
  })();
</script>

<style>
  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--s-8);
  }

  .work-card {
    display: flex;
    flex-direction: column;
    color: var(--ink);
    transition: transform 0.2s ease;
  }

  .work-card:hover {
    transform: translateY(-2px);
  }

  .work-card .cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--rule);
    margin-bottom: var(--s-3);
  }

  .work-card .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-card .cover-placeholder {
    background: linear-gradient(135deg, var(--rule) 0%, var(--paper) 100%);
  }

  .work-card .title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: 0 0 var(--s-1);
    line-height: 1.3;
  }

  .work-card .author {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    margin: 0 0 var(--s-2);
  }

  .work-card .extras {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--ink-muted);
    margin: 0;
  }

  .work-card .extras .dot {
    margin: 0 var(--s-1);
  }
</style>
