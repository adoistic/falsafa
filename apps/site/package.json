{
  "name": "@falsafa/site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Falsafa reading site — Astro 5, editorial typography, watercolor covers, polymorphic chapter renderer (prose / verse / manuscript).",
  "license": "MIT",
  "scripts": {
    "predev": "bun run scripts/prepare-covers.ts",
    "prebuild": "bun run scripts/prepare-covers.ts",
    "prepare-covers": "bun run scripts/prepare-covers.ts",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "search:build": "astro build && pagefind --site dist && rm -rf public/pagefind && cp -r dist/pagefind public/pagefind"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/preact": "4.1.3",
    "@fontsource/crimson-pro": "^5.0.0",
    "@fontsource/inter": "^5.0.0",
    "@fontsource/source-serif-4": "^5.0.0",
    "astro": "^5.0.0",
    "marked": "^18.0.2",
    "preact": "^10.29.1",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.6",
    "pagefind": "^1.5.2",
    "playwright": "^1.59.1"
  }
}
