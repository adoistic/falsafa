{
  "name": "falsafa",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A premium reading platform for translated philosophical and classical texts, plus an open-source MCP engine for any LLM to query the corpus.",
  "license": "MIT",
  "author": "Adnan",
  "homepage": "https://github.com/adoistic/falsafa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adoistic/falsafa.git"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "audit": "bun run scripts/corpus-audit.ts",
    "convert": "bun run scripts/convert.ts",
    "cross-link": "bun run scripts/cross-link.ts",
    "images": "bun run scripts/generate-images.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
