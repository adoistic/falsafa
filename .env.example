# Falsafa local environment template.
#
# Copy this file to .env and fill in the values you need. Bun auto-loads
# .env (and .env.local, .env.*.local) into process.env, so any script in
# this repo that reads process.env.FOO will pick up your local value.
#
# .env / .env.local / .env.*.local are gitignored. .env.example is NOT —
# it's the template that ships with the repo. Don't put real secrets in it.

# OpenRouter API key — used by apps/mcp/eval/run-openrouter.ts to run the
# eval against any model on OpenRouter. Get one at:
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-replace-me
