[
  {
    "id": "p-99a7c4",
    "offset": 0,
    "text": "sāntānikaṃ yakṣyamāṇam adhvagaṃ sārvavedasam  /"
  },
  {
    "id": "p-8fb8b2",
    "offset": 49,
    "text": "gurvarthaṃ pitṛmātrarthaṃ svādhyāyārthy upatāpinaḥ  // Mn_11.1 //"
  },
  {
    "id": "p-3f92a2",
    "offset": 116,
    "text": "na vai tān snātakān vidyād brāhmaṇān dharmabhikṣukān  /"
  },
  {
    "id": "p-abaf55",
    "offset": 173,
    "text": "niḥsvebhyo deyam etebhyo dānaṃ vidyāviśeṣataḥ  // Mn_11.2 //"
  },
  {
    "id": "p-e08cee",
    "offset": 235,
    "text": "etebhyo hi dvijāgryebhyo deyam annaṃ sadakṣiṇam  /"
  },
  {
    "id": "p-98769e",
    "offset": 287,
    "text": "itarebhyo bahirvedi kṛtānnaṃ deyam ucyate  // Mn_11.3 //"
  },
  {
    "id": "p-246eee",
    "offset": 345,
    "text": "sarvaratnāni rājā tu yathārhaṃ pratipādayet  /"
  },
  {
    "id": "p-ed7d63",
    "offset": 393,
    "text": "brāhmaṇān vedaviduṣo yajñārthaṃ caiva dakṣiṇām  // Mn_11.4 //"
  },
  {
    "id": "p-5dbe3d",
    "offset": 456,
    "text": "kṛtadāro 'parān dārān bhikṣitvā yo 'dhigacchati  /"
  },
  {
    "id": "p-6f60f7",
    "offset": 508,
    "text": "ratimātraṃ phalaṃ tasya dravyadātus tu saṃtatiḥ  // Mn_11.5 //"
  },
  {
    "id": "p-2adbc2",
    "offset": 572,
    "text": "dhanāni tu yathāśakti vipreṣu pratipādayet  /"
  },
  {
    "id": "p-4590af",
    "offset": 619,
    "text": "vedavitsu vivikteṣu pretya svargaṃ samaśnute  // Mn_11.6 //"
  }
]