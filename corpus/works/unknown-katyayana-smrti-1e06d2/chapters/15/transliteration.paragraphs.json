[
  {
    "id": "p-7c1a81",
    "offset": 0,
    "text": "[pratibhūtvenāgrāhyāḥ]"
  },
  {
    "id": "p-50a68e",
    "offset": 24,
    "text": "na svāmī na ca vai śatruḥ svāminādhikṛtas tathā  /"
  },
  {
    "id": "p-8a6e5e",
    "offset": 76,
    "text": "niruddho daṇḍitaś caiva saṃśayasthāś ca na kvacit  // K_114 //"
  },
  {
    "id": "p-f00c18",
    "offset": 140,
    "text": "naiva rikthī na riktaś ca na caivātyantavāsinaḥ  /"
  },
  {
    "id": "p-caa6f1",
    "offset": 192,
    "text": "rājakāryaniyuktaś ca ye ca pravrajitā narāḥ  // K_115 //"
  },
  {
    "id": "p-d8d797",
    "offset": 250,
    "text": "nāśakto dhanine dātuṃ daṇḍaṃ rājñe ca tatsamam  /"
  },
  {
    "id": "p-7717db",
    "offset": 301,
    "text": "jīvan vāpi pitā yasya tathaivecchāpravartakaḥ  /"
  },
  {
    "id": "p-bded94",
    "offset": 351,
    "text": "nāvijñāto grahītavyaḥ pratibhūtvakriyāṃ prati  // K_116 //"
  },
  {
    "id": "p-dc559f",
    "offset": 411,
    "text": "atha cet pratibhūr nāsti vādayogyasya vādinaḥ  /"
  },
  {
    "id": "p-e87ccf",
    "offset": 461,
    "text": "sa rakṣito dinasyānte dadyād dūtāya vetanam  // K_117 //"
  },
  {
    "id": "p-c9e954",
    "offset": 519,
    "text": "dvijātiḥ pratibhūhīno rakṣyaḥ syād bāhyacāribhiḥ  /"
  },
  {
    "id": "p-3ca943",
    "offset": 572,
    "text": "śūdrādīn pratibhūhīnān bandhayen nigaḍena tu  // K_118 //"
  },
  {
    "id": "p-72ad1c",
    "offset": 631,
    "text": "atikrame 'payāte ca daṇḍayet taṃ paṇāṣṭakam  /"
  },
  {
    "id": "p-1c8d0d",
    "offset": 679,
    "text": "nityakarmāparodhas tu kāryaḥ sarvavarṇinām  // K_119 //"
  },
  {
    "id": "p-4b8488",
    "offset": 736,
    "text": "grahītagrahaṇo nyāye na pravartyo mahībhṛtā  /"
  },
  {
    "id": "p-914f5e",
    "offset": 784,
    "text": "tasya vā tatsamarpyaṃ syāt sthāpayed vā parasya tat  // K_120 //"
  }
]