[
  {
    "id": "p-ed52bc",
    "offset": 0,
    "text": "[pratijñādoṣāḥ : pūrvapakṣadoṣāḥ]"
  },
  {
    "id": "p-95ff5c",
    "offset": 35,
    "text": "yaś ca rāṣṭraviruddhaś ca yaś ca rājñā vivarjitaḥ  /"
  },
  {
    "id": "p-68f3e4",
    "offset": 89,
    "text": "anekapadasaṃkīrṇaḥ pūrvapakṣo na siddhyati  // K_136 //"
  },
  {
    "id": "p-b56983",
    "offset": 146,
    "text": "bahupratijñaṃ yat kāryaṃ vyavahāreṣu niścitam  /"
  },
  {
    "id": "p-4f1e95",
    "offset": 196,
    "text": "kāmaṃ tad api gṛhṇīyād rājā tattvabubhutsayā  // K_137 //"
  },
  {
    "id": "p-cdd381",
    "offset": 255,
    "text": "deśakālavihīnaś ca dravyasaṃkhyāvivarjitaḥ  /"
  },
  {
    "id": "p-05be5b",
    "offset": 302,
    "text": "sādhyapramāṇahīnaś ca pakṣo 'nādeya iṣyate  // K_138 //"
  },
  {
    "id": "p-712379",
    "offset": 359,
    "text": "nyāyasthaṃ necchate kartum anyāyaṃ vā karoty ayam  /"
  },
  {
    "id": "p-1ae451",
    "offset": 413,
    "text": "na lekhayati yat tv evaṃ tasya pakṣo na sidhyati  // K_139 //"
  },
  {
    "id": "p-496898",
    "offset": 476,
    "text": "aprasiddhaṃ nirābādhaṃ nirarthaṃ niṣprayojanam  /"
  },
  {
    "id": "p-fef184",
    "offset": 527,
    "text": "asādhyaṃ vā viruddhaṃ vā pakṣābhāsaṃ vivarjayet  // K_140 //"
  },
  {
    "id": "p-7922c7",
    "offset": 589,
    "text": "pratijñādoṣanirmuktaṃ sādhyaṃ satkāraṇānvitam   /"
  },
  {
    "id": "p-7c5363",
    "offset": 640,
    "text": "niścitaṃ lokasiddhaṃ ca pakṣaṃ pakṣavido viduḥ  // K_141 //"
  },
  {
    "id": "p-ec16da",
    "offset": 701,
    "text": "svalpākṣaraḥ prabhūtārtho niḥsaṃdigdho nirākulaḥ  /"
  },
  {
    "id": "p-a31df3",
    "offset": 754,
    "text": "virodhikāraṇair mukto virodhipratiṣedhakaḥ  // K_142 //"
  },
  {
    "id": "p-e889f0",
    "offset": 811,
    "text": "yadā tv evaṃ vidhaḥ pakṣaḥ kalpitaḥ pūrvavādinā  /"
  },
  {
    "id": "p-ec0ba2",
    "offset": 863,
    "text": "dadyāt tatpakṣasaṃbaddhaṃ prativādī tadottaram  // K_143 //"
  },
  {
    "id": "p-554a88",
    "offset": 924,
    "text": "śrāvyamāṇo 'rthinā yatra yo hy artho na vighātitaḥ  /"
  },
  {
    "id": "p-5a9975",
    "offset": 979,
    "text": "dānakāle 'thavā tūṣṇīṃ sthitaḥ so 'rtho 'numoditaḥ  // K_144 //"
  }
]