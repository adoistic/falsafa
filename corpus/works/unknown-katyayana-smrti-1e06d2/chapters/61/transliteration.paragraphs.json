[
  {
    "id": "p-fa4d60",
    "offset": 0,
    "text": "[naigamādisaṃjñālakṣaṇam]"
  },
  {
    "id": "p-ccec68",
    "offset": 27,
    "text": "nānāpaurasamūhas tu naigamaḥ parikīrtitaḥ  /"
  },
  {
    "id": "p-66b5c1",
    "offset": 73,
    "text": "nānāyudhadharā vrātāḥ samavetāḥ prakīrtitāḥ  // K_678 //"
  },
  {
    "id": "p-46bd3c",
    "offset": 131,
    "text": "samūho vaṇijādīnāṃ pūgaḥ saṃparikīrtitaḥ  /"
  },
  {
    "id": "p-8e7b33",
    "offset": 176,
    "text": "pravrajyāvasitā ye tu pāṣaṇḍāḥ parikīrtitāḥ  // K_679 //"
  },
  {
    "id": "p-785b59",
    "offset": 234,
    "text": "brāhmaṇānāṃ samūhas tu gaṇaḥ saṃparikīrtitaḥ  /"
  },
  {
    "id": "p-98097c",
    "offset": 283,
    "text": "śilpopajīvino ye tu śilpinaḥ parikīrtitāḥ  // K_680 //"
  },
  {
    "id": "p-921563",
    "offset": 339,
    "text": "ārhatasaugatānāṃ tu samūhaḥ saṅgha ucyate  /"
  },
  {
    "id": "p-1177cb",
    "offset": 385,
    "text": "cāṇḍālaśvapacādīnāṃ samūho gulma ucyate  // K_681 //"
  },
  {
    "id": "p-2d6f28",
    "offset": 439,
    "text": "gaṇapāṣaṇḍapūgāś ca vrātāś ca śreṇayas tathā  /"
  },
  {
    "id": "p-f4ece1",
    "offset": 488,
    "text": "samūhasthāś ca ye cānye vargākhyās te bṛhaspatiḥ  // K_682 //"
  }
]