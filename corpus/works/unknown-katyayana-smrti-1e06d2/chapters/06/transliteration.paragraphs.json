[
  {
    "id": "p-44c6ff",
    "offset": 0,
    "text": "[kāryadarśanakālaḥ]"
  },
  {
    "id": "p-2098e3",
    "offset": 21,
    "text": "sabhāsthāneṣu pūrvāhṇe kāryāṇāṃ nirṇayaṃ nṛpaḥ  /"
  },
  {
    "id": "p-34e81d",
    "offset": 72,
    "text": "kuryāc chāstrapraṇītena mārgeṇāmitrakarṣaṇaḥ  // K_060 //"
  },
  {
    "id": "p-2b973e",
    "offset": 131,
    "text": "divasasyāṣṭamaṃ bhāgaṃ muktvā kālatrayaṃ tu yat  /"
  },
  {
    "id": "p-ba4b02",
    "offset": 183,
    "text": "sa kālo vyavahārāṇāṃ śāstradṛṣṭaḥ paraḥ smṛtaḥ  // K_061 //"
  },
  {
    "id": "p-880934",
    "offset": 244,
    "text": "ādyād ahno 'ṣṭabhāgād yad ūrdhvaṃ bhāgatrayaṃ bhavet  /"
  },
  {
    "id": "p-cda081",
    "offset": 301,
    "text": "sa kālo vyavahārasya śāstre dṛṣṭo manīṣibhiḥ  // K_062 //"
  }
]