[
  {
    "id": "p-5236ee",
    "offset": 0,
    "text": "[unmattāsvatantrādikṛtānāṃ vicāraḥ]"
  },
  {
    "id": "p-9ad4a6",
    "offset": 37,
    "text": "unmattenaiva mattena tathā bhāvāntareṇa vā  /"
  },
  {
    "id": "p-8a6790",
    "offset": 84,
    "text": "yad dattaṃ yat kṛtaṃ vātha pramāṇaṃ naiva tad bhavet  // K_464 //"
  },
  {
    "id": "p-e22bb7",
    "offset": 151,
    "text": "asvatantrakṛtaṃ kāryaṃ tasya svāmī nivartayet  /"
  },
  {
    "id": "p-2c9f3a",
    "offset": 201,
    "text": "na bhartrā vivadetānyo bhītonmattakṛtād ṛte  // K_465 //"
  },
  {
    "id": "p-64229e",
    "offset": 259,
    "text": "pitāsvatantraḥ pitṛmān bhrātā bhātṛvya eva vā  /"
  },
  {
    "id": "p-38c541",
    "offset": 309,
    "text": "kaniṣṭho vāvibhaktasvo dāsaḥ karmakaras tathā  // K_466 //"
  },
  {
    "id": "p-994486",
    "offset": 369,
    "text": "na kṣetragṛhadāsānāṃ dānādhamanavikrayāḥ  /"
  },
  {
    "id": "p-09b083",
    "offset": 414,
    "text": "asvatantrakṛtāḥ siddhiṃ prāpnuyur nānuvarṇitāḥ  // K_467 //"
  },
  {
    "id": "p-4d53b6",
    "offset": 475,
    "text": "pramāṇaṃ sarva evaite paṇyānāṃ krayavikraye  /"
  },
  {
    "id": "p-518083",
    "offset": 523,
    "text": "yadi saṃvyavahāraṃ te kurvanto 'py anumoditāḥ  // K_468 //"
  },
  {
    "id": "p-054ed8",
    "offset": 583,
    "text": "kṣetrādīṇāṃ tathaiva syur bhrātā bhrātṛsutaḥ sutaḥ  /"
  },
  {
    "id": "p-d126e8",
    "offset": 638,
    "text": "nisṛṣṭāḥ kṛtyakaraṇe guruṇā yadi gacchatā  // K_469 //"
  },
  {
    "id": "p-6ec8e7",
    "offset": 694,
    "text": "nisṛṣṭārthas tu yo yasmin tasminn arthe prabhus tu saḥ  /"
  },
  {
    "id": "p-f6212c",
    "offset": 753,
    "text": "tadbhartā tatkṛtaṃ kāryaṃ nānyathā kartum arhati  // K_470 //"
  },
  {
    "id": "p-0bff17",
    "offset": 816,
    "text": "sutasya sutadārāṇāṃ vaśitvaṃ tv anuśāsane  /"
  },
  {
    "id": "p-117fd2",
    "offset": 862,
    "text": "vikraye caiva dāne ca vaśitvaṃ na sute pituḥ  // K_471 //"
  }
]