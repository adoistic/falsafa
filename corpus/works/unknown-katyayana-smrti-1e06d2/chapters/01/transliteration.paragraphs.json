    "text": "[rājaguṇāḥ]"
  },
  {
    "id": "p-f59ec9",
    "offset": 40,
    "text": "vinītaḥ śāstrasaṃpannaḥ kośaśauryasamanvitaḥ  /"
  },
  {
    "id": "p-db6384",
    "offset": 89,
    "text": "brahmaṇyo dānaśīlaḥ syāt satyadharmaparo nṛpaḥ  // K_001 //"
  },
  {
    "id": "p-3f8bad",
    "offset": 150,
    "text": "stambhopatāpapaiśunya- cāpalakrodhavarjitaḥ  /"
  },
  {
    "id": "p-624f1e",
    "offset": 198,
    "text": "pragalbhaḥ sannatodagraḥ saṃbhāṣī priyadarśanaḥ  // K_002 //"
  },
  {
    "id": "p-e65604",
    "offset": 260,
    "text": "vaśyendriyaṃ jitātmānaṃ dhṛtadaṇḍaṃ vikāriṣu  /"
  },
  {
    "id": "p-e7f7dd",
    "offset": 309,
    "text": "parīkṣyakāriṇaṃ dhīram atyantaṃ śrīr niṣevate  // K_003 //"
  }
