[
  {
    "id": "p-b14644",
    "offset": 0,
    "text": "[pratinidhiḥ]"
  },
  {
    "id": "p-641bfd",
    "offset": 15,
    "text": "samarpito 'rthinā yo 'nyaḥ paro dharmādhikāriṇi  /"
  },
  {
    "id": "p-63252d",
    "offset": 67,
    "text": "prativādī sa vijñeyaḥ pratipannaś ca yaḥ svayam  // K_089 //"
  },
  {
    "id": "p-83e722",
    "offset": 129,
    "text": "adhikāro 'bhiyuktasya netarasyāsty asaṅgateḥ   /"
  },
  {
    "id": "p-a8c2a0",
    "offset": 179,
    "text": "itaro 'py abhiyuktena pratirodhikṛto mataḥ  // K_090 //"
  },
  {
    "id": "p-d31a7b",
    "offset": 236,
    "text": "arthinā saṃniyukto vā pratyarthiprahito 'pi vā  /"
  },
  {
    "id": "p-0cc3c7",
    "offset": 287,
    "text": "yo yasyārthe vivadate tayor jayaparājayau  // K_091 //"
  },
  {
    "id": "p-4d869a",
    "offset": 343,
    "text": "dāsāḥ karmakarāḥ śiṣyā niyuktā bāndhavās tathā  /"
  },
  {
    "id": "p-62f0af",
    "offset": 394,
    "text": "vādino na ca daṇḍyāḥ syuḥ yas tv ato 'nyaḥ sa daṇḍabhāk  // K_092 //"
  },
  {
    "id": "p-03d4f3",
    "offset": 464,
    "text": "brahmahatyāsurāpāna- steyagurvaṅganāgame  /"
  },
  {
    "id": "p-770553",
    "offset": 509,
    "text": "anyeṣu cātipāpeṣu prativādī na dīyate  // K_093 //"
  },
  {
    "id": "p-2cd942",
    "offset": 561,
    "text": "manuṣyamāraṇe steye paradārābhimarśane  /"
  },
  {
    "id": "p-6b7728",
    "offset": 604,
    "text": "abhakṣyabhakṣaṇe caiva kanyāharaṇadūṣaṇe  // K_094 //"
  },
  {
    "id": "p-e128e7",
    "offset": 659,
    "text": "pāruṣye kūṭakaraṇe nṛpadrohe tathaiva ca  /"
  },
  {
    "id": "p-1ad7d7",
    "offset": 704,
    "text": "prativādī na dātavyaḥ kartā tu vivadet svayam  // K_095 //"
  }
]