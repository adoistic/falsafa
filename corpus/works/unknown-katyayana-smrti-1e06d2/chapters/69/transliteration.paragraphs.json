[
  {
    "id": "p-c9b44a",
    "offset": 0,
    "text": "[strīsaṃgrahaṇam]"
  },
  {
    "id": "p-fbac80",
    "offset": 19,
    "text": "dūtopacārayuktaś ced avelāsthānasaṃsthitiḥ  /"
  },
  {
    "id": "p-68df86",
    "offset": 66,
    "text": "kṇṭhakeśāṇ calagrāhaḥ karṇanāsākarādiṣu  /"
  },
  {
    "id": "p-db1669",
    "offset": 110,
    "text": "ekasthānāsanāhārāḥ saṃgraho navadhā smṛtaḥ  // K_829 //"
  },
  {
    "id": "p-411bca",
    "offset": 167,
    "text": "strīṣu vṛttopabhogaḥ syāt prasahya puruṣo yadā  /"
  },
  {
    "id": "p-9a0be8",
    "offset": 218,
    "text": "vadhe tatra pravarteta kāryātikramaṇaṃ hi tat  // K_830 //"
  },
  {
    "id": "p-52dc45",
    "offset": 278,
    "text": "kāmārtā svairiṇī yā tu svayam eva prakāmayet  /"
  },
  {
    "id": "p-d41ac1",
    "offset": 327,
    "text": "rājādeśena moktavyā vikhyāpya janasaṃnidhau  // K_831 //"
  },
  {
    "id": "p-25b149",
    "offset": 385,
    "text": "ārambhakṛtsahāyaś ca tathā mārgānudeśakaḥ  /"
  },
  {
    "id": "p-173da1",
    "offset": 431,
    "text": "āśrayaḥ śastradātā ca bhaktadātā vikarmiṇām  // K_832 //"
  },
  {
    "id": "p-a58e93",
    "offset": 489,
    "text": "yuddhopadeśakaś caiva tadvināśapradarśakaḥ  /"
  },
  {
    "id": "p-0ab6fb",
    "offset": 536,
    "text": "upekṣākāryayuktaś ca doṣavaktranumokakaḥ  // K_833 //"
  },
  {
    "id": "p-3265d5",
    "offset": 591,
    "text": "aniṣeddhākṣamo yaḥ syāt sarve tatkāryakāriṇaḥ  /"
  },
  {
    "id": "p-3fbc58",
    "offset": 641,
    "text": "yathāśaktyanurūpaṃ tu daṇḍam eṣāṃ prakalpayet  // K_834 //"
  }
]