[
  {
    "id": "p-806fc5",
    "offset": 0,
    "text": "[āhvānaṃ]"
  },
  {
    "id": "p-97d3a8",
    "offset": 11,
    "text": "dharmotsukān abhyudaye rogiṇo 'tha jaḍān api  /"
  },
  {
    "id": "p-1b2193",
    "offset": 60,
    "text": "asvasthamattonmattārta- striyo nāhvānayen nṛpaḥ  // K_096 //"
  },
  {
    "id": "p-afc22d",
    "offset": 122,
    "text": "na hīnapakṣāṃ yuvatiṃ kule jātāṃ prasūtikām   /"
  },
  {
    "id": "p-964f32",
    "offset": 171,
    "text": "sarvavarṇottamāṃ kanyāṃ tā jñātiprabhukāḥ smṛtāḥ  // K_097 //"
  },
  {
    "id": "p-31ad5c",
    "offset": 234,
    "text": "tadadhīnakuṭumbinyaḥ svairiṇyo gaṇikāś ca yāḥ  /"
  },
  {
    "id": "p-9c5a2b",
    "offset": 284,
    "text": "niṣkulā yāś ca patitās tāsām āhvānam iṣyate  // K_098 //"
  },
  {
    "id": "p-cc66d7",
    "offset": 342,
    "text": "saśastro 'nuttarīyo vā muktakeśaḥ sahāsanaḥ  /"
  },
  {
    "id": "p-4ba88b",
    "offset": 390,
    "text": "vāmahas tena vā vādaṃ vadan daṇḍam avāpnuyāt  // K_099 //"
  },
  {
    "id": "p-a2492d",
    "offset": 449,
    "text": "āhūtas tv avamanyeta yaḥ śakto rājaśāsanam  /"
  },
  {
    "id": "p-47ce0e",
    "offset": 496,
    "text": "tasya kuryān nṛpo daṇḍaṃ vidhidṛṣṭena karmaṇā  // K_100 //"
  },
  {
    "id": "p-101963",
    "offset": 556,
    "text": "hīne karmāṇi pañcāśan- madhyame dviśatāvaraḥ  /"
  },
  {
    "id": "p-9401c5",
    "offset": 605,
    "text": "gurukāryeṣu daṇḍaḥ syān nityaṃ pañcaśatāvaraḥ  // K_101 //"
  },
  {
    "id": "p-1b5b86",
    "offset": 665,
    "text": "kalpito yasya yo daṇḍas tv aparādhasya yatnataḥ  /"
  },
  {
    "id": "p-037bc4",
    "offset": 717,
    "text": "paṇānāṃ grahaṇaṃ tu syāt tanmūlyaṃ vātha rājani  // K_102 //"
  }
]