[
  {
    "id": "p-85831f",
    "offset": 0,
    "text": "[strīpuṃdharmaḥ]"
  },
  {
    "id": "p-de4ba0",
    "offset": 18,
    "text": "patyā cāpy aviyoginyā śuśrūṣyo 'gnir vinītayā  /"
  },
  {
    "id": "p-69cba2",
    "offset": 68,
    "text": "saubhāgyavad avvaidhavya- kāmyayā bhartṛbhaktayā  // K_835 //"
  },
  {
    "id": "p-9ceb98",
    "offset": 131,
    "text": "matiśuśrūṣayaiva strī sarvān kāmān samaśnute  /"
  },
  {
    "id": "p-93fc5b",
    "offset": 180,
    "text": "divaḥ punar ihāyātā sukhānāṃ śevadhir bhavet  // K_836 //"
  },
  {
    "id": "p-e6cdae",
    "offset": 239,
    "text": "mṛte bhartari yā sādhvī brahmacarye vyavasthitā  /"
  },
  {
    "id": "p-a02c4d",
    "offset": 291,
    "text": "sārundhatīsamācārā brahmaloke mahīyate  // K_837 //"
  }
]