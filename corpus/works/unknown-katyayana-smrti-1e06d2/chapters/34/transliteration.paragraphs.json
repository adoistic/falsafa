[
  {
    "id": "p-21905c",
    "offset": 0,
    "text": "[divyadeśāḥ]"
  },
  {
    "id": "p-793419",
    "offset": 14,
    "text": "indrasthāne 'bhiśastānāṃ mahāpātakināṃ nṛṇām  /"
  },
  {
    "id": "p-535a94",
    "offset": 63,
    "text": "nṛpadrohe pravṛttānāṃ rājadvāre prayojayet  // K_434 //"
  },
  {
    "id": "p-9852ce",
    "offset": 120,
    "text": "prātilomyaprasūtānāṃ divyaṃ deyaṃ catuṣpathe  /"
  },
  {
    "id": "p-fe138b",
    "offset": 169,
    "text": "ato 'nyeṣu sabhāmadhye divyaṃ deyaṃ vidur budhāḥ  // K_435 //"
  },
  {
    "id": "p-688d51",
    "offset": 232,
    "text": "kāladeśavirodhe tu yathāyuktaṃ prakalpayet  /"
  },
  {
    "id": "p-f6fae7",
    "offset": 279,
    "text": "anyena hārayed divyaṃ vidhir eṣa viparyaye  // K_436 //"
  },
  {
    "id": "p-b4306a",
    "offset": 336,
    "text": "adeśakāladattāni bahirvāsakṛtāni ca  /"
  },
  {
    "id": "p-c0f5a2",
    "offset": 376,
    "text": "vyabhicāraṃ sadārtheṣu kurvantīha na saṃśayaḥ  // K_437 //"
  },
  {
    "id": "p-55ea65",
    "offset": 436,
    "text": "sādhayet tat punaḥ sādhyaṃ vyāghāte sādhanasya hi  /"
  },
  {
    "id": "p-4920a4",
    "offset": 490,
    "text": "dattāny api yathoktāni rājā divyāni varjayet  /"
  },
  {
    "id": "p-4bf6cf",
    "offset": 539,
    "text": "mūrkhair lubdhaiś ca duṣṭaiś ca punar deyāni tāni vai  // K_438 //"
  },
  {
    "id": "p-92e649",
    "offset": 607,
    "text": "tasmād yathoktavidhinā divyaṃ deyaṃ viśāradaiḥ  /"
  },
  {
    "id": "p-dd1d19",
    "offset": 658,
    "text": "ayathoktaprayuktaṃ tu na śaktaṃ tasya sādhane  // K_439 //"
  },
  {
    "id": "p-856055",
    "offset": 718,
    "text": "śikyac chede tulābhaṅge tathā vāpi guṇasya vā  /"
  },
  {
    "id": "p-d5b028",
    "offset": 768,
    "text": "śuddhes tu saṃśaye caiva parīkṣeta punar naram  // K_440 //"
  }
]