[
  {
    "id": "p-760897",
    "offset": 0,
    "text": "[kriyāpādaḥ]"
  },
  {
    "id": "p-bdae73",
    "offset": 14,
    "text": "kāraṇāt pūrvapakṣo 'pi hy uttaratvaṃ prapadyate  /"
  },
  {
    "id": "p-29c4b5",
    "offset": 66,
    "text": "ataḥ kriyā tadā proktā pūrvapakṣaprasādhinī  // K_211 //"
  },
  {
    "id": "p-6b152c",
    "offset": 124,
    "text": "śodhite likhite samyag iti nirdoṣa uttare  /"
  },
  {
    "id": "p-a5f8d3",
    "offset": 170,
    "text": "pratyarthino 'rthino vāpi kriyākaraṇam iṣyate  // K_212 //"
  },
  {
    "id": "p-d99eeb",
    "offset": 230,
    "text": "vādinā yad abhipretaṃ svayaṃ sādhayitum sphuṭam  /"
  },
  {
    "id": "p-5a5b00",
    "offset": 282,
    "text": "tat sādhyaṃ sādhanaṃ yena tat sādhyaṃ sādhyate 'khilam  // K_213 //"
  }
]