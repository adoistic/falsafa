[
  {
    "id": "p-d562ae",
    "offset": 0,
    "text": "[kāryanirṇetṝṇāṃ gurulāghavam]"
  },
  {
    "id": "p-999478",
    "offset": 32,
    "text": "kulāni śreṇayaś caiva gaṇas tv adhikṛto nṛpaḥ  /"
  },
  {
    "id": "p-48e4da",
    "offset": 82,
    "text": "pratiṣṭhā vyavahārāṇāṃ gurvebhyas tūttarottaram  // K_082 //"
  },
  {
    "id": "p-5eb813",
    "offset": 144,
    "text": "tapasvināṃ tu kāryāṇi traividyair eva kārayet   /"
  },
  {
    "id": "p-8596a8",
    "offset": 195,
    "text": "māyāyogavidāṃ caiva na svayaṃ kopakāraṇāt  // K_083 //"
  },
  {
    "id": "p-b2aaf5",
    "offset": 251,
    "text": "samyagvijñānasaṃpanno nopadeśaṃ prakalpayet  /"
  },
  {
    "id": "p-ce353a",
    "offset": 299,
    "text": "utkṛṣṭajātiśīlānāṃ gurvācāryatapasvinām  // K_084 //"
  },
  {
    "id": "p-2297cb",
    "offset": 353,
    "text": "gotrasthitis tu yā teṣāṃ kramād āyāti dharmataḥ  /"
  },
  {
    "id": "p-52d7af",
    "offset": 405,
    "text": "kuladharmaṃ tu taṃ prāhuḥ pālayet taṃ tathaiva tu  // K_085 //"
  }
]