[
  {
    "id": "p-d5adf2",
    "offset": 0,
    "text": "[svāmipālavivādaḥ]"
  },
  {
    "id": "p-167dca",
    "offset": 20,
    "text": "kṣetrārāmavivīteṣu gṛheṣu paśuvāṭiṣu  /"
  },
  {
    "id": "p-d511f5",
    "offset": 61,
    "text": "grahaṇaṃ tatpraviṣṭānāṃ tāḍanaṃ vā bṛhaspatiḥ  // K_664 //"
  },
  {
    "id": "p-be5c06",
    "offset": 121,
    "text": "adhamottamamadhyānāṃ paśūnāṃ caiva tāḍane  /"
  },
  {
    "id": "p-5e59f4",
    "offset": 167,
    "text": "svāmī tu vivaded yatra daṇḍaṃ tatra prakalpayet  // K_665 //"
  },
  {
    "id": "p-8d0dbe",
    "offset": 229,
    "text": "ajāteṣv eva sasyeṣu kuryād āvaraṇaṃ mahat  /"
  },
  {
    "id": "p-1513cb",
    "offset": 275,
    "text": "duḥkheneha nivāryante labdhasvādurasā mṛgāḥ  // K_666 //"
  },
  {
    "id": "p-2a8067",
    "offset": 333,
    "text": "dāpayet paṇapādaṃ gāṃ dvau pādau mahiṣīṃ tathā  /"
  },
  {
    "id": "p-0c18aa",
    "offset": 384,
    "text": "tathājāvikavatsānāṃ pādo daṇḍaḥ prakīrtitaḥ  // K_667 //"
  }
]