[
  {
    "id": "p-17483b",
    "offset": 0,
    "text": "Vi_44"
  },
  {
    "id": "p-546843",
    "offset": 7,
    "text": "atha pāpātmanāṃ narakeṣv anubhūtaduḥkhānāṃ tiryagyonayo bhavanti // Vi_44.1 //"
  },
  {
    "id": "p-4f1c3c",
    "offset": 87,
    "text": "atipātakināṃ paryāyeṇa sarvāḥ sthāvarayonayaḥ // Vi_44.2 //"
  },
  {
    "id": "p-ed0f16",
    "offset": 148,
    "text": "mahāpātakināṃ ca krimiyonayaḥ // Vi_44.3 //"
  },
  {
    "id": "p-37cb7d",
    "offset": 193,
    "text": "anupātakināṃ pakṣiyonayaḥ // Vi_44.4 //"
  },
  {
    "id": "p-ae82c6",
    "offset": 234,
    "text": "upapātakināṃ jalajayonayaḥ // Vi_44.5 //"
  },
  {
    "id": "p-abdcf9",
    "offset": 276,
    "text": "kṛtajātibhraṃśakarāṇāṃ jalacarayonayaḥ // Vi_44.6 //"
  },
  {
    "id": "p-7e0c86",
    "offset": 330,
    "text": "kṛtasaṃkarīkaraṇakarmaṇāṃ mṛgayonayaḥ // Vi_44.7 //"
  },
  {
    "id": "p-aaa83e",
    "offset": 383,
    "text": "kṛtāpātrīkaraṇakarmaṇāṃ paśuyonayaḥ // Vi_44.8 //"
  },
  {
    "id": "p-ff0eaa",
    "offset": 434,
    "text": "kṛtamalinīkaraṇakarmaṇāṃ manuṣyeṣv aspṛśyayonayaḥ // Vi_44.9 //"
  },
  {
    "id": "p-e38ec6",
    "offset": 499,
    "text": "prakīrṇakeṣu prakīrṇā hiṃsrāḥ kravyādā bhavanti // Vi_44.10 //"
  },
  {
    "id": "p-359ff6",
    "offset": 563,
    "text": "abhojyānnābhakṣyāśī krimiḥ // Vi_44.11 //"
  },
  {
    "id": "p-9c813c",
    "offset": 606,
    "text": "stenaḥ śyenaḥ // Vi_44.12 //"
  },
  {
    "id": "p-39e592",
    "offset": 636,
    "text": "prakṛṣṭavartmāpahārī bileśayaḥ // Vi_44.13 //"
  },
  {
    "id": "p-de8117",
    "offset": 683,
    "text": "ākhur dhānyahārī // Vi_44.14 //"
  },
  {
    "id": "p-9936b4",
    "offset": 716,
    "text": "haṃsaḥ kāṃsyāpahārī // Vi_44.15 //"
  },
  {
    "id": "p-ebc71a",
    "offset": 752,
    "text": "jalahṛj jalābhiplavaḥ // Vi_44.16 //"
  },
  {
    "id": "p-f36e4e",
    "offset": 790,
    "text": "madhu daṃśaḥ // Vi_44.17 //"
  },
  {
    "id": "p-bfa158",
    "offset": 819,
    "text": "payaḥ kākaḥ // Vi_44.18 //"
  },
  {
    "id": "p-3a24e9",
    "offset": 847,
    "text": "rasaṃ śvā // Vi_44.19 //"
  },
  {
    "id": "p-05a70e",
    "offset": 873,
    "text": "ghṛtaṃ nakulaḥ // Vi_44.20 //"
  },
  {
    "id": "p-38586f",
    "offset": 904,
    "text": "māṃsaṃ gṛdhraḥ // Vi_44.21 //"
  },
  {
    "id": "p-3b28cf",
    "offset": 935,
    "text": "vasāṃ madguḥ // Vi_44.22 //"
  },
  {
    "id": "p-32d906",
    "offset": 964,
    "text": "tailaṃ tailapāyikaḥ // Vi_44.23 //"
  },
  {
    "id": "p-a02026",
    "offset": 1000,
    "text": "lavaṇaṃ cīvivāk // Vi_44.24 //"
  },
  {
    "id": "p-fc1984",
    "offset": 1032,
    "text": "dadhi balākā // Vi_44.25 //"
  },
  {
    "id": "p-bc051a",
    "offset": 1061,
    "text": "kauśeyaṃ hṛtvā bhavati tittiriḥ // Vi_44.26 //"
  },
  {
    "id": "p-72aa39",
    "offset": 1109,
    "text": "kṣaumaṃ darduraḥ // Vi_44.27 //"
  },
  {
    "id": "p-c29c0b",
    "offset": 1142,
    "text": "kārpāsatāntavaṃ krauñcaḥ // Vi_44.28 //"
  },
  {
    "id": "p-859f8e",
    "offset": 1183,
    "text": "godhā gām // Vi_44.29 //"
  },
  {
    "id": "p-4b70ab",
    "offset": 1209,
    "text": "vālgudo guḍam // Vi_44.30 //"
  },
  {
    "id": "p-cc1a86",
    "offset": 1239,
    "text": "chuchundarir gandhān // Vi_44.31 //"
  },
  {
    "id": "p-d38c47",
    "offset": 1276,
    "text": "patraśākaṃ barhī // Vi_44.32 //"
  },
  {
    "id": "p-59163f",
    "offset": 1309,
    "text": "kṛtānnaṃ sedhā // Vi_44.33 //"
  },
  {
    "id": "p-0aa5db",
    "offset": 1340,
    "text": "akṛtānnaṃ śalyakaḥ // Vi_44.34 //"
  },
  {
    "id": "p-3a3cf8",
    "offset": 1375,
    "text": "agniṃ bakaḥ // Vi_44.35 //"
  },
  {
    "id": "p-03fd4f",
    "offset": 1403,
    "text": "gṛhakāry upaskaram // Vi_44.36 //"
  },
  {
    "id": "p-b534e4",
    "offset": 1438,
    "text": "raktavāsāṃsi jīvajīvakaḥ // Vi_44.37 //"
  },
  {
    "id": "p-065f1a",
    "offset": 1479,
    "text": "gajaṃ kūrmaḥ // Vi_44.38 //"
  },
  {
    "id": "p-6c863f",
    "offset": 1508,
    "text": "aśvaṃ vyāghraḥ // Vi_44.39 //"
  },
  {
    "id": "p-8a8837",
    "offset": 1539,
    "text": "phalaṃ puṣpaṃ vā markaṭaḥ // Vi_44.40 //"
  },
  {
    "id": "p-08956a",
    "offset": 1581,
    "text": "ṛkṣaḥ striyam // Vi_44.41 //"
  },
  {
    "id": "p-529291",
    "offset": 1611,
    "text": "yānam uṣṭraḥ // Vi_44.42 //"
  },
  {
    "id": "p-3ddb60",
    "offset": 1640,
    "text": "paśūn gṛdhraḥ // Vi_44.43 //"
  },
  {
    "id": "p-3ceb0f",
    "offset": 1670,
    "text": "yad vā tad vā paradravyam apahṛtya balān naraḥ  /"
  },
  {
    "id": "p-29b9c5",
    "offset": 1721,
    "text": "avaśyam yāti tiryaktvaṃ jagdhvā caivāhutaṃ haviḥ  || Vi_44.44 ||"
  },
  {
    "id": "p-2e7b45",
    "offset": 1787,
    "text": "striyo 'py etena kalpena hṛtvā doṣam avāpnuyuḥ  /"
  },
  {
    "id": "p-4884ff",
    "offset": 1838,
    "text": "eteṣām eva jantūnāṃ bhāryātvam upayānti tāḥ  || Vi_44.45 ||"
  }
]