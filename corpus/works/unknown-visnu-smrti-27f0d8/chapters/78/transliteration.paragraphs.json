[
  {
    "id": "p-914b3a",
    "offset": 0,
    "text": "Vi_78"
  },
  {
    "id": "p-590d73",
    "offset": 7,
    "text": "satatam āditye 'hni śrāddhaṃ kurvann ārogyam āpnoti // Vi_78.1 //"
  },
  {
    "id": "p-557135",
    "offset": 74,
    "text": "saubhāgyaṃ cāndre // Vi_78.2 //"
  },
  {
    "id": "p-8b3002",
    "offset": 107,
    "text": "samaravijayaṃ kauje // Vi_78.3 //"
  },
  {
    "id": "p-401733",
    "offset": 142,
    "text": "sarvān kāmān baudhe // Vi_78.4 //"
  },
  {
    "id": "p-cb8de3",
    "offset": 177,
    "text": "vidyām abhīṣṭāṃ jaive // Vi_78.5 //"
  },
  {
    "id": "p-f2e6da",
    "offset": 214,
    "text": "dhanaṃ śaukre // Vi_78.6 //"
  },
  {
    "id": "p-a30489",
    "offset": 243,
    "text": "jīvitaṃ śanaiścare // Vi_78.7 //"
  },
  {
    "id": "p-c66932",
    "offset": 277,
    "text": "svargaṃ kṛttikāsu // Vi_78.8 //"
  },
  {
    "id": "p-9e9e7b",
    "offset": 310,
    "text": "apatyaṃ rohiṇīṣu // Vi_78.9 //"
  },
  {
    "id": "p-17d681",
    "offset": 342,
    "text": "brahmavarcasyaṃ saumye // Vi_78.10 //"
  },
  {
    "id": "p-38b177",
    "offset": 381,
    "text": "karmasiddhiṃ raudre // Vi_78.11 //"
  },
  {
    "id": "p-b1405a",
    "offset": 417,
    "text": "bhuvaṃ punarvasau // Vi_78.12 //"
  },
  {
    "id": "p-e0889c",
    "offset": 451,
    "text": "puṣṭiṃ puṣye // Vi_78.13 //"
  },
  {
    "id": "p-bb46e9",
    "offset": 480,
    "text": "śriyaṃ sārpe // Vi_78.14 //"
  },
  {
    "id": "p-f976cd",
    "offset": 509,
    "text": "sarvān kāmān paitrye // Vi_78.15 //"
  },
  {
    "id": "p-e2ab3b",
    "offset": 546,
    "text": "saubhāgyaṃ bhāgye // Vi_78.16 //"
  },
  {
    "id": "p-e773ce",
    "offset": 580,
    "text": "dhanam āyamaṇe // Vi_78.17 //"
  },
  {
    "id": "p-f570dc",
    "offset": 611,
    "text": "jñātiśraiṣṭhyaṃ haste // Vi_78.18 //"
  },
  {
    "id": "p-ac7002",
    "offset": 649,
    "text": "rūpavataḥ sutāṃs tvāṣṭre // Vi_78.19 //"
  },
  {
    "id": "p-288efb",
    "offset": 690,
    "text": "vāṇijyasiddhiṃ svātau // Vi_78.20 //"
  },
  {
    "id": "p-b085ac",
    "offset": 728,
    "text": "kanakaṃ viśākhāsu // Vi_78.21 //"
  },
  {
    "id": "p-b2b5c4",
    "offset": 762,
    "text": "mitrāṇi maitre // Vi_78.22 //"
  },
  {
    "id": "p-8f00d3",
    "offset": 793,
    "text": "rājyaṃ śākre // Vi_78.23 //"
  },
  {
    "id": "p-94d7ce",
    "offset": 822,
    "text": "kṛṣiṃ mūle // Vi_78.24 //"
  },
  {
    "id": "p-eebeab",
    "offset": 849,
    "text": "samudrayānasiddhim āpye // Vi_78.25 //"
  },
  {
    "id": "p-a71a9f",
    "offset": 889,
    "text": "sarvān kāmān vaiśvadeve // Vi_78.26 //"
  },
  {
    "id": "p-b3df41",
    "offset": 929,
    "text": "śraiṣṭhyam abhijiti // Vi_78.27 //"
  },
  {
    "id": "p-2971a0",
    "offset": 965,
    "text": "sarvān kāmān śravaṇe // Vi_78.28 //"
  },
  {
    "id": "p-0edd31",
    "offset": 1002,
    "text": "lavaṇaṃ vāsave // Vi_78.29 //"
  },
  {
    "id": "p-690cc5",
    "offset": 1033,
    "text": "ārogyaṃ vāruṇe // Vi_78.30 //"
  },
  {
    "id": "p-ed004a",
    "offset": 1064,
    "text": "kupyadravyam āje // Vi_78.31 //"
  },
  {
    "id": "p-63e091",
    "offset": 1097,
    "text": "gṛhamāhir budhnye // Vi_78.32 //"
  },
  {
    "id": "p-ca2949",
    "offset": 1131,
    "text": "gāḥ pauṣṇe // Vi_78.33 //"
  },
  {
    "id": "p-019f05",
    "offset": 1158,
    "text": "turaṅgamān āśvine // Vi_78.34 //"
  },
  {
    "id": "p-7bd5ad",
    "offset": 1192,
    "text": "jīvitaṃ yāmye // Vi_78.35 //"
  },
  {
    "id": "p-1258e5",
    "offset": 1222,
    "text": "gṛhaṃ surūpāḥ striyaḥ pratipadi // Vi_78.36 //"
  },
  {
    "id": "p-1e152d",
    "offset": 1270,
    "text": "kanyāṃ varadāṃ dvitīyāyām // Vi_78.37 //"
  },
  {
    "id": "p-aaa561",
    "offset": 1312,
    "text": "sarvān kāmāṃs tṛtīyāyām // Vi_78.38 //"
  },
  {
    "id": "p-5482fa",
    "offset": 1352,
    "text": "paśūṃś caturthyām // Vi_78.39 //"
  },
  {
    "id": "p-12aceb",
    "offset": 1386,
    "text": "surūpān sutān pañcamyām // Vi_78.40 //"
  },
  {
    "id": "p-1e30a7",
    "offset": 1426,
    "text": "dyūtavijayaṃ ṣaṣṭhyām // Vi_78.41 //"
  },
  {
    "id": "p-8350f2",
    "offset": 1464,
    "text": "kṛṣiṃ saptamyām // Vi_78.42 //"
  },
  {
    "id": "p-1f88ff",
    "offset": 1496,
    "text": "vāṇijyam aṣṭamyām // Vi_78.43 //"
  },
  {
    "id": "p-1f1391",
    "offset": 1530,
    "text": "paśūn navamyām // Vi_78.44 //"
  },
  {
    "id": "p-ad349e",
    "offset": 1561,
    "text": "vājino daśamyām // Vi_78.45 //"
  },
  {
    "id": "p-792448",
    "offset": 1593,
    "text": "putrān brahmavarcasvina ekādaśyām // Vi_78.46 //"
  },
  {
    "id": "p-689636",
    "offset": 1643,
    "text": "kanakarajataṃ dvādaśyām // Vi_78.47 //"
  },
  {
    "id": "p-dbaab4",
    "offset": 1683,
    "text": "sāubhāgyaṃ trayodaśyām // Vi_78.48 //"
  },
  {
    "id": "p-a1ad7b",
    "offset": 1722,
    "text": "sarvān kāmān pañcadaśyām // Vi_78.49 //"
  },
  {
    "id": "p-41ff59",
    "offset": 1763,
    "text": "śastrahatānāṃ śrāddhakarmaṇi caturdaśī śastā // Vi_78.50 //"
  },
  {
    "id": "p-970895",
    "offset": 1824,
    "text": "api pitṛgīte gāthe bhavataḥ // Vi_78.51 //"
  },
  {
    "id": "p-b9f1c8",
    "offset": 1868,
    "text": "api jāyeta so 'smākaṃ kule kaścin narottamaḥ  /"
  },
  {
    "id": "p-8a0e08",
    "offset": 1917,
    "text": "prāvṛṭkāle 'site pakṣe trayodaśyāṃ samāhitaḥ  || Vi_78.52 ||"
  },
  {
    "id": "p-2dae15",
    "offset": 1979,
    "text": "madhūtkaṭena yaḥ śrāddhaṃ pāyasena samācaret  /"
  },
  {
    "id": "p-2ed0ce",
    "offset": 2028,
    "text": "kārttikaṃ sakalaṃ māsaṃ prākchāye kuñjarasya ca  || Vi_78.53 ||"
  }
]