[
  {
    "id": "p-844fa2",
    "offset": 0,
    "text": "Vi_17"
  },
  {
    "id": "p-d07fcf",
    "offset": 7,
    "text": "pitā cet putrān vibhajet tasya svecchā svayam upārjite 'rthe // Vi_17.1 //"
  },
  {
    "id": "p-880405",
    "offset": 83,
    "text": "paitāmahe tv arthe pitṛputrayos tulyaṃ svāmitvam // Vi_17.2 //"
  },
  {
    "id": "p-8af649",
    "offset": 147,
    "text": "pitṛvibhaktā vibhāgānantarotpannasya bhāgaṃ dadyuḥ // Vi_17.3 //"
  },
  {
    "id": "p-4be5d9",
    "offset": 213,
    "text": "aputradhanaṃ patnyabhigāmi // Vi_17.4 //"
  },
  {
    "id": "p-0704b4",
    "offset": 255,
    "text": "tadabhāve duhitṛgāmi // Vi_17.5 //"
  },
  {
    "id": "p-df7710",
    "offset": 291,
    "text": "tadabhāve pitṛgāmi // Vi_17.6 //"
  },
  {
    "id": "p-9f35fa",
    "offset": 325,
    "text": "tadabhāve mātṛgāmi // Vi_17.7 //"
  },
  {
    "id": "p-39ac1b",
    "offset": 359,
    "text": "tadabhāve bhrātṛgāmi // Vi_17.8 //"
  },
  {
    "id": "p-a5027e",
    "offset": 395,
    "text": "tadabhāve bhrātṛputragāmi // Vi_17.9 //"
  },
  {
    "id": "p-56dfa4",
    "offset": 436,
    "text": "tadabhāve bandhugāmi // Vi_17.10 //"
  },
  {
    "id": "p-609c58",
    "offset": 473,
    "text": "tadabhāve sakulyagāmi // Vi_17.11 //"
  },
  {
    "id": "p-4c6e46",
    "offset": 511,
    "text": "tadabhāve sahādhyāyigāmi // Vi_17.12 //"
  },
  {
    "id": "p-3899dd",
    "offset": 552,
    "text": "tadabhāve brāhmaṇadhanavarjaṃ rājagāmi // Vi_17.13 //"
  },
  {
    "id": "p-89a176",
    "offset": 607,
    "text": "brāhmaṇārtho brāhmaṇānām // Vi_17.14 //"
  },
  {
    "id": "p-f5490e",
    "offset": 648,
    "text": "vānaprasthadhanam ācāryo gṛhṇīyāt // Vi_17.15 //"
  },
  {
    "id": "p-c8d5fa",
    "offset": 698,
    "text": "śiṣyo vā // Vi_17.16 //"
  },
  {
    "id": "p-b4010f",
    "offset": 723,
    "text": "saṃsṛṣṭinas tu saṃsṛṣṭī sodarasya tu sodaraḥ  /"
  },
  {
    "id": "p-ad6827",
    "offset": 772,
    "text": "dadyād apaharec cāṃśaṃ jātasya ca mṛtasya ca  || Vi_17.17 ||"
  },
  {
    "id": "p-970f4f",
    "offset": 834,
    "text": "pitṛmātṛsutabhrātṛdattam, adhyagnyupāgatam, ādhivedanikaṃ, bandhudattaṃ, śulkam, anvādheyakam iti strīdhanam // Vi_17.18 //"
  },
  {
    "id": "p-33c911",
    "offset": 959,
    "text": "brāhmādiṣu caturṣu vivāheṣv aprajāyām atītāyāṃ tadbhartuḥ // Vi_17.19 //"
  },
  {
    "id": "p-630ed9",
    "offset": 1033,
    "text": "śeṣeṣu ca pitā haret // Vi_17.20 //"
  },
  {
    "id": "p-5556c2",
    "offset": 1070,
    "text": "sarveṣv eva prasūtāyāṃ yaddhanaṃ tat duhitṛgāmi // Vi_17.21 //"
  },
  {
    "id": "p-e8ceee",
    "offset": 1134,
    "text": "patyau jīvati yaḥ strībhir alaṃkāro dhṛto bhavet  /"
  },
  {
    "id": "p-b3002a",
    "offset": 1187,
    "text": "na taṃ bhajeran dāyādā bhajamānāḥ patanti te  || Vi_17.22 ||"
  },
  {
    "id": "p-a4e2d5",
    "offset": 1249,
    "text": "anekapitṛkāṇāṃ tu pitṛto 'ṃśaprakalpanā  /"
  },
  {
    "id": "p-5eda63",
    "offset": 1293,
    "text": "yasya yat paitṛkaṃ rikthaṃ sa tad gṛhṇīta netaraḥ  || Vi_17.23 ||"
  }
]