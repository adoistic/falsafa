[
  {
    "id": "p-0545e0",
    "offset": 0,
    "text": "Vi_58"
  },
  {
    "id": "p-b7c80a",
    "offset": 7,
    "text": "atha gṛhāśramiṇas trividho 'rtho bhavati // Vi_58.1 //"
  },
  {
    "id": "p-686916",
    "offset": 63,
    "text": "śuklaḥ śabalo 'sitaś ca // Vi_58.2 //"
  },
  {
    "id": "p-e13478",
    "offset": 102,
    "text": "śuklenārthena yad+aurdhvadehikaṃ karoti tenāsya devatvam āsādayati // Vi_58.3 //"
  },
  {
    "id": "p-51d132",
    "offset": 184,
    "text": "yac chabalena tan mānuṣyam // Vi_58.4 //"
  },
  {
    "id": "p-4872e8",
    "offset": 226,
    "text": "yat kṛṣṇena tat tiryaktvam // Vi_58.5 //"
  },
  {
    "id": "p-6f7ace",
    "offset": 268,
    "text": "svavṛttyupārjitaṃ sarveṣāṃ śuklam // Vi_58.6 //"
  },
  {
    "id": "p-feda06",
    "offset": 317,
    "text": "anantaravṛttyupāttaṃ śabalam // Vi_58.7 //"
  },
  {
    "id": "p-feffc9",
    "offset": 361,
    "text": "ekāntaritavṛttyupāttaṃ ca kṛṣṇam // Vi_58.8 //"
  },
  {
    "id": "p-5c8271",
    "offset": 409,
    "text": "kramāgataṃ prītidāyaṃ prāptaṃ ca saha bhāryayā  /"
  },
  {
    "id": "p-36b40e",
    "offset": 460,
    "text": "aviśeṣeṇa sarveṣāṃ dhanaṃ śuklam udāhṛtam  || Vi_58.9 ||"
  },
  {
    "id": "p-7e206d",
    "offset": 518,
    "text": "utkocaśulkasaṃprāptam avikreyasya vikrayaiḥ  /"
  },
  {
    "id": "p-ee0df6",
    "offset": 566,
    "text": "kṛtopakārād āptaṃ ca śabalaṃ samudāhṛtam  || Vi_58.10 ||"
  },
  {
    "id": "p-bc8d60",
    "offset": 624,
    "text": "pārśvikadyūtacauryāpta pratirūpakasāhasaiḥ  /"
  },
  {
    "id": "p-c97e16",
    "offset": 671,
    "text": "vyājenopārjitaṃ yac ca tat kṛṣṇaṃ samudāhṛtam  || Vi_58.11 ||"
  },
  {
    "id": "p-4a0bba",
    "offset": 734,
    "text": "yathāvidhena dravyeṇa yat kiṃcit kurute naraḥ  /"
  },
  {
    "id": "p-7a67db",
    "offset": 784,
    "text": "tathāvidham avāpnoti sa phalaṃ pretya ceha ca  || Vi_58.12 ||"
  }
]