[
  {
    "id": "p-974b43",
    "offset": 0,
    "text": "Vi_72"
  },
  {
    "id": "p-de519a",
    "offset": 7,
    "text": "damayamena tiṣṭhet // Vi_72.1 //"
  },
  {
    "id": "p-890cec",
    "offset": 41,
    "text": "damaś cendriyāṇāṃ prakīrtitaḥ // Vi_72.2 //"
  },
  {
    "id": "p-f19667",
    "offset": 86,
    "text": "dāntasyāyaṃ lokaḥ paraś ca // Vi_72.3 //"
  },
  {
    "id": "p-020fe5",
    "offset": 128,
    "text": "nādāntasya kriyā kācit samṛdhyati // Vi_72.4 //"
  },
  {
    "id": "p-e42812",
    "offset": 177,
    "text": "damaḥ pavitraṃ paramaṃ maṅgalyaṃ paramaṃ damaḥ  /"
  },
  {
    "id": "p-c8718a",
    "offset": 228,
    "text": "damena sarvam āpnoti yat kiṃcin manasecchati  || Vi_72.5 ||"
  },
  {
    "id": "p-2a9058",
    "offset": 289,
    "text": "daśārdhayuktena rathena yāto manovaśenāryapathānuvartinā  /"
  },
  {
    "id": "p-a8653d",
    "offset": 350,
    "text": "taṃ ced rathaṃ nāpaharanti vājinas tathāgataṃ nāvajayanti śatravaḥ  || Vi_72.6 ||"
  },
  {
    "id": "p-b5b091",
    "offset": 433,
    "text": "āpūryamāṇam acalapratiṣṭhaṃ samudram āpaḥ praviśanti yadvat  /"
  },
  {
    "id": "p-cd8f6b",
    "offset": 497,
    "text": "tadvat kāmā yaṃ praviśanti sarve sa śāntim āpnoti na kāmakāmī  || Vi_72.7 ||"
  }
]