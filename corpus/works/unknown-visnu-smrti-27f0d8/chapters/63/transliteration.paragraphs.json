[
  {
    "id": "p-804d5e",
    "offset": 0,
    "text": "Vi_63"
  },
  {
    "id": "p-df2303",
    "offset": 7,
    "text": "atha yogakṣemārtham īśvaram abhigacchet // Vi_63.1 //"
  },
  {
    "id": "p-a02535",
    "offset": 62,
    "text": "naiko 'dhvānaṃ prapadyeta // Vi_63.2 //"
  },
  {
    "id": "p-ad2d81",
    "offset": 103,
    "text": "nādhārmikaiḥ sārdham // Vi_63.3 //"
  },
  {
    "id": "p-18156a",
    "offset": 139,
    "text": "na vṛṣalaiḥ // Vi_63.4 //"
  },
  {
    "id": "p-92b02c",
    "offset": 166,
    "text": "na dviṣadbhiḥ // Vi_63.5 //"
  },
  {
    "id": "p-795eb6",
    "offset": 195,
    "text": "nātipratyūṣasi // Vi_63.6 //"
  },
  {
    "id": "p-8fbcd1",
    "offset": 225,
    "text": "nātisāyam // Vi_63.7 //"
  },
  {
    "id": "p-3dc412",
    "offset": 250,
    "text": "na saṃdhyayoḥ // Vi_63.8 //"
  },
  {
    "id": "p-68da0a",
    "offset": 279,
    "text": "na madhyāhne // Vi_63.9 //"
  },
  {
    "id": "p-368e0c",
    "offset": 307,
    "text": "na saṃnihitapānīyam // Vi_63.10 //"
  },
  {
    "id": "p-a0eaa2",
    "offset": 343,
    "text": "nātitūrṇam // Vi_63.11 //"
  },
  {
    "id": "p-3f0b12",
    "offset": 370,
    "text": "na satataṃ bālavyādhitārtair vāhanaiḥ // Vi_63.12 //"
  },
  {
    "id": "p-7e634a",
    "offset": 424,
    "text": "na hīnāṅgaiḥ // Vi_63.13 //"
  },
  {
    "id": "p-451484",
    "offset": 453,
    "text": "na dīnaiḥ // Vi_63.14 //"
  },
  {
    "id": "p-2c630a",
    "offset": 479,
    "text": "na gobhiḥ // Vi_63.15 //"
  },
  {
    "id": "p-e794b6",
    "offset": 505,
    "text": "nādāntaiḥ // Vi_63.16 //"
  },
  {
    "id": "p-4bbe4b",
    "offset": 531,
    "text": "yavasodake vāhanānām adattvā ātmanaḥ kṣuttṛṣṇāpanodanaṃ na kuryāt // Vi_63.17 //"
  },
  {
    "id": "p-472cb6",
    "offset": 613,
    "text": "na catuṣpatham adhitiṣṭhet // Vi_63.18 //"
  },
  {
    "id": "p-005437",
    "offset": 656,
    "text": "na rātrau vṛkṣamūle // Vi_63.19 //"
  },
  {
    "id": "p-c6244c",
    "offset": 692,
    "text": "na śūnyālayam // Vi_63.20 //"
  },
  {
    "id": "p-300632",
    "offset": 722,
    "text": "na tṛṇam // Vi_63.21 //"
  },
  {
    "id": "p-20b1b3",
    "offset": 747,
    "text": "na paśūnāṃ bandhanāgāram // Vi_63.22 //"
  },
  {
    "id": "p-937da0",
    "offset": 788,
    "text": "na keśatuṣakapālāsthibhasmāṅgārān // Vi_63.23 //"
  },
  {
    "id": "p-194704",
    "offset": 838,
    "text": "na kārpāsāsthi // Vi_63.24 //"
  },
  {
    "id": "p-55dc6a",
    "offset": 869,
    "text": "catuṣpathaṃ prakakṣiṇīkuryāt // Vi_63.25 //"
  },
  {
    "id": "p-63aa33",
    "offset": 914,
    "text": "devatārcāṃ ca // Vi_63.26 //"
  },
  {
    "id": "p-2c0687",
    "offset": 944,
    "text": "prajñātāṃś ca vanasptīn // Vi_63.27 //"
  },
  {
    "id": "p-275a4e",
    "offset": 984,
    "text": "agnibrāhmaṇagaṇikāpūrṇakumbhādarśacchatradhvajapatākāśrīvṛkṣavardhamānanandyāvartāṃś ca // Vi_63.28 //"
  },
  {
    "id": "p-c6bd9f",
    "offset": 1088,
    "text": "tālavṛntacāmarāśvagajājagodadhikṣīramadhusiddhārthakāṃś ca // Vi_63.29 //"
  },
  {
    "id": "p-91e531",
    "offset": 1163,
    "text": "vīṇācandanāyudhārdragomayaphalapuṣpārdraśākagorocanādūrvāprarohāṃś ca // Vi_63.30 //"
  },
  {
    "id": "p-1bc939",
    "offset": 1249,
    "text": "uṣṇīṣālaṃkāramaṇikanakarajatavastrāsanayānāmiṣāṃś ca // Vi_63.31 //"
  },
  {
    "id": "p-f186ec",
    "offset": 1318,
    "text": "bhṛṅgāroddhṛtorvarābaddhaikapaśukumārīmīnāṃś ca dṛṣṭvā prayāyād iti // Vi_63.32 //"
  },
  {
    "id": "p-126660",
    "offset": 1402,
    "text": "atha mattonmattavyaṅgān dṛṣṭvā nivarteta // Vi_63.33 //"
  },
  {
    "id": "p-a8784b",
    "offset": 1459,
    "text": "vāntaviriktamuṇḍajaṭilavāmanāṃś ca // Vi_63.34 //"
  },
  {
    "id": "p-cacda5",
    "offset": 1510,
    "text": "kāṣāyipravrajitamalināṃś ca // Vi_63.35 //"
  },
  {
    "id": "p-772e47",
    "offset": 1554,
    "text": "tailaguḍaśuṣkagomayendhanatṛṇapalāśabhasmāṅgārāṃś ca // Vi_63.36 //"
  },
  {
    "id": "p-599465",
    "offset": 1623,
    "text": "lavaṇaklībāsavanapuṃsakakārpāsarajjunigaḍamuktakeśāṃś ca // Vi_63.37 //"
  },
  {
    "id": "p-a4baab",
    "offset": 1696,
    "text": "vīnācandanārdraśākoṣṇīṣālaṃkaraṇakumārīs tu prasthānakāle abhinandayed iti // Vi_63.38 //"
  },
  {
    "id": "p-54deee",
    "offset": 1787,
    "text": "devabrāhmaṇagurubabhrudīkṣitānāṃ chāyāṃ nākrāmet // Vi_63.39 //"
  },
  {
    "id": "p-32b760",
    "offset": 1852,
    "text": "niṣṭhyūtavāntarudhiraviṇmūtrasnānodakāni ca // Vi_63.40 //"
  },
  {
    "id": "p-fd82ad",
    "offset": 1912,
    "text": "na vatsatantrīṃ laṅghayet // Vi_63.41 //"
  },
  {
    "id": "p-754b98",
    "offset": 1954,
    "text": "pravarṣati na dhāvet // Vi_63.42 //"
  },
  {
    "id": "p-8e3cb4",
    "offset": 1991,
    "text": "na vṛthā nadīṃ taret // Vi_63.43 //"
  },
  {
    "id": "p-f13d03",
    "offset": 2028,
    "text": "na devatābhyaḥ pitṛbhyaś codakam apradāya // Vi_63.44 //"
  },
  {
    "id": "p-ed459a",
    "offset": 2086,
    "text": "na bāhubhyām // Vi_63.45 //"
  },
  {
    "id": "p-4e186b",
    "offset": 2115,
    "text": "na bhinnayā nāvā // Vi_63.46 //"
  },
  {
    "id": "p-a4f073",
    "offset": 2148,
    "text": "na kūlam adhitiṣṭhet // Vi_63.47 //"
  },
  {
    "id": "p-cffe57",
    "offset": 2185,
    "text": "na kūpam avalokayet // Vi_63.48 //"
  },
  {
    "id": "p-e3e65a",
    "offset": 2221,
    "text": "na laṅghayet // Vi_63.49 //"
  },
  {
    "id": "p-679bb3",
    "offset": 2250,
    "text": "vṛddhabhārinṛpasnāta strīrogivaracakriṇām  /"
  },
  {
    "id": "p-00f7e7",
    "offset": 2296,
    "text": "panthā deyā nṛpas tv eṣāṃ mānyaḥ snātaś ca bhūpateḥ  || Vi_63.50 ||"
  }
]