[
  {
    "id": "p-104830",
    "offset": 0,
    "text": "Vi_43"
  },
  {
    "id": "p-d533f1",
    "offset": 7,
    "text": "atha narakāḥ // Vi_43.1 //"
  },
  {
    "id": "p-56e6ff",
    "offset": 35,
    "text": "tāmisram // Vi_43.2 //"
  },
  {
    "id": "p-be4314",
    "offset": 59,
    "text": "andhatāmisram // Vi_43.3 //"
  },
  {
    "id": "p-51cad4",
    "offset": 88,
    "text": "rauravam // Vi_43.4 //"
  },
  {
    "id": "p-d55778",
    "offset": 112,
    "text": "mahārauravam // Vi_43.5 //"
  },
  {
    "id": "p-ff931f",
    "offset": 140,
    "text": "kālasūtram // Vi_43.6 //"
  },
  {
    "id": "p-6f4729",
    "offset": 166,
    "text": "mahānarakam // Vi_43.7 //"
  },
  {
    "id": "p-d25907",
    "offset": 193,
    "text": "saṃjīvanam // Vi_43.8 //"
  },
  {
    "id": "p-3bfdcc",
    "offset": 219,
    "text": "avīci // Vi_43.9 //"
  },
  {
    "id": "p-433d86",
    "offset": 240,
    "text": "tapanam // Vi_43.10 //"
  },
  {
    "id": "p-09e8df",
    "offset": 264,
    "text": "saṃpratāpanam // Vi_43.11 //"
  },
  {
    "id": "p-794e01",
    "offset": 294,
    "text": "saṃghātakam // Vi_43.12 //"
  },
  {
    "id": "p-15110f",
    "offset": 322,
    "text": "kākolam // Vi_43.13 //"
  },
  {
    "id": "p-5f0402",
    "offset": 346,
    "text": "kuḍmalam // Vi_43.14 //"
  },
  {
    "id": "p-5b6f24",
    "offset": 371,
    "text": "pūtimṛttikam // Vi_43.15 //"
  },
  {
    "id": "p-bb078e",
    "offset": 400,
    "text": "lohaśaṅkuḥ // Vi_43.16 //"
  },
  {
    "id": "p-9d699a",
    "offset": 427,
    "text": "ṛbīsam // Vi_43.17 //"
  },
  {
    "id": "p-86a525",
    "offset": 450,
    "text": "viṣamapanthāḥ // Vi_43.18 //"
  },
  {
    "id": "p-32f3d5",
    "offset": 480,
    "text": "kaṇṭakaśālmaliḥ // Vi_43.19 //"
  },
  {
    "id": "p-1fdcd0",
    "offset": 512,
    "text": "dīpanadī // Vi_43.20 //"
  },
  {
    "id": "p-279ab2",
    "offset": 537,
    "text": "asipatravanam // Vi_43.21 //"
  },
  {
    "id": "p-97a976",
    "offset": 567,
    "text": "lohacārakam iti // Vi_43.22 //"
  },
  {
    "id": "p-dc809e",
    "offset": 599,
    "text": "eteṣv akṛtaprāyaścittā atipātakinaḥ paryāyeṇa kalpaṃ pacyante // Vi_43.23 //"
  },
  {
    "id": "p-343796",
    "offset": 677,
    "text": "mahāpātakino manvantaram // Vi_43.24 //"
  },
  {
    "id": "p-e339c9",
    "offset": 718,
    "text": "anupātakinaś ca // Vi_43.25 //"
  },
  {
    "id": "p-cfb800",
    "offset": 750,
    "text": "upapātakinaś caturyugam // Vi_43.26 //"
  },
  {
    "id": "p-2be8a4",
    "offset": 790,
    "text": "kṛtasaṃkarīkaraṇāś ca saṃvatsarasahasram // Vi_43.27 //"
  },
  {
    "id": "p-bdbb49",
    "offset": 847,
    "text": "kṛtajātibhraṃśakaraṇāś ca // Vi_43.28 //"
  },
  {
    "id": "p-aa1db3",
    "offset": 889,
    "text": "kṛtāpātrīkaraṇāś ca // Vi_43.29 //"
  },
  {
    "id": "p-314bbf",
    "offset": 925,
    "text": "kṛtamalinīkaraṇāś ca // Vi_43.30 //"
  },
  {
    "id": "p-1b06de",
    "offset": 962,
    "text": "prakīrṇapātakinaś ca bahūn varṣapūgān // Vi_43.31 //"
  },
  {
    "id": "p-81d895",
    "offset": 1016,
    "text": "kṛtapātakinaḥ pāpāḥ prāṇatyāgād anantaram  /"
  },
  {
    "id": "p-22f5bf",
    "offset": 1062,
    "text": "yāmyaṃ panthānam āsādya duḥkham aśnanti dāruṇam  || Vi_43.32 ||"
  },
  {
    "id": "p-aeaff7",
    "offset": 1127,
    "text": "yamasya puruṣair ghoraiḥ kṛṣyamāṇā yatas tataḥ  /"
  },
  {
    "id": "p-3338d5",
    "offset": 1178,
    "text": "sakṛcchreṇānukāreṇa nīyamānāś ca te yathā  || Vi_43.33 ||"
  },
  {
    "id": "p-c5eea3",
    "offset": 1237,
    "text": "śvabhiḥ śṛgālaiḥ kravyādaiḥ kākakaṅkabakādibhiḥ  /"
  },
  {
    "id": "p-063b12",
    "offset": 1289,
    "text": "agnituṇḍair bhakṣyamāṇā bhujaṅgair vṛścikais tathā  || Vi_43.34 ||"
  },
  {
    "id": "p-79bc24",
    "offset": 1357,
    "text": "agninā dahyamānāś ca tudyamānāś ca kaṇṭakaiḥ  /"
  },
  {
    "id": "p-062b90",
    "offset": 1406,
    "text": "krakacaiḥ pāṭyamānāś ca pīḍyamānāś ca tṛṣṇayā  || Vi_43.35 ||"
  },
  {
    "id": "p-f89b9f",
    "offset": 1469,
    "text": "kṣudhayā vyathamānāś ca ghorair vyāghragaṇais tathā  /"
  },
  {
    "id": "p-c4e0b1",
    "offset": 1525,
    "text": "pūyaśoṇitagandhena mūrchamānāḥ pade pade  || Vi_43.36 ||"
  },
  {
    "id": "p-e20515",
    "offset": 1583,
    "text": "parānnapānaṃ lipsantas tādyamānāś ca kiṃkaraiḥ  /"
  },
  {
    "id": "p-475632",
    "offset": 1634,
    "text": "kākakaṅkabakādīnāṃ bhīmānāṃ sadṛśānanaiḥ  || Vi_43.37 ||"
  },
  {
    "id": "p-9a0f50",
    "offset": 1692,
    "text": "kvacit tailena kvāthyante tāḍyante musalaiḥ kvacit  /"
  },
  {
    "id": "p-6c3296",
    "offset": 1747,
    "text": "āyasīṣu ca vaṭyante śilāsu ca tathā kvacit  || Vi_43.38 ||"
  },
  {
    "id": "p-2cbb63",
    "offset": 1807,
    "text": "kvacid vāntam athāśnanti kvacit pūyam asṛk kvacit  /"
  },
  {
    "id": "p-b8769b",
    "offset": 1861,
    "text": "kvacid viṣṭhāṃ kvacin māṃsaṃ pūyagandhi sudāruṇam  || Vi_43.39 ||"
  },
  {
    "id": "p-a1704d",
    "offset": 1928,
    "text": "andhakāreṣu tiṣṭhanti dāruṇeṣu tathā kvacit  /"
  },
  {
    "id": "p-6c2068",
    "offset": 1976,
    "text": "krimibhir bhakṣyamāṇāś ca vahnituṇḍaiḥ sudāruṇaiḥ  || Vi_43.40 ||"
  },
  {
    "id": "p-0a9f58",
    "offset": 2043,
    "text": "kvacic chītena bādhyante kvacit cāmedhyamadhyagāḥ  /"
  },
  {
    "id": "p-1e5d68",
    "offset": 2097,
    "text": "parasparam athāśnanti kvacit pretāḥ sudāruṇāḥ  || Vi_43.41 ||"
  },
  {
    "id": "p-8b5119",
    "offset": 2160,
    "text": "kvacid bhūtena tāḍyante lambamānās tathā kvacit  /"
  },
  {
    "id": "p-85160a",
    "offset": 2212,
    "text": "kvacit kṣipyanti bānaughair utkṛtyante tathā kvacit  || Vi_43.42 ||"
  },
  {
    "id": "p-8bc07d",
    "offset": 2281,
    "text": "kaṇṭeṣu dattapādāś ca bhujaṅgābhogaveṣṭitāḥ  /"
  },
  {
    "id": "p-7015dc",
    "offset": 2329,
    "text": "pīḍyamānās tathā yantraiḥ kṛṣyamāṇāś ca jānubhiḥ  || Vi_43.43 ||"
  },
  {
    "id": "p-90c663",
    "offset": 2395,
    "text": "bhagnapṛṣṭhaśirogrīvāḥ sūcīkaṇṭhāḥ sudāruṇāḥ  /"
  },
  {
    "id": "p-f7d557",
    "offset": 2444,
    "text": "kūṭāgārapramāṇaiś ca śarīrair yātanākṣamaiḥ  || Vi_43.44 ||"
  },
  {
    "id": "p-ae3241",
    "offset": 2505,
    "text": "evaṃ pātakinaḥ pāpam anubhūya suduḥkhitāḥ  /"
  },
  {
    "id": "p-0c44b6",
    "offset": 2551,
    "text": "tiryagyonau prapadyante duḥkhāni vividhāni ca  || Vi_43.45 ||"
  }
]