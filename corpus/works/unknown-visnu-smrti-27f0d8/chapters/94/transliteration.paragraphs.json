[
  {
    "id": "p-913c2f",
    "offset": 0,
    "text": "Vi_94"
  },
  {
    "id": "p-a7c72e",
    "offset": 7,
    "text": "gṛhī valīpalitadarśane vanāśrayo bhavet // Vi_94.1 //"
  },
  {
    "id": "p-ec6ffd",
    "offset": 62,
    "text": "apatyasya cāpatyadarśane vā // Vi_94.2 //"
  },
  {
    "id": "p-58c146",
    "offset": 105,
    "text": "putreṣu bhāryāṃ nikṣipya tayānugmyamāno vā // Vi_94.3 //"
  },
  {
    "id": "p-c40a05",
    "offset": 163,
    "text": "tatrāpy agnīn upacaret // Vi_94.4 //"
  },
  {
    "id": "p-1a89d8",
    "offset": 201,
    "text": "aphālakṛṣṭena pañca yajñān na hāpayet // Vi_94.5 //"
  },
  {
    "id": "p-086860",
    "offset": 254,
    "text": "svādhyāyaṃ ca na jahyāt // Vi_94.6 //"
  },
  {
    "id": "p-71b49d",
    "offset": 293,
    "text": "brahmacaryaṃ pālayet // Vi_94.7 //"
  },
  {
    "id": "p-a0b737",
    "offset": 329,
    "text": "carmacīravāsāḥ syāt // Vi_94.8 //"
  },
  {
    "id": "p-e11912",
    "offset": 364,
    "text": "jaṭāśmaśrulomanakhāṃś ca bibhṛyāt // Vi_94.9 //"
  },
  {
    "id": "p-f428b9",
    "offset": 413,
    "text": "triṣavaṇasnāyī syāt // Vi_94.10 //"
  },
  {
    "id": "p-9869b8",
    "offset": 449,
    "text": "kapotavṛttir māsanicayaḥ saṃvatsaranicayo vā // Vi_94.11 //"
  },
  {
    "id": "p-503048",
    "offset": 510,
    "text": "saṃvatsaranicayī pūrvanicitam āśvayujyāṃ jahyāt // Vi_94.12 //"
  },
  {
    "id": "p-9438ce",
    "offset": 574,
    "text": "grāmād āhṛtya vāśnīyād aṣṭau grāsān vane vasan  /"
  },
  {
    "id": "p-fba1f9",
    "offset": 625,
    "text": "puṭenaiva palāśena pāṇinā śakalena vā  || Vi_94.13 ||"
  }
]