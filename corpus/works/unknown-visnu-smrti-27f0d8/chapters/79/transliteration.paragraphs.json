[
  {
    "id": "p-924b3b",
    "offset": 0,
    "text": "Vi_79"
  },
  {
    "id": "p-54482d",
    "offset": 7,
    "text": "atha na naktaṃ gṛhītenodakena śrāddhaṃ kuryāt // Vi_79.1 //"
  },
  {
    "id": "p-e73f39",
    "offset": 68,
    "text": "kuśābhāve kuśasthāne kāśān dūrvāṃ vā dadyāt // Vi_79.2 //"
  },
  {
    "id": "p-62d62d",
    "offset": 127,
    "text": "vāso 'rthe kārpāsotthaṃ sūtram // Vi_79.3 //"
  },
  {
    "id": "p-982a10",
    "offset": 173,
    "text": "daśāṃ visarjayet yady apy ahatavastrajā syāt // Vi_79.4 //"
  },
  {
    "id": "p-57195a",
    "offset": 233,
    "text": "ugragandhīny agandhīni kaṇṭakijāni ca puṣpāṇi // Vi_79.5 //"
  },
  {
    "id": "p-f3ac9c",
    "offset": 294,
    "text": "śuklāni sugandhīni kaṇṭakijāny api jalajāni raktāny api dadyāt // Vi_79.6 //"
  },
  {
    "id": "p-057231",
    "offset": 372,
    "text": "vasāṃ medaṃ ca dīpārthe na dadyāt // Vi_79.7 //"
  },
  {
    "id": "p-5b4fa5",
    "offset": 421,
    "text": "ghṛtaṃ tailaṃ vā dadyāt // Vi_79.8 //"
  },
  {
    "id": "p-7395ee",
    "offset": 460,
    "text": "jīvajaṃ sarvaṃ dhūpārthe na dadyāt // Vi_79.9 //"
  },
  {
    "id": "p-5d9e12",
    "offset": 510,
    "text": "madhughṛtasaṃyuktaṃ gugguluṃ dadyāt // Vi_79.10 //"
  },
  {
    "id": "p-49ac37",
    "offset": 562,
    "text": "candanakuṅkumakarpūrāgarupadmakāny anulepanārthe // Vi_79.11 //"
  },
  {
    "id": "p-3d8040",
    "offset": 627,
    "text": "na pratyakṣalavaṇaṃ dadyāt // Vi_79.12 //"
  },
  {
    "id": "p-728c8f",
    "offset": 670,
    "text": "hastena ca ghṛtavyañjanādi // Vi_79.13 //"
  },
  {
    "id": "p-4bd91b",
    "offset": 713,
    "text": "taijasāni pātrāṇi dadyāt // Vi_79.14 //"
  },
  {
    "id": "p-c2da7e",
    "offset": 754,
    "text": "viśeṣato rājatāni // Vi_79.15 //"
  },
  {
    "id": "p-b474c4",
    "offset": 788,
    "text": "khaḍgakutapakṛṣṇājinatilasiddhārthakākṣatāni ca pavitrāṇi rakṣoghnāni ca nidadhyāt // Vi_79.16 //"
  },
  {
    "id": "p-cddf79",
    "offset": 887,
    "text": "pippalīmukundakabhūstṛṇaśigrusarṣapasurasāsarjakasuvarcalakūśmāṇḍālābuvārtākapālakyopodakītaṇḍulīyakakusumbhapiṇḍālukamahiṣīkṣīrāṇi varjayet // Vi_79.17 //"
  },
  {
    "id": "p-d47d1b",
    "offset": 1044,
    "text": "rājamāṣamasūraparyuṣitakṛtalavaṇāni ca // Vi_79.18 //"
  },
  {
    "id": "p-462716",
    "offset": 1099,
    "text": "kopaṃ pariharet // Vi_79.19 //"
  },
  {
    "id": "p-52835a",
    "offset": 1131,
    "text": "nāśru pātayet // Vi_79.20 //"
  },
  {
    "id": "p-86bfb6",
    "offset": 1161,
    "text": "na tvarāṃ kuryāt // Vi_79.21 //"
  },
  {
    "id": "p-10ce8d",
    "offset": 1194,
    "text": "ghṛtādidāne taijasāni pātrāṇi khaḍgapātrāṇi phalgupātrāṇi ca praśastāni // Vi_79.22 //"
  },
  {
    "id": "p-89ed47",
    "offset": 1282,
    "text": "atra ca śloko bhavati // Vi_79.23 //"
  },
  {
    "id": "p-cddd61",
    "offset": 1320,
    "text": "sauvarṇarājatābhyāṃ ca khaḍgenaudumbareṇa vā  /"
  },
  {
    "id": "p-562030",
    "offset": 1369,
    "text": "dattam akṣayyatāṃ yāti phalgupātreṇa cāpy atha  || Vi_79.24 ||"
  }
]