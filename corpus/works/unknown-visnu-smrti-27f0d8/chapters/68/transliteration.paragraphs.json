[
  {
    "id": "p-874d69",
    "offset": 0,
    "text": "Vi_68"
  },
  {
    "id": "p-ff45b0",
    "offset": 7,
    "text": "candrārkoparāge nāśnīyāt // Vi_68.1 //"
  },
  {
    "id": "p-affd34",
    "offset": 47,
    "text": "snātvā muktayor aśnīyāt // Vi_68.2 //"
  },
  {
    "id": "p-347fad",
    "offset": 86,
    "text": "amuktayor astaṃ gatayoḥ snātvā dṛṣṭvā cāpare 'hni // Vi_68.3 //"
  },
  {
    "id": "p-2dbfba",
    "offset": 151,
    "text": "na gobrāhmaṇoparāge 'śnīyāt // Vi_68.4 //"
  },
  {
    "id": "p-b39f47",
    "offset": 194,
    "text": "na rājño vyasane // Vi_68.5 //"
  },
  {
    "id": "p-d876eb",
    "offset": 226,
    "text": "pravasitāgnihotrī yadāgnihotraṃ kṛtaṃ manyate tadāśnīyāt // Vi_68.6 //"
  },
  {
    "id": "p-f44e93",
    "offset": 298,
    "text": "yadā kṛtaṃ manyeta vaiśvadevam api // Vi_68.7 //"
  },
  {
    "id": "p-cdf369",
    "offset": 348,
    "text": "parvaṇi ca yadā kṛtaṃ manyeta parva // Vi_68.8 //"
  },
  {
    "id": "p-a0c93d",
    "offset": 399,
    "text": "nāśnīyāc cājīrṇe // Vi_68.9 //"
  },
  {
    "id": "p-262ef7",
    "offset": 431,
    "text": "nārdharātre // Vi_68.10 //"
  },
  {
    "id": "p-f9b9c0",
    "offset": 459,
    "text": "na madyāhne // Vi_68.11 //"
  },
  {
    "id": "p-3c90e4",
    "offset": 487,
    "text": "na saṃdhyayoḥ // Vi_68.12 //"
  },
  {
    "id": "p-653d4b",
    "offset": 517,
    "text": "nārdravāsāḥ // Vi_68.13 //"
  },
  {
    "id": "p-77066b",
    "offset": 545,
    "text": "naikavāsāḥ // Vi_68.14 //"
  },
  {
    "id": "p-c36e65",
    "offset": 572,
    "text": "na nagnaḥ // Vi_68.15 //"
  },
  {
    "id": "p-f09101",
    "offset": 598,
    "text": "nodake // Vi_68.16 //"
  },
  {
    "id": "p-1ea99a",
    "offset": 621,
    "text": "notkuṭakaḥ // Vi_68.17 //"
  },
  {
    "id": "p-878368",
    "offset": 648,
    "text": "na bhinnāsanagataḥ // Vi_68.18 //"
  },
  {
    "id": "p-1ed92b",
    "offset": 683,
    "text": "na ca śayanagataḥ // Vi_68.19 //"
  },
  {
    "id": "p-ad3057",
    "offset": 717,
    "text": "na bhinnabhojane // Vi_68.20 //"
  },
  {
    "id": "p-e0c824",
    "offset": 750,
    "text": "notsaṅge // Vi_68.21 //"
  },
  {
    "id": "p-898ef9",
    "offset": 775,
    "text": "na bhuvi // Vi_68.22 //"
  },
  {
    "id": "p-ae5345",
    "offset": 800,
    "text": "na pāṇau // Vi_68.23 //"
  },
  {
    "id": "p-35a94a",
    "offset": 825,
    "text": "lavaṇaṃ ca yatra dadyāt tan nāśnīyāt // Vi_68.24 //"
  },
  {
    "id": "p-769e82",
    "offset": 878,
    "text": "na bālakān nirbhatseyan // Vi_68.25 //"
  },
  {
    "id": "p-db06ba",
    "offset": 918,
    "text": "naiko mṛṣṭam // Vi_68.26 //"
  },
  {
    "id": "p-89d27a",
    "offset": 947,
    "text": "noddhṛtasneham // Vi_68.27 //"
  },
  {
    "id": "p-b19404",
    "offset": 978,
    "text": "na divā dhānāḥ // Vi_68.28 //"
  },
  {
    "id": "p-355428",
    "offset": 1009,
    "text": "na rātrau tilasaṃbandham // Vi_68.29 //"
  },
  {
    "id": "p-68b2ec",
    "offset": 1050,
    "text": "na dadhisaktūn // Vi_68.30 //"
  },
  {
    "id": "p-97b12d",
    "offset": 1081,
    "text": "na kovidāravaṭapippalaśāṇaśākam // Vi_68.31 //"
  },
  {
    "id": "p-0acd9f",
    "offset": 1129,
    "text": "nādattvā // Vi_68.32 //"
  },
  {
    "id": "p-f84b67",
    "offset": 1154,
    "text": "nāhutvā // Vi_68.33 //"
  },
  {
    "id": "p-8bad47",
    "offset": 1178,
    "text": "nānārdrapādaḥ // Vi_68.34 //"
  },
  {
    "id": "p-36f7c1",
    "offset": 1208,
    "text": "nānārdrakaramukhaś ca // Vi_68.35 //"
  },
  {
    "id": "p-d0bbec",
    "offset": 1246,
    "text": "nocchiṣṭaś ca ghṛtam ādadyāt // Vi_68.36 //"
  },
  {
    "id": "p-e817be",
    "offset": 1291,
    "text": "na candrārkatārakā nirīkṣeta // Vi_68.37 //"
  },
  {
    "id": "p-2d9917",
    "offset": 1336,
    "text": "na mūrdhānaṃ spṛśet // Vi_68.38 //"
  },
  {
    "id": "p-193ef5",
    "offset": 1372,
    "text": "na brahma kīrtayet // Vi_68.39 //"
  },
  {
    "id": "p-08ad59",
    "offset": 1407,
    "text": "prāṅmukho 'śnīyāt // Vi_68.40 //"
  },
  {
    "id": "p-a4a6df",
    "offset": 1441,
    "text": "dakṣiṇāmukho vā // Vi_68.41 //"
  },
  {
    "id": "p-17e07e",
    "offset": 1473,
    "text": "abhipūjyānnam // Vi_68.42 //"
  },
  {
    "id": "p-741fae",
    "offset": 1503,
    "text": "sumanāḥ sragvyanuliptaś ca // Vi_68.43 //"
  },
  {
    "id": "p-550459",
    "offset": 1546,
    "text": "na niḥśeṣakṛt syāt // Vi_68.44 //"
  },
  {
    "id": "p-06557e",
    "offset": 1581,
    "text": "anyatra dadhimadhusarpiḥpayaḥsaktupalamodakebhyaḥ // Vi_68.45 //"
  },
  {
    "id": "p-c7acb9",
    "offset": 1647,
    "text": "nāśnīyād bhāryayā sārdhaṃ nākāśe na tathotthitaḥ  /"
  },
  {
    "id": "p-3c9675",
    "offset": 1700,
    "text": "bahūnāṃ prekṣamāṇānāṃ naikasmin bahavas tathā  || Vi_68.46 ||"
  },
  {
    "id": "p-3a0adc",
    "offset": 1763,
    "text": "śūnyālaye vahnigṛhe devāgāre kathaṃcana  /"
  },
  {
    "id": "p-ddb7ab",
    "offset": 1807,
    "text": "piben nāñjalinā toyaṃ nātisauhityam ācaret  || Vi_68.47 ||"
  },
  {
    "id": "p-8cf806",
    "offset": 1867,
    "text": "na tṛtīyam athāśnīta na cāpathyaṃ kathaṃcana  /"
  },
  {
    "id": "p-11e6f0",
    "offset": 1916,
    "text": "nātiprage nātisāyaṃ na sāyaṃ prātar āśitaḥ  || Vi_68.48 ||"
  },
  {
    "id": "p-10e7ed",
    "offset": 1976,
    "text": "na bhāvaduṣṭam aśnīyān na bhāṇḍe bhāvadūṣite  /"
  },
  {
    "id": "p-24998c",
    "offset": 2025,
    "text": "śayānaḥ prauḍhapādaś ca kṛtvā caivāvasakthikām  || Vi_68.49 ||"
  }
]