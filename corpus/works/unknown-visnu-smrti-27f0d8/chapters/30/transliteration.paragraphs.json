[
  {
    "id": "p-1154fe",
    "offset": 0,
    "text": "Vi_30"
  },
  {
    "id": "p-451994",
    "offset": 7,
    "text": "śrāvaṇyāṃ prauṣṭhapadyāṃ vā chandāṃsy upākṛtyārdhapañcamān māsān adhīyīta // Vi_30.1 //"
  },
  {
    "id": "p-e44237",
    "offset": 96,
    "text": "tatas teṣām utsargaṃ bahiḥ kuryāt // Vi_30.2 //"
  },
  {
    "id": "p-a35e58",
    "offset": 145,
    "text": "utsarjanopākarmaṇor madhye vedāṅgādhyayanaṃ kuryāt // Vi_30.3 //"
  },
  {
    "id": "p-860eb1",
    "offset": 211,
    "text": "nādhīyītāhorātraṃ caturdaśyaṣṭamīṣu ca // Vi_30.4 //"
  },
  {
    "id": "p-83147e",
    "offset": 265,
    "text": "na+ṛtvantaragrahasūtake // Vi_30.5 //"
  },
  {
    "id": "p-acabe5",
    "offset": 304,
    "text": "nendraprayāṇe // Vi_30.6 //"
  },
  {
    "id": "p-f33100",
    "offset": 333,
    "text": "na vāti caṇḍapavane // Vi_30.7 //"
  },
  {
    "id": "p-c46d68",
    "offset": 368,
    "text": "nākālavarṣavidyutstaniteṣu // Vi_30.8 //"
  },
  {
    "id": "p-f906c2",
    "offset": 410,
    "text": "na bhūkaṃpolkāpātadigdāheṣu // Vi_30.9 //"
  },
  {
    "id": "p-eb0369",
    "offset": 453,
    "text": "nāntaḥśave grāme // Vi_30.10 //"
  },
  {
    "id": "p-3dc846",
    "offset": 486,
    "text": "na śāstrasaṃpāte // Vi_30.11 //"
  },
  {
    "id": "p-9cba58",
    "offset": 519,
    "text": "na śvasṛgālagardabhanirhrādeṣu // Vi_30.12 //"
  },
  {
    "id": "p-9ae6d7",
    "offset": 566,
    "text": "na vāditraśabde // Vi_30.13 //"
  },
  {
    "id": "p-aa637f",
    "offset": 598,
    "text": "na śūdrapatitayoḥ samīpe // Vi_30.14 //"
  },
  {
    "id": "p-0b5680",
    "offset": 639,
    "text": "na devatāyatanaśmaśānacatuṣpatharathyāsu // Vi_30.15 //"
  },
  {
    "id": "p-e6ec5b",
    "offset": 696,
    "text": "nodakāntaḥ // Vi_30.16 //"
  },
  {
    "id": "p-84e547",
    "offset": 723,
    "text": "na pīṭhopahitapādaḥ // Vi_30.17 //"
  },
  {
    "id": "p-13a3f9",
    "offset": 759,
    "text": "na hastyaśvoṣṭranaugoyāneṣu // Vi_30.18 //"
  },
  {
    "id": "p-812b98",
    "offset": 803,
    "text": "na vāntaḥ // Vi_30.19 //"
  },
  {
    "id": "p-b8616e",
    "offset": 829,
    "text": "na viriktaḥ // Vi_30.20 //"
  },
  {
    "id": "p-20a17e",
    "offset": 857,
    "text": "nājīrṇī // Vi_30.21 //"
  },
  {
    "id": "p-ac23f5",
    "offset": 881,
    "text": "na pañcanakhāntarāgamane // Vi_30.22 //"
  },
  {
    "id": "p-a15533",
    "offset": 922,
    "text": "na rājaśrotriyagobrāhmaṇavyasane // Vi_30.23 //"
  },
  {
    "id": "p-849e17",
    "offset": 971,
    "text": "nopākarmaṇi // Vi_30.24 //"
  },
  {
    "id": "p-271d06",
    "offset": 999,
    "text": "notsarge // Vi_30.25 //"
  },
  {
    "id": "p-2312d1",
    "offset": 1024,
    "text": "na sāmadhvanāv ṛgyajuṣī // Vi_30.26 //"
  },
  {
    "id": "p-ff3f4f",
    "offset": 1064,
    "text": "nāpararātram adhītya śayīta // Vi_30.27 //"
  },
  {
    "id": "p-99038e",
    "offset": 1108,
    "text": "abhiyukto 'py anadhyāyeṣv adhyayanaṃ pariharet // Vi_30.28 //"
  },
  {
    "id": "p-8e4ee9",
    "offset": 1171,
    "text": "yasmād anadhyāyādhītaṃ nehāmutra phalapradam // Vi_30.29 //"
  },
  {
    "id": "p-2435b7",
    "offset": 1232,
    "text": "tadadhyayanenāyuṣaḥ kṣayo guruśiṣyayoś ca // Vi_30.30 //"
  },
  {
    "id": "p-4d6334",
    "offset": 1290,
    "text": "tasmād anadhyāyavarjaṃ guruṇā brahmalokakāmena vidyā satśiṣyakṣetreṣu vaptavyā // Vi_30.31 //"
  },
  {
    "id": "p-ef5daf",
    "offset": 1385,
    "text": "śiṣyeṇa brahmārambhāvasānayor guroḥ pādopasaṃgrahaṇaṃ kāryam // Vi_30.32 //"
  },
  {
    "id": "p-54c11d",
    "offset": 1462,
    "text": "praṇavaś ca vyāhartavyaḥ // Vi_30.33 //"
  },
  {
    "id": "p-d09b15",
    "offset": 1503,
    "text": "tatra ca yad ṛco 'dhīte tenāsyājyena pitṝṇāṃ tṛptir bhavati // Vi_30.34 //"
  },
  {
    "id": "p-afd9e4",
    "offset": 1579,
    "text": "yad yajūṃṣi tena madhunā // Vi_30.35 //"
  },
  {
    "id": "p-6283d5",
    "offset": 1620,
    "text": "yat sāmāni tena payasā // Vi_30.36 //"
  },
  {
    "id": "p-5181b9",
    "offset": 1659,
    "text": "yad ātharvaṇaṃ tena māṃsena // Vi_30.37 //"
  },
  {
    "id": "p-d45e16",
    "offset": 1703,
    "text": "yat purāṇetihāsavedāṅgadharmaśāstrāṇy adhīte tenāsyānnena // Vi_30.38 //"
  },
  {
    "id": "p-90095b",
    "offset": 1777,
    "text": "yaś ca vidyām āsādyāsmin loke tayā jīvet, na sā tasya paraloke phalapradā bhavet // Vi_30.39 //"
  },
  {
    "id": "p-b41468",
    "offset": 1874,
    "text": "yaś ca vidyayā yaśaḥ pareṣāṃ hanti // Vi_30.40 //"
  },
  {
    "id": "p-978cdf",
    "offset": 1925,
    "text": "ananujñātaś cānyasmād adhīyānān na vidyām ādadyāt // Vi_30.41 //"
  },
  {
    "id": "p-243a48",
    "offset": 1991,
    "text": "tadādānam asya brahmasteyaṃ narakāya bhavati // Vi_30.42 //"
  },
  {
    "id": "p-3b6c1f",
    "offset": 2052,
    "text": "laukikaṃ vaidikaṃ vāpi tathādhyātmikam eva vā  /"
  },
  {
    "id": "p-c4bcee",
    "offset": 2102,
    "text": "ādadīta yato jñānaṃ na taṃ druhyet kadācana  || Vi_30.43 ||"
  },
  {
    "id": "p-479cb7",
    "offset": 2163,
    "text": "utpādakabrahmadātror garīyān brahmadaḥ pitā  /"
  },
  {
    "id": "p-6235b7",
    "offset": 2211,
    "text": "brahmajanma hi viprasya pretya ceha ca śāśvatam  || Vi_30.44 ||"
  },
  {
    "id": "p-09f781",
    "offset": 2276,
    "text": "kāmān mātā pitā cainaṃ yad utpādayato mithaḥ  /"
  },
  {
    "id": "p-dea96b",
    "offset": 2325,
    "text": "saṃbhūtiṃ tasya tāṃ vidyād yad yonāv iha jāyate  || Vi_30.45 ||"
  },
  {
    "id": "p-4fc6eb",
    "offset": 2390,
    "text": "ācāryas tv asya yāṃ jātiṃ vidhivad vedapāragaḥ  /"
  },
  {
    "id": "p-e8e47f",
    "offset": 2441,
    "text": "utpādayati sāvitryā sā satyā sājarāmarā  || Vi_30.46 ||"
  },
  {
    "id": "p-7eae18",
    "offset": 2498,
    "text": "ya āvṛṇoty avitathena karṇāv aduḥkhaṃ kurvann amṛtaṃ saṃprayacchan  /"
  },
  {
    "id": "p-ace4ca",
    "offset": 2569,
    "text": "taṃ manyeta pitaraṃ mātaraṃ ca tasmai na druhyet kṛtam asya jānan  || Vi_30.47 ||"
  }
]