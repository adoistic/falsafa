[
  {
    "id": "p-154838",
    "offset": 0,
    "text": "Vi_46"
  },
  {
    "id": "p-8bbf56",
    "offset": 7,
    "text": "atha kṛcchrāṇi bhavanti // Vi_46.1 //"
  },
  {
    "id": "p-c1b4d1",
    "offset": 46,
    "text": "tryahaṃ nāśnīyāt // Vi_46.2 //"
  },
  {
    "id": "p-15ba68",
    "offset": 78,
    "text": "pratyahaṃ ca triṣavaṇaṃ snānam ācaret // Vi_46.3 //"
  },
  {
    "id": "p-c2b3de",
    "offset": 131,
    "text": "triḥ pratisnānam apsu majjanam // Vi_46.4 //"
  },
  {
    "id": "p-aca4ee",
    "offset": 177,
    "text": "magnas trir aghamarṣaṇaṃ japet // Vi_46.5 //"
  },
  {
    "id": "p-b0f8ba",
    "offset": 223,
    "text": "divā sthitas tiṣṭhet // Vi_46.6 //"
  },
  {
    "id": "p-d7de27",
    "offset": 259,
    "text": "rātrāv āsīnaḥ // Vi_46.7 //"
  },
  {
    "id": "p-df5ad5",
    "offset": 288,
    "text": "karmaṇo 'nte payasvinīṃ dadyāt // Vi_46.8 //"
  },
  {
    "id": "p-bee123",
    "offset": 334,
    "text": "ity aghmarṣaṇam // Vi_46.9 //"
  },
  {
    "id": "p-935db8",
    "offset": 365,
    "text": "tryahaṃ sāyaṃ tryahaṃ prātas tryaham ayācitam aśnīyāt / eṣa prājāpatyaḥ // Vi_46.10 //"
  },
  {
    "id": "p-54d2cf",
    "offset": 453,
    "text": "tryaham uṣṇāḥ pibed apas tryaham uṣṇaṃ ghṛtaṃ tryaham uṣṇaṃ payas tryahaṃ ca nāśnīyād eṣa taptakṛcchraḥ // Vi_46.11 //"
  },
  {
    "id": "p-f5d289",
    "offset": 573,
    "text": "etair eva śītaiḥ śītakṛcchraḥ // Vi_46.12 //"
  },
  {
    "id": "p-a2127f",
    "offset": 619,
    "text": "kṛcchrātikṛcchraḥ payasā divasaikaviṃśatikṣapaṇam // Vi_46.13 //"
  },
  {
    "id": "p-6cfe66",
    "offset": 685,
    "text": "udakasaktūnāṃ māsābhyavahāreṇodakakṛcchraḥ // Vi_46.14 //"
  },
  {
    "id": "p-5e229a",
    "offset": 744,
    "text": "bisābhyavahāreṇa mūlakṛcchraḥ // Vi_46.15 //"
  },
  {
    "id": "p-e41124",
    "offset": 790,
    "text": "bilvābhyavahāreṇa śrīphalakṛcchraḥ // Vi_46.16 //"
  },
  {
    "id": "p-e80477",
    "offset": 841,
    "text": "padmākṣair vā // Vi_46.17 //"
  },
  {
    "id": "p-179b51",
    "offset": 871,
    "text": "nirāhārasya dvādaśāhena parākaḥ // Vi_46.18 //"
  },
  {
    "id": "p-b90ab8",
    "offset": 919,
    "text": "gomūtraṃ gomayaṃ kṣīraṃ dadhi sarpiḥ kuśodakāny ekadivasam aśnīyāt / dvitīyam upavaset / etat sāṃtapanam // Vi_46.19 //"
  },
  {
    "id": "p-80d03e",
    "offset": 1040,
    "text": "gomūtrādibhiḥ pratyaham abhyastair mahāsāṃtapanam // Vi_46.20 //"
  },
  {
    "id": "p-7ac180",
    "offset": 1106,
    "text": "tryahābhyastaiś cātisāṃtapanam // Vi_46.21 //"
  },
  {
    "id": "p-120a9a",
    "offset": 1153,
    "text": "piṇyākācāmatakrodakasaktūnām upavāsāntarito 'bhyavahāras tulāpuruṣaḥ // Vi_46.22 //"
  },
  {
    "id": "p-21cb73",
    "offset": 1238,
    "text": "kuśapalāśodumbarapadmaśaṅkhapuṣpīvaṭabrāhmīsuvarcalāpatraiḥ kvathitasyāmbhasaḥ pratyekaṃ pānena parṇakṛcchraḥ // Vi_46.23 //"
  },
  {
    "id": "p-95d8ce",
    "offset": 1364,
    "text": "kṛcchrāṇy etāni sarvāṇi kurvīta kṛtavāpanaḥ  /"
  },
  {
    "id": "p-ba75b5",
    "offset": 1412,
    "text": "nityaṃ triṣavaṇasnāyī adhaḥśāyī jitendriyaḥ  || Vi_46.24 ||"
  },
  {
    "id": "p-bb026f",
    "offset": 1473,
    "text": "strīśūdrapatitānāṃ ca varjayec cātibhāṣaṇam  /"
  },
  {
    "id": "p-e30bee",
    "offset": 1521,
    "text": "pavitrāṇi japen nityaṃ juhuyāc caiva śaktitaḥ  || Vi_46.25 ||"
  }
]