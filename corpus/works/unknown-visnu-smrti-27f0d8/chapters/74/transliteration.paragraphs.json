[
  {
    "id": "p-954b40",
    "offset": 0,
    "text": "Vi_74"
  },
  {
    "id": "p-b06d5e",
    "offset": 7,
    "text": "aṣṭakāsu daivapūrvaṃ śākamāṃsāpūpaiḥ śrāddhaṃ kṛtvānvaṣṭakāsv aṣṭakāvad vahnau hutvā daivapūrvam eva mātre pitāmahyai prapitāmahyai ca pūrvavad brāhmaṇān bhojayitvā dakṣiṇābhiś cābhyarcyānuvrajya visarjayet // Vi_74.1 //"
  },
  {
    "id": "p-9a3cd0",
    "offset": 229,
    "text": "tataḥ karṣūḥ kuryāt // Vi_74.2 //"
  },
  {
    "id": "p-70aa33",
    "offset": 264,
    "text": "tanmūle prāgudagagnyupasamādhānaṃ kṛtvā piṇḍanirvapaṇam // Vi_74.3 //"
  },
  {
    "id": "p-1d7e3f",
    "offset": 335,
    "text": "karṣūtrayamūle puruṣāṇāṃ karṣūtrayamūle strīṇām // Vi_74.4 //"
  },
  {
    "id": "p-530994",
    "offset": 398,
    "text": "puruṣakarṣūtrayaṃ sānnenodakena pūrayet // Vi_74.5 //"
  },
  {
    "id": "p-d295b6",
    "offset": 453,
    "text": "strīkarṣūtrayaṃ sānnena payasā // Vi_74.6 //"
  },
  {
    "id": "p-de77fe",
    "offset": 499,
    "text": "dadhnā māṃsena payasā pratyekaṃ karṣūtrayam // Vi_74.7 //"
  },
  {
    "id": "p-ac7386",
    "offset": 558,
    "text": "pūrayitvā japed etad bhavadbhyo bhavatībyo 'stu cākṣayam // Vi_74.8 //"
  }
]