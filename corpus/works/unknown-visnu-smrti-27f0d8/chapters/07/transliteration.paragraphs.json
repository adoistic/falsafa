[
  {
    "id": "p-5a373b",
    "offset": 0,
    "text": "darśane pratyaye dāne prātibhāvyaṃ vidhīyate  /"
  },
  {
    "id": "p-9dc059",
    "offset": 49,
    "text": "ādyau tu vitathe dāpyāv itarasya sutā api  || Vi_6 41 ||"
  },
  {
    "id": "p-7e7a57",
    "offset": 107,
    "text": "bahavaś cet pratibhuvo dadyus te 'rthaṃ yathākṛtam  /"
  },
  {
    "id": "p-241530",
    "offset": 162,
    "text": "arthe 'viśeṣite tv eṣu dhanikacchandataḥ kriyā  || Vi_6 42 ||"
  },
  {
    "id": "p-709b0a",
    "offset": 225,
    "text": "yam arthaṃ pratibhūr dadyād dhanikenopapīḍitaḥ  /"
  },
  {
    "id": "p-a9c632",
    "offset": 276,
    "text": "ṛṇikas taṃ pratibhuve dviguṇaṃ dātum arhati  || Vi_6 43 ||"
  },
  {
    "id": "p-1e3dcd",
    "offset": 336,
    "text": "Vi_7"
  },
  {
    "id": "p-1f473d",
    "offset": 342,
    "text": "atha lekhyaṃ trividham // Vi_7.1 //"
  },
  {
    "id": "p-321e9f",
    "offset": 379,
    "text": "rājasākṣikaṃ sasākṣikam asākṣikaṃ ca // Vi_7.2 //"
  },
  {
    "id": "p-cc071a",
    "offset": 430,
    "text": "rājādhikaraṇe tanniyuktakāyasthakṛtaṃ tadadhyakṣakaracihnitaṃ rājasākṣikam // Vi_7.3 //"
  },
  {
    "id": "p-9cab27",
    "offset": 519,
    "text": "yatra kvacana yena kenacil likhitaṃ sākṣibhiḥ svahastacihnitaṃ sasākṣikam // Vi_7.4 //"
  },
  {
    "id": "p-90fd4a",
    "offset": 607,
    "text": "svahastalikhitam asākṣikam // Vi_7.5 //"
  },
  {
    "id": "p-251849",
    "offset": 648,
    "text": "tat balāt kāritam apramāṇam // Vi_7.6 //"
  },
  {
    "id": "p-d1d4da",
    "offset": 690,
    "text": "upadhikṛtāni sarvāṇy eva // Vi_7.7 //"
  },
  {
    "id": "p-2f767f",
    "offset": 729,
    "text": "dūṣitakarmaduṣṭasākṣyaṅkitaṃ sasākṣikam api // Vi_7.8 //"
  },
  {
    "id": "p-c6ce3f",
    "offset": 787,
    "text": "tādṛgvidhena lekhakena likhitaṃ ca // Vi_7.9 //"
  },
  {
    "id": "p-12560c",
    "offset": 836,
    "text": "strībālāsvatantramattonmattabhītatāḍitakṛtaṃ ca // Vi_7.10 //"
  },
  {
    "id": "p-dbf3ca",
    "offset": 899,
    "text": "deśācārāviruddhaṃ vyaktādhikṛtalakṣaṇam aluptaprakramākṣaraṃ pramāṇam // Vi_7.11 //"
  },
  {
    "id": "p-7169f8",
    "offset": 984,
    "text": "varṇaiś ca tatkṛtaiś cihnaiḥ patrair eva ca yuktibhiḥ  /"
  },
  {
    "id": "p-2f3c19",
    "offset": 1042,
    "text": "saṃdigdhaṃ sādhayel lekhyaṃ tadyuktipratirūpitaiḥ  || Vi_7.12 ||"
  },
  {
    "id": "p-9444d9",
    "offset": 1108,
    "text": "yatra+ṛṇī dhaniko vāpi sākṣī vā lekhako 'pi vā  /"
  },
  {
    "id": "p-c70d40",
    "offset": 1159,
    "text": "mriyate tatra tallekhyaṃ tatsvahastaiḥ prasādhayet  || Vi_7.13 ||"
  }
]