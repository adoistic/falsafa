[
  {
    "id": "p-9a4b48",
    "offset": 0,
    "text": "Vi_71"
  },
  {
    "id": "p-433e62",
    "offset": 7,
    "text": "atha na kaṃcanāvamanyeta // Vi_71.1 //"
  },
  {
    "id": "p-31525c",
    "offset": 47,
    "text": "na ca hīnādhikāṅgān mūrkhān dhanahīnān avahaset // Vi_71.2 //"
  },
  {
    "id": "p-7df659",
    "offset": 110,
    "text": "na hīnān seveta // Vi_71.3 //"
  },
  {
    "id": "p-e68a1f",
    "offset": 141,
    "text": "svādhyāyavirodhi karma nācaret // Vi_71.4 //"
  },
  {
    "id": "p-706345",
    "offset": 187,
    "text": "vayo 'nurūpaṃ veṣaṃ kuryāt // Vi_71.5 //"
  },
  {
    "id": "p-e1dfc5",
    "offset": 229,
    "text": "śrutasyābhijanasya dhanasya deśasya ca // Vi_71.6 //"
  },
  {
    "id": "p-7d7531",
    "offset": 283,
    "text": "noddhataḥ // Vi_71.7 //"
  },
  {
    "id": "p-29b663",
    "offset": 308,
    "text": "nityaṃ śāstrādyavekṣī syāt // Vi_71.8 //"
  },
  {
    "id": "p-045f74",
    "offset": 350,
    "text": "sati vibhave na jīrṇamalavadvāsāḥ syāt // Vi_71.9 //"
  },
  {
    "id": "p-10499d",
    "offset": 404,
    "text": "na nāstīty abhibhāṣeta // Vi_71.10 //"
  },
  {
    "id": "p-45328c",
    "offset": 443,
    "text": "na nirgandhogragandhi raktaṃ ca mālyaṃ bibhṛyāt // Vi_71.11 //"
  },
  {
    "id": "p-649a39",
    "offset": 507,
    "text": "bibhṛyāj jalajaṃ raktam api // Vi_71.12 //"
  },
  {
    "id": "p-33b6c4",
    "offset": 551,
    "text": "yaṣṭiṃ ca vaiṇavīm // Vi_71.13 //"
  },
  {
    "id": "p-fdc451",
    "offset": 586,
    "text": "kamaṇḍaluṃ ca sodakam // Vi_71.14 //"
  },
  {
    "id": "p-77b603",
    "offset": 624,
    "text": "kārpāsam upavītam // Vi_71.15 //"
  },
  {
    "id": "p-481128",
    "offset": 658,
    "text": "raukme ca kuṇḍale // Vi_71.16 //"
  },
  {
    "id": "p-6ff823",
    "offset": 692,
    "text": "nādityam udyantam īkṣeta // Vi_71.17 //"
  },
  {
    "id": "p-a57701",
    "offset": 733,
    "text": "nāstaṃ yāntam // Vi_71.18 //"
  },
  {
    "id": "p-56de66",
    "offset": 763,
    "text": "na vāsasā tirohitam // Vi_71.19 //"
  },
  {
    "id": "p-4a0d91",
    "offset": 799,
    "text": "na cādarśajalamadhyastham // Vi_71.20 //"
  },
  {
    "id": "p-2e4926",
    "offset": 841,
    "text": "na madhyāhne // Vi_71.21 //"
  },
  {
    "id": "p-c8a751",
    "offset": 870,
    "text": "na kruddhasya guror mukham // Vi_71.22 //"
  },
  {
    "id": "p-819736",
    "offset": 913,
    "text": "na tailodakayoḥ svāṃ chāyām // Vi_71.23 //"
  },
  {
    "id": "p-94e9eb",
    "offset": 957,
    "text": "na malavaty ādarśe // Vi_71.24 //"
  },
  {
    "id": "p-410b91",
    "offset": 992,
    "text": "na patnīṃ bhojanasamaye // Vi_71.25 //"
  },
  {
    "id": "p-66e407",
    "offset": 1032,
    "text": "na striyaṃ nagnām // Vi_71.26 //"
  },
  {
    "id": "p-513a96",
    "offset": 1066,
    "text": "na kaṃcana mehamānam // Vi_71.27 //"
  },
  {
    "id": "p-f42726",
    "offset": 1103,
    "text": "na cālānabhraṣṭaṃ kuñjaram // Vi_71.28 //"
  },
  {
    "id": "p-40c2c0",
    "offset": 1146,
    "text": "na ca viṣamastho vṛṣādiyuddham // Vi_71.29 //"
  },
  {
    "id": "p-f0f3d9",
    "offset": 1193,
    "text": "nonmattam // Vi_71.30 //"
  },
  {
    "id": "p-f4bed1",
    "offset": 1219,
    "text": "na mattam // Vi_71.31 //"
  },
  {
    "id": "p-cf06d1",
    "offset": 1245,
    "text": "nāmedhyam agnau prakṣipet // Vi_71.32 //"
  },
  {
    "id": "p-6563c7",
    "offset": 1287,
    "text": "nāsṛk // Vi_71.33 //"
  },
  {
    "id": "p-391ef0",
    "offset": 1309,
    "text": "na viṣam // Vi_71.34 //"
  },
  {
    "id": "p-030298",
    "offset": 1334,
    "text": "ambhasyāpi // Vi_71.35 //"
  },
  {
    "id": "p-8af5b9",
    "offset": 1361,
    "text": "nāgniṃ laṅghayet // Vi_71.36 //"
  },
  {
    "id": "p-6fe183",
    "offset": 1394,
    "text": "na pādau pratāpayet // Vi_71.37 //"
  },
  {
    "id": "p-9009ca",
    "offset": 1430,
    "text": "na kuśeṣu parimṛjyāt // Vi_71.38 //"
  },
  {
    "id": "p-6e52c5",
    "offset": 1467,
    "text": "na kāṃsyabhājane dhāvayet // Vi_71.39 //"
  },
  {
    "id": "p-d99db7",
    "offset": 1509,
    "text": "na pādaṃ pādena // Vi_71.40 //"
  },
  {
    "id": "p-e009a5",
    "offset": 1541,
    "text": "na bhuvam ālikhet // Vi_71.41 //"
  },
  {
    "id": "p-8e1604",
    "offset": 1575,
    "text": "na loṣṭamardī syāt // Vi_71.42 //"
  },
  {
    "id": "p-2af03f",
    "offset": 1610,
    "text": "na tṛṇacchedī syāt // Vi_71.43 //"
  },
  {
    "id": "p-5a0c21",
    "offset": 1645,
    "text": "na dantair nakhalomāni chindyāt // Vi_71.44 //"
  },
  {
    "id": "p-08c750",
    "offset": 1693,
    "text": "dyūtaṃ ca varjayet // Vi_71.45 //"
  },
  {
    "id": "p-27ac4a",
    "offset": 1728,
    "text": "bālātapasevāṃ va // Vi_71.46 //"
  },
  {
    "id": "p-841466",
    "offset": 1761,
    "text": "vastropānahamālyopavītāny anyadhṛtāni na dhārayet // Vi_71.47 //"
  },
  {
    "id": "p-d5565e",
    "offset": 1827,
    "text": "na śūdrāya matiṃ dadyāt // Vi_71.48 //"
  },
  {
    "id": "p-81d661",
    "offset": 1867,
    "text": "nocchiṣṭahaviṣī // Vi_71.49 //"
  },
  {
    "id": "p-24b776",
    "offset": 1899,
    "text": "na tilān // Vi_71.50 //"
  },
  {
    "id": "p-4a4f98",
    "offset": 1924,
    "text": "na cāsyopadiśed dharmam // Vi_71.51 //"
  },
  {
    "id": "p-329638",
    "offset": 1964,
    "text": "na vratam // Vi_71.52 //"
  },
  {
    "id": "p-fdd7f3",
    "offset": 1990,
    "text": "na saṃhatābhyāṃ pāṇibhyāṃ śira udaraṃ ca kaṇḍūyet // Vi_71.53 //"
  },
  {
    "id": "p-0b7f28",
    "offset": 2056,
    "text": "na dadhisumanasī pratyācakṣīta // Vi_71.54 //"
  },
  {
    "id": "p-259e1a",
    "offset": 2103,
    "text": "nātmanaḥ srajam apakarṣet // Vi_71.55 //"
  },
  {
    "id": "p-5982c1",
    "offset": 2145,
    "text": "suptaṃ na prabodhayet // Vi_71.56 //"
  },
  {
    "id": "p-02b857",
    "offset": 2183,
    "text": "na raktaṃ virāgayet // Vi_71.57 //"
  },
  {
    "id": "p-c99914",
    "offset": 2219,
    "text": "nodakyām abhibhāṣeta // Vi_71.58 //"
  },
  {
    "id": "p-fd85b0",
    "offset": 2256,
    "text": "na mlecchāntyajān // Vi_71.59 //"
  },
  {
    "id": "p-19242b",
    "offset": 2290,
    "text": "agnidevabrāhmaṇasaṃnidhau dakṣiṇaṃ pāṇim uddharet // Vi_71.60 //"
  },
  {
    "id": "p-13013c",
    "offset": 2356,
    "text": "na parakṣetre carantīṃ gām ācakṣīta // Vi_71.61 //"
  },
  {
    "id": "p-4e7286",
    "offset": 2408,
    "text": "na pibantaṃ vatsakam // Vi_71.62 //"
  },
  {
    "id": "p-d3aa7e",
    "offset": 2445,
    "text": "noddhatān praharṣayet // Vi_71.63 //"
  },
  {
    "id": "p-66523f",
    "offset": 2483,
    "text": "na śūdrarājye nivaset // Vi_71.64 //"
  },
  {
    "id": "p-22efe0",
    "offset": 2521,
    "text": "nādhārmikajanākīrṇe // Vi_71.65 //"
  },
  {
    "id": "p-722a43",
    "offset": 2557,
    "text": "na saṃvased vaidyahīne // Vi_71.66 //"
  },
  {
    "id": "p-6748a3",
    "offset": 2596,
    "text": "nopasṛṣṭe // Vi_71.67 //"
  },
  {
    "id": "p-191c79",
    "offset": 2622,
    "text": "na ciraṃ parvate // Vi_71.68 //"
  },
  {
    "id": "p-e4db6d",
    "offset": 2655,
    "text": "na vṛthāceṣṭāṃ kuryāt // Vi_71.69 //"
  },
  {
    "id": "p-f4a6cc",
    "offset": 2693,
    "text": "na nṛtyagīte // Vi_71.70 //"
  },
  {
    "id": "p-0800c9",
    "offset": 2722,
    "text": "nāsphoṭanam // Vi_71.71 //"
  },
  {
    "id": "p-a37d39",
    "offset": 2750,
    "text": "nāślīlaṃ kīrtayet // Vi_71.72 //"
  },
  {
    "id": "p-553d1b",
    "offset": 2784,
    "text": "nānṛtam // Vi_71.73 //"
  },
  {
    "id": "p-08a434",
    "offset": 2808,
    "text": "nāpriyam // Vi_71.74 //"
  },
  {
    "id": "p-df4c28",
    "offset": 2833,
    "text": "na kaṃcin marmaṇi spṛśet // Vi_71.75 //"
  },
  {
    "id": "p-04f465",
    "offset": 2874,
    "text": "nātmānam avajānīyād dīrgham āyur jijīviṣuḥ // Vi_71.76 //"
  },
  {
    "id": "p-c48a4c",
    "offset": 2933,
    "text": "ciraṃ saṃdhyopāsanaṃ kuryāt // Vi_71.77 //"
  },
  {
    "id": "p-e6bd43",
    "offset": 2977,
    "text": "na sarpaśastraiḥ kṛīḍet // Vi_71.78 //"
  },
  {
    "id": "p-34a957",
    "offset": 3017,
    "text": "animittataḥ khāni na spṛśet // Vi_71.79 //"
  },
  {
    "id": "p-457098",
    "offset": 3061,
    "text": "parasya daṇḍaṃ nodyacchet // Vi_71.80 //"
  },
  {
    "id": "p-dacc4e",
    "offset": 3103,
    "text": "śāsyaṃ śāsanārthaṃ tāḍayet // Vi_71.81 //"
  },
  {
    "id": "p-4c01dd",
    "offset": 3146,
    "text": "taṃ veṇudalena rajjvā vā pṛṣṭhe // Vi_71.82 //"
  },
  {
    "id": "p-a568ae",
    "offset": 3194,
    "text": "devabrāhmaṇaśāstramahātmanāṃ parivādaṃ pariharet // Vi_71.83 //"
  },
  {
    "id": "p-279097",
    "offset": 3259,
    "text": "dharmaviruddhau cārthakāmau // Vi_71.84 //"
  },
  {
    "id": "p-c7f3e0",
    "offset": 3303,
    "text": "lokavidviṣṭaṃ ca dharmam api // Vi_71.85 //"
  },
  {
    "id": "p-77bd75",
    "offset": 3348,
    "text": "parvasu ca śāntihomān kuryāt // Vi_71.86 //"
  },
  {
    "id": "p-e7b263",
    "offset": 3393,
    "text": "na tṛṇam api chindyāt // Vi_71.87 //"
  },
  {
    "id": "p-31c4ff",
    "offset": 3431,
    "text": "alaṃkṛtaś ca tiṣṭhet // Vi_71.88 //"
  },
  {
    "id": "p-578446",
    "offset": 3468,
    "text": "evam ācārasevī syāt // Vi_71.89 //"
  },
  {
    "id": "p-285ec2",
    "offset": 3504,
    "text": "śrutismṛtyuditaṃ dharmyaṃ sādhubhiś ca niṣevitam  /"
  },
  {
    "id": "p-e83210",
    "offset": 3557,
    "text": "tam ācāraṃ niṣeveta dharmakāmo jitendriyaḥ  || Vi_71.90 ||"
  },
  {
    "id": "p-6fc23e",
    "offset": 3617,
    "text": "ācārāl labhate cāyur ācārād īpsitāṃ gatim  /"
  },
  {
    "id": "p-158d20",
    "offset": 3663,
    "text": "ācārād dhanam akṣayyam ācārād dhanty alakṣaṇam  || Vi_71.91 ||"
  },
  {
    "id": "p-d60e51",
    "offset": 3727,
    "text": "sarvalakṣanahīno 'pi yaḥ sadācāravān naraḥ  /"
  },
  {
    "id": "p-51776b",
    "offset": 3774,
    "text": "śraddhadhāno 'nasūyaś ca śataṃ varṣāṇi jīvati  || Vi_71.93 ||"
  }
]