[
  {
    "id": "p-973c39",
    "offset": 0,
    "text": "Vi_92"
  },
  {
    "id": "p-99d9d9",
    "offset": 7,
    "text": "sarvadānādhikam abhayapradānam // Vi_92.1 //"
  },
  {
    "id": "p-f48db0",
    "offset": 53,
    "text": "tatpradānenābhīpsitaṃ lokam āpnoti // Vi_92.2 //"
  },
  {
    "id": "p-f5b364",
    "offset": 103,
    "text": "bhūmidānena ca // Vi_92.3 //"
  },
  {
    "id": "p-2554c9",
    "offset": 133,
    "text": "gocarmamātrām api bhuvaṃ pradāya sarvapāpebhyaḥ pūto bhavati // Vi_92.4 //"
  },
  {
    "id": "p-07b97c",
    "offset": 209,
    "text": "gopradānena svargalokam āpnoti // Vi_92.5 //"
  },
  {
    "id": "p-38c2c0",
    "offset": 255,
    "text": "daśadhenuprado golokān // Vi_92.6 //"
  },
  {
    "id": "p-5e8bd6",
    "offset": 293,
    "text": "śatadhenuprado brahamalokān // Vi_92.7 //"
  },
  {
    "id": "p-43e9b1",
    "offset": 336,
    "text": "suvarṇaśṛṅgīṃ raupyakhurāṃ muktālāṅgūlāṃ kāṃsyopadohāṃ vastrottarīyāṃ dattvā dhenuromasaṃkhyāni varṣāṇi svargalokam āpnoti // Vi_92.8 //"
  },
  {
    "id": "p-d5095d",
    "offset": 474,
    "text": "viśeṣataḥ kapilām // Vi_92.9 //"
  },
  {
    "id": "p-bf5dcd",
    "offset": 507,
    "text": "dāntaṃ dhuraṃdharaṃ dattvā daśadhenuprado bhavati // Vi_92.10 //"
  },
  {
    "id": "p-3e78f1",
    "offset": 573,
    "text": "aśvadaḥ sūryasālokyam āpnoti // Vi_92.11 //"
  },
  {
    "id": "p-fe93e6",
    "offset": 618,
    "text": "vāsodaś candrasālokyam // Vi_92.12 //"
  },
  {
    "id": "p-424528",
    "offset": 657,
    "text": "suvarṇadānenāgnisālokyam // Vi_92.13 //"
  },
  {
    "id": "p-cd4961",
    "offset": 698,
    "text": "rūpyadānena rūpam // Vi_92.14 //"
  },
  {
    "id": "p-9d3f64",
    "offset": 732,
    "text": "taijasānāṃ pātrāṇāṃ pradānena pātrībhavati sarvakāmānām // Vi_92.15 //"
  },
  {
    "id": "p-3bd08d",
    "offset": 804,
    "text": "ghṛtamadhutailapradānenārogyam // Vi_92.16 //"
  },
  {
    "id": "p-794311",
    "offset": 851,
    "text": "auṣadhapradānena // Vi_92.17 //"
  },
  {
    "id": "p-979320",
    "offset": 884,
    "text": "lavaṇadānena ca lāvaṇyam // Vi_92.18 //"
  },
  {
    "id": "p-a44ad1",
    "offset": 925,
    "text": "dhānyapradānena tṛptim // Vi_92.19 //"
  },
  {
    "id": "p-d74eaa",
    "offset": 964,
    "text": "sasyapradānena ca // Vi_92.20 //"
  },
  {
    "id": "p-aee863",
    "offset": 998,
    "text": "annadaḥ sarvam // Vi_92.21 //"
  },
  {
    "id": "p-652070",
    "offset": 1029,
    "text": "dhānyapradānena saubhāgyam // Vi_92.22 //"
  },
  {
    "id": "p-31a193",
    "offset": 1072,
    "text": "tilapradaḥ prajām iṣṭām // Vi_92.23 //"
  },
  {
    "id": "p-33b8d8",
    "offset": 1112,
    "text": "indhanapradānena dīptāgnir bhavati // Vi_92.24 //"
  },
  {
    "id": "p-45576b",
    "offset": 1163,
    "text": "saṃgrāme ca sarvajayam āpnoti // Vi_92.25 //"
  },
  {
    "id": "p-930163",
    "offset": 1209,
    "text": "āsanapradānena sthānam // Vi_92.26 //"
  },
  {
    "id": "p-fca8d1",
    "offset": 1248,
    "text": "śayyāpradānena bhāryām // Vi_92.27 //"
  },
  {
    "id": "p-12cd2a",
    "offset": 1287,
    "text": "upānatpradānenāśvatarīyuktaṃ ratham // Vi_92.28 //"
  },
  {
    "id": "p-41f6d1",
    "offset": 1339,
    "text": "chatrapradānena svargam // Vi_92.29 //"
  },
  {
    "id": "p-7e9ed0",
    "offset": 1379,
    "text": "tālavṛntacāmarapradānenādhvasukhitvam // Vi_92.30 //"
  },
  {
    "id": "p-207d85",
    "offset": 1433,
    "text": "vāstupradānena nagarādhipatyam // Vi_92.31 //"
  },
  {
    "id": "p-e8cb7a",
    "offset": 1480,
    "text": "yad yad iṣṭatamaṃ loke yac cāsti dayitaṃ gṛhe  /"
  },
  {
    "id": "p-f42bce",
    "offset": 1530,
    "text": "tat tad guṇavate deyaṃ tad evākṣayam icchatā  || Vi_92.32 ||"
  }
]