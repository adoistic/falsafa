[
  {
    "id": "p-834d62",
    "offset": 0,
    "text": "Vi_64"
  },
  {
    "id": "p-764a73",
    "offset": 7,
    "text": "paranipāneṣu na snānam ācaret // Vi_64.1 //"
  },
  {
    "id": "p-971bd2",
    "offset": 52,
    "text": "ācaret pañca piṇḍān uddhṛtyāpas tad āpadi // Vi_64.2 //"
  },
  {
    "id": "p-30eabb",
    "offset": 109,
    "text": "nājīrṇe // Vi_64.3 //"
  },
  {
    "id": "p-c13647",
    "offset": 132,
    "text": "na cāturaḥ // Vi_64.4 //"
  },
  {
    "id": "p-86e5b7",
    "offset": 158,
    "text": "na nagnaḥ // Vi_64.5 //"
  },
  {
    "id": "p-c630fd",
    "offset": 183,
    "text": "na rātrau // Vi_64.6 //"
  },
  {
    "id": "p-4b0e9a",
    "offset": 208,
    "text": "rāhudarśanavarjam // Vi_64.7 //"
  },
  {
    "id": "p-63aec9",
    "offset": 241,
    "text": "na saṃdhyayoḥ // Vi_64.8 //"
  },
  {
    "id": "p-3023ec",
    "offset": 270,
    "text": "prātaḥsnānaśīlo 'ruṇatāmrāṃ prācīm ālokya snāyāt // Vi_64.9 //"
  },
  {
    "id": "p-fd26ca",
    "offset": 334,
    "text": "snātaḥ śiro nāvadhunet // Vi_64.10 //"
  },
  {
    "id": "p-e17380",
    "offset": 373,
    "text": "nāṅgebhyas toyam uddharet // Vi_64.11 //"
  },
  {
    "id": "p-650697",
    "offset": 415,
    "text": "na tailavat saṃspṛśet // Vi_64.12 //"
  },
  {
    "id": "p-e2ccfa",
    "offset": 453,
    "text": "nāprakṣālitaṃ pūrvadhṛtaṃ vasanaṃ bibhṛyāt // Vi_64.13 //"
  },
  {
    "id": "p-373434",
    "offset": 512,
    "text": "snāta eva soṣṇīṣe dhaute vāsasī bibhṛyāt // Vi_64.14 //"
  },
  {
    "id": "p-9f4a4b",
    "offset": 569,
    "text": "na mlecchāntyajapatitaiḥ saha saṃbhāṣaṇaṃ kuryāt // Vi_64.15 //"
  },
  {
    "id": "p-e57ae6",
    "offset": 634,
    "text": "snāyāt prasravaṇadevakhātasarovareṣu // Vi_64.16 //"
  },
  {
    "id": "p-44bf0a",
    "offset": 687,
    "text": "uddhṛtāt bhūmiṣṭham udakaṃ puṇyaṃ, sthāvarāt prasravat, tasmān nādeyaṃ, tasmād api sādhuparigṛhītaṃ, sarvata eva gāṅgam // Vi_64.17 //"
  },
  {
    "id": "p-d89118",
    "offset": 823,
    "text": "mṛttoyaiḥ kṛtamalāpakaṛṣo 'psu nimajjyopaviśyāpo hi ṣṭheti tisṛbhir hiraṇyavarṇeti catasṛbhir idam āpaḥ pravahateti ca tīrtham abhimantrayet // Vi_64.18 //"
  },
  {
    "id": "p-5ff9ae",
    "offset": 980,
    "text": "tato 'psu nimagnas trir aghamarṣaṇaṃ japet // Vi_64.19 //"
  },
  {
    "id": "p-a987f0",
    "offset": 1039,
    "text": "tadviṣṇoḥ paramaṃ padam iti vā // Vi_64.20 //"
  },
  {
    "id": "p-23bd33",
    "offset": 1086,
    "text": "drupadāṃ sāvitrīṃ ca // Vi_64.21 //"
  },
  {
    "id": "p-564b59",
    "offset": 1123,
    "text": "yuñjate mana ity anuvākaṃ vā // Vi_64.22 //"
  },
  {
    "id": "p-1fdf5b",
    "offset": 1168,
    "text": "puruṣasūktaṃ vā // Vi_64.23 //"
  },
  {
    "id": "p-3aac59",
    "offset": 1200,
    "text": "snātaś cārdravāsā devapitṛtarpaṇam ambhaḥstha eva kuryāt // Vi_64.24 //"
  },
  {
    "id": "p-88f39d",
    "offset": 1273,
    "text": "parivartitavāsāś cet tīrtham uttīrya // Vi_64.25 //"
  },
  {
    "id": "p-8541ba",
    "offset": 1326,
    "text": "akṛtvā devapitṛtarpaṇaṃ snānaśāṭīṃ na pīḍayet // Vi_64.26 //"
  },
  {
    "id": "p-2023a6",
    "offset": 1388,
    "text": "snātvācamya vidhivad upaspṛśet // Vi_64.27 //"
  },
  {
    "id": "p-c5563a",
    "offset": 1435,
    "text": "puruṣasūktena pratyṛcaṃ puruṣāya puṣpāni dadyāt // Vi_64.28 //"
  },
  {
    "id": "p-1815e5",
    "offset": 1499,
    "text": "udakāñjalīṃś ca // Vi_64.29 //"
  },
  {
    "id": "p-761f94",
    "offset": 1531,
    "text": "ādāv eva daivena tīrthena devānāṃ tarpaṇaṃ kuryāt // Vi_64.30 //"
  },
  {
    "id": "p-fa0e4a",
    "offset": 1597,
    "text": "tadanantaraṃ pitryeṇa pitṝṇām // Vi_64.31 //"
  },
  {
    "id": "p-9ae7d7",
    "offset": 1643,
    "text": "tatrādau svavaṃśyānāṃ tarpaṇaṃ kuryāt // Vi_64.32 //"
  },
  {
    "id": "p-de4210",
    "offset": 1697,
    "text": "tataḥ saṃbandhibāndhavānām // Vi_64.33 //"
  },
  {
    "id": "p-ec1922",
    "offset": 1740,
    "text": "tataḥ suhṛdām // Vi_64.34 //"
  },
  {
    "id": "p-bea5e5",
    "offset": 1770,
    "text": "evaṃ nityasnāyī syāt // Vi_64.35 //"
  },
  {
    "id": "p-c87c2d",
    "offset": 1807,
    "text": "snātaś ca pavitrāṇi yathāśakti japet // Vi_64.36 //"
  },
  {
    "id": "p-659926",
    "offset": 1860,
    "text": "viśeṣataḥ sāvitrīm // Vi_64.37 //"
  },
  {
    "id": "p-b9aa2d",
    "offset": 1895,
    "text": "puruṣasūktaṃ ca // Vi_64.38 //"
  },
  {
    "id": "p-cfa4e4",
    "offset": 1927,
    "text": "naitābhyām adhikam asti // Vi_64.39 //"
  },
  {
    "id": "p-2a6996",
    "offset": 1967,
    "text": "snāto 'dhikārī bhavati daive pitrye ca karmaṇi  /"
  },
  {
    "id": "p-02c949",
    "offset": 2018,
    "text": "pavitrāṇāṃ tathā japye dāne ca vidhibodhite  || Vi_64.40 ||"
  },
  {
    "id": "p-9f03ee",
    "offset": 2079,
    "text": "alaksmīḥ kālakarṇī ca duḥsvapnaṃ durvicintitam  /"
  },
  {
    "id": "p-1e136a",
    "offset": 2130,
    "text": "abmātreṇābhiṣiktasya naśyanta iti dhāraṇā  || Vi_64.41 ||"
  },
  {
    "id": "p-53c376",
    "offset": 2189,
    "text": "yāmyaṃ hi yātanāduḥkhaṃ nityasnāyī na paśyati  /"
  },
  {
    "id": "p-e5a07c",
    "offset": 2239,
    "text": "nityasnānena pūyante ye 'pi pāpakṛto narāḥ  || Vi_64.42 ||"
  }
]