[
  {
    "id": "p-0f5739",
    "offset": 0,
    "text": "Vi_28"
  },
  {
    "id": "p-344db9",
    "offset": 7,
    "text": "atha brahmacariṇāṃ gurukulavāsaḥ // Vi_28.1 //"
  },
  {
    "id": "p-f26dfa",
    "offset": 55,
    "text": "saṃdhyādvayopāsanam // Vi_28.2 //"
  },
  {
    "id": "p-8baf6b",
    "offset": 90,
    "text": "pūrvāṃ saṃdhyāṃ japet tiṣṭhan paścimām āsīnaḥ // Vi_28.3 //"
  },
  {
    "id": "p-824333",
    "offset": 151,
    "text": "kāladvayam abhiṣekāgnikarmakaraṇam // Vi_28.4 //"
  },
  {
    "id": "p-464d30",
    "offset": 201,
    "text": "apsu daṇḍavan majjanam // Vi_28.5 //"
  },
  {
    "id": "p-e9cd7e",
    "offset": 239,
    "text": "āhūtādhyayanam // Vi_28.6 //"
  },
  {
    "id": "p-f296b1",
    "offset": 269,
    "text": "guroḥ priyahitācaraṇam // Vi_28.7 //"
  },
  {
    "id": "p-dbf8c0",
    "offset": 307,
    "text": "mekhalādaṇḍājinopavītadhāraṇam // Vi_28.8 //"
  },
  {
    "id": "p-9d8525",
    "offset": 353,
    "text": "gurukulavarjaṃ guṇavatsu bhaikṣyacaraṇam // Vi_28.9 //"
  },
  {
    "id": "p-dd7b5e",
    "offset": 409,
    "text": "gurvanujñātaṃ bhaikṣyābhyavaharaṇam // Vi_28.10 //"
  },
  {
    "id": "p-5a4133",
    "offset": 461,
    "text": "śrāddhakṛtalavaṇaśuktaparyuṣitanṛtyagītastrīmadhumāṃsāñjanocchiṣṭaprāṇihiṃsāślīlaparivarjanam // Vi_28.11 //"
  },
  {
    "id": "p-24a1cf",
    "offset": 571,
    "text": "adhaḥ śayyā // Vi_28.12 //"
  },
  {
    "id": "p-a96883",
    "offset": 599,
    "text": "guroḥ pūrvotthānaṃ caramaṃ saṃveśanam // Vi_28.13 //"
  },
  {
    "id": "p-3fd63e",
    "offset": 653,
    "text": "kṛtasaṃdhyopāsanaś ca gurvabhivādanaṃ kuryāt // Vi_28.14 //"
  },
  {
    "id": "p-aa74b4",
    "offset": 714,
    "text": "tasya ca vyatyastakaraḥ pādāv upaspṛśet // Vi_28.15 //"
  },
  {
    "id": "p-6db756",
    "offset": 770,
    "text": "dakṣiṇaṃ dakṣiṇenetaram itareṇa // Vi_28.16 //"
  },
  {
    "id": "p-ca9069",
    "offset": 818,
    "text": "svaṃ ca nāmāsyābhivādanānte bhoḥśabdāntaṃ nivedayet // Vi_28.17 //"
  },
  {
    "id": "p-3790d9",
    "offset": 886,
    "text": "tiṣṭhann āsīnaḥ śayāno bhuñjānaḥ parāṅmukhaś ca nāsyābhibhāṣaṇaṃ kuryāt // Vi_28.18 //"
  },
  {
    "id": "p-194e2f",
    "offset": 974,
    "text": "āsīnasya sthitaḥ kuryād abhigacchaṃs tu gacchataḥ / āgacchataḥ pratyudgamya paścād dhāvaṃs tu dhāvataḥ // Vi_28.19 //"
  },
  {
    "id": "p-534651",
    "offset": 1093,
    "text": "parāṅmukhasyābhimukhaḥ // Vi_28.20 //"
  },
  {
    "id": "p-0d634a",
    "offset": 1132,
    "text": "dūrasthasyāntikam upetya // Vi_28.21 //"
  },
  {
    "id": "p-1a0b40",
    "offset": 1173,
    "text": "śayānasya praṇamya // Vi_28.22 //"
  },
  {
    "id": "p-2fb55a",
    "offset": 1208,
    "text": "tasya ca cakṣurviṣaye na yatheṣṭāsanaḥ syāt // Vi_28.23 //"
  },
  {
    "id": "p-57c9e6",
    "offset": 1268,
    "text": "na cāsya kevalaṃ nāma brūyāt // Vi_28.24 //"
  },
  {
    "id": "p-892240",
    "offset": 1313,
    "text": "gaticeṣṭābhāṣitādyaṃ nāsyānukuryāt // Vi_28.25 //"
  },
  {
    "id": "p-d250c7",
    "offset": 1364,
    "text": "yatrāsya nindāparivādau syātāṃ na tatra tiṣṭhet // Vi_28.26 //"
  },
  {
    "id": "p-22610a",
    "offset": 1428,
    "text": "nāsyaikāsano bhavet // Vi_28.27 //"
  },
  {
    "id": "p-8d75cc",
    "offset": 1464,
    "text": "ṛte śilāphalakanauyānebhyaḥ // Vi_28.28 //"
  },
  {
    "id": "p-cf616b",
    "offset": 1508,
    "text": "guror gurau saṃnihite guruvad varteta // Vi_28.29 //"
  },
  {
    "id": "p-4d92cd",
    "offset": 1562,
    "text": "anirdiṣṭaś ca guruṇā svān gurun nābhivādayet // Vi_28.30 //"
  },
  {
    "id": "p-b03ef8",
    "offset": 1623,
    "text": "bāle samānavayasi vādhyāpake guruputre guruvad varteta // Vi_28.31 //"
  },
  {
    "id": "p-fd5deb",
    "offset": 1694,
    "text": "nāsya pādau prakṣālayet // Vi_28.32 //"
  },
  {
    "id": "p-fdb108",
    "offset": 1734,
    "text": "nocchiṣṭam aśnīyāt // Vi_28.33 //"
  },
  {
    "id": "p-278f76",
    "offset": 1769,
    "text": "evaṃ vedaṃ vedau vedān vā svīkuryāt // Vi_28.34 //"
  },
  {
    "id": "p-f76ecd",
    "offset": 1821,
    "text": "tato vedāṅgāni // Vi_28.35 //"
  },
  {
    "id": "p-5fd9fe",
    "offset": 1852,
    "text": "yas tv anadhītavedo 'nyatra śramaṃ kuryād asau sasaṃtānaḥ śūdratvam eti // Vi_28.36 //"
  },
  {
    "id": "p-d810db",
    "offset": 1940,
    "text": "mātur agre vijananaṃ dvitīyaṃ mauñjibandhanam // Vi_28.37 //"
  },
  {
    "id": "p-78c75d",
    "offset": 2002,
    "text": "tatrāsya mātā sāvitrī bhavati pitā tv *ācāryaḥ [ācārthaḥ] // Vi_28.38 //"
  },
  {
    "id": "p-718f8f",
    "offset": 2076,
    "text": "etenaiva teṣāṃ dvijatvam // Vi_28.39 //"
  },
  {
    "id": "p-56ecdf",
    "offset": 2117,
    "text": "prāṅ mauñjībandhanād dvijaḥ śūdrasamo bhavati // Vi_28.40 //"
  },
  {
    "id": "p-b3c55d",
    "offset": 2179,
    "text": "brahmacāriṇā muṇḍena jaṭilena vā bhāvyam // Vi_28.41 //"
  },
  {
    "id": "p-29d91e",
    "offset": 2236,
    "text": "vedasvīkaraṇād ūrdhvaṃ gurvanujñātas tasmai varaṃ dattvā snāyāt // Vi_28.42 //"
  },
  {
    "id": "p-a2dbf3",
    "offset": 2316,
    "text": "tato gurukula eva vā janmanaḥ śeṣaṃ nayet // Vi_28.43 //"
  },
  {
    "id": "p-a8b529",
    "offset": 2374,
    "text": "tatrācārye prete guruvat guruputre varteta // Vi_28.44 //"
  },
  {
    "id": "p-dc06b4",
    "offset": 2433,
    "text": "gurudāreṣu savarṇeṣu vā // Vi_28.45 //"
  },
  {
    "id": "p-da52a9",
    "offset": 2473,
    "text": "tadabhāve 'gniśuśrūṣur naiṣṭhiko brahmacārī syāt // Vi_28.46 //"
  },
  {
    "id": "p-8d73b4",
    "offset": 2538,
    "text": "evaṃ carati yo vipro brahmacaryam atandritaḥ  /"
  },
  {
    "id": "p-71f723",
    "offset": 2587,
    "text": "sa gacchaty uttamaṃ sthānaṃ na cehājāyate punaḥ  || Vi_28.47 ||"
  },
  {
    "id": "p-42e3cb",
    "offset": 2652,
    "text": "kāmato retasaḥ sekaṃ vratasthasya dvijanmanaḥ  /"
  },
  {
    "id": "p-f6e781",
    "offset": 2702,
    "text": "atikramaṃ vratasyāhur dharmajñā brahmacāriṇaḥ  || Vi_28.48 ||"
  },
  {
    "id": "p-893c1a",
    "offset": 2765,
    "text": "etasminn enasi prāpte vasitvā gardabhājinam  /"
  },
  {
    "id": "p-38df9f",
    "offset": 2813,
    "text": "saptāgāraṃ cared bhaikṣaṃ svakarma parikīrtayan  || Vi_28.49 ||"
  },
  {
    "id": "p-ccf13d",
    "offset": 2878,
    "text": "tebhyo labdhena bhaikṣyeṇa vartayann ekakālikam  /"
  },
  {
    "id": "p-0b9663",
    "offset": 2930,
    "text": "upaspṛśaṃs triṣavaṇam abdena sa viśudhyati  || Vi_28.50 ||"
  },
  {
    "id": "p-99b716",
    "offset": 2990,
    "text": "svapne siktvā brahmacārī dvijaḥ śukram akāmataḥ  /"
  },
  {
    "id": "p-4649d6",
    "offset": 3042,
    "text": "snātvārkam arcayitvā triḥ punar mām ity ṛcaṃ japet  || Vi_28.51 ||"
  },
  {
    "id": "p-1f608f",
    "offset": 3110,
    "text": "akṛtvā bhaikṣacaraṇam asamiddhya ca pāvakam  /"
  },
  {
    "id": "p-56f9a0",
    "offset": 3158,
    "text": "anāturaḥ saptarātram avakīrṇivrataṃ caret  || Vi_28.52 ||"
  },
  {
    "id": "p-245502",
    "offset": 3217,
    "text": "taṃ ced abhyudiyāt sūryaḥ śayānaṃ kāmakārataḥ  /"
  },
  {
    "id": "p-165caa",
    "offset": 3267,
    "text": "nimloced vāpy+avijñānāj japann upavased dinam  || Vi_28.53 ||"
  }
]