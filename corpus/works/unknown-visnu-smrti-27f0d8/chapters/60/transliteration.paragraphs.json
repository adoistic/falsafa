[
  {
    "id": "p-7f4d5c",
    "offset": 0,
    "text": "Vi_60"
  },
  {
    "id": "p-327ff9",
    "offset": 7,
    "text": "brāhme muhūrte utthāya mūtrapurīṣotsargaṃ kuryāt // Vi_60.1 //"
  },
  {
    "id": "p-521cae",
    "offset": 71,
    "text": "dakṣiṇābhimukho rātrau divā codaṅmukhaḥ saṃdhyayoś ca // Vi_60.2 //"
  },
  {
    "id": "p-f523de",
    "offset": 140,
    "text": "nāpracchāditāyāṃ bhūmau // Vi_60.3 //"
  },
  {
    "id": "p-af8c3d",
    "offset": 179,
    "text": "na phālakṛṣṭāyām // Vi_60.4 //"
  },
  {
    "id": "p-f3897c",
    "offset": 211,
    "text": "na chāyāyām // Vi_60.5 //"
  },
  {
    "id": "p-b940ee",
    "offset": 238,
    "text": "na coṣare // Vi_60.6 //"
  },
  {
    "id": "p-8427b1",
    "offset": 263,
    "text": "na śādvale // Vi_60.7 //"
  },
  {
    "id": "p-ebff95",
    "offset": 289,
    "text": "na sasattve // Vi_60.8 //"
  },
  {
    "id": "p-cc3ffb",
    "offset": 316,
    "text": "na garte // Vi_60.9 //"
  },
  {
    "id": "p-dc8c60",
    "offset": 340,
    "text": "na valmīke // Vi_60.10 //"
  },
  {
    "id": "p-2cbc4d",
    "offset": 367,
    "text": "na pathi // Vi_60.11 //"
  },
  {
    "id": "p-803dff",
    "offset": 392,
    "text": "na rathyāyām // Vi_60.12 //"
  },
  {
    "id": "p-bc7f54",
    "offset": 421,
    "text": "na parāśucau // Vi_60.13 //"
  },
  {
    "id": "p-4e5164",
    "offset": 450,
    "text": "nodyāne // Vi_60.14 //"
  },
  {
    "id": "p-63d639",
    "offset": 474,
    "text": "nodyānodkasamīpayoḥ // Vi_60.15 //"
  },
  {
    "id": "p-c28484",
    "offset": 510,
    "text": "na bhasmani // Vi_60.16 //"
  },
  {
    "id": "p-8db1da",
    "offset": 538,
    "text": "nāṅgāre // Vi_60.17 //"
  },
  {
    "id": "p-86e0f8",
    "offset": 562,
    "text": "na gomaye // Vi_60.18 //"
  },
  {
    "id": "p-c18806",
    "offset": 588,
    "text": "na govraje // Vi_60.19 //"
  },
  {
    "id": "p-cc4587",
    "offset": 615,
    "text": "nākāśe // Vi_60.20 //"
  },
  {
    "id": "p-551839",
    "offset": 638,
    "text": "nodake // Vi_60.21 //"
  },
  {
    "id": "p-48eb5b",
    "offset": 661,
    "text": "na pratyanilānalendvarkastrīgurubrāhmaṇānām // Vi_60.22 //"
  },
  {
    "id": "p-3a94ea",
    "offset": 721,
    "text": "naivānavaguṇṭhitaśirāḥ // Vi_60.23 //"
  },
  {
    "id": "p-075a99",
    "offset": 760,
    "text": "loṣṭeṣṭakāparimṛṣṭagudo gṛhītaśiśnaś cotthāyādbhir mṛdbhiś coddhṛtābhir gandhalepakṣayakaraṃ śaucaṃ kuryāt // Vi_60.24 //"
  },
  {
    "id": "p-a56995",
    "offset": 883,
    "text": "ekā liṅge gude tisras tathaikatra kare daśa  /"
  },
  {
    "id": "p-9c7150",
    "offset": 931,
    "text": "ubhayoḥ sapta dātavyā mṛdas tisras tu pādayoḥ  || Vi_60.25 ||"
  },
  {
    "id": "p-39e5c5",
    "offset": 994,
    "text": "etac chaucaṃ gṛhasthānāṃ dviguṇaṃ brahmacāriṇām  /"
  },
  {
    "id": "p-103a06",
    "offset": 1046,
    "text": "triguṇaṃ tu vanasthānāṃ yatīnāṃ tu caturguṇam  || Vi_60.26 ||"
  }
]