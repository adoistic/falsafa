[
  {
    "id": "p-854fa4",
    "offset": 0,
    "text": "Vi_10"
  },
  {
    "id": "p-492968",
    "offset": 7,
    "text": "atha dhaṭaḥ // Vi_10.1 //"
  },
  {
    "id": "p-5f22e3",
    "offset": 34,
    "text": "caturhastocchrito dvihastāyataḥ // Vi_10.2 //"
  },
  {
    "id": "p-ccf6b9",
    "offset": 81,
    "text": "tatra sāravṛkṣodbhavā pañcahastāyatobhayataḥśikyā tulā // Vi_10.3 //"
  },
  {
    "id": "p-90a00c",
    "offset": 151,
    "text": "tāṃ ca suvarṇakārakāṃsyakārāṇām anyatamo bibhṛyāt // Vi_10.4 //"
  },
  {
    "id": "p-e9be90",
    "offset": 216,
    "text": "tatra caikasmin śikye puruṣaṃ divyakāriṇam āropayet, dvitīye pratimānaṃ śilādi // Vi_10.5 //"
  },
  {
    "id": "p-aae979",
    "offset": 310,
    "text": "pratimānapuruṣau samadhṛtau sucihnitau kṛtvā puruṣam avatārayet // Vi_10.6 //"
  },
  {
    "id": "p-73b2a7",
    "offset": 389,
    "text": "dhaṭaṃ ca samayena gṛhṇīyāt // Vi_10.7 //"
  },
  {
    "id": "p-092b07",
    "offset": 432,
    "text": "tulādhāraṃ ca // Vi_10.8 //"
  },
  {
    "id": "p-00e51a",
    "offset": 461,
    "text": "brahmaghnāṃ ye smṛtā lokā ye lokāḥ kūṭasākṣiṇām  /"
  },
  {
    "id": "p-520c33",
    "offset": 513,
    "text": "tulādhārasya te lokās tulāṃ dhārayato mṛṣā  || Vi_10.9 ||"
  },
  {
    "id": "p-ad5760",
    "offset": 572,
    "text": "dharmaparyāyavacanair dhaṭa ity abhidhīyase  /"
  },
  {
    "id": "p-06d42f",
    "offset": 620,
    "text": "tvam eva dhaṭa jānīṣe na vidur yāni mānuṣāḥ  || Vi_10.10 ||"
  },
  {
    "id": "p-6d5e09",
    "offset": 681,
    "text": "vyavahārābhiśasto 'yaṃ mānuṣas tolyate tvayi  /"
  },
  {
    "id": "p-ce1683",
    "offset": 730,
    "text": "tad enaṃ saṃśayād asmād dharmatas trātum arhasi  || Vi_10.11 ||"
  },
  {
    "id": "p-583ffc",
    "offset": 795,
    "text": "tatas tv āropayec chikye bhūya evātha taṃ naram  /"
  },
  {
    "id": "p-869aca",
    "offset": 847,
    "text": "tulito yadi vardheta tataḥ śuddhaḥ sa dharmataḥ  || Vi_10.12 ||"
  },
  {
    "id": "p-a8e14b",
    "offset": 912,
    "text": "śikyacchedākṣabhaṅgeṣu bhūyas tv āropayen naram  /"
  },
  {
    "id": "p-706cd7",
    "offset": 964,
    "text": "evaṃ niḥsaṃśayaṃ jñānaṃ yato bhavati nirṇayaḥ  || Vi_10.13 ||"
  }
]