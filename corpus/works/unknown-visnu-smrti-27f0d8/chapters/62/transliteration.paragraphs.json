[
  {
    "id": "p-814d5f",
    "offset": 0,
    "text": "Vi_62"
  },
  {
    "id": "p-fd0f60",
    "offset": 7,
    "text": "atha dvijātīnāṃ kanīnikāmūle prājāpatyaṃ nāma tīrtham // Vi_62.1 //"
  },
  {
    "id": "p-39c30c",
    "offset": 76,
    "text": "aṅguṣṭhamūle brāhmam // Vi_62.2 //"
  },
  {
    "id": "p-128a4b",
    "offset": 112,
    "text": "aṅgulyagre daivam // Vi_62.3 //"
  },
  {
    "id": "p-c53a22",
    "offset": 145,
    "text": "tarjanīmūle pitryam // Vi_62.4 //"
  },
  {
    "id": "p-ffd0bc",
    "offset": 180,
    "text": "anagnyuṣṇābhir aphenilābhiḥ aśūdraikakarāvarjitābhir akṣārābhir adbhiḥ śucau deśe svāsīno 'ntarjānu prāṅmukhaś codaṅmukho vā tanmanāḥ sumanāś cācāmet // Vi_62.5 //"
  },
  {
    "id": "p-28b7f9",
    "offset": 345,
    "text": "brāhmeṇa tīrthena trir ācāmet // Vi_62.6 //"
  },
  {
    "id": "p-cf75ae",
    "offset": 390,
    "text": "dviḥ pramṛjyāt // Vi_62.7 //"
  },
  {
    "id": "p-ecf910",
    "offset": 420,
    "text": "khāny adbhir mūrdhānaṃ hṛdayaṃ spṛśet // Vi_62.8 //"
  },
  {
    "id": "p-2f9bba",
    "offset": 473,
    "text": "hṛtkaṇṭhatālugābhiś ca yathāsaṃkhyaṃ dvijātayaḥ  /"
  },
  {
    "id": "p-e176ca",
    "offset": 525,
    "text": "śudhyeran strī ca śūdraś ca sakṛt spṛṣṭābhir antataḥ  || Vi_62.9 ||"
  }
]