[
  {
    "id": "p-185747",
    "offset": 0,
    "text": "Vi_23"
  },
  {
    "id": "p-081dbd",
    "offset": 7,
    "text": "śārīrair malaiḥ surābhir madyair vā yad upahataṃ tad atyantopahatam // Vi_23.1 //"
  },
  {
    "id": "p-85eb1c",
    "offset": 90,
    "text": "atyantopahataṃ sarvaṃ lohabhāṇḍam agnau prakṣiptaṃ śudhyet // Vi_23.2 //"
  },
  {
    "id": "p-7b19f0",
    "offset": 164,
    "text": "maṇimayam aśmamayam abjaṃ ca saptarātraṃ mahīnikhananena // Vi_23.3 //"
  },
  {
    "id": "p-b3fe5a",
    "offset": 236,
    "text": "śṛṅgadantāsthimayaṃ takṣaṇena // Vi_23.4 //"
  },
  {
    "id": "p-c6ff9e",
    "offset": 281,
    "text": "dāravaṃ mṛnmayaṃ ca jahyāt // Vi_23.5 //"
  },
  {
    "id": "p-28c6ee",
    "offset": 323,
    "text": "atyantopahatasya vastrasya yat prakṣālitaṃ sad virajyate tac chindyāt // Vi_23.6 //"
  },
  {
    "id": "p-f73470",
    "offset": 408,
    "text": "sauvarṇarājatābjamaṇimayānāṃ nirlepānām adbhiḥ śuddhiḥ // Vi_23.7 //"
  },
  {
    "id": "p-ec9c8f",
    "offset": 478,
    "text": "aśmamayānāṃ camasānāṃ grahāṇāṃ ca // Vi_23.8 //"
  },
  {
    "id": "p-5d0731",
    "offset": 527,
    "text": "carusruksruvāṇām uṣṇenāmbhasā // Vi_23.9 //"
  },
  {
    "id": "p-ad6be2",
    "offset": 572,
    "text": "yajñakarmaṇi yajñapātrāṇāṃ pāṇinā saṃmārjanena // Vi_23.10 //"
  },
  {
    "id": "p-d2aec5",
    "offset": 635,
    "text": "sphyaśūrpaśakaṭamusalolūkhalānāṃ prokṣaṇena // Vi_23.11 //"
  },
  {
    "id": "p-f824fc",
    "offset": 695,
    "text": "śayanayānāsanānāṃ ca // Vi_23.12 //"
  },
  {
    "id": "p-fa9f62",
    "offset": 732,
    "text": "bahūnāṃ ca // Vi_23.13 //"
  },
  {
    "id": "p-3ad2bf",
    "offset": 759,
    "text": "dhānyājinarajjutāntavavaidalasūtrakārpāsavāsasāṃ ca // Vi_23.14 //"
  },
  {
    "id": "p-72adc5",
    "offset": 827,
    "text": "śākamūlaphalapuṣpāṇāṃ ca // Vi_23.15 //"
  },
  {
    "id": "p-432c01",
    "offset": 868,
    "text": "tṛṇakāṣṭhaśuṣkapalāśānāṃ ca // Vi_23.16 //"
  },
  {
    "id": "p-42a8b5",
    "offset": 912,
    "text": "eteṣāṃ prakṣālanena // Vi_23.17 //"
  },
  {
    "id": "p-2ed985",
    "offset": 948,
    "text": "alpānāṃ ca // Vi_23.18 //"
  },
  {
    "id": "p-192f7a",
    "offset": 975,
    "text": "ūṣaiḥ kauśeyāvikayoḥ // Vi_23.19 //"
  },
  {
    "id": "p-d1d396",
    "offset": 1012,
    "text": "ariṣṭakaiḥ kutapānām // Vi_23.20 //"
  },
  {
    "id": "p-6655e6",
    "offset": 1049,
    "text": "śrīphalair aṃśupaṭṭānām // Vi_23.21 //"
  },
  {
    "id": "p-9ef4e7",
    "offset": 1089,
    "text": "gaurasarṣapaiḥ kṣaumāṇām // Vi_23.22 //"
  },
  {
    "id": "p-1ccec7",
    "offset": 1130,
    "text": "śṛṅgāsthidantamayānāṃ ca // Vi_23.23 //"
  },
  {
    "id": "p-50c5d1",
    "offset": 1171,
    "text": "padmākṣair mṛgalomikānām // Vi_23.24 //"
  },
  {
    "id": "p-7c6d4a",
    "offset": 1212,
    "text": "tāmrarītitrapusīsamayānām amlodakena // Vi_23.25 //"
  },
  {
    "id": "p-ef67da",
    "offset": 1265,
    "text": "bhasmanā kāṃsyalohayoḥ // Vi_23.26 //"
  },
  {
    "id": "p-86573e",
    "offset": 1304,
    "text": "takṣaṇena dāravāṇām // Vi_23.27 //"
  },
  {
    "id": "p-39ef3c",
    "offset": 1340,
    "text": "govālaiḥ phalasaṃbhavānām // Vi_23.28 //"
  },
  {
    "id": "p-03fca3",
    "offset": 1382,
    "text": "prokṣaṇena saṃhatānām // Vi_23.29 //"
  },
  {
    "id": "p-c881e9",
    "offset": 1420,
    "text": "utpavanena dravāṇām // Vi_23.30 //"
  },
  {
    "id": "p-b9c2e2",
    "offset": 1456,
    "text": "guḍādīnām ikṣuvikārāṇāṃ prabhūtānāṃ gṛhanihitānāṃ vāryagnidānena // Vi_23.31 //"
  },
  {
    "id": "p-9df565",
    "offset": 1537,
    "text": "sarvalavaṇānāṃ ca // Vi_23.32 //"
  },
  {
    "id": "p-4e3f70",
    "offset": 1571,
    "text": "punaḥ pākena mṛnmayānām // Vi_23.33 //"
  },
  {
    "id": "p-0832ce",
    "offset": 1611,
    "text": "dravyavat kṛtaśaucānāṃ devatārcānāṃ bhūyaḥ pratiṣṭhāpanena // Vi_23.34 //"
  },
  {
    "id": "p-73a91f",
    "offset": 1686,
    "text": "asiddhasyānnasya yanmātram upahataṃ tanmātraṃ parityajya śeṣasya kaṇḍanaprakṣālane kuryāt // Vi_23.35 //"
  },
  {
    "id": "p-6f0b48",
    "offset": 1792,
    "text": "droṇābhyadhikam siddham annam upahataṃ na duṣyati // Vi_23.36 //"
  },
  {
    "id": "p-885c11",
    "offset": 1858,
    "text": "tasyopahatamātram apāsya gāyatryābhimantritaṃ suvarṇāmbhaḥ prakṣipet bastasya ca pradarśayed agneś ca // Vi_23.37 //"
  },
  {
    "id": "p-d82eb9",
    "offset": 1976,
    "text": "pakṣijagdhaṃ gavā ghrātam avadhūtam avakṣutam  /"
  },
  {
    "id": "p-59ff14",
    "offset": 2026,
    "text": "dūṣitaṃ keśakīṭaiś ca mṛtprakṣepeṇa śudhyati  || Vi_23.38 ||"
  },
  {
    "id": "p-4798a4",
    "offset": 2088,
    "text": "yāvan nāpaity amedhyāktād gandho lepaś ca tatkṛtaḥ  /"
  },
  {
    "id": "p-2a04af",
    "offset": 2143,
    "text": "tāvan mṛdvāri deyaṃ syāt sarvāsu dravyaśuddhiṣu  || Vi_23.39 ||"
  },
  {
    "id": "p-10c30c",
    "offset": 2208,
    "text": "ajāśvaṃ mukhato medhyaṃ na gaur na narajā malāḥ  /"
  },
  {
    "id": "p-7425be",
    "offset": 2260,
    "text": "panthānaś ca viśudhyanti somasūryāṃśumārutaiḥ  || Vi_23.40 ||"
  },
  {
    "id": "p-d8ff7e",
    "offset": 2323,
    "text": "rathyākardamatoyāni spṛṣṭāny antyaśvavāyasaiḥ  /"
  },
  {
    "id": "p-c545ab",
    "offset": 2373,
    "text": "mārutenaiva śudhyanti pakveṣṭakacitāni ca  || Vi_23.41 ||"
  },
  {
    "id": "p-0aa0e0",
    "offset": 2432,
    "text": "prāṇinām atha sarveṣāṃ mṛdbhir adbhiś ca kārayet  /"
  },
  {
    "id": "p-74540c",
    "offset": 2485,
    "text": "atyantopahatānāṃ ca śaucaṃ nityam atandritam  || Vi_23.42 ||"
  },
  {
    "id": "p-543bfc",
    "offset": 2547,
    "text": "bhūmiṣṭham udakaṃ puṇyaṃ vaitṛṣṇyaṃ yatra gor bhavet  /"
  },
  {
    "id": "p-7f313c",
    "offset": 2604,
    "text": "avyāptaṃ ced amedhyena tadvad eva śilāgatam  || Vi_23.43 ||"
  },
  {
    "id": "p-0c20fd",
    "offset": 2665,
    "text": "mṛtapañcanakhāt kūpād atyantopahatāt tathā  /"
  },
  {
    "id": "p-cbcf98",
    "offset": 2712,
    "text": "apaḥ samuddharet sarvāḥ śeṣaṃ vastreṇa śodhayet  || Vi_23.44 ||"
  },
  {
    "id": "p-a8a5fe",
    "offset": 2777,
    "text": "vahniprajvālanaṃ kuryāt kūpe pakveṣṭakācite  /"
  },
  {
    "id": "p-fcc37f",
    "offset": 2825,
    "text": "pañcagavyaṃ nyaset paścān navatoyasamudbhave  || Vi_23.45 ||"
  },
  {
    "id": "p-da6d5b",
    "offset": 2887,
    "text": "jalāśayeṣv athālpeṣu sthāvareṣu vasuṃdhare  /"
  },
  {
    "id": "p-c2b809",
    "offset": 2934,
    "text": "kūpavat kathitā śuddhir mahatsu ca na dūṣaṇam  || Vi_23.46 ||"
  },
  {
    "id": "p-847313",
    "offset": 2997,
    "text": "trīṇi devāḥ pavitrāṇi brāhmaṇānām akalpayan  /"
  },
  {
    "id": "p-b34149",
    "offset": 3045,
    "text": "adṛṣṭam adbhir nirṇiktaṃ yac ca vācā praśasyate  || Vi_23.47 ||"
  },
  {
    "id": "p-034956",
    "offset": 3110,
    "text": "nityaṃ śuddhaḥ kāruhastaḥ paṇyaṃ yac ca prasāritam  /"
  },
  {
    "id": "p-140b49",
    "offset": 3165,
    "text": "brāhamaṇāntaritaṃ bhaikṣyam ākarāḥ sarva eva ca  || Vi_23.48 ||"
  },
  {
    "id": "p-acadb8",
    "offset": 3230,
    "text": "nityam āsyaṃ śuci strīṇāṃ śakuniḥ phalapātane  /"
  },
  {
    "id": "p-104d18",
    "offset": 3280,
    "text": "prasrave ca śucir vatsaḥ śvā mṛgagrahaṇe śuciḥ  || Vi_23.49 ||"
  },
  {
    "id": "p-9cf43d",
    "offset": 3344,
    "text": "śvabhir hatasya yan māṃsaṃ śuci tat parikīrtitam  /"
  },
  {
    "id": "p-4ed1ef",
    "offset": 3397,
    "text": "kravyādbhiś ca hatasyānyaiś caṇḍālādyaiś ca dasyubhiḥ  || Vi_23.50 ||"
  },
  {
    "id": "p-37b95c",
    "offset": 3468,
    "text": "ūrdhvaṃ nābher yāni khāni tāni medhyāni nirdiśet  /"
  },
  {
    "id": "p-c21dd8",
    "offset": 3521,
    "text": "yāny adhastāny amedhyāni dehāc caiva malāś cyutāḥ  || Vi_23.51 ||"
  },
  {
    "id": "p-a1d5ef",
    "offset": 3588,
    "text": "makṣikā vipruṣaś chāyā gaur gajāśvamarīcayaḥ  /"
  },
  {
    "id": "p-471764",
    "offset": 3637,
    "text": "rajo bhūr vāyur agniś ca mārjāraś ca sadā śuciḥ  || Vi_23.52 ||"
  },
  {
    "id": "p-f75de0",
    "offset": 3702,
    "text": "nocchiṣṭaṃ kurvate mukhyā vipruṣo 'ṅge na yānti yāḥ  /"
  },
  {
    "id": "p-5f4645",
    "offset": 3758,
    "text": "na śmaśrūṇi gatāny āsyaṃ na dantāntaraveṣṭitam  || Vi_23.53 ||"
  },
  {
    "id": "p-be86b2",
    "offset": 3822,
    "text": "spṛśanti bindavaḥ pādau ya ācāmayataḥ parān  /"
  },
  {
    "id": "p-470014",
    "offset": 3870,
    "text": "bhaumikais te samā jñeyā na tair aprayato bhavet  || Vi_23.54 ||"
  },
  {
    "id": "p-1c9163",
    "offset": 3936,
    "text": "ucchiṣṭena tu saṃspṛṣṭo dravyahastaḥ kathaṃcana  /"
  },
  {
    "id": "p-91f9cb",
    "offset": 3988,
    "text": "anidhāyaiva tad dravyam ācāntaḥ śucitām iyāt  || Vi_23.55 ||"
  },
  {
    "id": "p-d59cc3",
    "offset": 4050,
    "text": "mārjanopāñjanair veśma prokṣaṇenaiva pustakam  /"
  },
  {
    "id": "p-ba3063",
    "offset": 4100,
    "text": "saṃmārjanenāñjanena sekenollekhanena ca  || Vi_23.56 ||"
  },
  {
    "id": "p-4121e4",
    "offset": 4157,
    "text": "dāhena ca bhuvaḥ śuddhir vāsenāpy atha vā gavām  /"
  },
  {
    "id": "p-79cd0c",
    "offset": 4209,
    "text": "gāvaḥ pavitramaṅgalyaṃ goṣu lokāḥ pratiṣṭhitāḥ  || Vi_23.57 ||"
  },
  {
    "id": "p-ba3a0a",
    "offset": 4273,
    "text": "gāvo vitanvate yjñaṃ gāvaḥ sarvāghasūdanāḥ  /"
  },
  {
    "id": "p-a39f2b",
    "offset": 4320,
    "text": "gomūtraṃ gomayaṃ sarpiḥ kṣīraṃ dadhi ca rocanā  || Vi_23.58 ||"
  },
  {
    "id": "p-59dbd9",
    "offset": 4384,
    "text": "ṣaḍaṅgam etat paramaṃ maṅgalyaṃ paramaṃ gavām  /"
  },
  {
    "id": "p-22db93",
    "offset": 4434,
    "text": "śṛṅgodakaṃ gavāṃ puṇyaṃ sarvāghaviniṣūdanam  || Vi_23.59 ||"
  },
  {
    "id": "p-e4ec17",
    "offset": 4495,
    "text": "gavām kaṇḍūyanaṃ caiva sarvakalmaṣanāśanam  /"
  },
  {
    "id": "p-b73949",
    "offset": 4542,
    "text": "gavāṃ grāsapradānena svargaloke mahīyate  || Vi_23.60 ||"
  },
  {
    "id": "p-f434b2",
    "offset": 4600,
    "text": "gavāṃ hi tīrthe vasatīha gaṅgā puṣṭis tathāsāṃ rajasi pravṛddhā  /"
  },
  {
    "id": "p-ea1a30",
    "offset": 4668,
    "text": "lakṣmīḥ karīṣe praṇatau ca dharmas tāsāṃ praṇāmaṃ satataṃ ca kuryāt  || Vi_23.61 ||"
  }
]