    "text": "Vi_33"
  },
  {
    "id": "p-20f3c1",
    "offset": 24,
    "text": "atha puruṣasya kāmakrodhalobhākhyaṃ riputrayaṃ sughoraṃ bhavati // Vi_33.1 //"
  },
  {
    "id": "p-48f425",
    "offset": 103,
    "text": "parigrahaprasaṅgād viśeṣeṇa gṛhāśramiṇaḥ // Vi_33.2 //"
  },
  {
    "id": "p-fe73ec",
    "offset": 159,
    "text": "tenāyam ākrānto 'tipātakamahāpātakānupātakopapātakeṣu pravartate // Vi_33.3 //"
  },
  {
    "id": "p-a8ae36",
    "offset": 239,
    "text": "jātibhraṃśakareṣu saṃkarīkaraṇeṣV apātrīkaraṇeṣu // Vi_33.4 //"
  },
  {
    "id": "p-2b50b2",
    "offset": 303,
    "text": "malāvaheṣu prakīrṇakeṣu ca // Vi_33.5 //"
  },
  {
    "id": "p-d2fec1",
    "offset": 345,
    "text": "trividhaṃ narakasyedaṃ dvāraṃ nāśanam ātmanaḥ  /"
  },
  {
    "id": "p-e36aea",
    "offset": 395,
    "text": "kāmaḥ krodhas tathā lobhas tasmād etat trayaṃ jyayet  || Vi_33.6 ||"
  }
]