[
  {
    "id": "p-854d65",
    "offset": 0,
    "text": "Vi_66"
  },
  {
    "id": "p-4ce758",
    "offset": 7,
    "text": "na naktaṃ gṛhītenodakena devapitṛkarma kuryāt // Vi_66.1 //"
  },
  {
    "id": "p-f05c9e",
    "offset": 68,
    "text": "cadanamṛgamadadārukarpūrakuṅkumajātīphalavarjam anulepanaṃ na dadyāt // Vi_66.2 //"
  },
  {
    "id": "p-506dae",
    "offset": 152,
    "text": "na vāso nīlīraktam // Vi_66.3 //"
  },
  {
    "id": "p-123d65",
    "offset": 186,
    "text": "na maṇisuvarṇayoḥ pratirūpam alaṃkaraṇam // Vi_66.4 //"
  },
  {
    "id": "p-797906",
    "offset": 242,
    "text": "nograghandhi // Vi_66.5 //"
  },
  {
    "id": "p-ade6e6",
    "offset": 270,
    "text": "nāgandhi // Vi_66.6 //"
  },
  {
    "id": "p-30fb6d",
    "offset": 294,
    "text": "na kaṇṭakijam // Vi_66.7 //"
  },
  {
    "id": "p-b0d749",
    "offset": 323,
    "text": "kaṇṭakijam api śuklaṃ sugandhikaṃ tu dadyāt // Vi_66.8 //"
  },
  {
    "id": "p-385348",
    "offset": 382,
    "text": "raktam api kuṅkumaṃ jalajaṃ ca dadyāt // Vi_66.9 //"
  },
  {
    "id": "p-c49a10",
    "offset": 435,
    "text": "na dhūpārthe jīvajātam // Vi_66.10 //"
  },
  {
    "id": "p-3f8244",
    "offset": 474,
    "text": "na ghṛtatailaṃ vinā kiṃcana dīpārthe // Vi_66.11 //"
  },
  {
    "id": "p-7f99f4",
    "offset": 527,
    "text": "nābhakṣyaṃ naivedyārthe // Vi_66.12 //"
  },
  {
    "id": "p-0f59d2",
    "offset": 567,
    "text": "na bhakṣye apy ajāmahiṣīkṣīre // Vi_66.13 //"
  },
  {
    "id": "p-f4232c",
    "offset": 613,
    "text": "pañcanakhamatsyavarāhamāṃsāni ca // Vi_66.14 //"
  },
  {
    "id": "p-1d89d0",
    "offset": 662,
    "text": "prayataś ca śucir bhūtvā sarvam eva nivedayet  /"
  },
  {
    "id": "p-9ddc43",
    "offset": 712,
    "text": "tanmanāḥ sumanā bhūtvā tvarākrodhavivarjitaḥ  || Vi_66.16 ||"
  }
]