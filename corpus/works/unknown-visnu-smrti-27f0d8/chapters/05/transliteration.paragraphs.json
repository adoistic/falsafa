[
  {
    "id": "p-1c3dca",
    "offset": 0,
    "text": "Vi_5"
  },
  {
    "id": "p-2d264b",
    "offset": 6,
    "text": "atha mahāpātakino brāhmaṇavarjaṃ sarve vadhyāḥ // Vi_5.1 //"
  },
  {
    "id": "p-1e5728",
    "offset": 67,
    "text": "na śārīro brāhmaṇasya daṇḍaḥ // Vi_5.2 //"
  },
  {
    "id": "p-10144c",
    "offset": 110,
    "text": "svadeśāt brāhmaṇaṃ kṛtāṅkaṃ vivāsayet // Vi_5.3 //"
  },
  {
    "id": "p-ed7547",
    "offset": 162,
    "text": "tasya ca brahmahatyāyām aśiraskaṃ puruṣaṃ lalāṭe kuryāt // Vi_5.4 //"
  },
  {
    "id": "p-9f6922",
    "offset": 232,
    "text": "surādhvajaṃ surāpāne // Vi_5.5 //"
  },
  {
    "id": "p-8134e9",
    "offset": 267,
    "text": "śvapadaṃ steye // Vi_5.6 //"
  },
  {
    "id": "p-1a39f4",
    "offset": 296,
    "text": "bhagaṃ gurutalpagamane // Vi_5.7 //"
  },
  {
    "id": "p-ea0caf",
    "offset": 333,
    "text": "anyatrāpi vadhyakarmaṇi tiṣṭhantaṃ samagradhanam akṣataṃ vivāsayet // Vi_5.8 //"
  },
  {
    "id": "p-cbe2e6",
    "offset": 414,
    "text": "kūṭaśāsanakartṝṃś ca rājā hanyāt // Vi_5.9 //"
  },
  {
    "id": "p-7855ec",
    "offset": 461,
    "text": "kūṭalekhyakārāṃś ca // Vi_5.10 //"
  },
  {
    "id": "p-03ae68",
    "offset": 496,
    "text": "garadāgnidaprasahyataskarān strībālapuruṣaghātinaś ca // Vi_5.11 //"
  },
  {
    "id": "p-a5a088",
    "offset": 565,
    "text": "ye ca dhānyaṃ daśabhyaḥ kumbhebhyo 'dhikam apahareyuḥ // Vi_5.12 //"
  },
  {
    "id": "p-f61e95",
    "offset": 634,
    "text": "dharimameyānāṃ śatād abhyadhikam // Vi_5.13 //"
  },
  {
    "id": "p-4685b7",
    "offset": 682,
    "text": "ye cākulīnā rājyam abhikāmayeyuḥ // Vi_5.14 //"
  },
  {
    "id": "p-e44fb6",
    "offset": 730,
    "text": "setubhedakāṃś ca // Vi_5.15 //"
  },
  {
    "id": "p-a1e2c9",
    "offset": 762,
    "text": "prasahya taskarāṇāṃ cāvakāśabhaktapradāṃś ca // Vi_5.16 //"
  },
  {
    "id": "p-fecc34",
    "offset": 822,
    "text": "anyatra rājāśakteḥ // Vi_5.17 //"
  },
  {
    "id": "p-563185",
    "offset": 856,
    "text": "striyam aśaktabhartṛkāṃ tadatikramaṇīṃ ca // Vi_5.18 //"
  },
  {
    "id": "p-1c0a7d",
    "offset": 913,
    "text": "hīnavarṇo 'dhikavarṇasya yenāṅgenāparādhaṃ kuryāt tad evāsya śātayet // Vi_5.19 //"
  },
  {
    "id": "p-5b7d14",
    "offset": 997,
    "text": "ekāsanopaveśī kaṭyāṃ kṛtāṅko nirvāsyaḥ // Vi_5.20 //"
  },
  {
    "id": "p-fd7bbe",
    "offset": 1051,
    "text": "niṣṭhīvyauṣṭhadvayavihīnaḥ kāryaḥ // Vi_5.21 //"
  },
  {
    "id": "p-f4627b",
    "offset": 1100,
    "text": "avaśardhayitā ca gudahīnaḥ // Vi_5.22 //"
  },
  {
    "id": "p-5a7e4c",
    "offset": 1142,
    "text": "ākrośayitā ca vijihvaḥ // Vi_5.23 //"
  },
  {
    "id": "p-dad56e",
    "offset": 1180,
    "text": "darpeṇa dharmopadeśakāriṇāṃ rājā taptam āsecayet tailam āsye // Vi_5.24 //"
  },
  {
    "id": "p-58394c",
    "offset": 1256,
    "text": "droheṇa ca nāmajātigrahaṇe daśāṅgulo 'sya śaṅkur nikheyaḥ // Vi_5.25 //"
  },
  {
    "id": "p-52021c",
    "offset": 1329,
    "text": "śrutadeśajātikarmaṇām anyathāvādī kārśāpaṇaśatadvayaṃ daṇḍyaḥ // Vi_5.26 //"
  },
  {
    "id": "p-a84da5",
    "offset": 1406,
    "text": "kāṇakhañjādīnāṃ tathyavādy api kārśāpaṇadvayam // Vi_5.27 //"
  },
  {
    "id": "p-21b7bc",
    "offset": 1468,
    "text": "gurūn ākṣipan kārśāpaṇaśatadvayam // Vi_5.28 //"
  },
  {
    "id": "p-a095a0",
    "offset": 1517,
    "text": "parasya patanīyākṣepe kṛte tūttamasāhasam // Vi_5.29 //"
  },
  {
    "id": "p-2d28de",
    "offset": 1574,
    "text": "upapātakayukte madhyamam // Vi_5.30 //"
  },
  {
    "id": "p-f9c35b",
    "offset": 1614,
    "text": "traividyavṛddhānāṃ kṣepe jātipūgānāṃ ca // Vi_5.31 //"
  },
  {
    "id": "p-20c076",
    "offset": 1669,
    "text": "grāmadeśayoś ca prathamasāhasam // Vi_5.32 //"
  },
  {
    "id": "p-bbe961",
    "offset": 1716,
    "text": "nyaṅgatāyukte kṣepe kārśāpaṇaśatam // Vi_5.33 //"
  },
  {
    "id": "p-ed3ffd",
    "offset": 1766,
    "text": "mātṛyukte tūttamam // Vi_5.34 //"
  },
  {
    "id": "p-c5320a",
    "offset": 1800,
    "text": "samavarṇākrośane dvādaśa paṇān daṇḍyaḥ // Vi_5.35 //"
  },
  {
    "id": "p-13f1a6",
    "offset": 1854,
    "text": "hīnavarṇākṛośane ṣaṭ // Vi_5.36 //"
  },
  {
    "id": "p-5e2dfd",
    "offset": 1890,
    "text": "yathākālam uttamavarṇākṣepe tatpramāṇo daṇḍaḥ // Vi_5.37 //"
  },
  {
    "id": "p-4455b5",
    "offset": 1951,
    "text": "trayo vā kārṣāpaṇāḥ // Vi_5.38 //"
  },
  {
    "id": "p-ffa7c0",
    "offset": 1986,
    "text": "śuktavākyābhidhāne tv evam eva // Vi_5.39 //"
  },
  {
    "id": "p-57427f",
    "offset": 2032,
    "text": "pārajāyī savarṇāgamane  tūttamasāhasaṃ daṇḍyaḥ // Vi_5.40 //"
  },
  {
    "id": "p-14490e",
    "offset": 2094,
    "text": "hīnavarṇāgamane madhyamam // Vi_5.41 //"
  },
  {
    "id": "p-ab553e",
    "offset": 2135,
    "text": "gogamane ca // Vi_5.42 //"
  },
  {
    "id": "p-6a283f",
    "offset": 2162,
    "text": "antyāgamane vadhyaḥ // Vi_5.43 //"
  },
  {
    "id": "p-565b16",
    "offset": 2197,
    "text": "paśugamane kārṣāpaṇaśataṃ daṇḍyaḥ // Vi_5.44 //"
  },
  {
    "id": "p-1c698e",
    "offset": 2246,
    "text": "doṣam anākhyāya kanyāṃ prayacchaṃś ca // Vi_5.45 //"
  },
  {
    "id": "p-3eaddf",
    "offset": 2299,
    "text": "tāṃ ca bibhṛyāt // Vi_5.46 //"
  },
  {
    "id": "p-41f415",
    "offset": 2330,
    "text": "aduṣṭāṃ duṣṭām iti bruvann uttamasāhasam // Vi_5.47 //"
  },
  {
    "id": "p-464db9",
    "offset": 2386,
    "text": "gajāśvoṣṭragoghātī tv ekakarapādaḥ kāryaḥ // Vi_5.48 //"
  },
  {
    "id": "p-2c72c2",
    "offset": 2443,
    "text": "vimāṃsavikrayī ca // Vi_5.49 //"
  },
  {
    "id": "p-23c47e",
    "offset": 2476,
    "text": "grāmyapaśughātī kārṣāpaṇaśataṃ daṇḍyaḥ // Vi_5.50 //"
  },
  {
    "id": "p-3dec9a",
    "offset": 2530,
    "text": "paśusvāmine tanmūlyaṃ dadyāt // Vi_5.51 //"
  },
  {
    "id": "p-43082a",
    "offset": 2574,
    "text": "āraṇyapaśughātī pañcāśataṃ kārṣāpaṇān // Vi_5.52 //"
  },
  {
    "id": "p-81a8a3",
    "offset": 2627,
    "text": "pakṣighātī matsyaghātī ca daśa kārṣāpaṇān // Vi_5.53 //"
  },
  {
    "id": "p-534444",
    "offset": 2684,
    "text": "kīṭopaghātī ca kārṣāpaṇam // Vi_5.54 //"
  },
  {
    "id": "p-61c9f9",
    "offset": 2725,
    "text": "phalopagamadrumacchedī tūttamasāhasam // Vi_5.55 //"
  },
  {
    "id": "p-4d1855",
    "offset": 2778,
    "text": "puṣpopagamadrumacchedī madhyamam // Vi_5.56 //"
  },
  {
    "id": "p-05407c",
    "offset": 2826,
    "text": "vallīgulmalatācchedī kārṣāpaṇaśatam // Vi_5.57 //"
  },
  {
    "id": "p-c631a6",
    "offset": 2877,
    "text": "tṛṇacchedy ekam // Vi_5.58 //"
  },
  {
    "id": "p-0b2590",
    "offset": 2908,
    "text": "sarve ca tatsvāmināṃ tadutpattim // Vi_5.59 //"
  },
  {
    "id": "p-bf5a8f",
    "offset": 2956,
    "text": "hastenodgūrayitā daśakārṣāpaṇam // Vi_5.60 //"
  },
  {
    "id": "p-297093",
    "offset": 3003,
    "text": "pādena viṃśatim // Vi_5.61 //"
  },
  {
    "id": "p-ca8976",
    "offset": 3034,
    "text": "kāṣṭhena prathamasāhasam // Vi_5.62 //"
  },
  {
    "id": "p-b37555",
    "offset": 3074,
    "text": "pāṣāṇena madhyamam // Vi_5.63 //"
  },
  {
    "id": "p-d24dc8",
    "offset": 3108,
    "text": "śastreṇottamam // Vi_5.64 //"
  },
  {
    "id": "p-612316",
    "offset": 3138,
    "text": "pādakeśāṃśukakaraluñcane daśa paṇān // Vi_5.65 //"
  },
  {
    "id": "p-d10736",
    "offset": 3189,
    "text": "śoṇitena vinā duḥkham utpādayitā dvātriṃśat paṇān // Vi_5.66 //"
  },
  {
    "id": "p-5ff642",
    "offset": 3254,
    "text": "saha śoṇitena catuḥṣaṣṭim // Vi_5.67 //"
  },
  {
    "id": "p-21caeb",
    "offset": 3295,
    "text": "karapādadantabhaṅge karṇanāsāvikartane madhyamam // Vi_5.68 //"
  },
  {
    "id": "p-1de2f6",
    "offset": 3359,
    "text": "ceṣṭābhojanavāgrodhe prahāradāne ca // Vi_5.69 //"
  },
  {
    "id": "p-96b97c",
    "offset": 3410,
    "text": "netrakaṃdharābāhusakthyaṃsabhaṅge cottamam // Vi_5.70 //"
  },
  {
    "id": "p-cfcb72",
    "offset": 3468,
    "text": "ubhayanetrabhedinaṃ rājā yāvaj jīvaṃ bandhanān na muñcet // Vi_5.71 //"
  },
  {
    "id": "p-05f419",
    "offset": 3540,
    "text": "tādṛśam eva vā kuryāt // Vi_5.72 //"
  },
  {
    "id": "p-837507",
    "offset": 3577,
    "text": "ekaṃ bahūnāṃ nighnatāṃ pratyekam uktād daṇḍād dviguṇaḥ // Vi_5.73 //"
  },
  {
    "id": "p-485c0c",
    "offset": 3647,
    "text": "utkrośantam anabhidhāvatāṃ tatsamīpavartināṃ saṃsaratāṃ ca // Vi_5.74 //"
  },
  {
    "id": "p-edfcbd",
    "offset": 3721,
    "text": "sarve ca puruṣapīḍākarās tadutthānavyayaṃ dadyuḥ // Vi_5.75 //"
  },
  {
    "id": "p-5dbec4",
    "offset": 3785,
    "text": "grāmyapaśupīḍākarāś ca // Vi_5.76 //"
  },
  {
    "id": "p-80cd29",
    "offset": 3823,
    "text": "go'śvoṣṭragajāpahāry ekakarapādaḥ kāryaḥ // Vi_5.77 //"
  },
  {
    "id": "p-e884a7",
    "offset": 3879,
    "text": "ajāvyapahāry ekakaraś ca // Vi_5.78 //"
  },
  {
    "id": "p-70e367",
    "offset": 3919,
    "text": "dhānyāpahāry ekādaśaguṇaṃ daṇḍyaḥ // Vi_5.79 //"
  },
  {
    "id": "p-3483c6",
    "offset": 3968,
    "text": "sasyāpahārī ca // Vi_5.80 //"
  },
  {
    "id": "p-1f8c9d",
    "offset": 3998,
    "text": "suvarṇarajatavastrāṇāṃ pañcāśatas tv abhyadhikam apaharan vikaraḥ // Vi_5.81 //"
  },
  {
    "id": "p-e213f8",
    "offset": 4079,
    "text": "tadūnam ekādaśaguṇaṃ daṇḍyaḥ // Vi_5.82 //"
  },
  {
    "id": "p-187b19",
    "offset": 4123,
    "text": "sūtrakārpāsagomayaguḍadadhikṣīratakratṛṇalavaṇamṛdbhasmapakṣimatsyaghṛtatailamāṃsamadhuvaidalaveṇumṛnmayalohabhāṇḍānām apahartā mūlyāt triguṇaṃ daṇḍyaḥ // Vi_5.83 //"
  },
  {
    "id": "p-222d89",
    "offset": 4290,
    "text": "pakvānnānāṃ ca // Vi_5.84 //"
  },
  {
    "id": "p-795c16",
    "offset": 4320,
    "text": "puṣpaharitagulmavallīlatāparṇānām apaharaṇe pañcakṛṣṇalam // Vi_5.85 //"
  },
  {
    "id": "p-bc1596",
    "offset": 4393,
    "text": "śākamūlaphalānāṃ ca // Vi_5.86 //"
  },
  {
    "id": "p-73e65d",
    "offset": 4428,
    "text": "ratnāpahāry uttamasāhasam // Vi_5.87 //"
  },
  {
    "id": "p-68a24a",
    "offset": 4469,
    "text": "anuktadravyāṇām apahartā mūlyasamam // Vi_5.88 //"
  },
  {
    "id": "p-ec8514",
    "offset": 4520,
    "text": "stenāḥ sarvam apahṛtaṃ dhanikasya dāpyāḥ // Vi_5.89 //"
  },
  {
    "id": "p-42ef5b",
    "offset": 4576,
    "text": "tatas teṣām abhihitadaṇḍaprayogaḥ // Vi_5.90 //"
  },
  {
    "id": "p-350602",
    "offset": 4625,
    "text": "yeṣāṃ deyaḥ panthās teṣām apathadāyī kārṣāpaṇapañcaviṃśatiṃ daṇḍyaḥ // Vi_5.91 //"
  },
  {
    "id": "p-260153",
    "offset": 4708,
    "text": "āsanārhasyāsanam adadac ca // Vi_5.92 //"
  },
  {
    "id": "p-e236e3",
    "offset": 4750,
    "text": "pūjārham apūjayaṃś ca // Vi_5.93 //"
  },
  {
    "id": "p-a5fdf8",
    "offset": 4787,
    "text": "prātiveśyabrāhmaṇanimantraṇātikramaṇe ca // Vi_5.94 //"
  },
  {
    "id": "p-35d235",
    "offset": 4843,
    "text": "nimantrayitvā bhojanādāyinaś ca // Vi_5.95 //"
  },
  {
    "id": "p-ed52f3",
    "offset": 4890,
    "text": "nimantritas tathety uktvā cābhuñjānaḥ suvarṇamāṣakam // Vi_5.96 //"
  },
  {
    "id": "p-5687bb",
    "offset": 4958,
    "text": "niketayituś ca dviguṇam annam // Vi_5.97 //"
  },
  {
    "id": "p-2684c3",
    "offset": 5003,
    "text": "abhakṣyeṇa brāhmaṇasya dūṣayitā ṣoḍaśa suvarṇān // Vi_5.98 //"
  },
  {
    "id": "p-6394b5",
    "offset": 5066,
    "text": "jātyapahāriṇā śatam // Vi_5.99 //"
  },
  {
    "id": "p-295998",
    "offset": 5101,
    "text": "surayā vadhyaḥ // Vi_5.100 //"
  },
  {
    "id": "p-a11144",
    "offset": 5132,
    "text": "kṣatriyaṃ dūṣayitus tadardham // Vi_5.101 //"
  },
  {
    "id": "p-6f685a",
    "offset": 5178,
    "text": "vaiśyaṃ dūṣayitus tadardham api // Vi_5.102 //"
  },
  {
    "id": "p-0fc0fb",
    "offset": 5226,
    "text": "śūdraṃ dūṣayituḥ prathamasāhasam // Vi_5.103 //"
  },
  {
    "id": "p-4891a0",
    "offset": 5275,
    "text": "aspṛśyaḥ kāmakāreṇa spṛśan spṛśyaṃ traivarṇikaṃ vadhyaḥ // Vi_5.104 //"
  },
  {
    "id": "p-5314f2",
    "offset": 5347,
    "text": "rajasvalāṃ śiphābhis tāḍayet // Vi_5.105 //"
  },
  {
    "id": "p-1429b2",
    "offset": 5392,
    "text": "pathyudyānodakasamīpe 'py aśucikārī paṇaśatam // Vi_5.106 //"
  },
  {
    "id": "p-e1ce74",
    "offset": 5454,
    "text": "tac cāpāsyāt // Vi_5.107 //"
  },
  {
    "id": "p-22300c",
    "offset": 5483,
    "text": "gṛhabhūkuḍyādyupabhettā madhyamasāhasam // Vi_5.108 //"
  },
  {
    "id": "p-e6599a",
    "offset": 5539,
    "text": "tac ca yojayet // Vi_5.109 //"
  },
  {
    "id": "p-c6b453",
    "offset": 5570,
    "text": "gṛhe pīḍākaraṃ dravyaṃ prakṣipan paṇaśatam // Vi_5.110 //"
  },
  {
    "id": "p-6129bb",
    "offset": 5629,
    "text": "sādhāraṇāpalāpī ca // Vi_5.111 //"
  },
  {
    "id": "p-d75138",
    "offset": 5664,
    "text": "preṣitasyāpradātā ca // Vi_5.112 //"
  },
  {
    "id": "p-ed3a31",
    "offset": 5701,
    "text": "pitṛputrācāryayājyartvijām anyonyāpatitatyāgī ca // Vi_5.113 //"
  },
  {
    "id": "p-a24805",
    "offset": 5766,
    "text": "na ca tān jahyāt // Vi_5.114 //"
  },
  {
    "id": "p-201722",
    "offset": 5799,
    "text": "śūdrapravrajitānāṃ daive pitrye bhojakāś ca // Vi_5.115 //"
  },
  {
    "id": "p-360ab9",
    "offset": 5859,
    "text": "ayogyakarmakārī ca // Vi_5.116 //"
  },
  {
    "id": "p-fb8e62",
    "offset": 5894,
    "text": "samudragṛhabhedakaś ca // Vi_5.117 //"
  },
  {
    "id": "p-7d8891",
    "offset": 5933,
    "text": "aniyuktaḥ śapathakārī // Vi_5.118 //"
  },
  {
    "id": "p-2e1931",
    "offset": 5971,
    "text": "paśūnāṃ puṃstvopaghātakārī // Vi_5.119 //"
  },
  {
    "id": "p-4b5c62",
    "offset": 6014,
    "text": "pitāputravirodhe sākṣiṇāṃ daśapaṇo daṇḍaḥ // Vi_5.120 //"
  },
  {
    "id": "p-9e32f1",
    "offset": 6072,
    "text": "yas tayoś cāntare syāt tasyottamasāhasaḥ // Vi_5.121 //"
  },
  {
    "id": "p-c8b8db",
    "offset": 6129,
    "text": "tulāmānakūṭakartuś ca // Vi_5.122 //"
  },
  {
    "id": "p-441d23",
    "offset": 6167,
    "text": "tadakūṭe kūṭavādinaś ca // Vi_5.123 //"
  },
  {
    "id": "p-8af944",
    "offset": 6207,
    "text": "dravyāṇāṃ pratirūpavikrayikasya ca // Vi_5.124 //"
  },
  {
    "id": "p-b9618b",
    "offset": 6258,
    "text": "saṃbhūya vaṇijāṃ paṇyam anargheṇāvarundhatām // Vi_5.125 //"
  },
  {
    "id": "p-5621b4",
    "offset": 6319,
    "text": "pratyekaṃ vikrīṇatāṃ ca // Vi_5.126 //"
  },
  {
    "id": "p-d078ba",
    "offset": 6359,
    "text": "gṛhītamūlyaṃ yaḥ paṇyaṃ kretur naiva dadyāt, tasyāsau sodayaṃ dāpyaḥ // Vi_5.127 //"
  },
  {
    "id": "p-02099f",
    "offset": 6444,
    "text": "rājñā ca paṇaśataṃ daṇḍyaḥ // Vi_5.128 //"
  },
  {
    "id": "p-2ae3e0",
    "offset": 6487,
    "text": "krītam akrīṇato yā hāniḥ sā kretur eva syāt // Vi_5.129 //"
  },
  {
    "id": "p-559179",
    "offset": 6547,
    "text": "rājaniṣiddhaṃ vikrīṇatas tadapahāraḥ // Vi_5.130 //"
  },
  {
    "id": "p-21f972",
    "offset": 6600,
    "text": "tarikaḥ sthalajaṃ śulkaṃ gṛhṇan daśapaṇān daṇḍyaḥ // Vi_5.131 //"
  },
  {
    "id": "p-eab3cb",
    "offset": 6666,
    "text": "brahmacārivānaprasthabhikṣugurviṇītīrthānusāriṇāṃ nāvikaḥ śaulkikaḥ śulkam ādadānaś ca // Vi_5.132 //"
  },
  {
    "id": "p-56f572",
    "offset": 6769,
    "text": "tac ca teṣāṃ dadyāt // Vi_5.133 //"
  },
  {
    "id": "p-304b7a",
    "offset": 6805,
    "text": "dyūte kūṭākṣadevināṃ karacchedaḥ // Vi_5.134 //"
  },
  {
    "id": "p-668c27",
    "offset": 6854,
    "text": "upadhidevināṃ saṃdaṃśacchedaḥ // Vi_5.135 //"
  },
  {
    "id": "p-fd6e38",
    "offset": 6900,
    "text": "granthibhedakānāṃ ca // Vi_5.136 //"
  },
  {
    "id": "p-8ae220",
    "offset": 6937,
    "text": "utkṣepakānāṃ ca karacchedaḥ // Vi_5.137 //"
  },
  {
    "id": "p-b4f019",
    "offset": 6981,
    "text": "divā paśūnāṃ vṛkādyupaghāte pāle tv anāyati pāladoṣaḥ // Vi_5.138 //"
  },
  {
    "id": "p-7ccb33",
    "offset": 7051,
    "text": "vinaṣṭapaśumūlyaṃ ca svāmine dadyāt // Vi_5.139 //"
  },
  {
    "id": "p-9fd4e5",
    "offset": 7103,
    "text": "ananujñātāṃ duhan pañcaviṃśatiṃ kārṣāpaṇān // Vi_5.140 //"
  },
  {
    "id": "p-301e4c",
    "offset": 7162,
    "text": "mahiṣī cet sasyanāśaṃ kuryāt, tatpālas tv aṣṭau māṣān daṇḍyaḥ // Vi_5.141 //"
  },
  {
    "id": "p-55c475",
    "offset": 7240,
    "text": "apālāyāḥ svāmī // Vi_5.142 //"
  },
  {
    "id": "p-436c35",
    "offset": 7271,
    "text": "aśvas tūṣṭro gardabho vā // Vi_5.143 //"
  },
  {
    "id": "p-e74fe1",
    "offset": 7312,
    "text": "gauś cet tadardham // Vi_5.144 //"
  },
  {
    "id": "p-ab9722",
    "offset": 7347,
    "text": "tadardham ajāvikam // Vi_5.145 //"
  },
  {
    "id": "p-f03fb5",
    "offset": 7382,
    "text": "bhakṣayitvopaviṣṭeṣu dviguṇam // Vi_5.146 //"
  },
  {
    "id": "p-a74b4c",
    "offset": 7428,
    "text": "sarvatra svāmine vinaṣṭasasyamūlyaṃ ca // Vi_5.147 //"
  },
  {
    "id": "p-fd65a1",
    "offset": 7483,
    "text": "pathi grāme vivītānte na doṣaḥ // Vi_5.148 //"
  },
  {
    "id": "p-6bbfed",
    "offset": 7530,
    "text": "anāvṛte ca // Vi_5.149 //"
  },
  {
    "id": "p-b8f19a",
    "offset": 7557,
    "text": "alpakālam // Vi_5.150 //"
  },
  {
    "id": "p-b7c927",
    "offset": 7583,
    "text": "utsṛṣṭavṛṣabhasūtikānāṃ ca // Vi_5.151 //"
  },
  {
    "id": "p-b23c57",
    "offset": 7626,
    "text": "yas tūttamavarṇān dāsye niyojayet tasyottamasāhaso daṇḍaḥ // Vi_5.152 //"
  },
  {
    "id": "p-25e827",
    "offset": 7700,
    "text": "tyaktapravrajyo rājño dāsyaṃ kuryāt // Vi_5.153 //"
  },
  {
    "id": "p-10925d",
    "offset": 7752,
    "text": "bhṛtakaś cāpūrṇe kāle bhṛtiṃ tyajan sakalam eva mūlyaṃ dadyāt // Vi_5.154 //"
  },
  {
    "id": "p-0fae0b",
    "offset": 7830,
    "text": "jājñe ca paṇaśataṃ dadyāt // Vi_5.155 //"
  },
  {
    "id": "p-c78e1f",
    "offset": 7872,
    "text": "taddoṣeṇa yad vinaśyet tat svāmine // Vi_5.156 //"
  },
  {
    "id": "p-c54217",
    "offset": 7923,
    "text": "anyatra daivopaghātāt // Vi_5.157 //"
  },
  {
    "id": "p-4659f1",
    "offset": 7961,
    "text": "svāmī cet bhṛtakam apūrṇe kāle jahyāt, tasya sarvam eva mūlyaṃ dadyāt // Vi_5.158 //"
  },
  {
    "id": "p-a2dd67",
    "offset": 8047,
    "text": "paṇaśataṃ ca rājani // Vi_5.159 //"
  },
  {
    "id": "p-1c1c66",
    "offset": 8083,
    "text": "anyatra bhṛtakadośāt // Vi_5.160 //"
  },
  {
    "id": "p-636c54",
    "offset": 8120,
    "text": "yaḥ kanyāṃ pūrvadattām anyasmai dadyāt, sa cauravac chāsyaḥ // Vi_5.161 //"
  },
  {
    "id": "p-266d91",
    "offset": 8196,
    "text": "varadoṣaṃ vinā // Vi_5.162 //"
  },
  {
    "id": "p-b84e5b",
    "offset": 8227,
    "text": "nirdoṣāṃ parityajan // Vi_5.163 //"
  },
  {
    "id": "p-f8f19a",
    "offset": 8263,
    "text": "patnīṃ ca // Vi_5.164 //"
  },
  {
    "id": "p-47debb",
    "offset": 8289,
    "text": "ajānānaḥ prakāśaṃ yaḥ paradravyaṃ krīṇīyāt, tatra tasya na doṣaḥ // Vi_5.165 //"
  },
  {
    "id": "p-88bb87",
    "offset": 8370,
    "text": "svāmī dravyam āpnuyāt // Vi_5.166 //"
  },
  {
    "id": "p-b1895b",
    "offset": 8408,
    "text": "yady aprakāśaṃ hīnamūlyaṃ ca krīṇīyāt, tadā kretā vikretā ca cauravac chāsyau // Vi_5.167 //"
  },
  {
    "id": "p-ee4af8",
    "offset": 8502,
    "text": "gaṇadravyāpahartā vivāsyaḥ // Vi_5.168 //"
  },
  {
    "id": "p-036135",
    "offset": 8545,
    "text": "tatsaṃvidaṃ yaś ca laṅghayet // Vi_5.169 //"
  },
  {
    "id": "p-262404",
    "offset": 8590,
    "text": "nikṣepāpahāryarthavṛddhisahitaṃ dhanaṃ dhanikasya dāpyaḥ // Vi_5.170 //"
  },
  {
    "id": "p-4754e2",
    "offset": 8663,
    "text": "rājñā cauravac chāsyaḥ // Vi_5.171 //"
  },
  {
    "id": "p-7a72da",
    "offset": 8702,
    "text": "yaś cānikṣiptaṃ nikṣiptam iti brūyāt // Vi_5.172 //"
  },
  {
    "id": "p-093ac2",
    "offset": 8755,
    "text": "sīmābhettāram uttamasāhasaṃ daṇḍayitvā punaḥ sīmāṃ kārayet // Vi_5.173 //"
  },
  {
    "id": "p-9bf40b",
    "offset": 8830,
    "text": "jātibhraṃśakarasyābhakṣyasya bhakṣayitā vivāsyaḥ // Vi_5.174 //"
  },
  {
    "id": "p-0da20e",
    "offset": 8895,
    "text": "abhakṣyasyāvikreyasya vikrayī devapratimābhedakaś cottamasāhasaṃ daṇḍanīyaḥ // Vi_5.175 //"
  },
  {
    "id": "p-dad3f4",
    "offset": 8987,
    "text": "bhiṣaṅ mithyācarann uttameṣu puruṣeṣu // Vi_5.176 //"
  },
  {
    "id": "p-43fd63",
    "offset": 9041,
    "text": "madhyameṣu madhyamam // Vi_5.177 //"
  },
  {
    "id": "p-b5d363",
    "offset": 9078,
    "text": "tiryakṣu prathamam // Vi_5.178 //"
  },
  {
    "id": "p-7b98c8",
    "offset": 9113,
    "text": "pratiśrutasyāpradāyī tad dāpayitvā prathamasāhasaṃ daṇḍyaḥ // Vi_5.179 //"
  },
  {
    "id": "p-f6393a",
    "offset": 9188,
    "text": "kūṭasākṣiṇāṃ sarvasvāpahāraḥ kāryaḥ // Vi_5.180 //"
  },
  {
    "id": "p-4a499c",
    "offset": 9240,
    "text": "utkocopajīvināṃ sabhyānāṃ ca // Vi_5.181 //"
  },
  {
    "id": "p-645b7b",
    "offset": 9285,
    "text": "gocarmamātrādhikāṃ bhuvam anyasyādhīkṛtāṃ tasmād anirmocyānyasya yaḥ prayacchet sa vadhyaḥ // Vi_5.182 //"
  },
  {
    "id": "p-d0d795",
    "offset": 9392,
    "text": "ūnāṃ cet ṣoḍaśa suvarṇān daṇḍyaḥ // Vi_5.183 //"
  },
  {
    "id": "p-ae969f",
    "offset": 9441,
    "text": "eko 'śnīyād yad utpannaṃ naraḥ saṃvatsaraṃ phalam  /"
  },
  {
    "id": "p-2137d3",
    "offset": 9495,
    "text": "gocarmamātrā sā kṣoṇī stokā vā yadi vā bahu  || Vi_5.184 ||"
  },
  {
    "id": "p-d6ef2a",
    "offset": 9556,
    "text": "yayor nikṣipta ādhis tau vivadetāṃ yadā narau  /"
  },
  {
    "id": "p-dac8b8",
    "offset": 9606,
    "text": "yasya bhuktiḥ phalaṃ tasya balāt kāraṃ vinā kṛtā  || Vi_5.185 ||"
  },
  {
    "id": "p-e07624",
    "offset": 9672,
    "text": "sāgamena tu bhogena bhuktaṃ samyag yadā tu yat  /"
  },
  {
    "id": "p-20f14c",
    "offset": 9723,
    "text": "āhartā labhate tatra nāpahāryaṃ tu tat kvacit  || Vi_5.186 ||"
  },
  {
    "id": "p-f82f65",
    "offset": 9786,
    "text": "pitrā bhuktaṃ tu yad dravyaṃ bhuktyācāreṇa dharmataḥ  /"
  },
  {
    "id": "p-171661",
    "offset": 9843,
    "text": "tasmin prete na vācyo 'sau bhuktyā prāptaṃ hi tasya tat  || Vi_5.187 ||"
  },
  {
    "id": "p-783f84",
    "offset": 9916,
    "text": "tribhir eva tu yā bhuktā puruṣair bhūr yathāvidhi  /"
  },
  {
    "id": "p-d08dde",
    "offset": 9970,
    "text": "lekhyābhāve 'pi tāṃ tatra caturthaḥ samavāpnuyāt  || Vi_5.188 ||"
  },
  {
    "id": "p-fd85f5",
    "offset": 10036,
    "text": "nakhināṃ śṛṅgiṇāṃ caiva daṃṣṭriṇām ātatāyinām  /"
  },
  {
    "id": "p-540d13",
    "offset": 10086,
    "text": "hastyaśvānāṃ tathānyeṣāṃ vadhe hantā na doṣabhāk  || Vi_5.189 ||"
  },
  {
    "id": "p-b5954c",
    "offset": 10152,
    "text": "guruṃ vā bālavṛddhau vā brāhmaṇaṃ vā bahuśrutam  /"
  },
  {
    "id": "p-00dfad",
    "offset": 10204,
    "text": "ātatāyinam āyāntaṃ hanyād evāvicārayan  || Vi_5.190 ||"
  },
  {
    "id": "p-a8470d",
    "offset": 10260,
    "text": "nātatāyivadhe doṣo hantur bhavati kaścana  /"
  },
  {
    "id": "p-f30b29",
    "offset": 10306,
    "text": "prakāśaṃ vāprakāśaṃ vā manyus tan manyum ṛcchati  || Vi_5.191 ||"
  },
  {
    "id": "p-871fca",
    "offset": 10372,
    "text": "udyatāsiviṣāgniṃ ca śāpodyatakaraṃ tathā  /"
  },
  {
    "id": "p-6eb192",
    "offset": 10417,
    "text": "ātharvaṇena hantāraṃ piśunaṃ caiva rājasu  || Vi_5.192 ||"
  },
  {
    "id": "p-54aa54",
    "offset": 10476,
    "text": "bhāryātikramiṇaṃ caiva vidyāt saptātatāyinaḥ  /"
  },
  {
    "id": "p-ac81ca",
    "offset": 10525,
    "text": "yaśovittaharān anyān āhur dharmārthahārakān  || Vi_5.193 ||"
  },
  {
    "id": "p-21a0bb",
    "offset": 10586,
    "text": "uddeśatas te kathito dhare daṇḍavidhir mayā  /"
  },
  {
    "id": "p-1badf2",
    "offset": 10634,
    "text": "sarveṣām aparādhānāṃ vistarād ativistaraḥ  || Vi_5.194 ||"
  },
  {
    "id": "p-fd6376",
    "offset": 10693,
    "text": "aparādheṣu cānyesu jñātvā jātiṃ dhanaṃ vayaḥ  /"
  },
  {
    "id": "p-bb877a",
    "offset": 10742,
    "text": "daṇḍaṃ prakalpayed rājā saṃmantrya brāhmaṇaiḥ saha  || Vi_5.195 ||"
  },
  {
    "id": "p-636702",
    "offset": 10810,
    "text": "daṇḍyaṃ pramocayan daṇḍyād dviguṇaṃ daṇḍam āvahet  /"
  },
  {
    "id": "p-2e2075",
    "offset": 10864,
    "text": "niyuktaś cāpy adaṇḍyānāṃ daṇḍakārī narādhamaḥ  || Vi_5.196 ||"
  },
  {
    "id": "p-0511ac",
    "offset": 10927,
    "text": "yasya cauraḥ pure nāsti nānyastrīgo na duṣṭavāk  /"
  },
  {
    "id": "p-5f718f",
    "offset": 10979,
    "text": "na sāhasikadaṇḍaghnau sa rājā śakralokabhāk  || Vi_5.197 ||"
  }
]