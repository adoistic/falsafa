[
  {
    "id": "p-12573e",
    "offset": 0,
    "text": "Vi_25"
  },
  {
    "id": "p-01920f",
    "offset": 7,
    "text": "atha strīṇāṃ dharmāḥ // Vi_25.1 //"
  },
  {
    "id": "p-02dcb7",
    "offset": 43,
    "text": "bhartuḥ samānavratacāritvam // Vi_25.2 //"
  },
  {
    "id": "p-8f5e62",
    "offset": 86,
    "text": "śvaśrūśvaśuragurudevatātithipūjanam // Vi_25.3 //"
  },
  {
    "id": "p-8a6250",
    "offset": 137,
    "text": "susaṃskṛtopaskaratā // Vi_25.4 //"
  },
  {
    "id": "p-cd68cc",
    "offset": 172,
    "text": "amuktahastatā // Vi_25.5 //"
  },
  {
    "id": "p-d85bf8",
    "offset": 201,
    "text": "suguptabhāṇḍatā // Vi_25.6 //"
  },
  {
    "id": "p-645a39",
    "offset": 232,
    "text": "mūlakriyāsv anabhiratiḥ // Vi_25.7 //"
  },
  {
    "id": "p-de582e",
    "offset": 271,
    "text": "maṅgalācāratatparatā // Vi_25.8 //"
  },
  {
    "id": "p-3aa321",
    "offset": 307,
    "text": "bhartari pravasite 'pratikarmakriyā // Vi_25.9 //"
  },
  {
    "id": "p-ad0d15",
    "offset": 358,
    "text": "paragṛheṣv anabhigamanam // Vi_25.10 //"
  },
  {
    "id": "p-9cb4ae",
    "offset": 399,
    "text": "dvāradeśagavākṣeṣv anavasthānam // Vi_25.11 //"
  },
  {
    "id": "p-cd9cba",
    "offset": 447,
    "text": "sarvakarmasv asvatantratā // Vi_25.12 //"
  },
  {
    "id": "p-15ab77",
    "offset": 489,
    "text": "bālyayauvanavārdhakeṣv api pitṛbhartṛputrādhīnatā // Vi_25.13 //"
  },
  {
    "id": "p-6c3ebd",
    "offset": 555,
    "text": "mṛte bhartari brahmacaryaṃ tadanv ārohaṇaṃ vā // Vi_25.14 //"
  },
  {
    "id": "p-92dc7b",
    "offset": 617,
    "text": "nāsti strīṇāṃ pṛthagyajño na vrataṃ nāpy upoṣitam  /"
  },
  {
    "id": "p-b85c0a",
    "offset": 671,
    "text": "patiṃ śuśrūṣate yat tu tena svarge mahīyate  || Vi_25.15 ||"
  },
  {
    "id": "p-ef94b4",
    "offset": 732,
    "text": "patyau jīvati yā yoṣid upavāsavrataṃ caret  /"
  },
  {
    "id": "p-399fb2",
    "offset": 779,
    "text": "āyuḥ sā harate bhartur narakaṃ caiva gacchati  || Vi_25.16 ||"
  },
  {
    "id": "p-788d2e",
    "offset": 842,
    "text": "mṛte bhartari sādhvī strī brahmacarye vyavasthitā  /"
  },
  {
    "id": "p-f0b07a",
    "offset": 896,
    "text": "svargaṃ gacchaty aputrāpi yathā te brahmacāriṇaḥ  || Vi_25.17 ||"
  }
]