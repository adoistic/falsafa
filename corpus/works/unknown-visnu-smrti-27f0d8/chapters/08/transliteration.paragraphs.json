[
  {
    "id": "p-193dc5",
    "offset": 0,
    "text": "Vi_8"
  },
  {
    "id": "p-467a87",
    "offset": 6,
    "text": "athāsākṣiṇaḥ // Vi_8.1 //"
  },
  {
    "id": "p-e5f1f9",
    "offset": 33,
    "text": "na rājaśrotriyapravrajitakitavataskaraparādhīnastrībālasāhasikātivṛddhamattonmatābhiśastapatitakṣuttṛṣṇārtavyasanirāgāndhāḥ // Vi_8.2 //"
  },
  {
    "id": "p-7279ea",
    "offset": 171,
    "text": "ripumitrārthasaṃbandhivikarmadṛṣṭadoṣasahāyāś ca // Vi_8.3 //"
  },
  {
    "id": "p-9df523",
    "offset": 234,
    "text": "anirdiṣṭas tu sākṣitve yaś copetya brūyāt // Vi_8.4 //"
  },
  {
    "id": "p-95193b",
    "offset": 290,
    "text": "ekaś cāsākṣī // Vi_8.5 //"
  },
  {
    "id": "p-892fa4",
    "offset": 317,
    "text": "steyasāhasavāgdaṇḍapāruṣyasaṃgrahaṇeṣu sākṣiṇo na parīkṣyāḥ // Vi_8.6 //"
  },
  {
    "id": "p-6b8820",
    "offset": 391,
    "text": "atha sākṣiṇaḥ // Vi_8.7 //"
  },
  {
    "id": "p-b27737",
    "offset": 419,
    "text": "kulajā vṛttavittasaṃpannā yajvānas tapasvinaḥ putriṇo dharmajñā adhīyānāḥ satyavantas traividyavṛddhāś ca // Vi_8.8 //"
  },
  {
    "id": "p-174abf",
    "offset": 539,
    "text": "abhihitaguṇasaṃpanna ubhayānumata eko 'pi // Vi_8.9 //"
  },
  {
    "id": "p-0c319f",
    "offset": 595,
    "text": "dvayor vivadamānayor yasya pūrvavādas tasya sākṣiṇaḥ praṣṭavyāḥ // Vi_8.10 //"
  },
  {
    "id": "p-9de665",
    "offset": 674,
    "text": "ādharyaṃ kāryavaśād yatra pūrvapakṣasya bhavet tatra prativādino 'pi // Vi_8.11 //"
  },
  {
    "id": "p-d54b93",
    "offset": 758,
    "text": "uddiṣṭasākṣiṇi mṛte deśāntaragate ca tadabhihitaśrotāraḥ pramāṇam // Vi_8.12 //"
  },
  {
    "id": "p-ae4120",
    "offset": 839,
    "text": "samakṣadarśanāt sākṣī śravaṇād vā // Vi_8.13 //"
  },
  {
    "id": "p-af684f",
    "offset": 888,
    "text": "sākṣiṇaś ca satyena pūyante // Vi_8.14 //"
  },
  {
    "id": "p-b3fe6c",
    "offset": 931,
    "text": "varṇināṃ yatra vadhas tatrānṛtena // Vi_8.15 //"
  },
  {
    "id": "p-093b50",
    "offset": 980,
    "text": "tatpāvanāya kūśmāṇḍībhir dvijo 'gniṃ ghṛtena juhuyāt // Vi_8.16 //"
  },
  {
    "id": "p-81174b",
    "offset": 1048,
    "text": "śūdra ekāhikam godaśakasya grāsaṃ dadyāt // Vi_8.17 //"
  },
  {
    "id": "p-398356",
    "offset": 1104,
    "text": "svabhāvavikṛtau mukhavarṇavināśe 'saṃbaddhapralāpe ca kūṭasākṣiṇaṃ vidyāt // Vi_8.18 //"
  },
  {
    "id": "p-6c042e",
    "offset": 1193,
    "text": "sākṣiṇaś cāhūya ādityodaye kṛtaśapathān pṛcchet // Vi_8.19 //"
  },
  {
    "id": "p-f74a28",
    "offset": 1256,
    "text": "brūhīti brāhmaṇaṃ pṛcchet // Vi_8.20 //"
  },
  {
    "id": "p-e1ed8c",
    "offset": 1297,
    "text": "satyaṃ brūhīti rājanyam // Vi_8.21 //"
  },
  {
    "id": "p-d8f2d9",
    "offset": 1336,
    "text": "gobījakāñcanair vaiśyam // Vi_8.22 //"
  },
  {
    "id": "p-eb080d",
    "offset": 1375,
    "text": "sarvamahāpātakais tu śūdram // Vi_8.23 //"
  },
  {
    "id": "p-b55383",
    "offset": 1418,
    "text": "sākṣiṇaś ca śrāvayet // Vi_8.24 //"
  },
  {
    "id": "p-4d1820",
    "offset": 1454,
    "text": "ye mahāpātakināṃ lokā ye copapātakināṃ te kūṭasākṣiṇām api // Vi_8.25 //"
  },
  {
    "id": "p-0cb002",
    "offset": 1528,
    "text": "jananamaraṇāntare kṛtasukṛtahāniś ca // Vi_8.26 //"
  },
  {
    "id": "p-57bbab",
    "offset": 1580,
    "text": "satyenādityas tapati // Vi_8.27 //"
  },
  {
    "id": "p-776ee8",
    "offset": 1616,
    "text": "satyena bhāti candramāḥ // Vi_8.28 //"
  },
  {
    "id": "p-fa8c17",
    "offset": 1655,
    "text": "satyena vāti pavanaḥ // Vi_8.29 //"
  },
  {
    "id": "p-e0803c",
    "offset": 1691,
    "text": "satyena bhūr dhārayati // Vi_8.30 //"
  },
  {
    "id": "p-2a919a",
    "offset": 1729,
    "text": "satyenāpas tiṣṭhanti // Vi_8.31 //"
  },
  {
    "id": "p-996a90",
    "offset": 1765,
    "text": "satyenāgniḥ // Vi_8.32 //"
  },
  {
    "id": "p-8b08db",
    "offset": 1792,
    "text": "khaṃ ca satyena // Vi_8.33 //"
  },
  {
    "id": "p-e7b638",
    "offset": 1823,
    "text": "satyena devāḥ // Vi_8.34 //"
  },
  {
    "id": "p-a7e798",
    "offset": 1852,
    "text": "satyena yajñāḥ // Vi_8.35 //"
  },
  {
    "id": "p-5a20f4",
    "offset": 1882,
    "text": "aśvamedhasahasraṃ ca satyaṃ ca tulayā dhṛtam  /"
  },
  {
    "id": "p-0ebd01",
    "offset": 1931,
    "text": "aśvamedhasahasrād dhi satyam eva viśiṣyate  || Vi_8.36 ||"
  },
  {
    "id": "p-9e7fd9",
    "offset": 1990,
    "text": "jānanto 'pi hi ye sākṣye tūṣṇīṃbhūtā udāsate  /"
  },
  {
    "id": "p-f14fca",
    "offset": 2039,
    "text": "te kūṭasākṣiṇāṃ pāpais tulyā daṇḍena cāpy atha  || Vi_8.37 ||"
  },
  {
    "id": "p-85f8c6",
    "offset": 2102,
    "text": "evaṃ hi sākṣiṇaḥ pṛcched varṇānukramato nṛpaḥ  || Vi_8.38 ||"
  },
  {
    "id": "p-a1e48f",
    "offset": 2164,
    "text": "yasyocuḥ sākṣiṇaḥ satyāṃ pratijñāṃ sa jayī bhavet  /"
  },
  {
    "id": "p-4ef141",
    "offset": 2218,
    "text": "anyathā vādino yasya dhruvas tasya parājayaḥ  || Vi_8.39 ||"
  },
  {
    "id": "p-92a97b",
    "offset": 2279,
    "text": "bahutvaṃ pratigṛhṇīyāt sākṣidvaidhe narādhipaḥ  /"
  },
  {
    "id": "p-b617bc",
    "offset": 2330,
    "text": "sameṣu ca guṇotkṛṣṭān guṇidvaidhe dvijottamān  || Vi_8.40 ||"
  },
  {
    "id": "p-4b89f7",
    "offset": 2392,
    "text": "yasmin yasmin vivāde tu kūṭasākṣy anṛtaṃ vadet  /"
  },
  {
    "id": "p-b76611",
    "offset": 2443,
    "text": "tattatkāryaṃ nivarteta kṛtaṃ cāpy akṛtaṃ bhavet  || Vi_8.41 ||"
  }
]