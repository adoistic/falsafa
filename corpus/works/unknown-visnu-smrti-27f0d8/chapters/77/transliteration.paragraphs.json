    "text": "ādityasaṃkramaṇam // Vi_77.1 //"
  },
  {
    "id": "p-fed9e3",
    "offset": 40,
    "text": "viṣuvaddvayam // Vi_77.2 //"
  },
  {
    "id": "p-5942f6",
    "offset": 69,
    "text": "viśeṣeṇāyanadvayam // Vi_77.3 //"
  },
  {
    "id": "p-b508f4",
    "offset": 103,
    "text": "vyatīpātaḥ // Vi_77.4 //"
  },
  {
    "id": "p-87dc8c",
    "offset": 129,
    "text": "janmarkṣam // Vi_77.5 //"
  },
  {
    "id": "p-b30105",
    "offset": 155,
    "text": "abhyudayaś ca // Vi_77.6 //"
  },
  {
    "id": "p-fb8d4a",
    "offset": 184,
    "text": "etāṃs tu śrāddhakālān vai kāmyān āha prajāpatiḥ  /"
  },
  {
    "id": "p-79048f",
    "offset": 236,
    "text": "śrāddham eteṣu yad dattaṃ tad ānantyāya kalpate  || Vi_77.7 ||"
  },
  {
    "id": "p-082f20",
    "offset": 300,
    "text": "saṃdhyārātryor na kartavyaṃ śrāddhaṃ khalu vicakṣaṇaiḥ  /"
  },
  {
    "id": "p-ed04f4",
    "offset": 359,
    "text": "tayor api ca kartavyaṃ yadi syād rāhudarśanam  || Vi_77.8 ||"
  },
  {
    "id": "p-c52cda",
    "offset": 421,
    "text": "rāhudarśanadattaṃ hi śrāddham ācandratārakam  /"
  },
  {
    "id": "p-d7f991",
    "offset": 470,
    "text": "guṇavatsarvakāmīyaṃ pitṝṇām upatiṣṭhate  || Vi_77.9 ||"
  }
]