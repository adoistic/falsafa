[
  {
    "id": "p-145741",
    "offset": 0,
    "text": "Vi_27"
  },
  {
    "id": "p-8854f0",
    "offset": 7,
    "text": "garbhasya spaṣṭatājñāne niṣekakarma // Vi_27.1 //"
  },
  {
    "id": "p-f39a19",
    "offset": 58,
    "text": "spandanāt purā puṃsavanam // Vi_27.2 //"
  },
  {
    "id": "p-f92d1a",
    "offset": 99,
    "text": "*ṣaṣṭhe 'ṣṭame vā māsi sīmantonnayanam [paṣṭhe] // Vi_27.3 //"
  },
  {
    "id": "p-e53518",
    "offset": 162,
    "text": "jāte ca dārake jātakarma // Vi_27.4 //"
  },
  {
    "id": "p-fdd6ab",
    "offset": 202,
    "text": "āśaucavyapagame nāmadheyam // Vi_27.5 //"
  },
  {
    "id": "p-36418a",
    "offset": 244,
    "text": "maṅgalyaṃ brāhamaṇasya // Vi_27.6 //"
  },
  {
    "id": "p-7d6481",
    "offset": 282,
    "text": "balavat kṣatriyasya // Vi_27.7 //"
  },
  {
    "id": "p-41057e",
    "offset": 317,
    "text": "dhanopetaṃ vaiśyasya // Vi_27.8 //"
  },
  {
    "id": "p-f94e75",
    "offset": 353,
    "text": "jugupsitaṃ śūdrasya // Vi_27.9 //"
  },
  {
    "id": "p-0aa51f",
    "offset": 388,
    "text": "caturthe māsy ādityadarśanam // Vi_27.10 //"
  },
  {
    "id": "p-201b4a",
    "offset": 433,
    "text": "ṣaṣṭhe 'nnaprāśanam // Vi_27.11 //"
  },
  {
    "id": "p-3dccce",
    "offset": 469,
    "text": "tṛtīye 'bde cūḍākaraṇam // Vi_27.12 //"
  },
  {
    "id": "p-87411b",
    "offset": 509,
    "text": "etā eva kriyāḥ strīṇām amantrakāḥ // Vi_27.13 //"
  },
  {
    "id": "p-b61cb3",
    "offset": 559,
    "text": "tāsāṃ samantrako vivāhaḥ // Vi_27.14 //"
  },
  {
    "id": "p-60ecda",
    "offset": 600,
    "text": "garbhāṣṭame 'bde brāhmaṇasyopanayanam // Vi_27.15 //"
  },
  {
    "id": "p-343c99",
    "offset": 654,
    "text": "garbhaikādaśe rājñaḥ // Vi_27.16 //"
  },
  {
    "id": "p-b192ad",
    "offset": 691,
    "text": "garbhadvādaśe viśaḥ // Vi_27.17 //"
  },
  {
    "id": "p-d7840c",
    "offset": 727,
    "text": "teṣāṃ muñjajyābalbajamayyo mauñjyaḥ // Vi_27.18 //"
  },
  {
    "id": "p-1998d7",
    "offset": 779,
    "text": "kārpāsaśāṇāvikāny upavītāni vāsāṃsi ca // Vi_27.19 //"
  },
  {
    "id": "p-861817",
    "offset": 834,
    "text": "mārgavaiyāghrabāstāni carmāṇi // Vi_27.20 //"
  },
  {
    "id": "p-fa80fb",
    "offset": 880,
    "text": "pālāśakhādiraudumbarā daṇḍāḥ // Vi_27.21 //"
  },
  {
    "id": "p-6a3385",
    "offset": 925,
    "text": "keśāntalalāṭanāsādeśatulyāḥ // Vi_27.22 //"
  },
  {
    "id": "p-f95aac",
    "offset": 969,
    "text": "sarva eva vā // Vi_27.23 //"
  },
  {
    "id": "p-bd85b0",
    "offset": 998,
    "text": "akuṭilāḥ satvacaś ca // Vi_27.24 //"
  },
  {
    "id": "p-a675cb",
    "offset": 1035,
    "text": "bhavadādyaṃ bhavanmadhyaṃ bhavadantaṃ ca bhaikṣyacaranam // Vi_27.25 //"
  },
  {
    "id": "p-2c246e",
    "offset": 1108,
    "text": "ā ṣoḍaśād brāhmaṇasya sāvitrī nātivartate  /"
  },
  {
    "id": "p-66756c",
    "offset": 1154,
    "text": "ā dvāviṃśāt kṣatrabandhor ā caturviṃśater viśaḥ  || Vi_27.26 ||"
  },
  {
    "id": "p-7861c3",
    "offset": 1219,
    "text": "ata ūrdhvaṃ trayo 'py ete yathākālam asaṃskṛtāḥ  /"
  },
  {
    "id": "p-c194c2",
    "offset": 1271,
    "text": "sāvitrīpatitā vrātyā bhavanty āryavigarhitāḥ  || Vi_27.27 ||"
  },
  {
    "id": "p-f51024",
    "offset": 1333,
    "text": "yady asya vihitaṃ carma yat sūtraṃ yā ca mekhalā  /"
  },
  {
    "id": "p-870684",
    "offset": 1386,
    "text": "yo daṇḍo yac ca vasanaṃ tat tad asya vrateṣv api  || Vi_27.28 ||"
  },
  {
    "id": "p-657ebf",
    "offset": 1452,
    "text": "mekhalām ajinaṃ daṇḍam upavītaṃ kamaṇḍalum  /"
  },
  {
    "id": "p-2b5853",
    "offset": 1499,
    "text": "apsu prāsya vinaṣṭāni gṛhṇītānyāni mantravat  || Vi_27.29 ||"
  }
]