[
  {
    "id": "p-1f3dcf",
    "offset": 0,
    "text": "Vi_6"
  },
  {
    "id": "p-42be40",
    "offset": 6,
    "text": "athottamarṇo 'dhamarṇād yathādattam arthaṃ gṛhṇīyāt // Vi_6.1 //"
  },
  {
    "id": "p-c57719",
    "offset": 72,
    "text": "dvikaṃ trikaṃ catuṣkaṃ pañcakaṃ ca śataṃ varṇānukrameṇa pratimāsam // Vi_6.2 //"
  },
  {
    "id": "p-90c686",
    "offset": 153,
    "text": "sarve varṇā vā svapratipannāṃ vṛddhiṃ dadyuḥ // Vi_6.3 //"
  },
  {
    "id": "p-10276d",
    "offset": 212,
    "text": "akṛtām api vatsarātikrameṇa yathāvihitam // Vi_6.4 //"
  },
  {
    "id": "p-107c89",
    "offset": 267,
    "text": "ādhyupabhoge vṛddhyabhāvaḥ // Vi_6.5 //"
  },
  {
    "id": "p-03e316",
    "offset": 308,
    "text": "daivarājopaghātād ṛte vinaṣṭam ādhim uttamarṇo dadyāt // Vi_6.6 //"
  },
  {
    "id": "p-6af6e1",
    "offset": 376,
    "text": "antavṛddhau praviṣṭāyām api // Vi_6.7 //"
  },
  {
    "id": "p-96dc28",
    "offset": 418,
    "text": "na sthāvaram ādhim ṛte vacanāt // Vi_6.8 //"
  },
  {
    "id": "p-a49fea",
    "offset": 463,
    "text": "gṛhītadhanapraveśārtham eva yat sthāvaraṃ dattaṃ tat gṛhītadhanapraveśe dadyāt // Vi_6.9 //"
  },
  {
    "id": "p-a71ece",
    "offset": 556,
    "text": "dīyamānaṃ prayuktam artham uttamarṇasyāgṛhṇatas tataḥ paraṃ na vardhate // Vi_6.10 //"
  },
  {
    "id": "p-ece169",
    "offset": 643,
    "text": "hiraṇyasya parā vṛddhir dviguṇā // Vi_6.11 //"
  },
  {
    "id": "p-056f6d",
    "offset": 690,
    "text": "dhānyasya triguṇā // Vi_6.12 //"
  },
  {
    "id": "p-4bf5a8",
    "offset": 723,
    "text": "vastrasya caturguṇā // Vi_6.13 //"
  },
  {
    "id": "p-ceff41",
    "offset": 758,
    "text": "rasasyāṣṭaguṇā // Vi_6.14 //"
  },
  {
    "id": "p-e731c4",
    "offset": 788,
    "text": "saṃtatiḥ strīpaśūnām // Vi_6.15 //"
  },
  {
    "id": "p-862393",
    "offset": 824,
    "text": "kiṇvakārpāsasūtracarmāyudheṣṭakāṅgarāṇām akṣayā // Vi_6.16 //"
  },
  {
    "id": "p-ab84d5",
    "offset": 887,
    "text": "anuktānāṃ dviguṇā // Vi_6.17 //"
  },
  {
    "id": "p-36d44d",
    "offset": 920,
    "text": "prayuktam arthaṃ yathā kathaṃcit sādhayan na rājño vācyaḥ syāt // Vi_6.18 //"
  },
  {
    "id": "p-d52bef",
    "offset": 998,
    "text": "sādhyamānaś ced rājānam abhigacchet tatsamaṃ daṇḍyaḥ // Vi_6.19 //"
  },
  {
    "id": "p-6739e0",
    "offset": 1066,
    "text": "uttamarṇaś ced rājānam iyāt, tadvibhāvito 'dhamarṇo rājñe dhanadaśabhāgasaṃmitaṃ daṇḍaṃ dadyāt // Vi_6.20 //"
  },
  {
    "id": "p-371a42",
    "offset": 1176,
    "text": "prāptārthaś cottamarṇo viṃśatitamam aṃśam // Vi_6.21 //"
  },
  {
    "id": "p-b03e19",
    "offset": 1233,
    "text": "sarvāpalāpy ekadeśavibhāvito 'pi sarvaṃ dadyāt // Vi_6.22 //"
  },
  {
    "id": "p-2b685a",
    "offset": 1295,
    "text": "tasya ca bhāvanās tisro bhavanti likhitaṃ sākṣiṇaḥ samayakriyā ca // Vi_6.23 //"
  },
  {
    "id": "p-4afb66",
    "offset": 1376,
    "text": "sasākṣikam āptaṃ sasākṣikam eva dadyāt // Vi_6.24 //"
  },
  {
    "id": "p-0dbde6",
    "offset": 1430,
    "text": "likhtārthe praviṣṭe likhitaṃ pāṭayet // Vi_6.25 //"
  },
  {
    "id": "p-7d4c1b",
    "offset": 1482,
    "text": "asamagradāne lekhyāsaṃnidhāne cottamarṇaḥ svalikhitaṃ dadyāt // Vi_6.26 //"
  },
  {
    "id": "p-316162",
    "offset": 1558,
    "text": "dhanagrāhiṇi prete prevrajite dvidaśāḥ samāḥ pravasite vā tatputrapautrair dhanaṃ deyam // Vi_6.27 //"
  },
  {
    "id": "p-d90a71",
    "offset": 1661,
    "text": "nātaḥ param anicchubhiḥ // Vi_6.28 //"
  },
  {
    "id": "p-d65460",
    "offset": 1700,
    "text": "saputrasya vāpy aputrasya vā rikthagrāhī ṛṇaṃ dadyāt // Vi_6.29 //"
  },
  {
    "id": "p-67d0ea",
    "offset": 1768,
    "text": "nirdhanasya strīgrāhī // Vi_6.30 //"
  },
  {
    "id": "p-d0cc84",
    "offset": 1805,
    "text": "na strī patiputrakṛtam // Vi_6.31 //"
  },
  {
    "id": "p-9e386f",
    "offset": 1843,
    "text": "na strīkṛtaṃ patiputrau // Vi_6.32 //"
  },
  {
    "id": "p-4906c2",
    "offset": 1882,
    "text": "na pitā putrakṛtam // Vi_6.33 //"
  },
  {
    "id": "p-0838dd",
    "offset": 1916,
    "text": "avibhaktaiḥ kṛtam ṛṇaṃ yas tiṣṭhet sa dadyāt // Vi_6.34 //"
  },
  {
    "id": "p-5708e5",
    "offset": 1976,
    "text": "paitṛkam ṛṇam avibhaktānāṃ bhrātṝṇāṃ ca // Vi_6.35 //"
  },
  {
    "id": "p-58a054",
    "offset": 2031,
    "text": "vibhaktāś ca dāyānurūpam aṃśam // Vi_6.36 //"
  },
  {
    "id": "p-cf7072",
    "offset": 2077,
    "text": "gopaśauṇḍikaśailūṣarajakavyādhastrīṇāṃ patir dadyāt // Vi_6.37 //"
  },
  {
    "id": "p-438f4f",
    "offset": 2144,
    "text": "vākpratipannaṃ nādeyaṃ kasyacit // Vi_6.38 //"
  },
  {
    "id": "p-5807d7",
    "offset": 2191,
    "text": "kuṭumbārthe kṛtaṃ ca // Vi_6.39 //"
  },
  {
    "id": "p-50778a",
    "offset": 2227,
    "text": "yo gṛhītvā ṛṇaṃ sarvaṃ śvo dāsyāmīti sāmakam  /"
  },
  {
    "id": "p-b1671b",
    "offset": 2276,
    "text": "na dadyāl lobhataḥ paścāt tathā vṛddhim avāpnuyāt  || Vi_6.40 ||"
  }
]