  },
  {
    "id": "p-affbf9",
    "offset": 100,
    "text": "tatsaṃyogaś ca // Vi_35.2 //"
  },
  {
    "id": "p-e32707",
    "offset": 130,
    "text": "saṃvatsareṇa patati patitena sahācaran // Vi_35.3 //"
  },
  {
    "id": "p-65afff",
    "offset": 184,
    "text": "ekayānabhojanāśanaśayanaiḥ // Vi_35.4 //"
  },
  {
    "id": "p-7b27b4",
    "offset": 226,
    "text": "yaunasrauvamukhyaiḥ saṃbandhais tu sadya eva // Vi_35.5 //"
  },
  {
    "id": "p-a70886",
    "offset": 286,
    "text": "aśvamedhena śuddhyeyur mahāpātakinas tv ime  /"
  },
  {
    "id": "p-8e5daf",
    "offset": 334,
    "text": "pṛthivyāṃ sarvatīrthānāṃ tathānusaraṇena ca  || Vi_35.6 ||"
  }
