[
  {
    "id": "p-0a4827",
    "offset": 0,
    "text": "Vi_49"
  },
  {
    "id": "p-245641",
    "offset": 7,
    "text": "mārgaśīrṣaśuklaikādaśyām upoṣito dvādaśyāṃ bhagavantaṃ śrīvāsudevam arcayet // Vi_49.1 //"
  },
  {
    "id": "p-dfd0ae",
    "offset": 98,
    "text": "puṣpadhūpānulepanadīpanaivedyaiḥ vahnibrāhmaṇatarpaṇaiś ca // Vi_49.2 //"
  },
  {
    "id": "p-4c0edc",
    "offset": 172,
    "text": "vratam etat saṃvatsaraṃ kṛtvā pāpebhyaḥ pūto bhavati // Vi_49.3 //"
  },
  {
    "id": "p-6ac9d6",
    "offset": 240,
    "text": "yāvaj jīvaṃ kṛtvā śvetadvīpam āpnoti // Vi_49.4 //"
  },
  {
    "id": "p-614d04",
    "offset": 292,
    "text": "ubhayapakṣadvādaśīṣv evaṃ saṃvatsareṇa svargalokam āpnoti // Vi_49.5 //"
  },
  {
    "id": "p-ee28fd",
    "offset": 365,
    "text": "yāvaj jīvaṃ kṛtvā viṣṇulokam // Vi_49.6 //"
  },
  {
    "id": "p-611572",
    "offset": 409,
    "text": "evam eva pañcadaśīṣv api // Vi_49.7 //"
  },
  {
    "id": "p-d58bcd",
    "offset": 449,
    "text": "brahmabhūtam amāvāsyāṃ paurṇamāsyāṃ tathaiva ca  /"
  },
  {
    "id": "p-186596",
    "offset": 501,
    "text": "yogabhūtaṃ paricaran keśavaṃ mahad āpnuyāt  || Vi_49.8 ||"
  },
  {
    "id": "p-8d81ae",
    "offset": 560,
    "text": "dṛśyete sahitau yasyāṃ divi candrabṛhaspatī  /"
  },
  {
    "id": "p-61cacb",
    "offset": 608,
    "text": "paurṇamāsī tu mahatī proktā saṃvatsare tu sā  || Vi_49.9 ||"
  },
  {
    "id": "p-5f79d6",
    "offset": 669,
    "text": "tasyāṃ dānopavāsādyam akṣayaṃ parikīrtitam  /"
  },
  {
    "id": "p-f531a8",
    "offset": 716,
    "text": "tathaiva dvādaśī śuklā yā syāc chravaṇasaṃyutā  || Vi_49.10 ||"
  }
]