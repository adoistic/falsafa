  },
  {
    "id": "p-c69cce",
    "offset": 7,
    "text": "ity evam uktā vasumatī jānubhyāṃ śirasā ca namaskāraṃ kṛtvovāca // Vi_98.1 //"
  },
  {
    "id": "p-6e4768",
    "offset": 86,
    "text": "bhagavan, tvatsamīpe satatam evaṃ catvāri bhūtāni kṛtālayāni ākāśaḥ śaṅkharūpī, vāyuś cakrarūpī, tejaś ca gadārūpi, ambho 'mbhoruharūpi / aham apy anenaiva rūpeṇa bhagavatpādamadhye parivartinī bhavitum icchāmi // Vi_98.2 //"
  },
  {
    "id": "p-f7e439",
    "offset": 312,
    "text": "ity evam ukto bhagavāṃs tathety uvāca // Vi_98.3 //"
  },
  {
    "id": "p-a01032",
    "offset": 365,
    "text": "vasudhāpi labdhakāmā tathā cakre // Vi_98.4 //"
  },
  {
    "id": "p-7861b3",
    "offset": 413,
