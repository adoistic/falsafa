[
  {
    "id": "p-0645e2",
    "offset": 0,
    "text": "Vi_59"
  },
  {
    "id": "p-38a0e1",
    "offset": 7,
    "text": "gṛhāśramī vaivāhikāgnau pākayajñān kuryāt // Vi_59.1 //"
  },
  {
    "id": "p-361b32",
    "offset": 64,
    "text": "sāyaṃ prātaś cāgnihotraṃ // Vi_59.2 //"
  },
  {
    "id": "p-ed1e2b",
    "offset": 104,
    "text": "*devatābhyo juhuyāt [devātābhyo] // Vi_59.3 //"
  },
  {
    "id": "p-6b4919",
    "offset": 152,
    "text": "candrārkasaṃnikarṣaviprakarṣayor darśapūrṇamāsābhyāṃ yajeta // Vi_59.4 //"
  },
  {
    "id": "p-123e82",
    "offset": 227,
    "text": "pratyayanaṃ paśunā // Vi_59.5 //"
  },
  {
    "id": "p-2dba96",
    "offset": 261,
    "text": "śaradgrīṣmayoś ca āgrayaṇena // Vi_59.6 //"
  },
  {
    "id": "p-6ad058",
    "offset": 305,
    "text": "vrīhiyavayor vā pāke // Vi_59.7 //"
  },
  {
    "id": "p-32d424",
    "offset": 341,
    "text": "traivārṣikābhyadhikān naḥ // Vi_59.8 //"
  },
  {
    "id": "p-467883",
    "offset": 382,
    "text": "pratyabdaṃ somena // Vi_59.9 //"
  },
  {
    "id": "p-efb46b",
    "offset": 415,
    "text": "vittābhāve iṣṭyā vaiśvānaryā // Vi_59.10 //"
  },
  {
    "id": "p-1a445f",
    "offset": 460,
    "text": "yajñārthaṃ bhikṣitam avāptam arthaṃ sakalam eva vitaret // Vi_59.11 //"
  },
  {
    "id": "p-c3e020",
    "offset": 532,
    "text": "sāyaṃ prātar vaiśvadevaṃ juhuyāt // Vi_59.12 //"
  },
  {
    "id": "p-7153cc",
    "offset": 581,
    "text": "bhikṣāṃ ca bhikṣave dadyāt // Vi_59.13 //"
  },
  {
    "id": "p-62fb7d",
    "offset": 624,
    "text": "arcitabhikṣādānena godānaphalam āpnoti // Vi_59.14 //"
  },
  {
    "id": "p-b2798e",
    "offset": 679,
    "text": "bhikṣvabhāve grāsamātraṃ gavāṃ dadyāt // Vi_59.15 //"
  },
  {
    "id": "p-45d24d",
    "offset": 733,
    "text": "vahnau vā prakṣipet // Vi_59.16 //"
  },
  {
    "id": "p-8b5283",
    "offset": 769,
    "text": "bhukte 'py anne vidyamāne na bhikṣukaṃ pratyācakṣīta // Vi_59.17 //"
  },
  {
    "id": "p-a129b1",
    "offset": 838,
    "text": "kaṇḍanī peṣaṇī cullī udakumbha upaskara iti pañca sūnā gṛhasthasya // Vi_59.18 //"
  },
  {
    "id": "p-603cc6",
    "offset": 921,
    "text": "tanniṣkṛtyarthaṃ ca brahmadevabhūtapitṛnarayajñān kuryāt // Vi_59.19 //"
  },
  {
    "id": "p-c83f31",
    "offset": 994,
    "text": "svādhyāyo brahmayajñaḥ // Vi_59.20 //"
  },
  {
    "id": "p-96be90",
    "offset": 1033,
    "text": "homo daivaḥ // Vi_59.21 //"
  },
  {
    "id": "p-395b97",
    "offset": 1061,
    "text": "pitṛtarpaṇaṃ pitryaḥ // Vi_59.22 //"
  },
  {
    "id": "p-845daf",
    "offset": 1098,
    "text": "balir bhautaḥ // Vi_59.23 //"
  },
  {
    "id": "p-cefcc7",
    "offset": 1128,
    "text": "nṛyajñaś cātithipūjanam // Vi_59.24 //"
  },
  {
    "id": "p-683ffe",
    "offset": 1168,
    "text": "devatātithibhṛtyānāṃ pitṝṇām ātmanaś ca yaḥ  /"
  },
  {
    "id": "p-8875ca",
    "offset": 1216,
    "text": "na nirvapati pañcānām ucchvasan na sa jīvati  || Vi_59.25 ||"
  },
  {
    "id": "p-ae99d2",
    "offset": 1278,
    "text": "brahmacārī yatir bhikṣur jīvanty ete gṛhāśramāt  /"
  },
  {
    "id": "p-d76a1b",
    "offset": 1330,
    "text": "tasmād abhyāgatān etān gṛhastho nāvamānayet  || Vi_59.26 ||"
  },
  {
    "id": "p-a812d0",
    "offset": 1391,
    "text": "gṛhastha eva yajate gṛhasthas tapyate tapaḥ  /"
  },
  {
    "id": "p-3b1529",
    "offset": 1439,
    "text": "pradadāti gṛhasthaś ca tasmāc chreṣṭho gṛhāśramī  || Vi_59.27 ||"
  },
  {
    "id": "p-8e5c51",
    "offset": 1505,
    "text": "ṛṣayaḥ pitaro devā bhūtāny atithayas tathā  /"
  },
  {
    "id": "p-7ff714",
    "offset": 1552,
    "text": "āśāsate kuḍumbibhyas tasmāc chreṣṭho gṛhāśramī  || Vi_59.28 ||"
  },
  {
    "id": "p-8f8886",
    "offset": 1616,
    "text": "trivargasevāṃ satatānnadānaṃ surārcanaṃ brāhmaṇapūjanaṃ ca  /"
  },
  {
    "id": "p-e82be7",
    "offset": 1679,
    "text": "svādhyāyasevāṃ pitṛtarpaṇaṃ ca kṛtvā gṛhī śakrapadaṃ prayāti  || Vi_59.29 ||"
  }
]