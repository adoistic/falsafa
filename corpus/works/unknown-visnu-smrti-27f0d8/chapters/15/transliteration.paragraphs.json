[
  {
    "id": "p-824f9f",
    "offset": 0,
    "text": "Vi_15"
  },
  {
    "id": "p-a5d783",
    "offset": 7,
    "text": "atha dvādaśa putrā bhavanti // Vi_15.1 //"
  },
  {
    "id": "p-48afc5",
    "offset": 50,
    "text": "svakṣetre saṃskṛtāyām utpāditaḥ svayam aurasaḥ prathamaḥ // Vi_15.2 //"
  },
  {
    "id": "p-fe59e5",
    "offset": 122,
    "text": "niyuktāyāṃ sapiṇḍenottamavarṇena votpāditaḥ kṣetrajo dvitīyaḥ // Vi_15.3 //"
  },
  {
    "id": "p-3c0fa4",
    "offset": 199,
    "text": "putrīkāputras tṛtīyaḥ // Vi_15.4 //"
  },
  {
    "id": "p-96d30c",
    "offset": 236,
    "text": "yas tv asyāḥ putraḥ sa me putro bhaved iti yā pitrā dattā sā putrikā // Vi_15.5 //"
  },
  {
    "id": "p-fe3190",
    "offset": 320,
    "text": "putrikāvidhiṃ vināpi pratipāditā bhrātṛvihīnā putrikaiva // Vi_15.6 //"
  },
  {
    "id": "p-46ec97",
    "offset": 392,
    "text": "paunarbhavaś caturthaḥ // Vi_15.7 //"
  },
  {
    "id": "p-d1d9c0",
    "offset": 430,
    "text": "akṣatā bhūyaḥ saṃskṛtā punarbhūḥ // Vi_15.8 //"
  },
  {
    "id": "p-538c04",
    "offset": 478,
    "text": "bhūyas tv asaṃskṛtāpi parapūrvā // Vi_15.9 //"
  },
  {
    "id": "p-e80c89",
    "offset": 525,
    "text": "kānīnaḥ pañcamaḥ // Vi_15.10 //"
  },
  {
    "id": "p-73c463",
    "offset": 558,
    "text": "pitṛgṛhe asaṃskṛtayaivotpāditaḥ // Vi_15.11 //"
  },
  {
    "id": "p-08fce7",
    "offset": 606,
    "text": "sa ca pāṇigrāhasya // Vi_15.12 //"
  },
  {
    "id": "p-c3caf6",
    "offset": 641,
    "text": "gṛhe ca gūḍhotpannaḥ ṣaṣṭhaḥ // Vi_15.13 //"
  },
  {
    "id": "p-fec32b",
    "offset": 686,
    "text": "yasya talpajas tasyāsau // Vi_15.14 //"
  },
  {
    "id": "p-6cc25b",
    "offset": 726,
    "text": "sahoḍhaḥ saptamaḥ // Vi_15.15 //"
  },
  {
    "id": "p-904a70",
    "offset": 760,
    "text": "yā garbhiṇī saṃskriyate tasyāḥ putraḥ // Vi_15.16 //"
  },
  {
    "id": "p-7147a7",
    "offset": 814,
    "text": "sa ca pāṇigrāhasya // Vi_15.17 //"
  },
  {
    "id": "p-e32e9e",
    "offset": 849,
    "text": "dattakaś cāṣṭamaḥ // Vi_15.18 //"
  },
  {
    "id": "p-c19bd3",
    "offset": 883,
    "text": "sa ca mātāpitṛbhyāṃ yasya dattaḥ // Vi_15.19 //"
  },
  {
    "id": "p-f285dc",
    "offset": 932,
    "text": "krītaś ca navamaḥ // Vi_15.20 //"
  },
  {
    "id": "p-689cfb",
    "offset": 966,
    "text": "sa ca yena krītaḥ // Vi_15.21 //"
  },
  {
    "id": "p-efc573",
    "offset": 1000,
    "text": "svayam upagato daśamaḥ // Vi_15.22 //"
  },
  {
    "id": "p-9d1727",
    "offset": 1039,
    "text": "sa ca yasyopagataḥ // Vi_15.23 //"
  },
  {
    "id": "p-8edccc",
    "offset": 1074,
    "text": "apaviddhas tv ekādaśaḥ // Vi_15.24 //"
  },
  {
    "id": "p-db19ec",
    "offset": 1113,
    "text": "pitrā mātrā ca parityaktaḥ // Vi_15.25 //"
  },
  {
    "id": "p-5e3248",
    "offset": 1156,
    "text": "sa ca yena gṛhītaḥ // Vi_15.26 //"
  },
  {
    "id": "p-b8d02c",
    "offset": 1191,
    "text": "yatra kvacanotpāditaś ca dvādaśaḥ // Vi_15.27 //"
  },
  {
    "id": "p-72555d",
    "offset": 1241,
    "text": "eteṣāṃ pūrvaḥ pūrvaḥ śreyān // Vi_15.28 //"
  },
  {
    "id": "p-ca62d4",
    "offset": 1285,
    "text": "sa eva dāyaharaḥ // Vi_15.29 //"
  },
  {
    "id": "p-e0caa6",
    "offset": 1318,
    "text": "sa cānyān bibhṛyāt // Vi_15.30 //"
  },
  {
    "id": "p-b5d44c",
    "offset": 1353,
    "text": "anūḍhānāṃ svavittānurūpeṇa saṃskāraṃ kuryāt // Vi_15.31 //"
  },
  {
    "id": "p-b47b40",
    "offset": 1413,
    "text": "patitaklībācikitsyarogavikalās tv abhāgahāriṇaḥ // Vi_15.32 //"
  },
  {
    "id": "p-dad459",
    "offset": 1477,
    "text": "rikthagrāhibhis te bhartavyāḥ // Vi_15.33 //"
  },
  {
    "id": "p-178d3b",
    "offset": 1523,
    "text": "teṣāṃ caurasāḥ putrā bhāgahāriṇaḥ // Vi_15.34 //"
  },
  {
    "id": "p-b9c931",
    "offset": 1573,
    "text": "na tu patitasya // Vi_15.35 //"
  },
  {
    "id": "p-007a56",
    "offset": 1605,
    "text": "patanīye karmaṇi kṛte tv anantarotpannāḥ // Vi_15.36 //"
  },
  {
    "id": "p-b8536d",
    "offset": 1662,
    "text": "pratilomāsu strīṣu cotpannāś cābhāginaḥ // Vi_15.37 //"
  },
  {
    "id": "p-8f0112",
    "offset": 1718,
    "text": "tatputrāḥ paitāmahe 'py arthe // Vi_15.38 //"
  },
  {
    "id": "p-d7c2eb",
    "offset": 1764,
    "text": "aṃśagrāhibhis te bharaṇīyāḥ // Vi_15.39 //"
  },
  {
    "id": "p-21d947",
    "offset": 1808,
    "text": "yaś cārthaharaḥ sa piṇḍadāyī // Vi_15.40 //"
  },
  {
    "id": "p-dd9743",
    "offset": 1853,
    "text": "ekoḍhānām apy ekasyāḥ putraḥ sarvāsāṃ putra eva // Vi_15.41 //"
  },
  {
    "id": "p-ae54c8",
    "offset": 1917,
    "text": "bhrātṝṇām ekajātānāṃ ca // Vi_15.42 //"
  },
  {
    "id": "p-295ab3",
    "offset": 1957,
    "text": "putraḥ pitṛvittālābhe 'pi piṇḍaṃ dadyāt // Vi_15.43 //"
  },
  {
    "id": "p-a13c44",
    "offset": 2013,
    "text": "punnāmno narakād yasmāt pitaraṃ trāyate sutaḥ  /"
  },
  {
    "id": "p-9f131b",
    "offset": 2063,
    "text": "tasmāt puttra iti proktaḥ svayam eva svayaṃbhuvā  || Vi_15.44 ||"
  },
  {
    "id": "p-a90161",
    "offset": 2129,
    "text": "ṛṇam asmin saṃnayaty amṛtatvaṃ ca gacchati  /"
  },
  {
    "id": "p-0f5568",
    "offset": 2176,
    "text": "pitā putrasya jātasya paśyec cej jīvato mukham  || Vi_15.45 ||"
  },
  {
    "id": "p-98cef9",
    "offset": 2240,
    "text": "putreṇa lokān jayati pautreṇānantyam aśnute  /"
  },
  {
    "id": "p-7fdf5a",
    "offset": 2288,
    "text": "atha putrasya pautreṇa bradhnasyāpnoti viṣṭapam  || Vi_15.46 ||"
  },
  {
    "id": "p-31c46a",
    "offset": 2353,
    "text": "pautradauhitrayor loke viśeṣo nopapadyate  /"
  },
  {
    "id": "p-1a0a2b",
    "offset": 2399,
    "text": "dauhitro 'pi hy aputraṃ taṃ saṃtārayati pautravat  || Vi_15.47 ||"
  }
]