[
  {
    "id": "p-16483a",
    "offset": 0,
    "text": "Vi_45"
  },
  {
    "id": "p-b70149",
    "offset": 7,
    "text": "narakābhibhūtaduḥkhānāṃ tiryaktvam uttīrṇānāṃ mānuṣyeṣu lakṣaṇāni bhavanti // Vi_45.1 //"
  },
  {
    "id": "p-8d5295",
    "offset": 97,
    "text": "kuṣṭhy atipātakī // Vi_45.2 //"
  },
  {
    "id": "p-7b2492",
    "offset": 129,
    "text": "brahmahā yakṣmī // Vi_45.3 //"
  },
  {
    "id": "p-87fd10",
    "offset": 160,
    "text": "surāpaḥ śyāvadantakaḥ // Vi_45.4 //"
  },
  {
    "id": "p-a6d777",
    "offset": 197,
    "text": "suvarṇahārī kunakhī // Vi_45.5 //"
  },
  {
    "id": "p-609d80",
    "offset": 232,
    "text": "gurutarlpago duścarmā // Vi_45.6 //"
  },
  {
    "id": "p-669af2",
    "offset": 269,
    "text": "pūtināsaḥ piśunaḥ // Vi_45.7 //"
  },
  {
    "id": "p-76a751",
    "offset": 302,
    "text": "pūtivaktraḥ sūcakaḥ // Vi_45.8 //"
  },
  {
    "id": "p-f8043d",
    "offset": 337,
    "text": "dhānyacoro 'ṅgahīnaḥ // Vi_45.9 //"
  },
  {
    "id": "p-eaff3b",
    "offset": 373,
    "text": "miśracoro 'tiriktāṅgaḥ // Vi_45.10 //"
  },
  {
    "id": "p-def49a",
    "offset": 412,
    "text": "annāpahārakas tv āmayāvī // Vi_45.11 //"
  },
  {
    "id": "p-736387",
    "offset": 453,
    "text": "vāgapahārako mūkaḥ // Vi_45.12 //"
  },
  {
    "id": "p-ba4316",
    "offset": 488,
    "text": "vastrāpahārakaḥ śvitrī // Vi_45.13 //"
  },
  {
    "id": "p-208263",
    "offset": 527,
    "text": "aśvāpahārakaḥ paṅguḥ // Vi_45.14 //"
  },
  {
    "id": "p-41f679",
    "offset": 564,
    "text": "devabrāhmaṇākrośako mūkaḥ // Vi_45.15 //"
  },
  {
    "id": "p-cf7657",
    "offset": 606,
    "text": "lolajihvo garadaḥ // Vi_45.16 //"
  },
  {
    "id": "p-af019b",
    "offset": 640,
    "text": "unmatto 'gnidaḥ // Vi_45.17 //"
  },
  {
    "id": "p-414f1b",
    "offset": 672,
    "text": "guroḥ pratikūlo 'pasmārī // Vi_45.18 //"
  },
  {
    "id": "p-c1e0f8",
    "offset": 713,
    "text": "goghnas tv andhaḥ // Vi_45.19 //"
  },
  {
    "id": "p-a9c607",
    "offset": 747,
    "text": "dīpāpahārakaś ca // Vi_45.20 //"
  },
  {
    "id": "p-5e0abb",
    "offset": 780,
    "text": "kāṇaś ca dīpanirvāpakaḥ // Vi_45.21 //"
  },
  {
    "id": "p-514e07",
    "offset": 820,
    "text": "trapucāmarasīsakavikrayī rajakaḥ // Vi_45.22 //"
  },
  {
    "id": "p-72bbd8",
    "offset": 869,
    "text": "ekaśaphavikrayī mṛgavyādhaḥ // Vi_45.23 //"
  },
  {
    "id": "p-949ea7",
    "offset": 913,
    "text": "kuṇḍāśī bhagāsyaḥ // Vi_45.24 //"
  },
  {
    "id": "p-f95d6f",
    "offset": 947,
    "text": "ghāṇṭikaḥ stenaḥ // Vi_45.25 //"
  },
  {
    "id": "p-3f8bb2",
    "offset": 980,
    "text": "vārdhuṣiko bhrāmarī // Vi_45.26 //"
  },
  {
    "id": "p-c1dcc1",
    "offset": 1016,
    "text": "mṛṣṭāśy ekākī vātagulmī // Vi_45.27 //"
  },
  {
    "id": "p-0690bc",
    "offset": 1056,
    "text": "samayabhettā khalvāṭaḥ // Vi_45.28 //"
  },
  {
    "id": "p-e75f49",
    "offset": 1095,
    "text": "ślīpady avakīrṇī // Vi_45.29 //"
  },
  {
    "id": "p-27a337",
    "offset": 1128,
    "text": "paravṛttighno daridraḥ // Vi_45.30 //"
  },
  {
    "id": "p-6220c9",
    "offset": 1167,
    "text": "parapīḍākaro dīrgharogī // Vi_45.31 //"
  },
  {
    "id": "p-f97ae1",
    "offset": 1207,
    "text": "evaṃ karmaviśeṣeṇa jāyante lakṣaṇānvitāḥ  /"
  },
  {
    "id": "p-52f10d",
    "offset": 1252,
    "text": "rogānvitās tathāndhāś ca kubjakhañjaikalocanāḥ  || Vi_45.32 ||"
  },
  {
    "id": "p-3ca52d",
    "offset": 1316,
    "text": "vāmanā badhirā mūkā durbalāś ca tathāpare  /"
  },
  {
    "id": "p-a31d75",
    "offset": 1362,
    "text": "tasmāt sarvaprayatnena prāyaścittaṃ samācaret  || Vi_45.33 ||"
  }
]