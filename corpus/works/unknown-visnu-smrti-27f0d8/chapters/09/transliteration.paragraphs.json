[
  {
    "id": "p-183dc4",
    "offset": 0,
    "text": "Vi_9"
  },
  {
    "id": "p-72d116",
    "offset": 6,
    "text": "atha samayakriyā // Vi_9.1 //"
  },
  {
    "id": "p-196ed5",
    "offset": 37,
    "text": "rājadrohasāhaseṣu yathākāmam // Vi_9.2 //"
  },
  {
    "id": "p-17c3d0",
    "offset": 80,
    "text": "nikṣepasteyeṣv arthapramāṇaṃ // Vi_9.3 //"
  },
  {
    "id": "p-4e366d",
    "offset": 123,
    "text": "sarveṣv evārthajāteṣu mūlyaṃ kanakaṃ kalpayet // Vi_9.4 //"
  },
  {
    "id": "p-c3f9f1",
    "offset": 183,
    "text": "tatra kṛṣṇalone śūdraṃ dūrvākaraṃ śāpayet // Vi_9.5 //"
  },
  {
    "id": "p-5e31f5",
    "offset": 239,
    "text": "dvikṛṣṇalone tilakaram // Vi_9.6 //"
  },
  {
    "id": "p-b969db",
    "offset": 276,
    "text": "trikṛṣṇalone rajatakaram // Vi_9.7 //"
  },
  {
    "id": "p-8b6801",
    "offset": 315,
    "text": "catuḥkṛṣṇalone suvarṇakaram // Vi_9.8 //"
  },
  {
    "id": "p-1f78ab",
    "offset": 357,
    "text": "pañcakṛṣṇalone sīroddhṛtamahīkaram // Vi_9.9 //"
  },
  {
    "id": "p-ce5233",
    "offset": 406,
    "text": "suvarṇārdhone kośo deyaḥ śūdrasya // Vi_9.10 //"
  },
  {
    "id": "p-11a725",
    "offset": 455,
    "text": "tataḥ paraṃ yathārhaṃ dhaṭāgnyudakaviṣāṇām anyatamam // Vi_9.11 //"
  },
  {
    "id": "p-f7d505",
    "offset": 523,
    "text": "dviguṇe 'rthe yathābhihitāḥ samayakriyā vaiśyasya // Vi_9.12 //"
  },
  {
    "id": "p-6d7ee1",
    "offset": 588,
    "text": "triguṇe rājanyasya // Vi_9.13 //"
  },
  {
    "id": "p-70b2ef",
    "offset": 622,
    "text": "kośavarjaṃ caturguṇe brāhmaṇasya // Vi_9.14 //"
  },
  {
    "id": "p-d6dc93",
    "offset": 670,
    "text": "na brāhmaṇasya kośaṃ dadyāt // Vi_9.15 //"
  },
  {
    "id": "p-8b84a1",
    "offset": 713,
    "text": "anyatrāgāmikālasamayanibandhanakriyātaḥ // Vi_9.16 //"
  },
  {
    "id": "p-5d67ca",
    "offset": 768,
    "text": "kośasthāne brāhmaṇaṃ sītoddhṛtamahīkaram eva śāpayet // Vi_9.17 //"
  },
  {
    "id": "p-95fbb8",
    "offset": 836,
    "text": "prāgdṛṣṭadoṣe svalpe 'py arthe divyānām anyatamam eva kārayet // Vi_9.18 //"
  },
  {
    "id": "p-780146",
    "offset": 913,
    "text": "satsu viditaṃ sac caritaṃ na mahaty arthe 'pi // Vi_9.19 //"
  },
  {
    "id": "p-2e1d4f",
    "offset": 974,
    "text": "abhiyoktā vartayec chīrṣam // Vi_9.20 //"
  },
  {
    "id": "p-3fac3a",
    "offset": 1016,
    "text": "abhiyuktaś ca divyaṃ kuryāt // Vi_9.21 //"
  },
  {
    "id": "p-f257a4",
    "offset": 1059,
    "text": "rājadrohasāhaseṣu vināpi śīrṣavartanāt // Vi_9.22 //"
  },
  {
    "id": "p-d4ee9a",
    "offset": 1113,
    "text": "strībrāhmaṇavikalāsamartharogiṇāṃ tulā deyā // Vi_9.23 //"
  },
  {
    "id": "p-cfd5bc",
    "offset": 1172,
    "text": "sā ca na vāti vāyau // Vi_9.24 //"
  },
  {
    "id": "p-4456e6",
    "offset": 1207,
    "text": "na kuṣṭhyasamarthalohakārāṇām agnir deyaḥ // Vi_9.25 //"
  },
  {
    "id": "p-0a16cc",
    "offset": 1264,
    "text": "śaradgrīṣmayoś ca // Vi_9.26 //"
  },
  {
    "id": "p-95e220",
    "offset": 1297,
    "text": "na kuṣṭhipaittikabrāhmaṇānāṃ viṣaṃ deyam // Vi_9.27 //"
  },
  {
    "id": "p-bcc418",
    "offset": 1353,
    "text": "prāvṛṣi ca // Vi_9.28 //"
  },
  {
    "id": "p-d9418b",
    "offset": 1379,
    "text": "na śleṣmavyādhyarditānāṃ bhīrūṇāṃ śvāsakāsinām ambujīvināṃ codakam // Vi_9.29 //"
  },
  {
    "id": "p-1308fc",
    "offset": 1461,
    "text": "hemantaśiśirayoś ca // Vi_9.30 //"
  },
  {
    "id": "p-0b92e2",
    "offset": 1496,
    "text": "na nāstikebhyaḥ kośo deyaḥ // Vi_9.31 //"
  },
  {
    "id": "p-7cfa4d",
    "offset": 1538,
    "text": "na deśe vyādhimarakopasṛṣṭe ce // Vi_9.32 //"
  },
  {
    "id": "p-d20fe0",
    "offset": 1584,
    "text": "sacailasnātam āhūya sūryodaya upoṣitam  /"
  },
  {
    "id": "p-a58439",
    "offset": 1627,
    "text": "kārayet sarvadivyāni devabrāhmaṇasaṃnidhau  || Vi_9.33 ||"
  }
]