[
  {
    "id": "p-203dd0",
    "offset": 0,
    "text": "Vi_1"
  },
  {
    "id": "p-ec22cc",
    "offset": 6,
    "text": "brahmarātryāṃ vyatītāyāṃ prabuddhe padmasaṃbhave  /"
  },
  {
    "id": "p-0ed2e3",
    "offset": 59,
    "text": "viṣṇuḥ sisṛkṣur bhūtāni jñātvā bhūmiṃ jalānugām  || Vi_1.1 ||"
  },
  {
    "id": "p-60a18c",
    "offset": 122,
    "text": "jalakrīḍāruci śubhaṃ kalpādhiṣu yathā purā  /"
  },
  {
    "id": "p-ae7c23",
    "offset": 169,
    "text": "vārāham āsthito rūpam ujjahāra vasuṃdharām  || Vi_1.2 ||"
  },
  {
    "id": "p-d0802f",
    "offset": 227,
    "text": "vedapādo yūpadaṃṣṭraḥ kratudantaś citīmukhaḥ  /"
  },
  {
    "id": "p-d651d7",
    "offset": 276,
    "text": "agnijihvo darbharomā brahmaśīrṣo mahātapāḥ  || Vi_1.3 ||"
  },
  {
    "id": "p-a6f08a",
    "offset": 334,
    "text": "ahorātrekṣaṇo divyo vedāṅgaśrutibhūṣaṇaḥ  /"
  },
  {
    "id": "p-398413",
    "offset": 379,
    "text": "ājyanāsaḥ sruvatuṇḍaḥ sāmaghoṣasvano mahān  || Vi_1.4 ||"
  },
  {
    "id": "p-4a6162",
    "offset": 437,
    "text": "dharmasatyamayaḥ śrīmān kramavikramasatkṛtaḥ  /"
  },
  {
    "id": "p-9dfb36",
    "offset": 486,
    "text": "prāyaścittamahāghoṇaḥ paśujānur mahākṛtiḥ  || Vi_1.5 ||"
  },
  {
    "id": "p-b435e3",
    "offset": 543,
    "text": "udgātrāntro homaliṅgo bījauṣadhimahāphalaḥ  /"
  },
  {
    "id": "p-56a9f7",
    "offset": 590,
    "text": "vedyantarātmā mantrasphig- vikṛtaḥ somaśoṇitaḥ  || Vi_1.6 ||"
  },
  {
    "id": "p-b82f5a",
    "offset": 652,
    "text": "vediskandho havir gandho havyakavyādivegavān  /"
  },
  {
    "id": "p-cab39c",
    "offset": 701,
    "text": "prāgvaṃṣakāyo dyutimān nānādīkṣābhir anvitaḥ  || Vi_1.7 ||"
  },
  {
    "id": "p-f91f1e",
    "offset": 761,
    "text": "dakṣiṇāhṛdayo yoga mahāmantramayo mahān  /"
  },
  {
    "id": "p-69c8df",
    "offset": 805,
    "text": "upākarmoṣṭharuciraḥ pravargyāvartabhūṣaṇaḥ  || Vi_1.8 ||"
  },
  {
    "id": "p-319c38",
    "offset": 863,
    "text": "nānācchandogatipatho guhyopaniṣadāsanaḥ  /"
  },
  {
    "id": "p-79dd38",
    "offset": 907,
    "text": "chāyāpatnīsahāyo vai maṇiśṛṅga ivoditaḥ  || Vi_1.9 ||"
  },
  {
    "id": "p-bd1835",
    "offset": 962,
    "text": "mahīṃ sāgaraparyantāṃ saśailavanakānanāṃ  /"
  },
  {
    "id": "p-c93ef1",
    "offset": 1007,
    "text": "ekārṇavajalabhraṣṭām ekārṇavagataḥ prabhuḥ  || Vi_1.10 ||"
  },
  {
    "id": "p-aac9c7",
    "offset": 1066,
    "text": "daṃṣṭrāgreṇa samuddhṛtya lokānāṃ hitakāmyayā  /"
  },
  {
    "id": "p-f67ced",
    "offset": 1115,
    "text": "ādidevo mahāyogī cakāra jagatīṃ punaḥ  || Vi_1.11 ||"
  },
  {
    "id": "p-75082f",
    "offset": 1169,
    "text": "evaṃ yajñavarāheṇa bhūtvā bhūtahitārthinā  /"
  },
  {
    "id": "p-3a0e74",
    "offset": 1215,
    "text": "uddhṛtā pṛthivī devī rasātalagatā purā  || Vi_1.12 ||"
  },
  {
    "id": "p-bdfb5a",
    "offset": 1270,
    "text": "uddhṛtya niścale sthāne sthāpayitvā tathā svake  /"
  },
  {
    "id": "p-5a8174",
    "offset": 1322,
    "text": "yathāsthānaṃ vibhajyāpas tadgatā madhusūdanaḥ  || Vi_1.13 ||"
  },
  {
    "id": "p-628890",
    "offset": 1384,
    "text": "sāmudryaś ca samudreṣu nādeyīś ca nadīṣu ca  /"
  },
  {
    "id": "p-cd86d3",
    "offset": 1432,
    "text": "palvaleṣu ca pālvalyaḥ saraḥsu ca sarobhavāḥ  || Vi_1.14 ||"
  },
  {
    "id": "p-8da44f",
    "offset": 1493,
    "text": "pātālasaptakaṃ cakre lokānāṃ saptakaṃ tathā  /"
  },
  {
    "id": "p-3abdd5",
    "offset": 1541,
    "text": "dvīpānām udadhīnāṃ ca sthānāni vividhāni ca  || Vi_1.15 ||"
  },
  {
    "id": "p-989334",
    "offset": 1601,
    "text": "sthānapālān lokapālān nadīḥ śailavanaspatīn  /"
  },
  {
    "id": "p-8f8c59",
    "offset": 1649,
    "text": "ṛṣīṃś ca sapta dharmajñān vedān sānṅān surāsurān  || Vi_1.16 ||"
  },
  {
    "id": "p-43d87f",
    "offset": 1714,
    "text": "piśācoragagandharva yakṣarākṣasamānuṣān  /"
  },
  {
    "id": "p-a5644c",
    "offset": 1758,
    "text": "paśupakṣimṛgādyāṃś ca bhūtagrāmaṃ caturvidham  /"
  },
  {
    "id": "p-4889a3",
    "offset": 1808,
    "text": "meghendracāpaśampādyān yajñāṃś ca vividhāṃs tathā  || Vi_1.17 ||"
  },
  {
    "id": "p-337b5b",
    "offset": 1874,
    "text": "evaṃ varāho bhagavān kṛtvedaṃ sacarācaram  /"
  },
  {
    "id": "p-7f0c00",
    "offset": 1920,
    "text": "jagaj jagāma lokānām avijñātāṃ tadā gatim  || Vi_1.18 ||"
  },
  {
    "id": "p-974e18",
    "offset": 1978,
    "text": "avijñātāṃ gatiṃ yāte devadeve janārdane  /"
  },
  {
    "id": "p-440927",
    "offset": 2022,
    "text": "vasudhā cintayām āsa kā dhṛtir me bhaviṣyati  || Vi_1.19 ||"
  },
  {
    "id": "p-eac7bc",
    "offset": 2083,
    "text": "pṛcchāmi kaśyapaṃ gatvā sa me vakṣyaty asaṃśayam  /"
  },
  {
    "id": "p-fe235e",
    "offset": 2136,
    "text": "madīyāṃ vahate cintāṃ nityam eva mahāmuniḥ  || Vi_1.20 ||"
  },
  {
    "id": "p-af0e4e",
    "offset": 2195,
    "text": "evaṃ sā niścayaṃ kṛtvā devī strīrūpadhāriṇī  /"
  },
  {
    "id": "p-6f6f39",
    "offset": 2243,
    "text": "jagāma kaśyapaṃ draṣṭuṃ dṛṣṭavāṃs tāṃ ca kaśyapaḥ  || Vi_1.21 ||"
  },
  {
    "id": "p-609e74",
    "offset": 2309,
    "text": "nīlapaṅkajapatrākṣīṃ śāradendunibhānanām  /"
  },
  {
    "id": "p-814792",
    "offset": 2354,
    "text": "alisaṃghālakāṃ śubhrāṃ bandhujīvādharāṃ śubhām  || Vi_1.22 ||"
  },
  {
    "id": "p-915c08",
    "offset": 2417,
    "text": "subhrūṃ susūkṣmadaśanāṃ cārunāsāṃ natabhruvam  /"
  },
  {
    "id": "p-58cf68",
    "offset": 2467,
    "text": "kambukaṇṭhīṃ saṃhatorūṃ pīnorujaghanasthalām  || Vi_1.23 ||"
  },
  {
    "id": "p-0cc464",
    "offset": 2528,
    "text": "virejatuḥ stanau yasyāḥ samau pīnau nirantarau  /"
  },
  {
    "id": "p-7e31a2",
    "offset": 2579,
    "text": "śakrebhakumbhasaṃkāśau śātakumbhasamadyutī  || Vi_1.24 ||"
  },
  {
    "id": "p-6bc661",
    "offset": 2638,
    "text": "mṛṇālakomalau bāhū karau kisalayopamau  /"
  },
  {
    "id": "p-2be9c4",
    "offset": 2681,
    "text": "rukmastambhanibhāv ūrū gūḍhe śliṣṭe ca jānunī  || Vi_1.25 ||"
  },
  {
    "id": "p-8831b0",
    "offset": 2743,
    "text": "jaṅghe virome susame pādāv atimanoramau  /"
  },
  {
    "id": "p-d090df",
    "offset": 2787,
    "text": "jaghanaṃ ca ghanaṃ madhyaṃ yathā kesariṇaḥ śiśoḥ  || Vi_1.26 ||"
  },
  {
    "id": "p-c91d4e",
    "offset": 2852,
    "text": "prabhāyutā nakhās tāmrā rūpaṃ sarvamanoharam  /"
  },
  {
    "id": "p-cae6d2",
    "offset": 2901,
    "text": "kurvāṇāṃ vīkṣitair nityaṃ nīlotpalayutā diśaḥ  || Vi_1.27 ||"
  },
  {
    "id": "p-044601",
    "offset": 2963,
    "text": "kurvāṇāṃ prabhayā devīṃ tathā vitimirā diśaḥ  /"
  },
  {
    "id": "p-94962d",
    "offset": 3012,
    "text": "susūkṣmaśuklavasanāṃ ratnottamavibhūṣitāṃ  || Vi_1.28 ||"
  },
  {
    "id": "p-eed95a",
    "offset": 3070,
    "text": "padanyāsair vasumatīṃ sapadmām iva kurvatīṃ  /"
  },
  {
    "id": "p-3e196a",
    "offset": 3118,
    "text": "rūpayauvanasaṃpannāṃ vinītavad upasthitām  || Vi_1.29 ||"
  },
  {
    "id": "p-e2d5c1",
    "offset": 3176,
    "text": "samīpam āgatāṃ dṛṣṭvā pūjayitvātha kaśyapaḥ  /"
  },
  {
    "id": "p-1e66d8",
    "offset": 3224,
    "text": "uvāca tāṃ varārohe vijñātaṃ hṛdgataṃ mayā  || Vi_1.30 ||"
  },
  {
    "id": "p-205889",
    "offset": 3282,
    "text": "dhare tava viśālākṣi gaccha devi janārdanam  /"
  },
  {
    "id": "p-c5ff57",
    "offset": 3330,
    "text": "sa te vakṣyaty aśeṣeṇa bhāvinī te yathā dhṛtiḥ  || Vi_1.31 ||"
  },
  {
    "id": "p-ccf405",
    "offset": 3393,
    "text": "kṣīrode vasatis tasya mayā jñātā śubhānane  /"
  },
  {
    "id": "p-b9e820",
    "offset": 3440,
    "text": "dhyānayogena cārvaṅgi tvadarthaṃ tatprasādataḥ  || Vi_1.32 ||"
  },
  {
    "id": "p-9dc33e",
    "offset": 3503,
    "text": "ity evam uktā saṃpūjya kaśyapaṃ vasudhā tataḥ  /"
  },
  {
    "id": "p-bd8518",
    "offset": 3553,
    "text": "prayayau keśavaṃ draṣṭuṃ kṣīrodam atha sāgaram  || Vi_1.33 ||"
  },
  {
    "id": "p-20aa6d",
    "offset": 3616,
    "text": "sā dadarśāmṛtanidhiṃ candraraśmimanoharam  /"
  },
  {
    "id": "p-360874",
    "offset": 3662,
    "text": "pavanakṣobhasaṃjāta- vīcīśatasamākulam  || Vi_1.34 ||"
  },
  {
    "id": "p-e6a0ac",
    "offset": 3717,
    "text": "himavacchatasaṃkāśaṃ bhūmaṇḍalam ivāparam  /"
  },
  {
    "id": "p-36259b",
    "offset": 3763,
    "text": "vīcīhastaiḥ pracalitair āhvayānam iva kṣitim  || Vi_1.35 ||"
  },
  {
    "id": "p-6c6714",
    "offset": 3824,
    "text": "tair eva śuklatāṃ candre vidadhānam ivāniśam  /"
  },
  {
    "id": "p-e6052d",
    "offset": 3873,
    "text": "antarasthena hariṇā vigatāśeṣakalmaṣam  || Vi_1.36 ||"
  },
  {
    "id": "p-dddfd1",
    "offset": 3928,
    "text": "yasmāt tasmād dhārayantaṃ suśuklāṃ tanum ūrjitām  /"
  },
  {
    "id": "p-747980",
    "offset": 3981,
    "text": "pāṇḍuraṃ khagamāgamyam adhobhuvanavartinam  || Vi_1.37 ||"
  },
  {
    "id": "p-fb5bb8",
    "offset": 4040,
    "text": "indranīlakaḍārāḍhyaṃ viparītam ivāmbaram  /"
  },
  {
    "id": "p-0efa6e",
    "offset": 4085,
    "text": "phalāvalīsamudbhūta- vanasaṃgham ivācitam  || Vi_1.38 ||"
  },
  {
    "id": "p-4e6cb6",
    "offset": 4143,
    "text": "nirmokam iva śeṣāher vistīrṇāntam atīva hi  /"
  },
  {
    "id": "p-318a34",
    "offset": 4190,
    "text": "taṃ dṛṣṭvā tatra madhyasthaṃ daḍṛśe keśavālayam  || Vi_1.39 ||"
  },
  {
    "id": "p-750ac3",
    "offset": 4254,
    "text": "anirdeśyaparīmāṇam anirdeśyarddhisaṃyutam  /"
  },
  {
    "id": "p-92682f",
    "offset": 4300,
    "text": "śeṣaparyaṅkagaṃ tasmin dadarśa madhusūdanam  || Vi_1.40 ||"
  },
  {
    "id": "p-dcec4d",
    "offset": 4360,
    "text": "śeṣāhiphaṇaratnāṃśu durvibhāvyamukhāmbujam  /"
  },
  {
    "id": "p-a066e8",
    "offset": 4407,
    "text": "śaśāṅkaśatasaṃkāśaṃ sūryāyutasamaprabham  || Vi_1.41 ||"
  },
  {
    "id": "p-38518c",
    "offset": 4464,
    "text": "pītavāsasamakṣobhyaṃ sarvaratnavibhūṣitam [savaratna]  /"
  },
  {
    "id": "p-2b2372",
    "offset": 4522,
    "text": "mukuṭenārkavarṇena kuṇḍalābhyāṃ virājitam  || Vi_1.42 ||"
  },
  {
    "id": "p-03f37c",
    "offset": 4580,
    "text": "saṃvāhyamānāṅghriyugaṃ lakṣmyā karatalaiḥ śubhaiḥ  /"
  },
  {
    "id": "p-bde34a",
    "offset": 4634,
    "text": "śarīradhāribhiḥ śastraiḥ sevyamānaṃ samantataḥ  || Vi_1.43 ||"
  },
  {
    "id": "p-1a368b",
    "offset": 4697,
    "text": "taṃ dṛṣṭvā puṇḍarīkākṣaṃ vavande madhusūdanam  /"
  },
  {
    "id": "p-102c29",
    "offset": 4747,
    "text": "jānubhyām avaniṃ gatvā vijñāpayati cāpy atha  || Vi_1.44 ||"
  },
  {
    "id": "p-987a56",
    "offset": 4808,
    "text": "uddhṛtāhaṃ tvayā deva rasātalatalaṃ gatā  /"
  },
  {
    "id": "p-580714",
    "offset": 4853,
    "text": "svasthāne sthāpitā viṣṇo lokānāṃ hitakāmyayā  || Vi_1.45 ||"
  },
  {
    "id": "p-97d85d",
    "offset": 4914,
    "text": "tatrādhunā hi deveśa kā dhṛtir me bhaviṣyati  /"
  },
  {
    "id": "p-7500d1",
    "offset": 4963,
    "text": "evam uktas tayā devyā devo vacanam abravīt  || Vi_1.46 ||"
  },
  {
    "id": "p-ca346c",
    "offset": 5022,
    "text": "varṇāśramācāraratāḥ santaḥ śāstraikatatparāḥ  /"
  },
  {
    "id": "p-fbfbf2",
    "offset": 5071,
    "text": "tvāṃ dhare dhārayiṣyanti teṣāṃ tvadbhāra āhitaḥ  || Vi_1.47 ||"
  },
  {
    "id": "p-38b3c7",
    "offset": 5135,
    "text": "evam uktā vasumatī devadevam abhāṣata  /"
  },
  {
    "id": "p-dd31a3",
    "offset": 5177,
    "text": "varṇānām āśramāṇāṃ ca dharmān vada sanātana  || Vi_1.48 ||"
  },
  {
    "id": "p-93a962",
    "offset": 5237,
    "text": "tvatto 'ham śrotum icchāmi tvaṃ hi me paramā gatiḥ  /"
  },
  {
    "id": "p-e28b9c",
    "offset": 5292,
    "text": "namas te devadeveśa devāribalasūdana  || Vi_1.49 ||"
  },
  {
    "id": "p-1cb530",
    "offset": 5345,
    "text": "nārāyaṇa jagannātha śaṅkhacakragadādhara  /"
  },
  {
    "id": "p-c4bd9a",
    "offset": 5390,
    "text": "padmanābha hṛṣīkeśa mahābalaparākrama  || Vi_1.50 ||"
  },
  {
    "id": "p-660dc0",
    "offset": 5444,
    "text": "atīndriya suduṣpāra deva śārṅgadhanurdhara  /"
  },
  {
    "id": "p-601d61",
    "offset": 5491,
    "text": "varāha bhīma govinda purāṇa puruṣottama  || Vi_1.51 ||"
  },
  {
    "id": "p-027923",
    "offset": 5547,
    "text": "hiraṇyakeśa viśvākṣa yajñamūrte nirañjana  /"
  },
  {
    "id": "p-ac8803",
    "offset": 5593,
    "text": "kṣetrakṣetrajñadeveśa salilārṇavaśāyaka  || Vi_1.52 ||"
  },
  {
    "id": "p-ce6b2c",
    "offset": 5649,
    "text": "mantra mantravahācintya vedavedāṅgavigraha  /"
  },
  {
    "id": "p-c2c470",
    "offset": 5696,
    "text": "jagato 'sya samagrasya sṛṣṭisaṃhārakāraka  || Vi_1.53 ||"
  },
  {
    "id": "p-e6ad2f",
    "offset": 5754,
    "text": "dharmādharmajña dharmāṅga dharmayone varaprada  /"
  },
  {
    "id": "p-d5227b",
    "offset": 5805,
    "text": "viṣvaksenāmṛta vyoma madhukaiṭabhasūdana  || Vi_1.54 ||"
  },
  {
    "id": "p-c28cdc",
    "offset": 5862,
    "text": "bṛhatāṃ bṛṃhaṇājñeya sarva sarvābhayaprada  /"
  },
  {
    "id": "p-996cc0",
    "offset": 5909,
    "text": "vareṇyānagha jīmūta jagannirmāṇakāraka  || Vi_1.55 ||"
  },
  {
    "id": "p-aa4325",
    "offset": 5964,
    "text": "āpyāyana apāṃ sthāna caitanyādhāra niṣkriya  /"
  },
  {
    "id": "p-27a8d4",
    "offset": 6012,
    "text": "saptaśīrṣādhvaraguro purāṇapuruṣottama  || Vi_1.56 ||"
  },
  {
    "id": "p-d13c0b",
    "offset": 6067,
    "text": "dhruvākṣara susūkṣmeśa bhaktavatsala pāvana  /"
  },
  {
    "id": "p-a4122d",
    "offset": 6115,
    "text": "tvaṃ gatiḥ sarvadevānāṃ tvaṃ gatir brahmavādinām  || Vi_1.57 ||"
  },
  {
    "id": "p-4a37ff",
    "offset": 6180,
    "text": "tathā viditavedyānāṃ gatis tvaṃ puruṣottama  /"
  },
  {
    "id": "p-c495ad",
    "offset": 6228,
    "text": "prapannāsmi jagannātha dhruvaṃ vācaspatiṃ prabhum  || Vi_1.58 ||"
  },
  {
    "id": "p-5764e3",
    "offset": 6294,
    "text": "subrahmaṇyam anādhṛṣyaṃ vasuṣeṇaṃ vasupradam  /"
  },
  {
    "id": "p-af697b",
    "offset": 6343,
    "text": "mahāyogabalopetaṃ pṛśnigarbhaṃ dhṛtārciṣam  || Vi_1.59 ||"
  },
  {
    "id": "p-503c08",
    "offset": 6402,
    "text": "vāsudevaṃ mahātmānaṃ puṇḍarīkākṣaṃ acyutam  /"
  },
  {
    "id": "p-525537",
    "offset": 6449,
    "text": "surāsuraguruṃ devaṃ vibhuṃ bhūtamaheśvaram  || Vi_1.60 ||"
  },
  {
    "id": "p-649f9a",
    "offset": 6508,
    "text": "ekavyūhaṃ caturbāhuṃ jagatkāraṇakāraṇam  /"
  },
  {
    "id": "p-c16950",
    "offset": 6552,
    "text": "brūhi me bhagavan dharmāṃś cāturvarṇyasya śāśvatān  || Vi_1.61 ||"
  },
  {
    "id": "p-cd65f3",
    "offset": 6619,
    "text": "āśramācārasaṃyuktān sarahasyān sasaṃgrahān  /"
  },
  {
    "id": "p-0ab9f5",
    "offset": 6666,
    "text": "evam uktas tu deveśaḥ kṣoṇyā kṣoṇīm abhāṣata  || Vi_1.62 ||"
  },
  {
    "id": "p-d01ab9",
    "offset": 6727,
    "text": "śṛṇu devi dhare dharmāṃś cāturvarṇyasya śāśvatān  /"
  },
  {
    "id": "p-f10fa7",
    "offset": 6780,
    "text": "āśramācārasaṃyuktān sarahasyān sasaṃgrahān  || Vi_1.63 ||"
  },
  {
    "id": "p-33d253",
    "offset": 6839,
    "text": "ye tu tvāṃ dhārayiṣyanti santas teṣāṃ parāyaṇān  /"
  },
  {
    "id": "p-9d1c63",
    "offset": 6891,
    "text": "niṣaṇṇā bhava vāmoru kāñcane 'smin varāsane  || Vi_1.64 ||"
  },
  {
    "id": "p-504047",
    "offset": 6951,
    "text": "sukhāsīnā nibodha tvaṃ dharmān nigadato mama  /"
  },
  {
    "id": "p-c5295c",
    "offset": 7000,
    "text": "śuśruve vaiṣṇavān dharmān sukhāsīnā dharā tadā  || Vi_1.65 ||"
  }
]