[
  {
    "id": "p-135501",
    "offset": 0,
    "text": "Vi_36"
  },
  {
    "id": "p-3963e8",
    "offset": 7,
    "text": "yāgasthasya kṣatriyasya vaiśyasya ca rajasvalāyāś cāntarvatnyāś cātrigotrāyāś cāvijñātasya garbhasya śaraṇāgatasya ca ghātanaṃ brahmahatyāsamānīti // Vi_36.1 //"
  },
  {
    "id": "p-45568c",
    "offset": 169,
    "text": "kauṭasākṣyaṃ suhṛdvadha ity etau surāpānasamau // Vi_36.2 //"
  },
  {
    "id": "p-954997",
    "offset": 231,
    "text": "brāhmaṇasya bhūmyapaharaṇaṃ nikṣepāpaharaṇaṃ suvarṇasteyasamam // Vi_36.3 //"
  },
  {
    "id": "p-83c66e",
    "offset": 309,
    "text": "pitṛvyamātāmahamātulaśvaśuranṛpapatnyabhigamanaṃ gurudāragamanasamam // Vi_36.4 //"
  },
  {
    "id": "p-3dc351",
    "offset": 393,
    "text": "pitṛṣvasṛmātṛṣvasṛsvasṛgamanam ca // Vi_36.5 //"
  },
  {
    "id": "p-996ba1",
    "offset": 442,
    "text": "śrotriyartvigupādhyāyamitrapatnyabhigamanaṃ ca // Vi_36.6 //"
  },
  {
    "id": "p-58e10f",
    "offset": 504,
    "text": "svasuḥ sakhyāḥ sagotrāya uttamavarṇāyāḥ kumāryā antyajāyā rajasvalāyāḥ śaraṇāgatāyāḥ *pravrajitāyā nikṣiptāyāś ca [pravrajitāyāḥ ni] // Vi_36.7 //"
  },
  {
    "id": "p-c9f8b0",
    "offset": 652,
    "text": "anupātakinas tv ete mahāpātakino yathā  /"
  },
  {
    "id": "p-8bf635",
    "offset": 695,
    "text": "aśvamedhena śudhyanti tīrthānusaraṇena vā  || Vi_36.8 ||"
  }
]