    "text": "Vi_89"
  },
  {
    "id": "p-03210b",
    "offset": 7,
    "text": "māsaḥ kārttiko 'gnidaivatyaḥ // Vi_89.1 //"
  },
  {
    "id": "p-487d32",
    "offset": 51,
    "text": "agniś ca sarvadevānāṃ mukham // Vi_89.2 //"
  },
  {
    "id": "p-4fa86c",
    "offset": 95,
    "text": "tasmāt tu kārttikaṃ māsaṃ bahiḥsnāyī gāyatrījapanirataḥ sakṛd eva haviṣyāśī saṃvatsarakṛtāt pāpāt pūto bhavati // Vi_89.3 //"
  },
  {
    "id": "p-03a59a",
    "offset": 221,
    "text": "kārttikaṃ sakalaṃ māsaṃ nityasnāyī jitendriyaḥ  /"
  },
  {
    "id": "p-d740e0",
    "offset": 272,
    "text": "japan haviṣyabhugdāntaḥ sarvapāpaiḥ pramucyate  || Vi_89.4 ||"
  }
]