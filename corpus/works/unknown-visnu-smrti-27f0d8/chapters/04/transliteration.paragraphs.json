[
  {
    "id": "p-1d3dcc",
    "offset": 0,
    "text": "Vi_4"
  },
  {
    "id": "p-582b2a",
    "offset": 6,
    "text": "jālasthārkamarīcigataṃ rajaḥ trasareṇusaṃjñakam // Vi_4.1 //"
  },
  {
    "id": "p-ae6c56",
    "offset": 68,
    "text": "tadaṣṭakaṃ likṣā // Vi_4.2 //"
  },
  {
    "id": "p-dee54a",
    "offset": 99,
    "text": "tattrayaṃ rājasarṣapaḥ // Vi_4.3 //"
  },
  {
    "id": "p-39672a",
    "offset": 136,
    "text": "tattrayaṃ gaurasarṣapaḥ // Vi_4.4 //"
  },
  {
    "id": "p-70d52f",
    "offset": 174,
    "text": "tatṣaṭkaṃ yavaḥ // Vi_4.5 //"
  },
  {
    "id": "p-961203",
    "offset": 204,
    "text": "tattrayaṃ kṛṣṇalam // Vi_4.6 //"
  },
  {
    "id": "p-85816b",
    "offset": 237,
    "text": "tatpañcakaṃ māṣaḥ // Vi_4.7 //"
  },
  {
    "id": "p-ad1c68",
    "offset": 269,
    "text": "taddvādaśakam akṣārdham // Vi_4.8 //"
  },
  {
    "id": "p-c7a007",
    "offset": 307,
    "text": "akṣārdham eva sacaturmāṣakaṃ suvarṇaḥ // Vi_4.9 //"
  },
  {
    "id": "p-2781f3",
    "offset": 359,
    "text": "catuḥsuvarṇako niṣkaḥ // Vi_4.10 //"
  },
  {
    "id": "p-e346a4",
    "offset": 396,
    "text": "dve kṛṣṇale samadhṛte rūpyamāṣakaḥ // Vi_4.11 //"
  },
  {
    "id": "p-f330ac",
    "offset": 446,
    "text": "tatṣoḍaśakaṃ dharaṇam // Vi_4.12 //"
  },
  {
    "id": "p-7e1218",
    "offset": 483,
    "text": "tāmrakārṣikaḥ kārṣāpaṇaḥ // Vi_4.13 //"
  },
  {
    "id": "p-94853f",
    "offset": 523,
    "text": "paṇānāṃ dve śate sārdhe prathamaḥ sāhasaḥ smṛtaḥ  /"
  },
  {
    "id": "p-e437af",
    "offset": 576,
    "text": "madhyamaḥ pañca vijñeyaḥ sahasraṃ tv eṣa cottamaḥ  || Vi_4.14 ||"
  }
]