[
  {
    "id": "p-963c37",
    "offset": 0,
    "text": "Vi_91"
  },
  {
    "id": "p-d0745f",
    "offset": 7,
    "text": "atha kūpakartus tatpravṛtte pānīye duṣkṛtasyārdhaṃ vinaśyati // Vi_91.1 //"
  },
  {
    "id": "p-6618d4",
    "offset": 83,
    "text": "taḍāgakṛn nityatṛpto vāruṇaṃ lokam aśnute // Vi_91.2 //"
  },
  {
    "id": "p-cda802",
    "offset": 140,
    "text": "jalapradaḥ sadā tṛpto bhavati // Vi_91.3 //"
  },
  {
    "id": "p-9a68fa",
    "offset": 185,
    "text": "vṛkṣāropayitur vṛkṣāḥ paraloke putrā bhavanti // Vi_91.4 //"
  },
  {
    "id": "p-5f7399",
    "offset": 246,
    "text": "vṛkṣaprado vṛkṣaprasūnair devān prīṇayati // Vi_91.5 //"
  },
  {
    "id": "p-20834c",
    "offset": 303,
    "text": "phalaiś cātithīn // Vi_91.6 //"
  },
  {
    "id": "p-c7d0fb",
    "offset": 335,
    "text": "chāyayā cābhyāgatān // Vi_91.7 //"
  },
  {
    "id": "p-934ffe",
    "offset": 370,
    "text": "deve varṣaty udakena pitṝn // Vi_91.8 //"
  },
  {
    "id": "p-005c44",
    "offset": 412,
    "text": "setukṛt svargam āpnoti // Vi_91.9 //"
  },
  {
    "id": "p-6c31de",
    "offset": 450,
    "text": "devāyatanakārī yasya devasyāyatanaṃ karoti tasyaiva lokam āpnoti // Vi_91.10 //"
  },
  {
    "id": "p-352dd2",
    "offset": 531,
    "text": "sudhāsiktaṃ kṛtvā yaśasā virājate // Vi_91.11 //"
  },
  {
    "id": "p-192e86",
    "offset": 581,
    "text": "vicitraṃ kṛtvā gandharvalokam āpnoti // Vi_91.12 //"
  },
  {
    "id": "p-b6c765",
    "offset": 634,
    "text": "puṣpapradānena śrīmān bhavati // Vi_91.13 //"
  },
  {
    "id": "p-6927f0",
    "offset": 680,
    "text": "anulepanapradānena kīrtimān // Vi_91.14 //"
  },
  {
    "id": "p-45a28e",
    "offset": 724,
    "text": "dīpapradānena cakṣuṣmān sarvatrojjvalaś ca // Vi_91.15 //"
  },
  {
    "id": "p-290c41",
    "offset": 783,
    "text": "annapradānena balavān // Vi_91.16 //"
  },
  {
    "id": "p-9a7638",
    "offset": 821,
    "text": "devanirmālyāpanayanāt godānaphalam āpnoti // Vi_91.17 //"
  },
  {
    "id": "p-b056fb",
    "offset": 879,
    "text": "devagṛhamārjanāt tadupalepanāt brāhmaṇocchiṣṭamārjanāt pādaśaucād akalyaparicaraṇāc ca // Vi_91.18 //"
  },
  {
    "id": "p-11eeec",
    "offset": 982,
    "text": "kūpārāmataḍāgeṣu devatāyataneṣu ca  /"
  },
  {
    "id": "p-d92ea4",
    "offset": 1021,
    "text": "punaḥ saṃskārakartā ca labhate maulikaṃ phalam  || Vi_91.19 ||"
  }
]