[
  {
    "id": "p-9a3e7c",
    "offset": 0,
    "text": "Vi_81"
  },
  {
    "id": "p-757078",
    "offset": 7,
    "text": "nānnam āsanam āropayet // Vi_81.1 //"
  },
  {
    "id": "p-ead52c",
    "offset": 45,
    "text": "na padā spṛśet // Vi_81.2 //"
  },
  {
    "id": "p-6928ea",
    "offset": 75,
    "text": "nāvakṣutaṃ kuryāt // Vi_81.3 //"
  },
  {
    "id": "p-3acbef",
    "offset": 108,
    "text": "tilaiḥ sarṣapair vā yātudhānān visarjayet // Vi_81.4 //"
  },
  {
    "id": "p-654210",
    "offset": 165,
    "text": "saṃvṛte ca śrāddhaṃ kuryāt // Vi_81.5 //"
  },
  {
    "id": "p-4d008f",
    "offset": 207,
    "text": "na rajasvalāṃ paśyet // Vi_81.6 //"
  },
  {
    "id": "p-d10dc3",
    "offset": 243,
    "text": "na śvānam // Vi_81.7 //"
  },
  {
    "id": "p-e5cafc",
    "offset": 268,
    "text": "na viḍvarāham // Vi_81.8 //"
  },
  {
    "id": "p-b5723b",
    "offset": 297,
    "text": "na grāmakukkuṭam // Vi_81.9 //"
  },
  {
    "id": "p-7fcfd9",
    "offset": 329,
    "text": "prayatnāt śrāddham ajasya darśayet // Vi_81.10 //"
  },
  {
    "id": "p-49e3e1",
    "offset": 380,
    "text": "aśnīyur brāhmaṇāś ca vāgyatāḥ // Vi_81.11 //"
  },
  {
    "id": "p-9e9177",
    "offset": 426,
    "text": "na veṣṭitaśirasaḥ // Vi_81.12 //"
  },
  {
    "id": "p-9f5112",
    "offset": 460,
    "text": "na sopānatkāḥ // Vi_81.13 //"
  },
  {
    "id": "p-dd3899",
    "offset": 490,
    "text": "na pīṭhopahitapādāḥ // Vi_81.14 //"
  },
  {
    "id": "p-2f0ca8",
    "offset": 526,
    "text": "na hīnāṅgā adhikāṅgāḥ śrāddhaṃ paśyeyuḥ // Vi_81.15 //"
  },
  {
    "id": "p-a50502",
    "offset": 582,
    "text": "na śūdrāḥ // Vi_81.16 //"
  },
  {
    "id": "p-bda90f",
    "offset": 608,
    "text": "na patitāḥ // Vi_81.17 //"
  },
  {
    "id": "p-e69c98",
    "offset": 635,
    "text": "na mahārogiṇaḥ // Vi_81.18 //"
  },
  {
    "id": "p-53ffda",
    "offset": 666,
    "text": "tatkālaṃ brāhmaṇaṃ brāhmaṇānumatena bhikṣukaṃ vā pūjayet // Vi_81.19 //"
  },
  {
    "id": "p-c79a1a",
    "offset": 739,
    "text": "havir guṇān na brāhmaṇā brūyur dātrā pṛṣṭāḥ // Vi_81.20 //"
  },
  {
    "id": "p-d2ae42",
    "offset": 799,
    "text": "yāvad ūṣmā bhavaty anne yāvad aśnanti vāgyatāḥ  /"
  },
  {
    "id": "p-2f8dd4",
    "offset": 850,
    "text": "tāvad aśnanti pitaro yāvan noktā havir guṇāḥ  || Vi_81.21 ||"
  },
  {
    "id": "p-8708e4",
    "offset": 912,
    "text": "sārvavarṇikam annādyaṃ saṃnīyāplāvya vāriṇā  /"
  },
  {
    "id": "p-fcb2b4",
    "offset": 960,
    "text": "samutsṛjed bhuktavatām agrato vikiran bhuvi  || Vi_81.22 ||"
  },
  {
    "id": "p-e0a60e",
    "offset": 1021,
    "text": "asaṃskṛtapramītānāṃ tyāgināṃ kulayoṣitām  /"
  },
  {
    "id": "p-f92f5e",
    "offset": 1066,
    "text": "ucchiṣṭaṃ bhāgadheyaṃ syād darbheṣu vikiraś ca yaḥ  || Vi_81.23 ||"
  },
  {
    "id": "p-8d51f1",
    "offset": 1134,
    "text": "uccheṣaṇaṃ bhūmigatam ajihmasyāśaṭhasya ca  /"
  },
  {
    "id": "p-51aeea",
    "offset": 1181,
    "text": "dāsavargasya tat pitrye bhāgadheyaṃ pracakṣate  || Vi_81.24 ||"
  }
]