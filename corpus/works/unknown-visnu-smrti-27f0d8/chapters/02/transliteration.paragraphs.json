[
  {
    "id": "p-233dd5",
    "offset": 0,
    "text": "Vi_2"
  },
  {
    "id": "p-9be5f3",
    "offset": 6,
    "text": "om / brāhmaṇaḥ kṣatriyo vaiśyaḥ śūdraś ceti varṇāś catvāraḥ // Vi_2.1 //"
  },
  {
    "id": "p-441e1d",
    "offset": 80,
    "text": "teṣām ādyā dvijātayas trayaḥ // Vi_2.2 //"
  },
  {
    "id": "p-4e8ed6",
    "offset": 123,
    "text": "teṣāṃ niṣekādyaḥ śmaśānānto mantravat kriyāsamūhaḥ // Vi_2.3 //"
  },
  {
    "id": "p-781837",
    "offset": 188,
    "text": "teṣāṃ ca dharmāḥ // Vi_2.4 //"
  },
  {
    "id": "p-395e82",
    "offset": 219,
    "text": "brāhmaṇasyādhyāpanam // Vi_2.5 //"
  },
  {
    "id": "p-685912",
    "offset": 254,
    "text": "kṣatriyasya śastranityatā // Vi_2.6 //"
  },
  {
    "id": "p-1a21cd",
    "offset": 294,
    "text": "vaiśyasya paśupālanam // Vi_2.7 //"
  },
  {
    "id": "p-eee87d",
    "offset": 330,
    "text": "śūdrasya dvijātiśuśrūṣā // Vi_2.8 //"
  },
  {
    "id": "p-322426",
    "offset": 368,
    "text": "dvijānāṃ yajanādhyayane // Vi_2.9 //"
  },
  {
    "id": "p-ca3b03",
    "offset": 406,
    "text": "athaiteṣāṃ vṛttayaḥ // Vi_2.10 //"
  },
  {
    "id": "p-165f58",
    "offset": 441,
    "text": "brāhmaṇasya yājanapratigrahau // Vi_2.11 //"
  },
  {
    "id": "p-208b8e",
    "offset": 486,
    "text": "kṣatriyasya kṣititrāṇam // Vi_2.12 //"
  },
  {
    "id": "p-eb2609",
    "offset": 525,
    "text": "kṛṣigorakṣavāṇijyakusīdayonipoṣaṇāni vaiśyasya // Vi_2.13 //"
  },
  {
    "id": "p-454a33",
    "offset": 587,
    "text": "śūdrasya sarvaśilpāni // Vi_2.14 //"
  },
  {
    "id": "p-414851",
    "offset": 624,
    "text": "āpady anantarā vṛttiḥ // Vi_2.15 //"
  },
  {
    "id": "p-8f5722",
    "offset": 661,
    "text": "kṣamā satyam damaḥ śaucaṃ dānam indriyasaṃyamaḥ  /"
  },
  {
    "id": "p-5474bd",
    "offset": 713,
    "text": "ahiṃsā guruśuśrūṣā tīrthānusaraṇaṃ dayā  || Vi_2.16 ||"
  },
  {
    "id": "p-efb675",
    "offset": 769,
    "text": "ārjavaṃ lobhaśūnyatvaṃ devabrāhmaṇapūjanam  /"
  },
  {
    "id": "p-0ffce6",
    "offset": 816,
    "text": "anabhyasūyā ca tathā dharmaḥ sāmānya ucyate  || Vi_2.17 ||"
  }
]