[
  {
    "id": "p-0e45ee",
    "offset": 0,
    "text": "Vi_51"
  },
  {
    "id": "p-9d51cb",
    "offset": 7,
    "text": "surāpaḥ sarvakarmavarjitaḥ kaṇān varṣam aśnīyāt // Vi_51.1 //"
  },
  {
    "id": "p-eda8ca",
    "offset": 70,
    "text": "malānāṃ madyānāṃ cānyatamasya prāśane cāndrāyaṇaṃ kuryāt // Vi_51.2 //"
  },
  {
    "id": "p-e28cc9",
    "offset": 142,
    "text": "laśunapalāṇḍugṛñjanaitadgandhiviḍvarāhagrāmakukkuṭavānaragomāṃsabhakṣaṇe ca // Vi_51.3 //"
  },
  {
    "id": "p-45efcf",
    "offset": 233,
    "text": "sarveṣv eteṣu dvijānāṃ prāyaścittānte bhūyaḥ saṃskāraṃ kuryāt // Vi_51.4 //"
  },
  {
    "id": "p-28a598",
    "offset": 310,
    "text": "vapanamekhalādaṇḍabhaikṣyacaryāvratāni punaḥsaṃskārakarmaṇi varjanīyāni // Vi_51.5 //"
  },
  {
    "id": "p-822b77",
    "offset": 397,
    "text": "śaśakaśalyakagodhākhaḍgakūrmavarjaṃ pañcanakhamāṃsāśane saptarātram upavaset // Vi_51.6 //"
  },
  {
    "id": "p-b79244",
    "offset": 489,
    "text": "gaṇagaṇikāstenagāyanānnāni bhuktvā saptarātraṃ payasā varteta // Vi_51.7 //"
  },
  {
    "id": "p-7495af",
    "offset": 566,
    "text": "takṣakānnaṃ carmakartuś ca // Vi_51.8 //"
  },
  {
    "id": "p-7fc42e",
    "offset": 608,
    "text": "vārdhuṣikakadaryadīkṣitabaddhanigaḍābhiśastaṣaṇḍhānāṃ ca // Vi_51.9 //"
  },
  {
    "id": "p-766e1a",
    "offset": 680,
    "text": "puṃścalīdāmbhikacikitsakalubdhakakrūrogrocchiṣṭabhojināṃ ca // Vi_51.10 //"
  },
  {
    "id": "p-d13649",
    "offset": 756,
    "text": "avīrastrī suvarṇakārasapatnapatitānāṃ ca // Vi_51.11 //"
  },
  {
    "id": "p-49ad12",
    "offset": 813,
    "text": "piśunānṛtavādikṣatadharmātmarasavikrayiṇāṃ ca // Vi_51.12 //"
  },
  {
    "id": "p-d14b8b",
    "offset": 875,
    "text": "śailūṣatantuvāyakṛtaghnarajakānāṃ ca // Vi_51.13 //"
  },
  {
    "id": "p-a8b95b",
    "offset": 928,
    "text": "karmakāraniṣādaraṅgāvatārivaiṇaśastravikrayiṇāṃ ca // Vi_51.14 //"
  },
  {
    "id": "p-356d49",
    "offset": 995,
    "text": "śvajīviśauṇḍikatailikacailanirṇejakānāṃ ca // Vi_51.15 //"
  },
  {
    "id": "p-101cb4",
    "offset": 1054,
    "text": "rajasvalāsahopapativeśmānāṃ ca // Vi_51.16 //"
  },
  {
    "id": "p-0ace97",
    "offset": 1101,
    "text": "bhrūṇaghnāvekṣitam udakyāsaṃspṛṣṭaṃ patatriṇāvalīḍhaṃ śunā saṃspṛṣṭaṃ gavāghrātaṃ ca // Vi_51.17 //"
  },
  {
    "id": "p-ffcc21",
    "offset": 1202,
    "text": "kāmataḥ padā spṛṣṭam avakṣutam // Vi_51.18 //"
  },
  {
    "id": "p-1fb397",
    "offset": 1249,
    "text": "mattakruddhāturāṇāṃ ca // Vi_51.19 //"
  },
  {
    "id": "p-ab2e55",
    "offset": 1288,
    "text": "anarcitaṃ vṛthā māṃsaṃ ca // Vi_51.20 //"
  },
  {
    "id": "p-548073",
    "offset": 1330,
    "text": "pāṭhīnarohitarājīvasiṃhatuṇḍaśakulavarjaṃ sarvamatsyamāṃsāśane trirātram upavaset // Vi_51.21 //"
  },
  {
    "id": "p-f98895",
    "offset": 1428,
    "text": "sarvajalajamāṃsāśane ca // Vi_51.22 //"
  },
  {
    "id": "p-eb4f93",
    "offset": 1468,
    "text": "āpaḥ surābhāṇḍasthāḥ pītvā saptarātraṃ śaṅkhapuṣpīśṛtaṃ payaḥ pibet // Vi_51.23 //"
  },
  {
    "id": "p-7ea18b",
    "offset": 1552,
    "text": "madyabhāṇḍasthāś ca pañcarātram // Vi_51.24 //"
  },
  {
    "id": "p-a92162",
    "offset": 1600,
    "text": "somapaḥ surāpasyāghrāya gandham udakamagnas trir aghamarṣaṇaṃ japtvā ghṛtaprāśanam ācaret // Vi_51.25 //"
  },
  {
    "id": "p-c25b6e",
    "offset": 1706,
    "text": "kharoṣṭrakākamāṃsāśane cāndrāyaṇaṃ kuryāt // Vi_51.26 //"
  },
  {
    "id": "p-f2c655",
    "offset": 1764,
    "text": "prāśyājñātaṃ sūnāsthaṃ śuṣkamāṃsaṃ ca // Vi_51.27 //"
  },
  {
    "id": "p-b950ac",
    "offset": 1818,
    "text": "kravyādamṛgapakṣimāṃsāśane taptakṛcchram // Vi_51.28 //"
  },
  {
    "id": "p-9e0839",
    "offset": 1875,
    "text": "kalaviṅkaplavacakravākahaṃsarajjudālasārasadātyūhaśukasārikābakabalākākokilakhañjarīṭāśane trirātram upavaset // Vi_51.29 //"
  },
  {
    "id": "p-7ee943",
    "offset": 2001,
    "text": "ekaśaphobhayadantāśane ca // Vi_51.30 //"
  },
  {
    "id": "p-3cff46",
    "offset": 2043,
    "text": "tittirikapiñjalalāvakavartikāmayūravarjaṃ sarvapakṣimāṃsāśane cāhorātram // Vi_51.31 //"
  },
  {
    "id": "p-6f3a4c",
    "offset": 2132,
    "text": "kīṭāśane dinam ekaṃ brahmasuvarcalāṃ pibet // Vi_51.32 //"
  },
  {
    "id": "p-3d48af",
    "offset": 2191,
    "text": "śunāṃ māṃsāśane ca // Vi_51.33 //"
  },
  {
    "id": "p-796695",
    "offset": 2226,
    "text": "chatrākakavakāśane sāṃtapanam // Vi_51.34 //"
  },
  {
    "id": "p-bb1eac",
    "offset": 2272,
    "text": "yavagodhūmapayovikāraṃ snehāktaṃ śuktaṃ khāṇḍavaṃ ca varjayitvā yat paryuṣitaṃ tat prāśyopavaset // Vi_51.35 //"
  },
  {
    "id": "p-7e95e6",
    "offset": 2385,
    "text": "vraścanāmedhyaprabhavān lohitāṃś ca vṛkṣaniryāsān // Vi_51.36 //"
  },
  {
    "id": "p-4830fb",
    "offset": 2451,
    "text": "śālūkavṛthākṛsarasaṃyāvapāyasāpūpaśaṣkulīdevānnāni havīṃṣi ca // Vi_51.37 //"
  },
  {
    "id": "p-342dcc",
    "offset": 2529,
    "text": "goajāmahiṣīvarjaṃ sarvapayāṃsi ca // Vi_51.38 //"
  },
  {
    "id": "p-aaf8a0",
    "offset": 2579,
    "text": "anirdaśāhāni tāny api // Vi_51.39 //"
  },
  {
    "id": "p-289c60",
    "offset": 2617,
    "text": "syandinīsandhinīvivatsākṣīraṃ ca // Vi_51.40 //"
  },
  {
    "id": "p-3631d8",
    "offset": 2666,
    "text": "amedhyabhujaś ca // Vi_51.41 //"
  },
  {
    "id": "p-4d23ef",
    "offset": 2699,
    "text": "dadhivarjaṃ kevalāni ca śuktāni // Vi_51.42 //"
  },
  {
    "id": "p-ad1b05",
    "offset": 2747,
    "text": "brahmacaryāśramī śrāddhabhojane trirātram upavaset // Vi_51.43 //"
  },
  {
    "id": "p-c099fc",
    "offset": 2814,
    "text": "dinam ekaṃ codake vaset // Vi_51.44 //"
  },
  {
    "id": "p-37ee6c",
    "offset": 2854,
    "text": "madhumāṃsāśane prājāpatyam // Vi_51.45 //"
  },
  {
    "id": "p-e1f027",
    "offset": 2897,
    "text": "biḍālakākanakulākhūcchiṣṭabhakṣaṇe brahmasuvarcalāṃ pibet // Vi_51.46 //"
  },
  {
    "id": "p-ea0738",
    "offset": 2971,
    "text": "śvocchiṣṭāśane dinam ekam upoṣitaḥ pañcagavyaṃ pibet // Vi_51.47 //"
  },
  {
    "id": "p-f9b2fa",
    "offset": 3040,
    "text": "pañcanakhaviṇmūtrāśane saptarātram // Vi_51.48 //"
  },
  {
    "id": "p-8870b3",
    "offset": 3091,
    "text": "āmaśrāddhāśane trirātraṃ payasā varteta // Vi_51.49 //"
  },
  {
    "id": "p-1e37ee",
    "offset": 3147,
    "text": "brāhmaṇaḥ śūdrocchiṣṭāśane saptarātram // Vi_51.50 //"
  },
  {
    "id": "p-ebbd90",
    "offset": 3202,
    "text": "vaiśyocchiṣṭāśane pañcarātram // Vi_51.51 //"
  },
  {
    "id": "p-0bbb88",
    "offset": 3248,
    "text": "rājanyocchiṣṭāśane trirātram // Vi_51.52 //"
  },
  {
    "id": "p-1c59c2",
    "offset": 3293,
    "text": "brāhmaṇocchiṣṭāśane tv ekāham // Vi_51.53 //"
  },
  {
    "id": "p-a3f95a",
    "offset": 3339,
    "text": "rājanyaḥ śūdrocchiṣṭāśī pañcarātram // Vi_51.54 //"
  },
  {
    "id": "p-4eff59",
    "offset": 3391,
    "text": "vaiśyocchiṣṭāśī trirātram // Vi_51.55 //"
  },
  {
    "id": "p-f3e45c",
    "offset": 3433,
    "text": "vaiśyaḥ śūdrocchiṣṭāśī ca // Vi_51.56 //"
  },
  {
    "id": "p-b64329",
    "offset": 3475,
    "text": "caṇḍālānnaṃ bhuktvā trirātram upavaset // Vi_51.57 //"
  },
  {
    "id": "p-a9c5e2",
    "offset": 3530,
    "text": "siddhaṃ bhuktvā parākaḥ // Vi_51.58 //"
  },
  {
    "id": "p-00da6f",
    "offset": 3570,
    "text": "asaṃskṛtān paśūn mantrair nādyād vipraḥ kathaṃcana  /"
  },
  {
    "id": "p-0a8497",
    "offset": 3625,
    "text": "mantrais tu saṃskṛtān adyāc chāśvataṃ vidhim āsthitaḥ  || Vi_51.59 ||"
  },
  {
    "id": "p-b6f518",
    "offset": 3696,
    "text": "yāvanti paśuromāṇi tāvat kṛtveha māraṇam  /"
  },
  {
    "id": "p-041ce3",
    "offset": 3741,
    "text": "vṛthā paśughnaḥ prāpnoti pretya ceha ca niṣkṛtim  || Vi_51.60 ||"
  },
  {
    "id": "p-ef358c",
    "offset": 3807,
    "text": "yajñārthaṃ paśavaḥ sṛṣṭāḥ svayam eva svayaṃbhuvā  /"
  },
  {
    "id": "p-a2c975",
    "offset": 3860,
    "text": "yajño hi bhūtyai sarvasya tasmād yajñe vadho 'vadhaḥ  || Vi_51.61 ||"
  },
  {
    "id": "p-7a6506",
    "offset": 3930,
    "text": "na tādṛśaṃ bhavaty eno mṛgahantur dhanārthinaḥ  /"
  },
  {
    "id": "p-e49d0f",
    "offset": 3981,
    "text": "yādṛśaṃ bhavati pretya vṛthā māṃsāni khādataḥ  || Vi_51.62 ||"
  },
  {
    "id": "p-0082bc",
    "offset": 4044,
    "text": "oṣadhyaḥ paśavo vṛkṣās tiryañcaḥ pakṣiṇas tathā  /"
  },
  {
    "id": "p-aca235",
    "offset": 4096,
    "text": "yajñārthaṃ nidhanam prāptāḥ prāpnuvanty ucchritīḥ punaḥ  || Vi_51.63 ||"
  },
  {
    "id": "p-2e3573",
    "offset": 4169,
    "text": "madhuparke ca yajñe ca pitṛdaivatakarmaṇi  /"
  },
  {
    "id": "p-33c9cb",
    "offset": 4215,
    "text": "atraiva paśavo hiṃsyā nānyatreti kathaṃcana  || Vi_51.64 ||"
  },
  {
    "id": "p-c3d87d",
    "offset": 4276,
    "text": "yajñārtheṣu paśūn hiṃsan vedatattvārthavid dvijaḥ  /"
  },
  {
    "id": "p-4f04a5",
    "offset": 4330,
    "text": "ātmānaṃ ca paśūṃś caiva gamayaty uttamāṃ gatim  || Vi_51.65 ||"
  },
  {
    "id": "p-7b3dca",
    "offset": 4394,
    "text": "gṛhe gurāv araṇye vā nivasann ātmavān dvijaḥ  /"
  },
  {
    "id": "p-e6e2fa",
    "offset": 4443,
    "text": "nāvedavihitāṃ hiṃsām āpady api samācaret  || Vi_51.66 ||"
  },
  {
    "id": "p-99482d",
    "offset": 4501,
    "text": "yā vedavihitā hiṃsā niyatāsmiṃś carācare  /"
  },
  {
    "id": "p-914dfc",
    "offset": 4546,
    "text": "ahiṃsām eva tāṃ vidyād vedād dharmo hi nirbabhau  || Vi_51.67 ||"
  },
  {
    "id": "p-4ce2d7",
    "offset": 4612,
    "text": "yo 'hiṃsakāni bhūtāni hinasty ātmasukhecchayā  /"
  },
  {
    "id": "p-d1829c",
    "offset": 4662,
    "text": "sa jīvaṃś ca mṛtaś caiva na kvacit sukham edhate  || Vi_51.68 ||"
  },
  {
    "id": "p-a268e4",
    "offset": 4728,
    "text": "yo bandhanavadhakleśān prāṇināṃ na cikīrṣati  /"
  },
  {
    "id": "p-9c3d96",
    "offset": 4777,
    "text": "sa sarvasya hitaprepsuḥ sukham atyantam aśnute  || Vi_51.69 ||"
  },
  {
    "id": "p-6cf70f",
    "offset": 4841,
    "text": "yad dhyāyati yat kurute ratiṃ badhnāti yatra ca  /"
  },
  {
    "id": "p-e0906e",
    "offset": 4893,
    "text": "tad evāpnoty ayatnena yo hinasti na kiṃcana  || Vi_51.70 ||"
  },
  {
    "id": "p-90d376",
    "offset": 4954,
    "text": "nākṛtvā prāṇināṃ hiṃsāṃ māṃsam utpadyate kvacit  /"
  },
  {
    "id": "p-f4df8e",
    "offset": 5006,
    "text": "na ca prāṇivadhaḥ svargyas tasmān māṃsaṃ vivarjayet  || Vi_51.71 ||"
  },
  {
    "id": "p-7dc866",
    "offset": 5075,
    "text": "samutpattiṃ ca māṃsasya vadhabandhau ca dehinām  /"
  },
  {
    "id": "p-753943",
    "offset": 5127,
    "text": "prasamīkṣya nivarteta sarvamāṃsasya bhakṣaṇāt  || Vi_51.72 ||"
  },
  {
    "id": "p-adee72",
    "offset": 5190,
    "text": "na bhakṣayati yo māṃsaṃ vidhiṃ hitvā piśācavat  /"
  },
  {
    "id": "p-2aa5f2",
    "offset": 5241,
    "text": "sa loke priyatāṃ yāti vyādhibhiś ca na pīḍyate  || Vi_51.73 ||"
  },
  {
    "id": "p-c4bce6",
    "offset": 5305,
    "text": "anumantā viśasitā nihantā krayavikrayī  /"
  },
  {
    "id": "p-91e9f6",
    "offset": 5348,
    "text": "saṃskartā copahartā ca khādakaś ceti ghātakāḥ  || Vi_51.74 ||"
  },
  {
    "id": "p-bd9365",
    "offset": 5411,
    "text": "svamāṃsaṃ paramāṃsena yo vardhayitum icchati  /"
  },
  {
    "id": "p-2f9c79",
    "offset": 5460,
    "text": "anabhyarcya pitṝn devān na tato 'nyo 'sty apuṇyakṛt  || Vi_51.75 ||"
  },
  {
    "id": "p-a0a475",
    "offset": 5529,
    "text": "varṣe varṣe 'śvamedhena yo yajeta śataṃ samāḥ  /"
  },
  {
    "id": "p-010d62",
    "offset": 5579,
    "text": "māṃsāni ca na khāded yas tayoḥ puṇyaphalaṃ samam  || Vi_51.76 ||"
  },
  {
    "id": "p-015c1d",
    "offset": 5645,
    "text": "phalamūlāśanair divyair munyannānāṃ ca bhojanaiḥ  /"
  },
  {
    "id": "p-90e98f",
    "offset": 5698,
    "text": "na tat phalam avāpnoti yan māṃsaparivarjanāt  || Vi_51.77 ||"
  },
  {
    "id": "p-246797",
    "offset": 5760,
    "text": "māṃ sa bhakṣayitāmutra yasya māṃsam ihādmy aham  /"
  },
  {
    "id": "p-1a5e41",
    "offset": 5812,
    "text": "etan māṃsasya māṃsatvaṃ pravadanti manīṣiṇaḥ  || Vi_51.78 ||"
  }
]