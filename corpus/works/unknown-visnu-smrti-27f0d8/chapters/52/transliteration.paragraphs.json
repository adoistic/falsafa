[
  {
    "id": "p-0f45f0",
    "offset": 0,
    "text": "Vi_52"
  },
  {
    "id": "p-0805c3",
    "offset": 7,
    "text": "suvarṇasteyakṛd rājñe karmācakṣāṇo musalam arpayet // Vi_52.1 //"
  },
  {
    "id": "p-93b16d",
    "offset": 73,
    "text": "vadhāt tyāgād vā prayato bhavati // Vi_52.2 //"
  },
  {
    "id": "p-80bb2e",
    "offset": 121,
    "text": "mahāvrataṃ dvādaśābdāni vā kuryāt // Vi_52.3 //"
  },
  {
    "id": "p-6068d9",
    "offset": 170,
    "text": "nikṣepāpahārī ca // Vi_52.4 //"
  },
  {
    "id": "p-164113",
    "offset": 202,
    "text": "dhānyadhanāpahārī ca kṛcchram abdam // Vi_52.5 //"
  },
  {
    "id": "p-5f98d0",
    "offset": 253,
    "text": "manuṣyastrīkūpakṣetravāpīnām apahāre cāndrāyaṇam // Vi_52.6 //"
  },
  {
    "id": "p-53b0bd",
    "offset": 317,
    "text": "dravyāṇām alpasārāṇāṃ sāṃtapanam // Vi_52.7 //"
  },
  {
    "id": "p-84f213",
    "offset": 365,
    "text": "bhakṣyabhojyayānaśayyāsanapuṣpamūlaphalānāṃ pañcagavyapānam // Vi_52.8 //"
  },
  {
    "id": "p-54bca5",
    "offset": 440,
    "text": "tṛṇakāṣṭhadrumaśuṣkānnaguḍavastracarmāmiṣāṇāṃ trirātram upavaset // Vi_52.9 //"
  },
  {
    "id": "p-be7b79",
    "offset": 520,
    "text": "maṇimuktāpravālatāmrarajatāyaḥkāṃsyānāṃ dvādaśāhaṃ kaṇān aśnīyāt // Vi_52.10 //"
  },
  {
    "id": "p-e9b933",
    "offset": 601,
    "text": "kārpāsakīṭajorṇādyapaharaṇe trirātraṃ payasā varteta // Vi_52.11 //"
  },
  {
    "id": "p-ddc0ff",
    "offset": 670,
    "text": "dviśaphaikaśaphāpaharaṇe dvirātram upavaset // Vi_52.12 //"
  },
  {
    "id": "p-501384",
    "offset": 730,
    "text": "pakṣigandhauṣadhirajjuvaidalānām apaharaṇe dinam upavaset // Vi_52.13 //"
  },
  {
    "id": "p-21836a",
    "offset": 804,
    "text": "dattvaivāpahṛtaṃ dravyaṃ dhanikasyāpy upāyataḥ  /"
  },
  {
    "id": "p-d43278",
    "offset": 855,
    "text": "prāyaścittaṃ tataḥ kuryāt kalmaṣasyāpanuttaye  || Vi_52.14 ||"
  },
  {
    "id": "p-ecd392",
    "offset": 918,
    "text": "yad yat parebhyas tv ādadyāt puruṣas tu niraṅkuśaḥ  /"
  },
  {
    "id": "p-61e300",
    "offset": 973,
    "text": "tena tena vihīnaḥ syād yatra yatrābhijāyate  || Vi_52.15 ||"
  },
  {
    "id": "p-a3c5fd",
    "offset": 1034,
    "text": "jīvitaṃ dharmakāmau ca dhane yasmāt pratiṣṭhitau  /"
  },
  {
    "id": "p-68a7c9",
    "offset": 1087,
    "text": "tasmāt sarvaprayatnena dhanahiṃsāṃ vivarjayet  || Vi_52.16 ||"
  },
  {
    "id": "p-c6d129",
    "offset": 1150,
    "text": "prāṇihiṃsāparo yas tu dhanahiṃsāparas tathā  /"
  },
  {
    "id": "p-0e99d7",
    "offset": 1198,
    "text": "mahad duḥkham avāpnoti dhanahiṃsāparas tayoḥ  || Vi_52.17 ||"
  }
]