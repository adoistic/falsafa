[
  {
    "id": "p-13573f",
    "offset": 0,
    "text": "Vi_24"
  },
  {
    "id": "p-08eede",
    "offset": 7,
    "text": "atha brāhmaṇasya varṇānukrameṇa catasro bhāryā bhavanti // Vi_24.1 //"
  },
  {
    "id": "p-9d48b3",
    "offset": 78,
    "text": "tisraḥ kṣatriyasya // Vi_24.2 //"
  },
  {
    "id": "p-59a973",
    "offset": 112,
    "text": "dve vaiśyasya // Vi_24.3 //"
  },
  {
    "id": "p-fc3f83",
    "offset": 141,
    "text": "ekā śūdrasya // Vi_24.4 //"
  },
  {
    "id": "p-8a37f5",
    "offset": 169,
    "text": "tāsāṃ savarṇāvedane pāṇir grāhyaḥ // Vi_24.5 //"
  },
  {
    "id": "p-2372bf",
    "offset": 218,
    "text": "asavarṇāvedane śaraḥ kṣatriyakanyayā // Vi_24.6 //"
  },
  {
    "id": "p-0a35a1",
    "offset": 270,
    "text": "pratodo vaiśyakanyayā // Vi_24.7 //"
  },
  {
    "id": "p-10c3f9",
    "offset": 307,
    "text": "vasanadaśāntaḥ śūdrakanyayā // Vi_24.8 //"
  },
  {
    "id": "p-e4dc5a",
    "offset": 350,
    "text": "na sagotrāṃ na samānārṣapravarāṃ bhāryāṃ vindeta // Vi_24.9 //"
  },
  {
    "id": "p-595b87",
    "offset": 414,
    "text": "mātṛtas tv ā pañcamāt puruṣāt *pitṛtaś cā saptamāt [pitṛtāś] // Vi_24.10 //"
  },
  {
    "id": "p-93c4c2",
    "offset": 491,
    "text": "nākulīnām // Vi_24.11 //"
  },
  {
    "id": "p-ca4f56",
    "offset": 517,
    "text": "na ca vyādhitām // Vi_24.12 //"
  },
  {
    "id": "p-e750fe",
    "offset": 549,
    "text": "nādhikāṅgīm // Vi_24.13 //"
  },
  {
    "id": "p-351585",
    "offset": 577,
    "text": "na hīnāṅgīm // Vi_24.14 //"
  },
  {
    "id": "p-642573",
    "offset": 605,
    "text": "nātikapilām // Vi_24.15 //"
  },
  {
    "id": "p-475ab7",
    "offset": 633,
    "text": "na vācāṭām // Vi_24.16 //"
  },
  {
    "id": "p-aec5bd",
    "offset": 660,
    "text": "athāṣṭau vivāhā bhavanti // Vi_24.17 //"
  },
  {
    "id": "p-873e24",
    "offset": 701,
    "text": "brāhmo daiva ārṣaḥ prājāpatyo gāndharva āsuro rākṣasaḥ paiśācaś ceti // Vi_24.18 //"
  },
  {
    "id": "p-814481",
    "offset": 786,
    "text": "āhūya guṇavate kanyādānaṃ brāhmaḥ // Vi_24.19 //"
  },
  {
    "id": "p-2fb6ee",
    "offset": 836,
    "text": "yajñasthartvije daivaḥ // Vi_24.20 //"
  },
  {
    "id": "p-cde68d",
    "offset": 875,
    "text": "gomithunagrahaṇenārṣaḥ // Vi_24.21 //"
  },
  {
    "id": "p-72a518",
    "offset": 914,
    "text": "prārthitapradānena prājāpatyaḥ // Vi_24.22 //"
  },
  {
    "id": "p-101017",
    "offset": 961,
    "text": "dvayoḥ sakāmayor mātāpitṛrahito yogo gāndharvaḥ // Vi_24.23 //"
  },
  {
    "id": "p-76ec28",
    "offset": 1025,
    "text": "krayeṇāsuraḥ // Vi_24.24 //"
  },
  {
    "id": "p-564a69",
    "offset": 1054,
    "text": "yuddhaharaṇena rākṣasaḥ // Vi_24.25 //"
  },
  {
    "id": "p-8c79f9",
    "offset": 1094,
    "text": "suptapramattābhigamanāt *paiśācaḥ [paiśacaḥ] // Vi_24.26 //"
  },
  {
    "id": "p-43c8c9",
    "offset": 1155,
    "text": "eteṣv ādyāś catvāro dharmyāḥ // Vi_24.27 //"
  },
  {
    "id": "p-fdadb0",
    "offset": 1200,
    "text": "gāndharvo 'pi rājanyānām // Vi_24.28 //"
  },
  {
    "id": "p-003230",
    "offset": 1241,
    "text": "brāhmīputraḥ puruṣān ekaviṃśatiṃ punīte // Vi_24.29 //"
  },
  {
    "id": "p-5ee670",
    "offset": 1297,
    "text": "daivīputraś caturdaśa // Vi_24.30 //"
  },
  {
    "id": "p-869343",
    "offset": 1335,
    "text": "ārṣīputraś ca sapta // Vi_24.31 //"
  },
  {
    "id": "p-bcfd4b",
    "offset": 1371,
    "text": "prājāpatyaś caturaḥ // Vi_24.32 //"
  },
  {
    "id": "p-4c8b94",
    "offset": 1407,
    "text": "brāhmeṇa vivāhena kanyāṃ dadat brahmalokaṃ gamayati // Vi_24.33 //"
  },
  {
    "id": "p-1598ce",
    "offset": 1475,
    "text": "daivena svargam // Vi_24.34 //"
  },
  {
    "id": "p-e9c5cd",
    "offset": 1507,
    "text": "ārṣeṇa vaiṣṇavam // Vi_24.35 //"
  },
  {
    "id": "p-1b0e5a",
    "offset": 1540,
    "text": "prājāpatyena devalokam // Vi_24.36 //"
  },
  {
    "id": "p-d66aca",
    "offset": 1579,
    "text": "gāndharveṇa gandharvalokaṃ gacchati // Vi_24.37 //"
  },
  {
    "id": "p-3b87e0",
    "offset": 1631,
    "text": "pitā pitāmaho bhrātā sakulyo mātāmaho mātā ceti kanyāpradāḥ // Vi_24.38 //"
  },
  {
    "id": "p-062a16",
    "offset": 1707,
    "text": "pūrvābhāve prakṛtisthaḥ paraḥ para iti // Vi_24.39 //"
  },
  {
    "id": "p-780271",
    "offset": 1762,
    "text": "ṛtutrayam upāsyaiva kanyā kuryāt svayaṃ varam  /"
  },
  {
    "id": "p-96d3fb",
    "offset": 1812,
    "text": "ṛtutraye vyatīte tu prabhavaty ātmanaḥ sadā  || Vi_24.40 ||"
  },
  {
    "id": "p-8acffa",
    "offset": 1873,
    "text": "pitṛveśmani yā kanyā rajaḥ paśyaty asaṃskṛtā  /"
  },
  {
    "id": "p-d3f506",
    "offset": 1922,
    "text": "sā kanyā vṛṣalī jñeyā haraṃs tāṃ na viduṣyati  || Vi_24.41 ||"
  }
]