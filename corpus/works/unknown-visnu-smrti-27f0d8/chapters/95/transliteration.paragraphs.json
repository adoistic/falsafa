[
  {
    "id": "p-923c31",
    "offset": 0,
    "text": "Vi_95"
  },
  {
    "id": "p-a4296a",
    "offset": 7,
    "text": "vānaprasthas tapasā śarīraṃ śoṣayet // Vi_95.1 //"
  },
  {
    "id": "p-947083",
    "offset": 58,
    "text": "grīṣme pañcatapāḥ syāt // Vi_95.2 //"
  },
  {
    "id": "p-e48a44",
    "offset": 96,
    "text": "ākāśaśāyī prāvṛṣi // Vi_95.3 //"
  },
  {
    "id": "p-93fe3d",
    "offset": 129,
    "text": "ārdravāsā hemante // Vi_95.4 //"
  },
  {
    "id": "p-9c0490",
    "offset": 162,
    "text": "naktāśī syāt // Vi_95.5 //"
  },
  {
    "id": "p-3f0df4",
    "offset": 190,
    "text": "ekāntaradvyantaratryantarāśī vā syāt // Vi_95.6 //"
  },
  {
    "id": "p-b54c7a",
    "offset": 242,
    "text": "puṣpāśī // Vi_95.7 //"
  },
  {
    "id": "p-1767ee",
    "offset": 265,
    "text": "phalāśī // Vi_95.8 //"
  },
  {
    "id": "p-b92fa6",
    "offset": 288,
    "text": "śākāśī // Vi_95.9 //"
  },
  {
    "id": "p-59aaba",
    "offset": 310,
    "text": "parṇāśī vā // Vi_95.10 //"
  },
  {
    "id": "p-8a759f",
    "offset": 337,
    "text": "yavānnaṃ pakṣāntayor vā sakṛd aśnīyāt // Vi_95.11 //"
  },
  {
    "id": "p-8eed4b",
    "offset": 391,
    "text": "cāndrāyaṇair vā varteta // Vi_95.12 //"
  },
  {
    "id": "p-65e068",
    "offset": 431,
    "text": "aśmakuṭṭaḥ // Vi_95.13 //"
  },
  {
    "id": "p-b0e5d8",
    "offset": 458,
    "text": "dantolūkhaliko vā // Vi_95.14 //"
  },
  {
    "id": "p-0fbe7b",
    "offset": 492,
    "text": "tapomūlam idaṃ sarvaṃ devamānuṣikaṃ jagat  /"
  },
  {
    "id": "p-23a368",
    "offset": 538,
    "text": "tapomadhyaṃ tapo 'ntaṃ ca tapasā ca tathā dhṛtam  || Vi_95.15 ||"
  },
  {
    "id": "p-0045e8",
    "offset": 604,
    "text": "yad duṣcaraṃ yad durāpaṃ yad dūraṃ yac ca duṣkaram  /"
  },
  {
    "id": "p-e8b284",
    "offset": 659,
    "text": "sarvaṃ tat tapasā sādhyaṃ tapo hi duratikramam  || Vi_95.16 ||"
  }
]