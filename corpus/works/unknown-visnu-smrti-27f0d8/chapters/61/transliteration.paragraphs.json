[
  {
    "id": "p-7e4d5a",
    "offset": 0,
    "text": "Vi_61"
  },
  {
    "id": "p-024363",
    "offset": 7,
    "text": "atha pālāśaṃ dantadhāvanaṃ nādyāt // Vi_61.1 //"
  },
  {
    "id": "p-18c952",
    "offset": 56,
    "text": "naiva śleṣmātakāriṣṭavibhītakadhavadhanvanajam // Vi_61.2 //"
  },
  {
    "id": "p-42ec95",
    "offset": 118,
    "text": "na ca bandhūkanirguṇḍīśigrutilvatindukajam // Vi_61.3 //"
  },
  {
    "id": "p-8a80e5",
    "offset": 176,
    "text": "na ca kovidāraśamīpīlupippaleṅgudaguggulujam // Vi_61.4 //"
  },
  {
    "id": "p-e7b259",
    "offset": 236,
    "text": "na pāribhadrakāmlikāmocakaśālmalīśaṇajam // Vi_61.5 //"
  },
  {
    "id": "p-395ad3",
    "offset": 292,
    "text": "na madhuram // Vi_61.6 //"
  },
  {
    "id": "p-72c065",
    "offset": 319,
    "text": "nāmlam // Vi_61.7 //"
  },
  {
    "id": "p-adc830",
    "offset": 341,
    "text": "nordhvaśuṣkam // Vi_61.8 //"
  },
  {
    "id": "p-1bb646",
    "offset": 370,
    "text": "na suṣiram // Vi_61.9 //"
  },
  {
    "id": "p-3ecf7e",
    "offset": 396,
    "text": "na pūtigandhi // Vi_61.10 //"
  },
  {
    "id": "p-ab7fa2",
    "offset": 426,
    "text": "na picchilam // Vi_61.11 //"
  },
  {
    "id": "p-257660",
    "offset": 455,
    "text": "na dakṣiṇāparābhimukhaḥ // Vi_61.12 //"
  },
  {
    "id": "p-fa014b",
    "offset": 495,
    "text": "adyāc codaṅmukhaḥ prāṅmukho vā // Vi_61.13 //"
  },
  {
    "id": "p-313dea",
    "offset": 542,
    "text": "vaṭāsanārkakhadirakarañjabadarasarjanimbārimedāpāmārgamālatīkakubhabilvānām anyatamam // Vi_61.14 //"
  },
  {
    "id": "p-7f86df",
    "offset": 644,
    "text": "kaṣāyaṃ tiktaṃ kaṭukaṃ ca // Vi_61.15 //"
  },
  {
    "id": "p-950455",
    "offset": 686,
    "text": "kanīnyagrasamasthaulyaṃ sakūrcaṃ dvādaśāṅgulam  /"
  },
  {
    "id": "p-b8ed6b",
    "offset": 737,
    "text": "prātarbhūtvā ca yatavāg bhakṣayed dantadhāvanam  || Vi_61.16 ||"
  },
  {
    "id": "p-0bb837",
    "offset": 802,
    "text": "prakṣālya bhaṅktvā taj jahyāc chucau deśe prayatnataḥ  /"
  },
  {
    "id": "p-c14293",
    "offset": 860,
    "text": "amāvāsyāṃ na cāśnīyād dantakāṣṭhaṃ kadācana  || Vi_61.17 ||"
  }
]