[
  {
    "id": "p-884fa9",
    "offset": 0,
    "text": "Vi_13"
  },
  {
    "id": "p-ab78b1",
    "offset": 7,
    "text": "atha viṣam // Vi_13.1 //"
  },
  {
    "id": "p-ae0632",
    "offset": 33,
    "text": "viṣāny adeyāni sārvāṇi // Vi_13.2 //"
  },
  {
    "id": "p-3fff0d",
    "offset": 71,
    "text": "ṛte himācalodbhavāt śārṅgāt // Vi_13.3 //"
  },
  {
    "id": "p-544378",
    "offset": 114,
    "text": "tasya ca yavasaptakaṃ ghṛtaplutam abhiśastāya dadyāt // Vi_13.4 //"
  },
  {
    "id": "p-939be1",
    "offset": 182,
    "text": "viṣaṃ vegaklamāpetaṃ sukhena yadi jīryate  /"
  },
  {
    "id": "p-6519d1",
    "offset": 228,
    "text": "viśuddhaṃ tam iti jñātvā divasānte visarjayet  || Vi_13.5 ||"
  },
  {
    "id": "p-18daca",
    "offset": 290,
    "text": "viṣatvād viṣamatvāc ca krūraṃ tvaṃ sarvadehinām  /"
  },
  {
    "id": "p-e552ef",
    "offset": 342,
    "text": "tvam eva viṣa jānīṣe na vidur yāni mānuṣāḥ  || Vi_13.6 ||"
  },
  {
    "id": "p-054173",
    "offset": 401,
    "text": "vyavahārābhiśasto 'yaṃ mānuṣaḥ śuddhim icchati  /"
  },
  {
    "id": "p-2c6b9f",
    "offset": 452,
    "text": "tad enaṃ saṃśayād asmād dharmatas trātum arhasi  || Vi_13.7 ||"
  }
]