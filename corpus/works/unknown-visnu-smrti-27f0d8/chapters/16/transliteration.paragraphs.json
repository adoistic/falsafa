[
  {
    "id": "p-834fa1",
    "offset": 0,
    "text": "Vi_16"
  },
  {
    "id": "p-c7ce88",
    "offset": 7,
    "text": "samānavarṇāsu putrāḥ savarṇā bhavanti // Vi_16.1 //"
  },
  {
    "id": "p-b2c219",
    "offset": 60,
    "text": "anulomāsu mātṛsavarṇāḥ // Vi_16.2 //"
  },
  {
    "id": "p-e72375",
    "offset": 98,
    "text": "pratilomāsv āryavigarhitāḥ // Vi_16.3 //"
  },
  {
    "id": "p-a62b8f",
    "offset": 140,
    "text": "tatra vaiśyāputraḥ śūdreṇāyogavaḥ // Vi_16.4 //"
  },
  {
    "id": "p-5fecbb",
    "offset": 189,
    "text": "pulkasamāgadhau kṣatriyāputrau vaiśyaśūdrābhyām // Vi_16.5 //"
  },
  {
    "id": "p-00ce28",
    "offset": 252,
    "text": "caṇḍālavaidehakasūtāś ca brāhmaṇīputrāḥ śūdraviṭkṣatriyaiḥ // Vi_16.6 //"
  },
  {
    "id": "p-cd6013",
    "offset": 326,
    "text": "saṃkarasaṃkarāś cāsaṃkhyeyāḥ // Vi_16.7 //"
  },
  {
    "id": "p-039417",
    "offset": 370,
    "text": "raṅgāvataraṇam āyogavānām // Vi_16.8 //"
  },
  {
    "id": "p-b4eab1",
    "offset": 411,
    "text": "vyādhatā pulkasānām // Vi_16.9 //"
  },
  {
    "id": "p-c92e65",
    "offset": 446,
    "text": "stutikriyā māgadhānām // Vi_16.10 //"
  },
  {
    "id": "p-e033af",
    "offset": 484,
    "text": "vadhyaghātitvaṃ caṇḍālānām // Vi_16.11 //"
  },
  {
    "id": "p-1e4893",
    "offset": 527,
    "text": "strīraksā tajjīvanaṃ ca vaidehakānām // Vi_16.12 //"
  },
  {
    "id": "p-1b35b8",
    "offset": 580,
    "text": "aśvasārathyaṃ sūtānām // Vi_16.13 //"
  },
  {
    "id": "p-8cd1ac",
    "offset": 618,
    "text": "caṇḍālānāṃ bahir grāmanivasanaṃ mṛtacailadhāraṇam iti viśeṣaḥ // Vi_16.14 //"
  },
  {
    "id": "p-bc647f",
    "offset": 696,
    "text": "sarveṣāṃ ca samānajātibhir vivāhaḥ // Vi_16.15 //"
  },
  {
    "id": "p-abbc1b",
    "offset": 747,
    "text": "svapitṛvittānuharaṇaṃ ca // Vi_16.16 //"
  },
  {
    "id": "p-d72d6b",
    "offset": 788,
    "text": "saṃkare jātayas tv etāḥ pitṛmātṛpradarśitāḥ  /"
  },
  {
    "id": "p-0cab06",
    "offset": 836,
    "text": "pracchannā vā prakāśā vā veditavyāḥ svakarmabhiḥ  || Vi_16.17 ||"
  },
  {
    "id": "p-44bd9b",
    "offset": 902,
    "text": "brāhmaṇārthe gavārthe vā dehatyāgo 'nupaskṛtaḥ  /"
  },
  {
    "id": "p-9199b7",
    "offset": 953,
    "text": "strībālādyavapattau ca bāhyānāṃ siddhikāraṇam  || Vi_16.18 ||"
  }
]