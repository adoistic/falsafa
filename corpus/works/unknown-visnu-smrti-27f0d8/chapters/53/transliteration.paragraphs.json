[
  {
    "id": "p-1045f2",
    "offset": 0,
    "text": "Vi_53"
  },
  {
    "id": "p-497eb6",
    "offset": 7,
    "text": "athāgamyāgamane mahāvratavidhānenābdaṃ cīravāsā vane prājāpatyaṃ kuryāt // Vi_53.1 //"
  },
  {
    "id": "p-dad2cd",
    "offset": 94,
    "text": "paradāragamane ca // Vi_53.2 //"
  },
  {
    "id": "p-374772",
    "offset": 127,
    "text": "govrataṃ gogamane ca // Vi_53.3 //"
  },
  {
    "id": "p-4a34ae",
    "offset": 163,
    "text": "puṃsy ayonāv ākāśe 'psu divā goyāne ca savāsāḥ snānam ācaret // Vi_53.4 //"
  },
  {
    "id": "p-3dbd3c",
    "offset": 239,
    "text": "caṇḍālīgamane tatsāmyam āpnuyāt // Vi_53.5 //"
  },
  {
    "id": "p-9175a0",
    "offset": 286,
    "text": "ajñānataś cāndrāyaṇadvayaṃ kuryāt // Vi_53.6 //"
  },
  {
    "id": "p-337432",
    "offset": 335,
    "text": "paśuveśyāgamane ca prājāpatyam // Vi_53.7 //"
  },
  {
    "id": "p-95835e",
    "offset": 381,
    "text": "sakṛd duṣṭā ca strī yat puruṣasya paradāre tadvrataṃ kuryāt // Vi_53.8 //"
  },
  {
    "id": "p-cba7df",
    "offset": 456,
    "text": "yat karoty ekarātreṇa vṛṣalīsevanād dvijaḥ  /"
  },
  {
    "id": "p-725ae9",
    "offset": 503,
    "text": "tad bhaikṣyabhug japan nityaṃ tribhir varṣair vyapohati  || Vi_53.9 ||"
  }
]